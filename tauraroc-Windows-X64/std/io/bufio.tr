# std.io.bufio — Buffered file reader and writer.

from std.core.string import StringBuilder
from std.string.str  import Str
from std.core.vec    import Vec

extern "C":
    def _tr_c_fopen(path: str, mode: str) -> Pointer[char]
    def _tr_c_fclose(fp: Pointer[char]) -> int
    def _tr_c_fread(buf: Pointer[char], size: int, nmemb: int, fp: Pointer[char]) -> int
    def _tr_c_fwrite(buf: Pointer[char], size: int, nmemb: int, fp: Pointer[char]) -> int
    def _tr_c_fseek(fp: Pointer[char], offset: int, whence: int) -> int
    def _tr_c_ftell(fp: Pointer[char]) -> int
    def _tr_c_malloc(size: int) -> Pointer[char]

# ─── BufReader ────────────────────────────────────────────────────────────────

pub class BufReader:
    pub _fp:     Pointer[char]
    pub _buf:    Pointer[char]
    pub _cap:    int
    pub _pos:    int
    pub _filled: int
    pub path:    str
    pub open:    bool

extend BufReader:
    # Open path for buffered reading with the given buffer size.
    pub def open(path: str, buf_size: int) -> BufReader:
        mut r = BufReader()
        r.path    = path
        r._cap    = buf_size
        r._pos    = 0
        r._filled = 0
        r._fp     = _tr_c_fopen(path, "rb")
        r.open    = r._fp as int != 0
        r._buf    = _tr_c_malloc(buf_size + 1)
        return r

    # Read and return the entire remaining content of the file.
    pub def read_all(self) -> str:
        if not self.open: return ""
        _tr_c_fseek(self._fp, 0, 2)
        mut size = _tr_c_ftell(self._fp)
        _tr_c_fseek(self._fp, 0, 0)
        if size <= 0: return ""
        mut buf = _tr_c_malloc(size + 1)
        _tr_c_fread(buf, 1, size, self._fp)
        unsafe:
            buf.offset(size).write('\0')
        return buf as str

    # Read all lines split on "\n".
    pub def readlines(self) -> Vec[str]:
        mut content: str = self.read_all()
        return Str.split(content, "\n")

    # Read a single line (without the newline character).
    # Returns "" when the file is exhausted.
    pub def readline(self) -> str:
        if not self.open: return ""
        mut sb = StringBuilder.init(128)
        mut done = false
        while not done:
            if self._pos >= self._filled:
                self._filled = _tr_c_fread(self._buf, 1, self._cap, self._fp)
                self._pos    = 0
                if self._filled <= 0:
                    done = true
            if not done:
                mut ch = self._buf.offset(self._pos).read() as int
                self._pos = self._pos + 1
                if ch == 10:
                    done = true
                elif ch == 13:
                    # skip \r
                    mut n = self._pos
                    if n < self._filled:
                        mut next = self._buf.offset(n).read() as int
                        if next == 10: self._pos = n + 1
                    done = true
                else:
                    sb.append_char(ch)
        return sb.to_owned()

    pub def close(self):
        if self.open:
            _tr_c_fclose(self._fp)
            self.open = false

# ─── BufWriter ────────────────────────────────────────────────────────────────

pub class BufWriter:
    pub _fp:   Pointer[char]
    pub _buf:  StringBuilder
    pub _cap:  int
    pub path:  str
    pub open:  bool

extend BufWriter:
    # Open path for buffered writing (create/overwrite) with the given buffer size.
    pub def open(path: str, buf_size: int) -> BufWriter:
        mut w = BufWriter()
        w.path  = path
        w._cap  = buf_size
        w._fp   = _tr_c_fopen(path, "wb")
        w.open  = w._fp as int != 0
        w._buf  = StringBuilder.init(buf_size)
        return w

    # Open path for buffered appending.
    pub def open_append(path: str, buf_size: int) -> BufWriter:
        mut w = BufWriter()
        w.path  = path
        w._cap  = buf_size
        w._fp   = _tr_c_fopen(path, "ab")
        w.open  = w._fp as int != 0
        w._buf  = StringBuilder.init(buf_size)
        return w

    # Write s to the internal buffer; flushes when buffer is full.
    pub def write(self, s: str):
        if not self.open: return
        self._buf.append(s)
        if self._buf.len >= self._cap:
            self.flush()

    # Write s followed by a newline.
    pub def writeln(self, s: str):
        self.write(s)
        self.write("\n")

    # Write the buffer to the file immediately.
    pub def flush(self):
        if not self.open: return
        mut n = self._buf.len
        if n > 0:
            mut content: str = self._buf.to_owned()
            mut p = content as Pointer[char]
            _tr_c_fwrite(p, 1, n, self._fp)
        self._buf.clear()

    # Flush remaining data and close the file.
    pub def close(self):
        if self.open:
            self.flush()
            _tr_c_fclose(self._fp)
            self.open = false
