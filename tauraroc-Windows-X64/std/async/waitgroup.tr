# std.async.waitgroup — WaitGroup: wait for a set of goroutine-style workers.
#
# The owner adds N to the counter before launching N workers.
# Each worker calls done() when finished.
# wait() blocks until the counter reaches zero.
#
# Usage:
#   let wg = WaitGroup.new()
#   wg.add(3)
#   spawn: do_work_a(); wg.done()
#   spawn: do_work_b(); wg.done()
#   spawn: do_work_c(); wg.done()
#   wg.wait()

extern "C":
    def _tr_wg_new_h() -> Pointer[char]
    def _tr_wg_add_h(w: Pointer[char], n: int)
    def _tr_wg_done_h(w: Pointer[char])
    def _tr_wg_wait_h(w: Pointer[char])
    def _tr_wg_wait_timeout_h(w: Pointer[char], ms: int) -> bool
    def _tr_wg_free_h(w: Pointer[char])

pub class WaitGroup:
    pub handle: Pointer[char]

extend WaitGroup:
    pub def new() -> WaitGroup:
        mut wg = WaitGroup()
        wg.handle = _tr_wg_new_h()
        return wg

    # Increment the internal counter by n before launching n workers.
    pub def add(self, n: int):
        _tr_wg_add_h(self.handle, n)

    # Decrement the counter by 1.  Call once per spawned worker on completion.
    pub def done(self):
        _tr_wg_done_h(self.handle)

    # Block until the counter reaches zero.
    pub def wait(self):
        _tr_wg_wait_h(self.handle)

    # Block with a timeout.  Returns true when counter reached zero in time.
    pub def wait_timeout(self, ms: int) -> bool:
        return _tr_wg_wait_timeout_h(self.handle, ms)

    pub def free(self):
        _tr_wg_free_h(self.handle)
