# std.net.tcp — TCP client (TcpStream) and server (TcpListener).
#
# Blocking API:
#   TcpStream.connect(host, port)  — blocking connect
#   stream.send(data)              — blocking send
#   stream.recv(cap)               — blocking recv
#
# Non-blocking API (use with std.io.poll.IOPoll):
#   TcpStream.connect_nb(host, port) — initiates connect, poll POLLOUT for completion
#   stream.set_nonblocking()         — switch existing fd to non-blocking mode
#   stream.recv_nb(cap)              — returns "" + would_block()=true on EAGAIN
#   stream.send_nb(data)             — returns -2 on EAGAIN
#   TcpListener.accept_nb()          — returns stream with fd=-2 when no conn pending
#
# TAURARO_WOULD_BLOCK = -2  (same as C-level constant)

extern "C":
    def _tr_tcp_connect(host: str, port: int) -> int
    def _tr_tcp_send(fd: int, data: str, len: int) -> int
    def _tr_tcp_recv(fd: int, buf: Pointer[char], cap: int) -> int
    def _tr_tcp_close(fd: int)
    def _tr_tcp_listen(host: str, port: int, backlog: int) -> int
    def _tr_tcp_accept(server_fd: int) -> int
    def _tr_tcp_peer_addr(fd: int) -> str
    def _tr_tcp_connect_nb(host: str, port: int) -> int
    def _tr_tcp_set_nonblocking(fd: int) -> int
    def _tr_tcp_recv_nb(fd: int, buf: Pointer[char], cap: int) -> int
    def _tr_tcp_send_nb(fd: int, data: str, len: int) -> int
    def _tr_tcp_send_raw(fd: int, buf: Pointer[char], len: int) -> int
    def _tr_tcp_accept_nb(server_fd: int) -> int
    def _tr_c_malloc(size: int) -> Pointer[char]
    def _tr_free(p: Pointer[char])
    # Green-thread reactor: park the current coroutine until fd is ready.
    def _tr_co_await_fd_h(fd: int, ev: int) -> int
    # Server-side TLS (OpenSSL, opt-in via -DTAURARO_TLS_OPENSSL): a TLS-backed
    # TcpStream routes blocking recv()/send()/close() through these.
    def _tr_tls_send(handle: Pointer[char], data: str) -> int
    def _tr_tls_recv(handle: Pointer[char], cap: int) -> str
    def _tr_tls_close(handle: Pointer[char])

# TAURARO_WOULD_BLOCK (-2): returned by non-blocking ops when no data is ready.
pub def WOULD_BLOCK() -> int: return -2

# ─── TcpStream ────────────────────────────────────────────────────────────────

pub class TcpStream:
    pub fd:          int
    pub connected:   bool
    pub nonblocking: bool
    pub host:        str
    pub port:        int
    pub _wb:         bool   # last nb op would-block flag
    pub async_mode:  bool   # when true, recv()/send() transparently use the
                            # reactor (recv_async/send_async) so existing
                            # blocking-style code runs cooperatively on a green
                            # thread without modification (see App.listen_async).
    pub tls:         Pointer[char]  # non-null => TLS-backed (server side): recv()/send()/
                                    # close() route through the OpenSSL handle. Defaults to
                                    # null (plaintext). Blocking, so use the threaded model.

extend TcpStream:
    # ── Blocking API ─────────────────────────────────────────────────────────

    # Connect to host:port (blocking).  Check .connected before use.
    pub def connect(host: str, port: int) -> TcpStream:
        mut s = TcpStream()
        s.host        = host
        s.port        = port
        s.connected   = false
        s.nonblocking = false
        s._wb         = false
        s.fd          = _tr_tcp_connect(host, port)
        if s.fd >= 0: s.connected = true
        return s

    # Send data (blocking, or cooperative non-blocking in async_mode).
    # Returns bytes sent, or -1 on error.
    pub def send(self, data: str) -> int:
        if (self.tls as usize) != 0: return _tr_tls_send(self.tls, data)
        if self.async_mode: return self.send_async(data)
        if not self.connected: return -1
        mut p = data as Pointer[char]
        mut n = 0
        while p.offset(n).read() as int != 0: n = n + 1
        return _tr_tcp_send(self.fd, data, n)

    # Receive up to cap bytes (blocking, or cooperative non-blocking in async_mode).
    pub def recv(self, cap: int) -> str:
        if (self.tls as usize) != 0: return _tr_tls_recv(self.tls, cap)
        if self.async_mode: return self.recv_async(cap)
        if not self.connected: return ""
        mut buf = _tr_c_malloc(cap + 1)
        mut n   = _tr_tcp_recv(self.fd, buf, cap)
        if n <= 0:
            self.connected = false
            _tr_free(buf)
            return ""
        unsafe:
            buf.offset(n).write('\0')
        return buf as str

    # ── Non-blocking API (use with IOPoll) ────────────────────────────────────

    # Initiate a non-blocking connect.  Poll POLLOUT on stream.fd to detect
    # when the connection is established (or has failed).
    pub def connect_nb(host: str, port: int) -> TcpStream:
        mut s = TcpStream()
        s.host        = host
        s.port        = port
        s.nonblocking = true
        s._wb         = false
        s.fd          = _tr_tcp_connect_nb(host, port)
        s.connected   = s.fd >= 0
        return s

    # Switch an existing connected fd to non-blocking mode.
    pub def set_nonblocking(self) -> bool:
        if self.fd < 0: return false
        mut ok = _tr_tcp_set_nonblocking(self.fd) == 0
        if ok: self.nonblocking = true
        return ok

    # Non-blocking recv.  Returns "" when no data is available (check would_block()).
    pub def recv_nb(self, cap: int) -> str:
        self._wb = false
        if not self.connected: return ""
        mut buf = _tr_c_malloc(cap + 1)
        mut n   = _tr_tcp_recv_nb(self.fd, buf, cap)
        if n == -2:
            self._wb = true
            _tr_free(buf)
            return ""
        if n <= 0:
            self.connected = false
            _tr_free(buf)
            return ""
        unsafe:
            buf.offset(n).write('\0')
        return buf as str

    # Non-blocking send.  Returns -2 (WOULD_BLOCK) if the send buffer is full.
    pub def send_nb(self, data: str) -> int:
        self._wb = false
        if not self.connected: return -1
        mut p = data as Pointer[char]
        mut n = 0
        while p.offset(n).read() as int != 0: n = n + 1
        mut r = _tr_tcp_send_nb(self.fd, data, n)
        if r == -2: self._wb = true
        return r

    # True when the last nb recv/send returned WOULD_BLOCK.
    pub def would_block(self) -> bool:
        return self._wb

    # ── Async API (green-thread, non-blocking via the reactor) ────────────────
    # These run inside an `async def` / spawned task: when the socket is not
    # ready they park the coroutine on the reactor (epoll/IOCP/kqueue) and yield
    # the worker to other tasks, so no OS thread ever blocks on I/O.

    # Receive up to `cap` bytes, awaiting readability if needed.
    pub def recv_async(self, cap: int) -> str:
        if not self.nonblocking: self.set_nonblocking()
        while true:
            mut data: str = self.recv_nb(cap)
            if not self._wb:
                return data
            # Would block: park until the socket is readable, then retry.
            _tr_co_await_fd_h(self.fd, 1)
        return ""   # unreachable (loop only exits via return); satisfies F-3

    # Send all of `data`, awaiting writability as the send buffer drains.
    # Fast path sends the whole buffer in one send_nb with NO allocation (the
    # common case for small responses); only a partial send falls back to
    # slicing the remainder, and that slice is freed to avoid a per-call leak.
    pub def send_async(self, data: str) -> int:
        if not self.nonblocking: self.set_nonblocking()
        mut p = data as Pointer[char]
        mut total = 0
        while p.offset(total).read() as int != 0: total = total + 1
        mut n0 = self.send_nb(data)
        if not self._wb and n0 >= total: return n0
        mut sent = 0
        if not self._wb and n0 > 0: sent = n0
        while sent < total:
            mut chunk: str = data.slice(sent, total)
            mut n = self.send_nb(chunk)
            if self._wb:
                _tr_co_await_fd_h(self.fd, 2)
            elif n <= 0:
                return sent
            else:
                sent = sent + n
        return sent

    # ── Raw binary async I/O (for framed protocols, e.g. WebSocket) ───────────
    # These work on caller-owned byte buffers with explicit lengths, so they are
    # safe for payloads containing NUL bytes (unlike the str-returning recv()).
    # Both park the coroutine on readiness when the socket would block.

    # Read up to `cap` bytes into `buf`; returns bytes read (0 = peer closed,
    # awaiting readability first if needed).
    pub def recv_into(self, buf: Pointer[char], cap: int) -> int:
        while true:
            mut n = _tr_tcp_recv_nb(self.fd, buf, cap)
            if n == -2:
                _tr_co_await_fd_h(self.fd, 1)
            else:
                if n <= 0: self.connected = false
                return n
        return 0   # unreachable; satisfies F-3

    # Send exactly `n` bytes from `buf`, awaiting writability as needed.
    # Returns bytes sent (< n only on error/closed).
    pub def send_raw(self, buf: Pointer[char], n: int) -> int:
        # TLS can't take a raw fd buffer; hand the (NUL-terminated) buffer to the
        # TLS layer as a str. Callers that build into a StringBuilder always
        # NUL-terminate, so this is correct for text/JSON/HTML responses.
        if (self.tls as usize) != 0: return _tr_tls_send(self.tls, buf as str)
        mut sent = 0
        while sent < n:
            mut r = _tr_tcp_send_raw(self.fd, buf.offset(sent), n - sent)
            if r == -2:
                _tr_co_await_fd_h(self.fd, 2)
            elif r <= 0:
                return sent
            else:
                sent = sent + r
        return sent

    # ── Common ────────────────────────────────────────────────────────────────

    pub def close(self):
        if (self.tls as usize) != 0:
            _tr_tls_close(self.tls)   # also closes the underlying fd
            self.tls       = 0 as Pointer[char]
            self.connected = false
            self.fd        = -1
            return
        if self.connected or self.fd >= 0:
            _tr_tcp_close(self.fd)
            self.connected = false
            self.fd        = -1

    pub def is_connected(self) -> bool:
        return self.connected

    pub def peer_addr(self) -> str:
        if self.fd < 0: return ""
        return _tr_tcp_peer_addr(self.fd)

# ─── TcpListener ──────────────────────────────────────────────────────────────

pub class TcpListener:
    pub fd:        int
    pub host:      str
    pub port:      int
    pub listening: bool

extend TcpListener:
    # Bind and listen on host:port with the given backlog.
    pub def bind(host: str, port: int, backlog: int) -> TcpListener:
        mut l = TcpListener()
        l.host      = host
        l.port      = port
        l.listening = false
        l.fd        = _tr_tcp_listen(host, port, backlog)
        if l.fd >= 0: l.listening = true
        return l

    pub def listen(host: str, port: int) -> TcpListener:
        # 1024 (rather than 128) so a burst of near-simultaneous connections
        # (e.g. a high-concurrency keep-alive load test) doesn't overflow the
        # kernel's accept queue and get connection-reset before accept().
        return TcpListener.bind(host, port, 1024)

    # Block until a client connects.
    pub def accept(self) -> TcpStream:
        mut client_fd = _tr_tcp_accept(self.fd)
        mut s = TcpStream()
        s.fd          = client_fd
        s.connected   = client_fd >= 0
        s.nonblocking = false
        s._wb         = false
        if s.connected:
            s.host = _tr_tcp_peer_addr(client_fd)
        else:
            s.host = ""
        s.port = 0
        return s

    # Non-blocking accept.  Returns stream with fd < 0 when no connection is pending.
    # Check stream.fd >= 0 before use.  Use with IOPoll POLLIN on listener.fd.
    pub def accept_nb(self) -> TcpStream:
        mut client_fd = _tr_tcp_accept_nb(self.fd)
        mut s = TcpStream()
        s._wb = false
        if client_fd == -2:
            s.fd        = -1
            s.connected = false
            s._wb       = true
            s.host      = ""
            s.port      = 0
            s.nonblocking = true
            return s
        s.fd          = client_fd
        s.connected   = client_fd >= 0
        s.nonblocking = true
        s._wb         = false
        if s.connected:
            s.host = _tr_tcp_peer_addr(client_fd)
            _tr_tcp_set_nonblocking(client_fd)
        else:
            s.host = ""
        s.port = 0
        return s

    # Await the next client connection without blocking the worker: when the
    # accept queue is empty, park the coroutine on the listener's readiness and
    # yield to other tasks. Returns a connected, non-blocking TcpStream.
    #
    # KNOWN ISSUE (Tier 3 WIP): returning a class instance (TcpStream) from a
    # method *across* a coroutine park currently misbehaves; until the codegen
    # fix lands, prefer the equivalent inline form in an accept loop:
    #     mut s = listener.accept_nb()
    #     if s.fd >= 0: <spawn handler with s.fd>
    #     else:        Coro.await_readable(listener.fd)
    pub def accept_async(self) -> TcpStream:
        while true:
            mut s: TcpStream = self.accept_nb()
            if s.fd >= 0:
                return s
            # No pending connection: park until the listener is readable.
            _tr_co_await_fd_h(self.fd, 1)
        return TcpStream()   # unreachable; satisfies F-3

    # Switch the listener fd to non-blocking mode (for use with accept_nb).
    pub def set_nonblocking(self) -> bool:
        if self.fd < 0: return false
        return _tr_tcp_set_nonblocking(self.fd) == 0

    pub def close(self):
        if self.listening:
            _tr_tcp_close(self.fd)
            self.listening = false
            self.fd        = -1

    pub def is_listening(self) -> bool:
        return self.listening
