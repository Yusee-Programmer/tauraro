# std.io.path — Cross-platform path manipulation via the Path class.

pub class Path:
    pub value: str

extend Path:
    # Create a Path wrapping the given string.
    pub def init(p: str) -> Path:
        mut path = Path()
        path.value = p
        return path

    # Normalise: replace every '\' with '/'.
    pub def normalize(self) -> str:
        mut n = 0
        mut ptr = self.value as Pointer[char]
        while ptr.offset(n).read() as int != 0: n = n + 1
        mut buf = _tr_str_slice(self.value, 0, n)
        mut bp = buf as Pointer[char]
        mut i = 0
        while i < n:
            if bp.offset(i).read() as int == 92:
                unsafe: bp.offset(i).write(47 as char)
            i = i + 1
        return buf

    # Join self with another segment, inserting exactly one '/' between them.
    pub def join(self, other: str) -> str:
        mut an = 0
        mut ap = self.value as Pointer[char]
        while ap.offset(an).read() as int != 0: an = an + 1
        if an == 0: return other
        mut bn = 0
        mut bp = other as Pointer[char]
        while bp.offset(bn).read() as int != 0: bn = bn + 1
        if bn == 0: return self.value
        mut last_a  = ap.offset(an - 1).read() as int
        mut first_b = bp.offset(0).read() as int
        if (last_a == 47 or last_a == 92) and (first_b == 47 or first_b == 92):
            return self.value + _tr_str_slice(other, 1, bn)
        if last_a == 47 or last_a == 92:
            return self.value + other
        if first_b == 47 or first_b == 92:
            return self.value + other
        return self.value + "/" + other

    # Return the directory portion: "dir/sub/file.txt" → "dir/sub/".
    pub def dirname(self) -> str:
        mut n = 0
        mut ptr = self.value as Pointer[char]
        while ptr.offset(n).read() as int != 0: n = n + 1
        mut last_sep = -1
        mut i = 0
        while i < n:
            mut c = ptr.offset(i).read() as int
            if c == 47 or c == 92: last_sep = i
            i = i + 1
        if last_sep < 0: return "./"
        return _tr_str_slice(self.value, 0, last_sep + 1)

    # Return the filename portion: "dir/sub/file.txt" → "file.txt".
    pub def basename(self) -> str:
        mut n = 0
        mut ptr = self.value as Pointer[char]
        while ptr.offset(n).read() as int != 0: n = n + 1
        mut last_sep = -1
        mut i = 0
        while i < n:
            mut c = ptr.offset(i).read() as int
            if c == 47 or c == 92: last_sep = i
            i = i + 1
        if last_sep < 0: return self.value
        return _tr_str_slice(self.value, last_sep + 1, n)

    # Return the file extension including dot: "file.tar.gz" → ".gz".
    pub def extension(self) -> str:
        mut base = self.basename()
        mut n = 0
        mut ptr = base as Pointer[char]
        while ptr.offset(n).read() as int != 0: n = n + 1
        mut last_dot = -1
        mut i = 0
        while i < n:
            if ptr.offset(i).read() as int == 46: last_dot = i
            i = i + 1
        if last_dot <= 0: return ""
        return _tr_str_slice(base, last_dot, n)

    # Strip the extension: "a.b.c" → "a.b".
    pub def strip_extension(self) -> str:
        mut n = 0
        mut ptr = self.value as Pointer[char]
        while ptr.offset(n).read() as int != 0: n = n + 1
        mut last_dot = -1
        mut i = 0
        while i < n:
            if ptr.offset(i).read() as int == 46: last_dot = i
            i = i + 1
        if last_dot <= 0: return self.value
        return _tr_str_slice(self.value, 0, last_dot)

    # True when the path is absolute (starts with '/' or a Windows drive letter).
    pub def is_absolute(self) -> bool:
        mut ptr = self.value as Pointer[char]
        mut c0 = ptr.offset(0).read() as int
        if c0 == 47: return true
        mut c1 = ptr.offset(1).read() as int
        if c1 == 58: return true
        return false

    # Return the underlying string.
    pub def to_str(self) -> str:
        return self.value
