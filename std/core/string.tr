# std.core.string - StringObj and StringBuilder for self-hosted Tauraro.
#
# StringObj: heap-owned string view (data: Pointer[char], len, capacity).
# StringBuilder: growable string builder backed by a StringObj buffer.
# Layout matches core/string.tr so the c.tr codegen's ->buf->len accesses work.

extern "C":
    def _tr_checked_alloc(size: int) -> Pointer[char]
    def _tr_c_realloc(ptr: Pointer[char], size: int) -> Pointer[char]
    def _tr_c_free(ptr: Pointer[char])
    def _tr_c_memcpy(dst: Pointer[char], src: Pointer[char], n: int)
    def _tr_strlen(s: str) -> int
    def _tr_str_lit(s: Pointer[char]) -> str

pub class StringObj:
    pub data: Pointer[char]
    pub len:  int
    pub capacity: int

extend StringObj:
    pub def init(s: str) -> StringObj:
        mut obj = StringObj()
        mut slen = _tr_strlen(s)
        obj.len = slen
        obj.capacity = slen + 8
        obj.data = _tr_checked_alloc(obj.capacity)
        if slen > 0:
            _tr_c_memcpy(obj.data, s as Pointer[char], slen)
        unsafe: obj.data.offset(slen).write('\0')
        return obj

    pub def as_str(self) -> str:
        return _tr_str_lit(self.data)

    pub def append(self, other: str):
        mut slen = _tr_strlen(other)
        if slen <= 0: return
        if self.len + slen >= self.capacity:
            self.capacity = (self.len + slen) * 2 + 8
            self.data = _tr_c_realloc(self.data, self.capacity)
        _tr_c_memcpy(self.data.offset(self.len), other as Pointer[char], slen)
        self.len = self.len + slen
        unsafe: self.data.offset(self.len).write('\0')

    pub def destroy(self):
        _tr_c_free(self.data)
        self.data = 0 as Pointer[char]
        self.len = 0
        self.capacity = 0

pub class StringBuilder:
    pub buf: StringObj

extend StringBuilder:
    pub def init(initial_capacity: int) -> StringBuilder:
        mut cap = initial_capacity
        if cap < 16: cap = 16
        mut sb = StringBuilder()
        sb.buf = StringObj()
        sb.buf.len = 0
        sb.buf.capacity = cap + 1
        sb.buf.data = _tr_checked_alloc(sb.buf.capacity)
        unsafe: sb.buf.data.offset(0).write('\0')
        return sb

    pub def append(self, s: str):
        self.buf.append(s)

    pub def append_char(self, c: int):
        if self.buf.len + 1 >= self.buf.capacity:
            self.buf.capacity = self.buf.capacity * 2 + 8
            self.buf.data = _tr_c_realloc(self.buf.data, self.buf.capacity)
        unsafe: self.buf.data.offset(self.buf.len).write(c as char)
        self.buf.len = self.buf.len + 1
        unsafe: self.buf.data.offset(self.buf.len).write('\0')

    pub def append_int(self, n: int):
        mut neg = false
        mut x = n
        if x == 0:
            self.append_char(48)
            return
        if x < 0:
            neg = true
            x = 0 - x
        mut start = self.buf.len
        while x > 0:
            mut d = x - (x / 10) * 10
            self.append_char(48 + d)
            x = x / 10
        if neg: self.append_char(45)
        mut lo = start
        mut hi = self.buf.len - 1
        while lo < hi:
            unsafe:
                mut a = self.buf.data.offset(lo).read()
                mut b = self.buf.data.offset(hi).read()
                self.buf.data.offset(lo).write(b)
                self.buf.data.offset(hi).write(a)
            lo = lo + 1
            hi = hi - 1

    pub def append_float(self, f: float):
        mut s = f.to_str()
        self.append(s)

    pub def len(self) -> int:
        return self.buf.len

    pub def to_string(self) -> StringObj:
        return StringObj.init(self.buf.as_str())

    pub def to_owned(self) -> str:
        mut sz = self.buf.len + 1
        mut out = _tr_checked_alloc(sz)
        _tr_c_memcpy(out, self.buf.data, sz)
        return out as str

    pub def as_str(self) -> str:
        return self.buf.as_str()

    pub def clear(self):
        self.buf.len = 0
        unsafe: self.buf.data.offset(0).write('\0')

    # Releases the StringObj's data buffer plus the heap-allocated StringObj
    # struct itself (self.buf is a pointer) and the StringBuilder struct
    # (self) - StringBuilder.init()/StringObj.init() each heap-allocate their
    # struct, so a plain self.buf.destroy() leaked both small structs.
    pub def free(self):
        self.buf.destroy()
        unsafe:
            _tr_c_free(self.buf as Pointer[char])
            _tr_c_free(self as Pointer[char])
