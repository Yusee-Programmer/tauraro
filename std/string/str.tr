# std.string.str — String utilities via the Str static-method class.

from std.core.string import StringBuilder

extern "C":
    def _tr_str_split(s: str, sep: str) -> List[str]
    def _tr_strx_join_trstr(parts: List[str], sep: str) -> str
    def _tr_c_free(ptr: Pointer[char])
    def _tr_str_slice(s: Pointer[char], start: int, end: int) -> str

pub class Str:
    _dummy: int

extend Str:
    # ── Measurement ──────────────────────────────────────────────────────────

    pub def len(s: str) -> int:
        mut p = s as Pointer[char]
        mut n = 0
        while p.offset(n).read() as int != 0: n = n + 1
        return n

    # ── Predicates ───────────────────────────────────────────────────────────

    pub def starts_with(s: str, prefix: str) -> bool:
        mut sp = s as Pointer[char]
        mut pp = prefix as Pointer[char]
        mut i  = 0
        while True:
            mut pc = pp.offset(i).read() as int
            if pc == 0: return true
            mut sc = sp.offset(i).read() as int
            if sc == 0 or sc != pc: return false
            i = i + 1
        return false

    pub def ends_with(s: str, suffix: str) -> bool:
        mut sl = Str.len(s)
        mut el = Str.len(suffix)
        if el > sl: return false
        mut sp  = s as Pointer[char]
        mut ep  = suffix as Pointer[char]
        mut off = sl - el
        mut i   = 0
        while i < el:
            if sp.offset(off + i).read() as int != ep.offset(i).read() as int:
                return false
            i = i + 1
        return true

    pub def contains_char(s: str, c: int) -> bool:
        mut p = s as Pointer[char]
        mut i = 0
        while True:
            mut ch = p.offset(i).read() as int
            if ch == 0: return false
            if ch == c: return true
            i = i + 1
        return false

    pub def contains(s: str, sub: str) -> bool:
        return Str.index_of(s, sub) >= 0

    pub def eq(a: str, b: str) -> bool:
        mut pa = a as Pointer[char]
        mut pb = b as Pointer[char]
        mut i  = 0
        while True:
            mut ca = pa.offset(i).read() as int
            mut cb = pb.offset(i).read() as int
            if ca != cb: return false
            if ca == 0: return true
            i = i + 1
        return true

    # ── Character classification ──────────────────────────────────────────────

    # True when every character in s is a decimal digit.
    pub def is_digit(s: str) -> bool:
        mut p = s as Pointer[char]
        mut i = 0
        mut c = p.offset(i).read() as int
        if c == 0: return false
        while c != 0:
            if c < 48 or c > 57: return false
            i = i + 1
            c = p.offset(i).read() as int
        return true

    # True when every character in s is an ASCII letter.
    pub def is_alpha(s: str) -> bool:
        mut p = s as Pointer[char]
        mut i = 0
        mut c = p.offset(i).read() as int
        if c == 0: return false
        while c != 0:
            if not ((c >= 65 and c <= 90) or (c >= 97 and c <= 122)): return false
            i = i + 1
            c = p.offset(i).read() as int
        return true

    # True when every character is a letter or digit.
    pub def is_alnum(s: str) -> bool:
        mut p = s as Pointer[char]
        mut i = 0
        mut c = p.offset(i).read() as int
        if c == 0: return false
        while c != 0:
            mut ok = (c >= 48 and c <= 57) or (c >= 65 and c <= 90) or (c >= 97 and c <= 122)
            if not ok: return false
            i = i + 1
            c = p.offset(i).read() as int
        return true

    # True when s consists entirely of whitespace characters.
    pub def is_space(s: str) -> bool:
        mut p = s as Pointer[char]
        mut i = 0
        mut c = p.offset(i).read() as int
        if c == 0: return false
        while c != 0:
            if c != 32 and c != 9 and c != 10 and c != 13: return false
            i = i + 1
            c = p.offset(i).read() as int
        return true

    # True when s is all upper-case letters.
    pub def is_upper(s: str) -> bool:
        mut p = s as Pointer[char]
        mut i = 0
        mut c = p.offset(i).read() as int
        if c == 0: return false
        while c != 0:
            if c >= 97 and c <= 122: return false
            i = i + 1
            c = p.offset(i).read() as int
        return true

    # True when s is all lower-case letters.
    pub def is_lower(s: str) -> bool:
        mut p = s as Pointer[char]
        mut i = 0
        mut c = p.offset(i).read() as int
        if c == 0: return false
        while c != 0:
            if c >= 65 and c <= 90: return false
            i = i + 1
            c = p.offset(i).read() as int
        return true

    # ── Slicing & building ───────────────────────────────────────────────────

    pub def slice(s: str, start: int, end: int) -> str:
        mut slen   = Str.len(s)
        mut real_s = start
        mut real_e = end
        if real_s < 0: real_s = 0
        if real_e > slen: real_e = slen
        if real_s >= real_e: return ""
        mut sz = real_e - real_s
        mut sb = StringBuilder.init(sz + 1)
        mut p  = s as Pointer[char]
        mut i  = real_s
        while i < real_e:
            sb.append_char(p.offset(i).read() as int)
            i = i + 1
        mut out = sb.to_owned()
        sb.free()
        return out

    pub def repeat(s: str, n: int) -> str:
        if n <= 0: return ""
        mut sb = StringBuilder.init(Str.len(s) * n + 1)
        mut i  = 0
        while i < n:
            sb.append(s)
            i = i + 1
        mut out = sb.to_owned()
        sb.free()
        return out

    pub def reverse(s: str) -> str:
        mut slen = Str.len(s)
        mut sb   = StringBuilder.init(slen + 1)
        mut p    = s as Pointer[char]
        mut i    = slen - 1
        while i >= 0:
            sb.append_char(p.offset(i).read() as int)
            i = i - 1
        mut out = sb.to_owned()
        sb.free()
        return out

    # ── Case conversion ──────────────────────────────────────────────────────

    pub def to_upper(s: str) -> str:
        mut slen = Str.len(s)
        mut sb   = StringBuilder.init(slen + 1)
        mut p    = s as Pointer[char]
        mut i    = 0
        while i < slen:
            mut ch = p.offset(i).read() as int
            if ch >= 97 and ch <= 122: ch = ch - 32
            sb.append_char(ch)
            i = i + 1
        mut out = sb.to_owned()
        sb.free()
        return out

    pub def to_lower(s: str) -> str:
        mut slen = Str.len(s)
        mut sb   = StringBuilder.init(slen + 1)
        mut p    = s as Pointer[char]
        mut i    = 0
        while i < slen:
            mut ch = p.offset(i).read() as int
            if ch >= 65 and ch <= 90: ch = ch + 32
            sb.append_char(ch)
            i = i + 1
        mut out = sb.to_owned()
        sb.free()
        return out

    # Capitalize: first letter upper, rest lower.
    pub def capitalize(s: str) -> str:
        mut low = Str.to_lower(s)
        if Str.len(low) == 0: return low
        mut p  = low as Pointer[char]
        mut ch = p.offset(0).read() as int
        if ch >= 97 and ch <= 122:
            mut result = Str.to_upper(Str.slice(low, 0, 1)) + Str.slice(low, 1, Str.len(low))
            unsafe: _tr_c_free(low as Pointer[char])
            return result
        return low

    # Title-case: capitalize each word.
    pub def title(s: str) -> str:
        mut slen  = Str.len(s)
        mut sb    = StringBuilder.init(slen + 1)
        mut p     = s as Pointer[char]
        mut prev  = 32
        mut i     = 0
        while i < slen:
            mut ch = p.offset(i).read() as int
            if prev == 32 and ch >= 97 and ch <= 122:
                sb.append_char(ch - 32)
            elif prev != 32 and ch >= 65 and ch <= 90:
                sb.append_char(ch + 32)
            else:
                sb.append_char(ch)
            prev = ch
            i = i + 1
        mut out = sb.to_owned()
        sb.free()
        return out

    # ── Trimming ─────────────────────────────────────────────────────────────

    pub def trim_left(s: str) -> str:
        mut p = s as Pointer[char]
        mut i = 0
        while True:
            mut c = p.offset(i).read() as int
            if c == 0 or (c != 32 and c != 9 and c != 10 and c != 13): break
            i = i + 1
        return Str.slice(s, i, Str.len(s))

    pub def trim_right(s: str) -> str:
        mut slen = Str.len(s)
        mut p    = s as Pointer[char]
        mut i    = slen - 1
        while i >= 0:
            mut c = p.offset(i).read() as int
            if c != 32 and c != 9 and c != 10 and c != 13: break
            i = i - 1
        return Str.slice(s, 0, i + 1)

    pub def trim(s: str) -> str:
        return Str.trim_left(Str.trim_right(s))

    # ── Char access ──────────────────────────────────────────────────────────

    pub def char_at(s: str, i: int) -> int:
        mut p = s as Pointer[char]
        return p.offset(i).read() as int

    # ── Padding & alignment ───────────────────────────────────────────────────

    # Left-pad s to width using pad_char (given as ASCII code).
    pub def lpad(s: str, width: int, pad_char: int) -> str:
        mut slen = Str.len(s)
        if slen >= width: return s
        mut sb = StringBuilder.init(width + 1)
        mut i  = slen
        while i < width:
            sb.append_char(pad_char)
            i = i + 1
        sb.append(s)
        mut out = sb.to_owned()
        sb.free()
        return out

    # Right-pad s to width using pad_char.
    pub def rpad(s: str, width: int, pad_char: int) -> str:
        mut slen = Str.len(s)
        if slen >= width: return s
        mut sb = StringBuilder.init(width + 1)
        sb.append(s)
        mut i  = slen
        while i < width:
            sb.append_char(pad_char)
            i = i + 1
        mut out = sb.to_owned()
        sb.free()
        return out

    # Center s within width, padding with spaces.
    pub def center(s: str, width: int) -> str:
        mut slen = Str.len(s)
        if slen >= width: return s
        mut total = width - slen
        mut left  = total / 2
        mut right = total - left
        mut sb    = StringBuilder.init(width + 1)
        mut i     = 0
        while i < left:
            sb.append_char(32)
            i = i + 1
        sb.append(s)
        i = 0
        while i < right:
            sb.append_char(32)
            i = i + 1
        mut out = sb.to_owned()
        sb.free()
        return out

    # ── Search ───────────────────────────────────────────────────────────────

    pub def index_of(s: str, sub: str) -> int:
        mut sl   = Str.len(s)
        mut subl = Str.len(sub)
        if subl == 0: return 0
        if subl > sl: return -1
        mut sp   = s as Pointer[char]
        mut subp = sub as Pointer[char]
        mut i    = 0
        while i <= sl - subl:
            mut j     = 0
            mut found = true
            while j < subl:
                if sp.offset(i + j).read() as int != subp.offset(j).read() as int:
                    found = false
                    j     = subl
                j = j + 1
            if found: return i
            i = i + 1
        return -1

    # Last occurrence of sub in s, or -1 if absent.
    pub def last_index_of(s: str, sub: str) -> int:
        mut sl   = Str.len(s)
        mut subl = Str.len(sub)
        if subl == 0: return sl
        if subl > sl: return -1
        mut sp   = s as Pointer[char]
        mut subp = sub as Pointer[char]
        mut i    = sl - subl
        while i >= 0:
            mut j     = 0
            mut found = true
            while j < subl:
                if sp.offset(i + j).read() as int != subp.offset(j).read() as int:
                    found = false
                    j     = subl
                j = j + 1
            if found: return i
            i = i - 1
        return -1

    # Count non-overlapping occurrences of sub in s.
    pub def count(s: str, sub: str) -> int:
        mut subl = Str.len(sub)
        if subl == 0: return 0
        mut sl = Str.len(s)
        mut n = 0
        mut i = 0
        while True:
            mut rest = Str.slice(s, i, sl)
            mut pos = Str.index_of(rest, sub)
            unsafe: _tr_c_free(rest as Pointer[char])
            if pos < 0: break
            n = n + 1
            i = i + pos + subl
        return n

    # ── Split / join / replace ────────────────────────────────────────────────

    pub def split(s: str, sep: str) -> List[str]:
        return _tr_str_split(s, sep)

    # Like split() but returns Vec[str] for use with std.iter and std.collections.
    pub def split_to_vec(s: str, sep: str) -> Vec[str]:
        mut out  = Vec[str].init(8)
        mut sl   = Str.len(s)
        mut sepl = Str.len(sep)
        if sepl == 0:
            mut i = 0
            while i < sl:
                out.push(Str.slice(s, i, i + 1))
                i = i + 1
            return out
        mut start = 0
        mut i     = 0
        while i <= sl - sepl:
            mut j     = 0
            mut match_ = true
            while j < sepl:
                if Str.char_at(s, i + j) != Str.char_at(sep, j):
                    match_ = false
                    j      = sepl
                j = j + 1
            if match_:
                out.push(Str.slice(s, start, i))
                start = i + sepl
                i     = start
            else:
                i = i + 1
        out.push(Str.slice(s, start, sl))
        return out

    pub def join(parts: List[str], sep: str) -> str:
        return _tr_strx_join_trstr(parts, sep)

    pub def replace(s: str, old: str, new_: str) -> str:
        mut result = StringBuilder.init(Str.len(s) + 1)
        mut oldl   = Str.len(old)
        if oldl == 0: return s
        mut sl     = Str.len(s)
        mut sp     = s as Pointer[char]
        mut i = 0
        while i < sl:
            mut found = true
            if i + oldl > sl: found = false
            if found:
                mut j = 0
                while j < oldl:
                    if sp.offset(i + j).read() as int != (old as Pointer[char]).offset(j).read() as int:
                        found = false
                        j     = oldl
                    j = j + 1
            if found:
                result.append(new_)
                i = i + oldl
            else:
                result.append_char(sp.offset(i).read() as int)
                i = i + 1
        mut out = result.to_owned()
        result.free()
        return out

    # Replace only the first occurrence of old.
    pub def replace_first(s: str, old: str, new_: str) -> str:
        mut pos = Str.index_of(s, old)
        if pos < 0: return s
        mut sb = StringBuilder.init(Str.len(s) + Str.len(new_))
        mut sl = Str.len(s)
        mut tail_start = pos + Str.len(old)
        mut head = Str.slice(s, 0, pos)
        mut tail = Str.slice(s, tail_start, sl)
        sb.append(head)
        sb.append(new_)
        sb.append(tail)
        unsafe:
            if pos > 0: _tr_c_free(head as Pointer[char])
            if tail_start < sl: _tr_c_free(tail as Pointer[char])
        mut out = sb.to_owned()
        sb.free()
        return out

    # Simple positional format: replaces each "{}" in template with the next value.
    pub def format(template: str, values: Vec[str]) -> str:
        mut result = template
        mut owned  = false
        mut i      = 0
        while i < values.len:
            if Str.index_of(result, "{}") >= 0:
                mut next = Str.replace_first(result, "{}", values.get(i))
                if owned: unsafe: _tr_c_free(result as Pointer[char])
                result = next
                unsafe: _tr_c_free(next as Pointer[char])
                owned  = true
            i = i + 1
        return result

    # ── Parsing ───────────────────────────────────────────────────────────────

    # Parse a decimal integer string (leading '-' or '+' accepted).
    pub def parse_int(s: str) -> int:
        mut p   = s as Pointer[char]
        mut i   = 0
        mut neg = false
        mut c   = p.offset(0).read() as int
        if c == 45:
            neg = true
            i   = 1
        elif c == 43:
            i = 1
        mut result = 0
        mut c2     = p.offset(i).read() as int
        while c2 >= 48 and c2 <= 57:
            result = result * 10 + (c2 - 48)
            i      = i + 1
            c2     = p.offset(i).read() as int
        if neg: return 0 - result
        return result

    # Parse a decimal float string (integer + optional fractional part).
    pub def parse_float(s: str) -> float:
        mut p        = s as Pointer[char]
        mut i        = 0
        mut neg      = false
        mut c        = p.offset(0).read() as int
        if c == 45:
            neg = true
            i   = 1
        elif c == 43:
            i = 1
        mut int_part  = 0
        mut frac_part = 0
        mut frac_div  = 1
        mut in_frac   = false
        mut c2        = p.offset(i).read() as int
        while c2 != 0:
            if c2 >= 48 and c2 <= 57:
                if not in_frac:
                    int_part = int_part * 10 + (c2 - 48)
                else:
                    frac_part = frac_part * 10 + (c2 - 48)
                    frac_div  = frac_div * 10
            elif c2 == 46:
                in_frac = true
            else:
                break
            i  = i + 1
            c2 = p.offset(i).read() as int
        mut result = int_part as float + frac_part as float / frac_div as float
        if neg: return 0.0 - result
        return result

    # Return true for "true", "1", or "yes"; false otherwise.
    pub def parse_bool(s: str) -> bool:
        if Str.eq(s, "true"): return true
        if Str.eq(s, "1"):    return true
        if Str.eq(s, "yes"):  return true
        return false

    # ── Line / word splitting ─────────────────────────────────────────────────

    # Split on '\n'.  A trailing newline does not produce an empty trailing element.
    pub def lines(s: str) -> Vec[str]:
        mut out   = Vec[str].init(8)
        mut slen  = Str.len(s)
        mut sp    = s as Pointer[char]
        mut start = 0
        mut i     = 0
        while i < slen:
            mut c = sp.offset(i).read() as int
            if c == 10:
                out.push(Str.slice(s, start, i))
                start = i + 1
            i = i + 1
        if start < slen:
            out.push(Str.slice(s, start, slen))
        return out

    # Split on runs of whitespace (space, tab, CR, LF).
    pub def words(s: str) -> Vec[str]:
        mut out   = Vec[str].init(8)
        mut slen  = Str.len(s)
        mut sp    = s as Pointer[char]
        mut start = -1
        mut i     = 0
        while i < slen:
            mut c  = sp.offset(i).read() as int
            mut ws = c == 32 or c == 9 or c == 10 or c == 13
            if not ws and start < 0:
                start = i
            elif ws and start >= 0:
                out.push(Str.slice(s, start, i))
                start = -1
            i = i + 1
        if start >= 0:
            out.push(Str.slice(s, start, slen))
        return out

    # ── Prefix / suffix removal ───────────────────────────────────────────────

    # Return s with prefix stripped, or s if it does not start with prefix.
    pub def strip_prefix(s: str, prefix: str) -> str:
        if Str.starts_with(s, prefix): return Str.slice(s, Str.len(prefix), Str.len(s))
        return s

    # Return s with suffix stripped, or s if it does not end with suffix.
    pub def strip_suffix(s: str, suffix: str) -> str:
        if Str.ends_with(s, suffix): return Str.slice(s, 0, Str.len(s) - Str.len(suffix))
        return s

    # Return s with every occurrence of the character (ASCII code) removed.
    pub def remove_char(s: str, c: int) -> str:
        mut slen = Str.len(s)
        mut sb   = StringBuilder.init(slen + 1)
        mut p    = s as Pointer[char]
        mut i    = 0
        while i < slen:
            mut ch = p.offset(i).read() as int
            if ch != c: sb.append_char(ch)
            i = i + 1
        mut out = sb.to_owned()
        sb.free()
        return out

# ── StrView: a ZERO-COPY substring view (Gap 1) ──────────────────────────────
# A StrView holds a BORROWED pointer into a source string plus a length — it does
# NOT own or copy the bytes. Creating/slicing a view is allocation-free; only
# `.to_str()` materializes an owned copy. The view is valid only while its source
# string is alive (the borrow checker can enforce this for `from`-region views).
@value_type
pub class StrView:
    pub data: Pointer[char]   # borrowed — points into the source's buffer
    pub len:  int

extend StrView:
    # Zero-copy view of `s[start : start+count]`. No allocation.
    pub def of(s: str, start: int, count: int) -> StrView:
        mut v = StrView()
        mut p = s as Pointer[char]
        v.data = p.offset(start)
        v.len  = count
        return v

    # Zero-copy view of the whole string.
    pub def all(s: str) -> StrView:
        mut v = StrView()
        v.data = s as Pointer[char]
        v.len  = Str.len(s)
        return v

    pub def length(self) -> int:
        return self.len

    pub def char_at(self, i: int) -> char:
        return self.data.offset(i).read()

    # Zero-copy sub-view of this view.
    pub def slice(self, start: int, count: int) -> StrView:
        mut v = StrView()
        v.data = self.data.offset(start)
        v.len  = count
        return v

    # Materialize into an OWNED `str` (this is the one operation that allocates).
    pub def to_str(self) -> str:
        return _tr_str_slice(self.data, 0, self.len)

    # Byte-wise equality with an owned str — no allocation.
    pub def eq(self, other: str) -> bool:
        if self.len != Str.len(other): return false
        mut op = other as Pointer[char]
        mut i  = 0
        while i < self.len:
            if self.data.offset(i).read() as int != op.offset(i).read() as int: return false
            i = i + 1
        return true

    pub def starts_with(self, prefix: str) -> bool:
        mut pl = Str.len(prefix)
        if pl > self.len: return false
        mut pp = prefix as Pointer[char]
        mut i  = 0
        while i < pl:
            if self.data.offset(i).read() as int != pp.offset(i).read() as int: return false
            i = i + 1
        return true

# Borrow-checked zero-copy view constructor (Gap 3): the returned StrView BORROWS its
# source `s` — under --strict the borrow checker enforces that `s` is not mutated/moved
# while the view is still live (so the view can never dangle).
pub def str_view(s: str, start: int, count: int) -> StrView from s:
    return StrView.of(s, start, count)
