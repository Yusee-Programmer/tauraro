# native≡c differential corpus: if/else and while loops.
def main():
    mut i = 0
    mut s = 0
    while i < 10:
        s = s + i
        i = i + 1
    print(s)            # 45
    mut n = 5
    mut fact = 1
    while n > 1:
        fact = fact * n
        n = n - 1
    print(fact)         # 120
    mut k = 0
    while k < 100:
        k = k + 7
    print(k)            # 105
