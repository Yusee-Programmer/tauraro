# nativeâ‰ˇc / llvmâ‰ˇc differential corpus: index/len/neg dunders.
class Grid:
    base: int
    store: int

extend Grid:
    def init(base: int) -> Grid:
        mut g = Grid()
        g.base = base
        g.store = 0
        return g
    def __getitem__(self, i: int) -> int:
        return self.base * i
    def __setitem__(self, i: int, v: int):
        self.store = self.store + i + v
    def __len__(self) -> int:
        return self.base
    def __neg__(self) -> Grid:
        return Grid.init(0 - self.base)

def main():
    mut g = Grid.init(5)
    print(g[3])          # 15
    print(g[0])          # 0
    print(len(g))        # 5
    g[2] = 10
    g[1] = 3
    print(g.store)       # 2+10 + 1+3 = 16
    mut n = -g
    print(n.base)        # -5
    print(len(n))        # -5
