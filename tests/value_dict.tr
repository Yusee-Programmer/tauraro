# Value type stored inline as a Dict value (typed Dict_str_Point), no boxing.
@value_type
pub class Point:
    pub x: int
    pub y: int

extend Point:
    pub def of(x: int, y: int) -> Point:
        mut p = Point()
        p.x = x
        p.y = y
        return p

def main():
    mut d: Dict[str, Point] = Dict[str, Point].init()
    d.set("a", Point.of(1, 2))
    d.set("b", Point.of(3, 4))
    mut pa: Point = d.get("a")
    print(pa.x)                 # 1
    print(pa.y)                 # 2
    print(d.has("b"))           # true
    print(d.len())              # 2
    mut pb: Point = d.get("b")
    print(pb.x + pb.y)          # 7
    d.remove("a")
    print(d.len())              # 1
    print("value dict ok")
