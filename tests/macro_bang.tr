# Function-like macros (the `name!` form). Each `macro def` receives `args` —
# the list of the call's argument SOURCE strings — and returns expression source.

# vec!(...) -> a list literal built from the arguments
macro def vec(args) -> code:
    mut s = "["
    mut first = true
    for a in args:
        if not first:
            s = s + ", "
        s = s + a
        first = false
    s = s + "]"
    return s

# square!(x) -> (x) * (x)
macro def square(args) -> code:
    mut a = args[0]
    return "(" + a + ") * (" + a + ")"

# max2!(a, b) -> ternary picking the larger
macro def max2(args) -> code:
    mut a = args[0]
    mut b = args[1]
    return "((" + a + ") if (" + a + ") > (" + b + ") else (" + b + "))"

# sum_to!(n) -> a `do:` block computing 1+2+...+n. Uses gensym() for HYGIENE so
# the macro's temporaries can never collide with the caller's variables.
macro def sum_to(args) -> code:
    mut n = args[0]
    mut t = gensym("t")
    mut i = gensym("i")
    mut s = "do:\n"
    s = s + "    mut " + t + " = 0\n"
    s = s + "    mut " + i + " = 1\n"
    s = s + "    while " + i + " <= " + n + ":\n"
    s = s + "        " + t + " = " + t + " + " + i + "\n"
    s = s + "        " + i + " = " + i + " + 1\n"
    s = s + "    " + t
    return s

# kindof!(x) -> a string literal naming the argument's syntactic kind.
# Demonstrates structured args: `args[0].kind` / `args[0].src`.
macro def kindof(args) -> code:
    return "\"" + args[0].kind + "\""

def main():
    mut v = vec!(10, 20, 30)
    print(f"v.len = {v.len()}")          # 3

    mut s = square!(7)
    print(f"square = {s}")               # 49

    mut m = max2!(3, 9)
    print(f"max = {m}")                  # 9

    # macros used inside a larger expression
    mut total = square!(4) + square!(5)
    print(f"total = {total}")            # 41

    # statement-generating macro via a do: block (hygienic temps)
    mut st = sum_to!(5)
    print(f"sum_to = {st}")              # 15

    # hygiene: macro's internal `t`/`i` don't clash with my own `t`/`i`
    mut t = 100
    mut i = 7
    mut st2 = sum_to!(4)
    print(f"hygiene t={t} i={i} st2={st2}")   # t=100 i=7 st2=10

    # structured args: introspect the argument's kind
    print(kindof!(42))                   # int
    print(kindof!("hi"))                 # str
    print(kindof!(v))                    # ident
