# Normalize line endings
* text=auto

# Mark .tr sample files as Tauraro
*.tr      linguist-language=Tauraro linguist-detectable=true
*.tau     linguist-language=Tauraro linguist-detectable=true
*.tauraro linguist-language=Tauraro linguist-detectable=true

# Mark the Rouge lexer as Ruby (it is Ruby, not Tauraro)
*.rb      linguist-language=Ruby

# Auto-generated benchmark results - use 'ours' merge strategy
# In case of conflicts, always keep the current branch version
# (Results are auto-generated, so conflicts are resolved by taking current state)
benchmarks/results.md merge=ours
