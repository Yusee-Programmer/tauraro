# Compiled binaries and debug info
*.exe
*.pdb
*.txt
*.py
*.c
*.log

# Generated build directories (tauraroc output, cargo, etc.)
build/
target/
bench/
g1/
g2/

# Runtime headers copied into benchmark build dirs
**/tauraro_rt.h
**/tauraro_types.h

# Bootstrap: ignore only the temporary stage0 / download dirs.
# The committed portable C seed bootstrap/c/ MUST be tracked.
bootstrap/tauraroc-*/
bootstrap/unzipped/
bootstrap/*.zip

# Re-include the portable C bootstrap tree (overrides build/ and the
# **/tauraro_*.h rules above so the seed's headers are tracked too).
!bootstrap/c/
!bootstrap/c/**


# --- Test SOURCE files that must be tracked despite the broad *.py/*.c rules ---
# The ownership fuzzer generator and the bare-metal platform harness are source,
# not build artifacts. (git check-ignore was hiding them from CI.)
!tests/fuzz/gen.py
!tests/freestanding/platform.c
# The native backend's runtime shim is hand-written source (extern entry points to the
# header-only runtime), not generated C — it must be tracked despite the broad *.c rule.
!runtime/native_abi.c
# Python bytecode is never source:
__pycache__/
*.pyc

# Bare-metal MCU platform SOURCE (startup/allocator/UART) — source, not artifacts.
!tests/freestanding/mcu/*.c
