# compiler/src/parser.tr - Recursive descent parser for the Tauraro self-hosted compiler.

from core.vec import Vec
from core.alloc import alloc, dealloc
from token import Token
from lexer import Lexer
from diag import c_red, c_bold, c_cyan, c_dim, c_green, repeat_char
from ast import Program, Decl, AstType, Param, FunctionDef, FieldDef, ClassDef, VariantDef, EnumDef, InterfaceDef, ImportItem, Expr, Stmt, Block, ElifClause, MatchArm, Pattern, Decorator, FStringPart, Ownership, ChanSelectArm, CatchClause

# --- Helpers ------------------------------------------------------------------

pub def box_expr(e: Expr) -> Pointer[Expr]:
    unsafe:
        mut p = alloc[Expr](1)
        p.write(e)
        return p

pub def box_stmt(s: Stmt) -> Pointer[Stmt]:
    unsafe:
        mut p = alloc[Stmt](1)
        p.write(s)
        return p

pub def box_decl(d: Decl) -> Pointer[Decl]:
    unsafe:
        mut p = alloc[Decl](1)
        p.write(d)
        return p

pub def box_asttype(t: AstType) -> Pointer[AstType]:
    unsafe:
        mut p = alloc[AstType](1)
        p.write(t)
        return p

# Extract the `n`-th (1-based) line of `src`, without its trailing newline.
# Returns "" if `n` is out of range. Used for source-snippet diagnostics.
pub def _nth_source_line(src: str, n: int) -> str:
    if n <= 0: return ""
    mut p = src as Pointer[char]
    mut i = 0
    mut line = 1
    mut sb = StringBuilder.init(80)
    while True:
        mut c = 0
        unsafe:
            c = p.offset(i).read() as int
        if c == 0: break
        if line == n:
            if c == 10 or c == 13: break
            sb.append_char(c)
        elif line > n:
            break
        if c == 10: line = line + 1
        i = i + 1
    return sb.to_string().as_str()

# A string of `n` spaces (for aligning a caret under a source column).
pub def _spaces(n: int) -> str:
    mut sb = StringBuilder.init(n + 1)
    mut i = 0
    while i < n:
        sb.append_char(32)
        i = i + 1
    return sb.to_string().as_str()

# --- Parser class --------------------------------------------------------------

pub class Parser:
    pub tokens: Vec[Token]
    pub pos: int
    pub lines: Vec[int]
    pub cols: Vec[int]     # parallel 1-based columns (from lexer.token_cols); may be empty
    pub src_text: str      # full source text, for source-snippet diagnostics ("" if unknown)
    pub error_count: int   # number of parse errors emitted (0 = clean parse)
    pub current_file: str  # source path, for diagnostic messages ("" if unknown)

extend Parser:
    pub def init(tokens: Vec[Token], lines: Vec[int]) -> Parser:
        mut p = Parser()
        p.tokens = tokens
        p.lines = lines
        p.cols = Vec[int].init(0)
        p.src_text = ""
        p.pos = 0
        p.error_count = 0
        p.current_file = ""
        return p

    pub def peek(self) -> Token:
        if self.pos < self.tokens.len:
            return self.tokens.get(self.pos)
        return Token.Eof

    pub def advance(self) -> Token:
        mut tok = self.peek()
        if self.pos < self.tokens.len:
            self.pos = self.pos + 1
        return tok

    pub def skip_newlines(self):
        mut going = True
        while going:
            going = False
            match self.peek():
                case Token.Newline:
                    self.pos = self.pos + 1
                    going = True

                case _:
                    pass
    pub def skip_newlines_and_indent(self):
        mut going = True
        while going:
            going = False
            match self.peek():
                case Token.Newline | Token.Indent | Token.Dedent:
                    self.pos = self.pos + 1
                    going = True

                case _:
                    pass
    pub def expect_newline(self):
        match self.peek():
            case Token.Newline | Token.Semicolon:
                self.pos = self.pos + 1
            case _:
                pass

    pub def at_end(self) -> bool:
        match self.peek():
            case Token.Eof:
                return True
            case _:
                pass
        return False

    pub def cur_line(self) -> int:
        if self.pos < self.lines.len:
            return self.lines.get(self.pos)
        if self.lines.len > 0:
            return self.lines.get(self.lines.len - 1)
        return 0

    # 1-based column of the current token (0 if column info is unavailable,
    # e.g. for the f-string sub-parser which is given no token_cols).
    pub def cur_col(self) -> int:
        if self.pos < self.cols.len:
            return self.cols.get(self.pos)
        if self.cols.len > 0:
            return self.cols.get(self.cols.len - 1)
        return 0

    # Render a diagnostic with the rustc-style format (colorized on a TTY):
    #   error: <msg>
    #     --> file:line:col
    #      N | <source line>
    #        |     ^^^^   (span underlined in red)
    #        = help: <hint>
    # Degrades gracefully: omits the col when 0, and the snippet/caret when
    # the source text or column is unavailable. Color auto-disables off a TTY.
    pub def emit_diag(self, msg: str, hint: str):
        mut ln  = self.cur_line()
        mut col = self.cur_col()
        print(c_red("error") + ": " + c_bold(msg))
        mut loc = ""
        if self.current_file.len() > 0:
            loc = self.current_file
        mut head = loc + ":" + str(ln)
        if col > 0:
            head = head + ":" + str(col)
        print("  " + c_cyan("-->") + " " + head)
        # Source snippet + caret, when we have both the text and a column.
        if self.src_text.len() > 0 and ln > 0:
            mut srcline = _nth_source_line(self.src_text, ln)
            if srcline.len() > 0:
                mut gnum = "   " + str(ln) + " | "       # plain — used for width math
                mut gbar = _spaces(gnum.len() - 2) + "| "
                print(c_dim(gnum) + srcline)
                if col > 0:
                    # Underline a span as wide as the offending token (distance to
                    # the next token on the same line), falling back to a single ^.
                    mut width = 1
                    if self.pos + 1 < self.cols.len and self.pos + 1 < self.lines.len:
                        if self.lines.get(self.pos + 1) == ln:
                            mut d = self.cols.get(self.pos + 1) - col
                            if d > 0 and d < 200:
                                width = d
                    print(c_dim(gbar) + _spaces(col - 1) + c_red(repeat_char("^", width)))
        if hint.len() > 0:
            print("  " + c_green("= help") + ": " + hint)
        self.error_count = self.error_count + 1

    pub def consume_ident(self) -> str:
        match self.peek():
            case Token.Ident(name):
                self.pos = self.pos + 1
                return name
            case Token.KwInt:
                self.pos = self.pos + 1
                return "int"
            case Token.KwFloat:
                self.pos = self.pos + 1
                return "float"
            case Token.KwBool:
                self.pos = self.pos + 1
                return "bool"
            case Token.KwStr | Token.KwString:
                self.pos = self.pos + 1
                return "str"
            case Token.KwChar:
                self.pos = self.pos + 1
                return "char"
            case Token.KwVoid:
                self.pos = self.pos + 1
                return "void"
            # Keywords that are valid method/function names in user code
            case Token.KwExtend:
                self.pos = self.pos + 1
                return "extend"
            # 'None' is KwNone but also a valid variant name in patterns like Option.None
            case Token.KwNone:
                self.pos = self.pos + 1
                return "None"
            # 'lambda' is KwLambda but used as a type name for function pointer params
            case Token.KwLambda:
                self.pos = self.pos + 1
                return "lambda"
            # 'spawn' is KwSpawn but valid as a method name (e.g. pool.spawn(...))
            case Token.KwSpawn:
                self.pos = self.pos + 1
                return "spawn"
            # 'async' is KwAsync but valid as a module path segment
            case Token.KwAsync:
                self.pos = self.pos + 1
                return "async"
            case _:
                pass
        return ""

    # Like consume_ident but also accepts keyword tokens that may appear as
    # directory/module names in dotted import paths (e.g. std.async.task).
    pub def consume_module_ident(self) -> str:
        match self.peek():
            case Token.KwAsync:
                self.pos = self.pos + 1
                return "async"
            case Token.KwMatch:
                self.pos = self.pos + 1
                return "match"
            case Token.KwFor:
                self.pos = self.pos + 1
                return "for"
            case Token.KwIn:
                self.pos = self.pos + 1
                return "in"
            case Token.KwIs:
                self.pos = self.pos + 1
                return "is"
            case _:
                return self.consume_ident()
        return ""

    # -- Type parsing ----------------------------------------------------------

    pub def parse_type(self) -> AstType:
        mut name = ""
        match self.peek():
            case Token.KwNone:
                self.pos = self.pos + 1
                return AstType.init("void")
            case Token.LParen:
                # Tuple type: (T1, T2, ...) -> AstType{ name="Tuple", args=[T1,T2,...] }
                self.pos = self.pos + 1
                mut tup_t = AstType.init("Tuple")
                while self.peek() != Token.RParen and self.peek() != Token.Eof:
                    mut elem_t = self.parse_type()
                    tup_t.args.push(box_asttype(elem_t))
                    if self.peek() == Token.Comma: self.pos = self.pos + 1
                if self.peek() == Token.RParen: self.pos = self.pos + 1
                return tup_t
            case Token.KwDef:
                # Function-pointer type: def(T1, T2) -> R  (zero-cost callable
                # value: a pointer to a top-level function). Encoded internally
                # as AstType{name="def", args=[T1, ..., R]} (last arg = return).
                self.pos = self.pos + 1
                mut dfn_t = AstType.init("def")
                if self.peek() == Token.LParen:
                    self.pos = self.pos + 1
                    while self.peek() != Token.RParen and self.peek() != Token.Eof:
                        mut dpt = self.parse_type()
                        dfn_t.args.push(box_asttype(dpt))
                        if self.peek() == Token.Comma: self.pos = self.pos + 1
                    if self.peek() == Token.RParen: self.pos = self.pos + 1
                mut dret = AstType.init("void")
                if self.peek() == Token.Arrow:
                    self.pos = self.pos + 1
                    dret = self.parse_type()
                dfn_t.args.push(box_asttype(dret))
                return dfn_t
            case Token.KwMut:
                # "mut ref T" - mutable (exclusive) borrow. ERASES to the inner type
                # T for codegen; the is_borrow/is_mut_borrow flags drive checking.
                self.pos = self.pos + 1
                mut mr_name = self.consume_ident()
                if mr_name == "ref":
                    mut mr_inner = self.parse_type()
                    mr_inner.is_borrow = true
                    mr_inner.is_mut_borrow = true
                    return mr_inner
                # Malformed - just return void
                return AstType.init("void")
            case _:
                name = self.consume_ident()

        if name == "":
            return AstType.init("void")

        # "ref T" - immutable (shared) borrow / region view. ERASES to the inner
        # type T for codegen (so a `ref str` is usable exactly like a `str`); the
        # is_borrow flag + a `from` region drive borrow checking. Named regions are
        # a checking concept layered over the ARC floor, not a representation change.
        if name == "ref":
            mut ref_inner = self.parse_type()
            ref_inner.is_borrow = true
            return ref_inner


        match self.peek():
            case Token.LBracket:
                self.pos = self.pos + 1
                mut t = AstType.init(name)
                mut going = True
                while going:
                    match self.peek():
                        case Token.RBracket | Token.Eof:
                            going = False
                        case _:
                            pass
                    if going:
                        arg_t = self.parse_type()
                        t.args.push(box_asttype(arg_t))
                        match self.peek():
                            case Token.Comma:
                                self.pos = self.pos + 1
                            case _:
                                going = False
                match self.peek():
                    case Token.RBracket:
                        self.pos = self.pos + 1
                    case _:
                        pass
                return t
            case _:
                pass
        return AstType.init(name)

    # -- Param list parsing ----------------------------------------------------

    pub def parse_param_list(self) -> Vec[Param]:
        mut pl = Vec[Param].init(4)
        mut going = True
        while going:
            self.skip_newlines_and_indent()
            match self.peek():
                case Token.RParen | Token.Eof:
                    going = False
                case _:
                    pass
            if going:
                mut item_name = self.consume_ident()
                if item_name != "":
                    mut ty_ptr = Pointer[AstType](0)
                    match self.peek():
                        case Token.Colon:
                            self.pos = self.pos + 1
                            ty = self.parse_type()
                            # Param region: `a: ref str from r`. A single region only —
                            # a comma here separates parameters, not regions.
                            if self.peek() == Token.KwFrom:
                                self.pos = self.pos + 1
                                ty.from_param = self.consume_ident()
                                ty.from_regions.push(ty.from_param)
                            ty_ptr = box_asttype(ty)
                        case _:
                            # Bare-type field (enum variant payload), e.g. `Word(str)` —
                            # `item_name` IS the type. Support a borrowed bare type
                            # `ref T from r`: `item_name == "ref"` means the real type
                            # follows; parse it, mark the borrow, and read the region.
                            if item_name == "ref":
                                mut bt = self.parse_type()
                                bt.is_borrow = true
                                if self.peek() == Token.KwFrom:
                                    self.pos = self.pos + 1
                                    bt.from_param = self.consume_ident()
                                    bt.from_regions.push(bt.from_param)
                                ty_ptr = box_asttype(bt)
                                # Mirror the bare-type convention: the field name is the
                                # inner type's name (codegen derives `_tr_v_<name>` from it).
                                item_name = bt.name
                    p = Param.init(item_name, ty_ptr)
                    if ty_ptr as usize != 0 as usize:
                        if ty_ptr.read().is_borrow:
                            p.is_ref = true
                        if ty_ptr.read().is_mut_borrow:
                            p.is_mut_ref = true
                    # Variadic param: `args...` or `args: T...` collects trailing
                    # call args into a List[T] (T defaults to int if unannotated).
                    if self.peek() == Token.DotDotDot:
                        self.pos = self.pos + 1
                        p.is_variadic = true
                    pl.push(p)
                    match self.peek():
                        case Token.Comma:
                            self.pos = self.pos + 1
                            self.skip_newlines_and_indent()
                        case _:
                            going = False
                else:
                    going = False
        return pl

    # -- Block parsing ---------------------------------------------------------

    pub def parse_block(self) -> Block:
        mut b = Block.init()
        mut is_inline = False
        match self.peek():
            case Token.Indent:
                self.pos = self.pos + 1
            case Token.Newline:
                self.pos = self.pos + 1
                self.skip_newlines_and_indent()
            case _:
                is_inline = True

        if is_inline:
            b.push(box_stmt(Stmt.SLine(self.cur_line())))
            b.push(self.parse_stmt())
            mut semi_going = True
            while semi_going:
                semi_going = False
                match self.peek():
                    case Token.Semicolon:
                        # Explicit semicolon still present - consume and parse next stmt.
                        self.pos = self.pos + 1
                        match self.peek():
                            case Token.Newline | Token.Eof | Token.Dedent:
                                pass
                            case _:
                                b.push(box_stmt(Stmt.SLine(self.cur_line())))
                                b.push(self.parse_stmt())
                                semi_going = True
                    case _:
                        # parse_stmt's expect_newline may have consumed the ';' already.
                        # Check the previous token: if it was ';', there are more stmts.
                        if self.pos > 0:
                            match self.tokens.get(self.pos - 1):
                                case Token.Semicolon:
                                    match self.peek():
                                        case Token.Newline | Token.Eof | Token.Dedent:
                                            pass
                                        case _:
                                            b.push(box_stmt(Stmt.SLine(self.cur_line())))
                                            b.push(self.parse_stmt())
                                            semi_going = True
                                case _:
                                    pass
            return b

        mut going = True
        while going:
            match self.peek():
                case Token.Dedent | Token.Eof:
                    going = False
                case _:
                    pass
            if going:
                self.skip_newlines()
                match self.peek():
                    case Token.Dedent | Token.Eof:
                        going = False
                    case _:
                        pass
                if going:
                    mut _sline = self.cur_line()
                    s = self.parse_stmt()
                    b.push(box_stmt(Stmt.SLine(_sline)))
                    b.push(s)
        match self.peek():
            case Token.Dedent:
                self.pos = self.pos + 1
            case _:
                pass
        return b

    # -- Statement parsing -----------------------------------------------------

    pub def parse_stmt(self) -> Pointer[Stmt]:
        match self.peek():
            case Token.KwReturn:
                self.pos = self.pos + 1
                match self.peek():
                    case Token.Newline | Token.Dedent | Token.Eof:
                        return box_stmt(Stmt.SReturn(Pointer[Expr](0)))
                    case _:
                        pass
                mut e = self.parse_expr()
                self.expect_newline()
                return box_stmt(Stmt.SReturn(e))
            case Token.KwPass:
                self.pos = self.pos + 1
                self.expect_newline()
                return box_stmt(Stmt.SPass)
            case Token.KwBreak:
                self.pos = self.pos + 1
                self.expect_newline()
                return box_stmt(Stmt.SBreak)
            case Token.KwContinue:
                self.pos = self.pos + 1
                self.expect_newline()
                return box_stmt(Stmt.SContinue)
            case Token.KwRaise:
                self.pos = self.pos + 1
                mut e = self.parse_expr()
                self.expect_newline()
                return box_stmt(Stmt.SRaise(e))
            case Token.KwAsm:
                return self.parse_asm_stmt()
            case Token.KwSpawn:
                return self.parse_spawn_stmt()
            case Token.KwTaskGroup:
                return self.parse_taskgroup_stmt()
            case Token.KwGpu:
                return self.parse_gpu_stmt()
            case Token.KwIf:
                return self.parse_if_stmt()
            case Token.KwWhile:
                return self.parse_while_stmt()
            case Token.KwFor:
                return self.parse_for_stmt()
            case Token.KwMatch:
                return self.parse_match_stmt()
            case Token.KwMut:
                return self.parse_let_stmt(True)
            case Token.KwShared:
                return self.parse_shared_let_stmt()
            case Token.KwConst:
                return self.parse_const_let_stmt()
            case Token.KwUnsafe:
                self.pos = self.pos + 1
                match self.peek():
                    case Token.Colon:
                        self.pos = self.pos + 1
                    case _:
                        pass
                body = self.parse_block()
                return box_stmt(Stmt.SUnsafe(body))
            case Token.KwDefer:
                # defer stmt - deferred execution at function exit (LIFO)
                self.pos = self.pos + 1
                mut deferred = self.parse_stmt()
                return box_stmt(Stmt.SDefer(deferred))
            case Token.KwWith:
                return self.parse_with_stmt()
            case Token.KwTry:
                return self.parse_try_stmt()
            case Token.KwAssert:
                return self.parse_assert_stmt()
            case Token.KwFrom:
                # Local `from X import Y` inside function body - already resolved at module level.
                self.parse_from_import()
                return box_stmt(Stmt.SPass)
            case Token.KwImport:
                self.parse_import()
                return box_stmt(Stmt.SPass)
            # Nested declarations - class/def/enum/interface/extend inside a function
            # body (Java-style local types). Sema restricts these to main() and
            # hoists them to file scope; codegen emits them as ordinary top-level
            # definitions.
            case Token.KwClass:
                return box_stmt(Stmt.SLocalDecl(self.parse_decl()))
            case Token.KwEnum:
                return box_stmt(Stmt.SLocalDecl(self.parse_decl()))
            case Token.KwInterface:
                return box_stmt(Stmt.SLocalDecl(self.parse_decl()))
            case Token.KwExtend:
                return box_stmt(Stmt.SLocalDecl(self.parse_decl()))
            case Token.KwDef:
                mut _ldline = self.cur_line()
                mut _ldf = self.parse_function_def(False)
                _ldf.line = _ldline
                return box_stmt(Stmt.SLocalDecl(box_decl(Decl.DFunction(_ldf))))
            case _:
                pass
        match self.peek():
            case Token.Ident(cs_nm):
                if cs_nm == "type":
                    # Local type alias: `type Name = ExistingType` inside a function.
                    # Consume and emit as SPass - the alias is registered in the outer parse_decl path.
                    # For local scopes we just need to parse and discard cleanly.
                    self.pos = self.pos + 1
                    mut _ta_name = self.consume_ident()
                    if self.peek() == Token.Eq:
                        self.pos = self.pos + 1
                        mut _ta_ty = self.parse_type()
                        self.expect_newline()
                        return box_stmt(Stmt.SPass)
                if cs_nm == "chan_select":
                    return self.parse_chan_select_stmt()
            case _: pass
        return self.parse_assign_or_expr_stmt()

    pub def parse_try_stmt(self) -> Pointer[Stmt]:
        self.pos = self.pos + 1
        match self.peek():
            case Token.Colon:
                self.pos = self.pos + 1
            case _:
                pass
        try_body = self.parse_block()
        mut catches = Vec[Pointer[CatchClause]].init(2)
        while self.peek() == Token.KwExcept:
            self.pos = self.pos + 1
            mut err_type = Pointer[AstType](0)
            mut err_name = ""
            if self.peek() != Token.Colon:
                # Peek: if next token is a simple ident followed by ':', treat as variable name
                mut is_bare_var = false
                match self.peek():
                    case Token.Ident(_):
                        mut save_pos = self.pos
                        self.pos = self.pos + 1
                        if self.peek() == Token.Colon:
                            is_bare_var = true
                        self.pos = save_pos
                    case _:
                        pass
                if is_bare_var:
                    err_name = self.consume_ident()
                else:
                    err_type = box_asttype(self.parse_type())
                    if self.peek() == Token.KwAs:
                        self.pos = self.pos + 1
                        err_name = self.consume_ident()
            match self.peek():
                case Token.Colon:
                    self.pos = self.pos + 1
                case _:
                    pass
            mut body = self.parse_block()
            mut c = CatchClause.init(err_name, Pointer[Block](0))
            unsafe:
                mut body_ptr = alloc[Block](1)
                body_ptr.write(body)
                c.body = body_ptr
            c.err_type = err_type
            unsafe:
                mut c_ptr = alloc[CatchClause](1)
                c_ptr.write(c)
                catches.push(c_ptr)
        
        mut finally_b = Block.init()
        if self.peek() == Token.KwFinally:
            self.pos = self.pos + 1
            match self.peek():
                case Token.Colon:
                    self.pos = self.pos + 1
                case _:
                    pass
            finally_b = self.parse_block()
        return box_stmt(Stmt.STry(try_body, catches, finally_b))

    pub def parse_assert_stmt(self) -> Pointer[Stmt]:
        self.pos = self.pos + 1
        cond = self.parse_expr()
        mut msg = Pointer[Expr](0)
        if self.peek() == Token.Comma:
            self.pos = self.pos + 1
            msg = self.parse_expr()
        self.expect_newline()
        return box_stmt(Stmt.SAssert(cond, msg))

    pub def parse_with_stmt(self) -> Pointer[Stmt]:
        self.pos = self.pos + 1  # consume 'with'
        mut items = Vec[Pointer[Expr]].init(1)
        mut aliases = Vec[str].init(1)
        mut going = true
        while going:
            mut item_e = self.parse_expr()
            mut alias = ""
            # parse_expr() consumes `as AliasName` as ECast; unwrap it to get the alias
            if item_e as usize != 0 as usize:
                match item_e.read():
                    case Expr.ECast(cast_inner, cast_ty_ptr):
                        if cast_ty_ptr as usize != 0 as usize:
                            alias = cast_ty_ptr.read().name
                        item_e = cast_inner
                    case _: pass
            items.push(item_e)
            aliases.push(alias)
            if self.peek() == Token.Comma:
                self.pos = self.pos + 1
            else:
                going = false
        match self.peek():
            case Token.Colon:
                self.pos = self.pos + 1
            case _:
                pass
        mut body = self.parse_block()
        return box_stmt(Stmt.SWith(items, aliases, body))

    pub def parse_asm_stmt(self) -> Pointer[Stmt]:
        self.pos = self.pos + 1  # consume 'asm'
        match self.peek():
            case Token.LParen:
                self.pos = self.pos + 1
            case _:
                pass
        mut parts = Vec[str].init(4)
        # collect up to 4 comma-separated string literal arguments
        mut reading = true
        while reading:
            match self.peek():
                case Token.StrLit(s):
                    self.pos = self.pos + 1
                    parts.push(s)
                    match self.peek():
                        case Token.Comma:
                            self.pos = self.pos + 1
                        case _: reading = false
                case _: reading = false
        match self.peek():
            case Token.RParen:
                self.pos = self.pos + 1
            case _:
                pass
        self.expect_newline()
        mut code = ""
        mut outs = ""
        mut ins  = ""
        mut clob = ""
        if parts.len > 0: code = parts.get(0)
        if parts.len > 1: outs = parts.get(1)
        if parts.len > 2: ins  = parts.get(2)
        if parts.len > 3: clob = parts.get(3)
        return box_stmt(Stmt.SAsm(code, outs, ins, clob))

    pub def parse_spawn_stmt(self) -> Pointer[Stmt]:
        self.pos = self.pos + 1
        e = self.parse_expr()
        self.expect_newline()
        return box_stmt(Stmt.SSpawn(e))

    pub def parse_taskgroup_stmt(self) -> Pointer[Stmt]:
        self.pos = self.pos + 1
        match self.peek():
            case Token.Colon:
                self.pos = self.pos + 1
            case _:
                pass
        body = self.parse_block()
        return box_stmt(Stmt.STaskGroup(body))

    pub def parse_chan_select_stmt(self) -> Pointer[Stmt]:
        # chan_select:
        #   case v = ch.recv():   body
        #   case ch.send(val):    body
        #   case timeout(ms):     body
        #   case default:         body
        self.pos = self.pos + 1  # consume 'chan_select' ident
        if self.peek() == Token.Colon: self.pos = self.pos + 1
        self.skip_newlines()
        if self.peek() == Token.Indent: self.pos = self.pos + 1
        self.skip_newlines()
        mut cases = Vec[Pointer[ChanSelectArm]].init(4)
        mut going = true
        while going:
            match self.peek():
                case Token.KwCase:
                    self.pos = self.pos + 1  # consume 'case'
                    # Peek to distinguish arm type
                    mut arm_kind = -1
                    mut var_nm = ""
                    mut chan_e = Pointer[Expr](0)
                    mut val_e = Pointer[Expr](0)
                    mut timeout_e = Pointer[Expr](0)
                    # Check for 'default', 'timeout', or binding/send expression
                    match self.peek():
                        case Token.Ident(arm_nm):
                            if arm_nm == "default":
                                self.pos = self.pos + 1
                                if self.peek() == Token.Colon: self.pos = self.pos + 1
                                arm_kind = 3
                            elif arm_nm == "timeout":
                                # timeout(ms):
                                self.pos = self.pos + 1
                                if self.peek() == Token.LParen: self.pos = self.pos + 1
                                timeout_e = self.parse_expr()
                                if self.peek() == Token.RParen: self.pos = self.pos + 1
                                if self.peek() == Token.Colon: self.pos = self.pos + 1
                                arm_kind = 2
                            else:
                                # Could be: v = ch.recv() -> recv arm
                                # Or: ch.send(val)        -> send arm
                                mut saved = self.pos
                                self.pos = self.pos + 1  # consume ident
                                match self.peek():
                                    case Token.Eq:
                                        # v = expr -> recv arm: v = ch.recv()
                                        self.pos = self.pos + 1
                                        chan_e = self.parse_expr()
                                        if self.peek() == Token.Colon: self.pos = self.pos + 1
                                        var_nm = arm_nm
                                        arm_kind = 0
                                    case _:
                                        # send arm: ch.send(val)
                                        self.pos = saved
                                        chan_e = self.parse_expr()
                                        if self.peek() == Token.Colon: self.pos = self.pos + 1
                                        arm_kind = 1
                        case _:
                            # send/recv without binding: parse as expression
                            chan_e = self.parse_expr()
                            if self.peek() == Token.Colon: self.pos = self.pos + 1
                            arm_kind = 1
                    mut arm_body = self.parse_block()
                    unsafe:
                        mut arm_p = alloc[ChanSelectArm](1)
                        if arm_kind == 0:
                            arm_p.write(ChanSelectArm.init_recv(chan_e, var_nm, arm_body))
                        elif arm_kind == 1:
                            arm_p.write(ChanSelectArm.init_send(chan_e, Pointer[Expr](0), arm_body))
                        elif arm_kind == 2:
                            arm_p.write(ChanSelectArm.init_timeout(timeout_e, arm_body))
                        else:
                            arm_p.write(ChanSelectArm.init_default(arm_body))
                        cases.push(arm_p)
                case Token.Dedent | Token.Eof:
                    going = false
                case Token.Newline:
                    self.pos = self.pos + 1
                case _:
                    going = false
        if self.peek() == Token.Dedent: self.pos = self.pos + 1
        return box_stmt(Stmt.SChanSelect(cases))

    pub def parse_gpu_stmt(self) -> Pointer[Stmt]:
        self.pos = self.pos + 1
        match self.peek():
            case Token.Colon:
                self.pos = self.pos + 1
            case _:
                pass
        body = self.parse_block()
        return box_stmt(Stmt.SGpuBlock(body))

    pub def parse_let_stmt(self, is_mut: bool) -> Pointer[Stmt]:
        if is_mut:
            self.pos = self.pos + 1
        name = self.consume_ident()
        # Detect tuple unpacking: mut a, b, c = expr
        if self.peek() == Token.Comma:
            mut names = Vec[str].init(4)
            names.push(name)
            while self.peek() == Token.Comma:
                self.pos = self.pos + 1
                names.push(self.consume_ident())
            match self.peek():
                case Token.Eq:
                    self.pos = self.pos + 1
                case _:
                    pass
            mut val_ptr = self.parse_expr()
            self.expect_newline()
            return box_stmt(Stmt.SMultiLet(names, is_mut, val_ptr))
        mut ty_ptr = Pointer[AstType](0)
        match self.peek():
            case Token.Colon:
                self.pos = self.pos + 1
                ty = self.parse_type()
                ty_ptr = box_asttype(ty)
            case _:
                pass
        mut val_ptr = Pointer[Expr](0)
        match self.peek():
            case Token.Eq:
                self.pos = self.pos + 1
                val_ptr = self.parse_expr()
            case _:
                pass
        self.expect_newline()
        return box_stmt(Stmt.SLet(name, Ownership.Own, is_mut, false, false, ty_ptr, val_ptr))

    pub def parse_shared_let_stmt(self) -> Pointer[Stmt]:
        self.pos = self.pos + 1  # consume 'shared'
        name = self.consume_ident()
        mut ty_ptr = Pointer[AstType](0)
        match self.peek():
            case Token.Colon:
                self.pos = self.pos + 1
                ty = self.parse_type()
                ty_ptr = box_asttype(ty)
            case _:
                pass
        mut val_ptr = Pointer[Expr](0)
        match self.peek():
            case Token.Eq:
                self.pos = self.pos + 1
                val_ptr = self.parse_expr()
            case _:
                pass
        self.expect_newline()
        return box_stmt(Stmt.SLet(name, Ownership.Shared, true, false, true, ty_ptr, val_ptr))

    pub def parse_const_let_stmt(self) -> Pointer[Stmt]:
        self.pos = self.pos + 1  # consume 'const'
        name = self.consume_ident()
        mut ty_ptr = Pointer[AstType](0)
        match self.peek():
            case Token.Colon:
                self.pos = self.pos + 1
                ty = self.parse_type()
                ty_ptr = box_asttype(ty)
            case _:
                pass
        mut val_ptr = Pointer[Expr](0)
        match self.peek():
            case Token.Eq:
                self.pos = self.pos + 1
                val_ptr = self.parse_expr()
            case _:
                pass
        self.expect_newline()
        return box_stmt(Stmt.SLet(name, Ownership.Own, false, true, false, ty_ptr, val_ptr))

    pub def parse_if_stmt(self) -> Pointer[Stmt]:
        self.pos = self.pos + 1
        cond = self.parse_expr()
        self.skip_newlines()
        match self.peek():
            case Token.Colon:
                self.pos = self.pos + 1
            case _:
                pass
        then_b = self.parse_block()
        mut elifs = Vec[ElifClause].init(2)
        mut else_b = Block.init()
        mut going = True
        while going:
            going = False
            self.skip_newlines()
            match self.peek():
                case Token.KwElif:
                    self.pos = self.pos + 1
                    ec = self.parse_expr()
                    self.skip_newlines()
                    match self.peek():
                        case Token.Colon:
                            self.pos = self.pos + 1
                        case _:
                            pass
                    eb = self.parse_block()
                    unsafe:
                        mut eb_ptr = alloc[Block](1)
                        eb_ptr.write(eb)
                        elifs.push(ElifClause.init(ec, eb_ptr))
                    going = True
                case Token.KwElse:
                    self.pos = self.pos + 1
                    self.skip_newlines()
                    match self.peek():
                        case Token.Colon:
                            self.pos = self.pos + 1
                        case _:
                            pass
                    else_b = self.parse_block()
                case _:
                    pass
        return box_stmt(Stmt.SIf(cond, then_b, elifs, else_b))

    pub def parse_while_stmt(self) -> Pointer[Stmt]:
        self.pos = self.pos + 1
        cond = self.parse_expr()
        self.skip_newlines()
        match self.peek():
            case Token.Colon:
                self.pos = self.pos + 1
            case _:
                pass
        body = self.parse_block()
        return box_stmt(Stmt.SWhile(cond, body, Vec[Decorator].init(0)))

    pub def parse_for_stmt(self) -> Pointer[Stmt]:
        self.pos = self.pos + 1
        # `for mut ref x` / `for ref x` — borrow each element (zero-copy iteration; the
        # loop body borrows the collection, so it can't be mutated mid-loop).
        mut for_is_ref = false
        if self.peek() == Token.KwMut:
            self.pos = self.pos + 1
            mut _mr = self.consume_ident()   # `ref`
            for_is_ref = true
        mut var = self.consume_ident()
        if not for_is_ref and var == "ref":
            match self.peek():
                case Token.KwIn: pass
                case Token.Comma: pass
                case _:
                    for_is_ref = true
                    var = self.consume_ident()
        # Multi-target: for a, b in ... -> SForUnpack
        if self.peek() == Token.Comma:
            mut unpack_vars = Vec[str].init(4)
            unpack_vars.push(var)
            while self.peek() == Token.Comma:
                self.pos = self.pos + 1
                unpack_vars.push(self.consume_ident())
            if self.peek() == Token.KwIn: self.pos = self.pos + 1
            mut fu_iter = self.parse_expr()
            self.skip_newlines()
            if self.peek() == Token.Colon: self.pos = self.pos + 1
            mut fu_body = self.parse_block()
            return box_stmt(Stmt.SForUnpack(unpack_vars, fu_iter, fu_body))
        match self.peek():
            case Token.KwIn:
                self.pos = self.pos + 1
            case _:
                pass
        iter_e = self.parse_expr()
        self.skip_newlines()
        match self.peek():
            case Token.Colon:
                self.pos = self.pos + 1
            case _:
                pass
        body = self.parse_block()
        return box_stmt(Stmt.SFor(var, iter_e, body, Vec[Decorator].init(0), for_is_ref))

    pub def parse_match_stmt(self) -> Pointer[Stmt]:
        self.pos = self.pos + 1
        subj = self.parse_expr()
        self.skip_newlines()
        match self.peek():
            case Token.Colon:
                self.pos = self.pos + 1
            case _:
                pass
        self.skip_newlines()
        match self.peek():
            case Token.Indent:
                self.pos = self.pos + 1
            case _:
                pass
        mut arms = Vec[MatchArm].init(4)
        mut going = True
        while going:
            self.skip_newlines()
            match self.peek():
                case Token.Dedent | Token.Eof:
                    going = False
                case _:
                    pass
            if going:
                mut pat = self.parse_pattern()
                if self.peek() == Token.Pipe:
                    mut or_pats = Vec[Pattern].init(4)
                    or_pats.push(pat)
                    while self.peek() == Token.Pipe:
                        self.pos = self.pos + 1
                        or_pats.push(self.parse_pattern())
                    pat = Pattern.POr(or_pats)
                # Pattern matching guard: `case Pattern if condition:`
                mut guard_expr = Pointer[Expr](0)
                if self.peek() == Token.KwIf:
                    self.pos = self.pos + 1
                    guard_expr = self.parse_expr()
                match self.peek():
                    case Token.Colon:
                        self.pos = self.pos + 1
                    case _:
                        pass
                mut arm_block = Block.init()
                mut is_block_arm = False
                match self.peek():
                    case Token.Newline | Token.Indent:
                        arm_block = self.parse_block()
                        is_block_arm = True
                    case _:
                        pass
                if not is_block_arm:
                    arm_block.push(self.parse_stmt())
                mut ab_ptr = Pointer[Block](0)
                unsafe:
                    ab_ptr = alloc[Block](1)
                    ab_ptr.write(arm_block)
                mut new_arm = MatchArm.init(pat, ab_ptr)
                new_arm.guard = guard_expr
                arms.push(new_arm)
        match self.peek():
            case Token.Dedent:
                self.pos = self.pos + 1
            case _:
                pass
        return box_stmt(Stmt.SMatch(subj, arms))

    pub def parse_pattern(self) -> Pattern:
        match self.peek():
            case Token.KwCase:
                self.pos = self.pos + 1
            case _:
                pass
        match self.peek():
            case Token.Ident(type_name):
                self.pos = self.pos + 1
                match self.peek():
                    case Token.Dot:
                        self.pos = self.pos + 1
                        variant = self.consume_ident()
                        match self.peek():
                            case Token.LParen:
                                self.pos = self.pos + 1
                                mut fields = Vec[str].init(4)
                                while self.peek() != Token.RParen and self.peek() != Token.Eof:
                                    mut fname = self.consume_ident()
                                    if fname == "":
                                        self.pos = self.pos + 1
                                    else:
                                        fields.push(fname)
                                    if self.peek() == Token.Comma:
                                        self.pos = self.pos + 1
                                if self.peek() == Token.RParen:
                                    self.pos = self.pos + 1
                                if fields.len == 1:
                                    return Pattern.PVariantBind(type_name, variant, fields.get(0))
                                return Pattern.PVariantBindMany(type_name, variant, fields)
                            case _:
                                pass
                        return Pattern.PVariant(type_name, variant)
                    case _:
                        pass
                return Pattern.PBind(type_name)
            case Token.IntLit(v):
                self.pos = self.pos + 1
                return Pattern.PLitInt(v)
            case Token.KwTrue:
                self.pos = self.pos + 1
                return Pattern.PLitBool(True)
            case Token.KwFalse:
                self.pos = self.pos + 1
                return Pattern.PLitBool(False)
            case Token.StrLit(s):
                self.pos = self.pos + 1
                return Pattern.PLitStr(s)
            case _:
                pass
        return Pattern.PWild

    pub def parse_assign_or_expr_stmt(self) -> Pointer[Stmt]:
        lhs = self.parse_expr()
        match self.peek():
            case Token.Colon:
                # Type declaration: name: type = val
                match lhs.read():
                    case Expr.EIdent(name):
                        self.pos = self.pos + 1
                        mut ty = self.parse_type()
                        mut val = Pointer[Expr](0)
                        if self.peek() == Token.Eq:
                            self.pos = self.pos + 1
                            val = self.parse_expr()
                        self.expect_newline()
                        return box_stmt(Stmt.SLet(name, Ownership.Own, False, false, false, box_asttype(ty), val))
                    case _: pass
            case Token.Eq:
                self.pos = self.pos + 1
                mut rhs = self.parse_expr()
                self.expect_newline()
                return box_stmt(Stmt.SAssign(lhs, rhs))
            case Token.PlusEq:
                self.pos = self.pos + 1
                mut rhs = self.parse_expr()
                self.expect_newline()
                return box_stmt(Stmt.SAssign(lhs, box_expr(Expr.EBinOp("+", lhs, rhs))))
            case Token.MinusEq:
                self.pos = self.pos + 1
                mut rhs = self.parse_expr()
                self.expect_newline()
                return box_stmt(Stmt.SAssign(lhs, box_expr(Expr.EBinOp("-", lhs, rhs))))
            case Token.StarEq:
                self.pos = self.pos + 1
                mut rhs = self.parse_expr()
                self.expect_newline()
                return box_stmt(Stmt.SAssign(lhs, box_expr(Expr.EBinOp("*", lhs, rhs))))
            case Token.SlashEq:
                self.pos = self.pos + 1
                mut rhs = self.parse_expr()
                self.expect_newline()
                return box_stmt(Stmt.SAssign(lhs, box_expr(Expr.EBinOp("/", lhs, rhs))))
            case Token.PercentEq:
                self.pos = self.pos + 1
                mut rhs = self.parse_expr()
                self.expect_newline()
                return box_stmt(Stmt.SAssign(lhs, box_expr(Expr.EBinOp("%", lhs, rhs))))
            case Token.FloorDivEq:
                self.pos = self.pos + 1
                mut rhs = self.parse_expr()
                self.expect_newline()
                return box_stmt(Stmt.SAssign(lhs, box_expr(Expr.EBinOp("//", lhs, rhs))))
            case Token.StarStarEq:
                self.pos = self.pos + 1
                mut rhs = self.parse_expr()
                self.expect_newline()
                return box_stmt(Stmt.SAssign(lhs, box_expr(Expr.EBinOp("**", lhs, rhs))))
            case Token.AmpEq:
                self.pos = self.pos + 1
                mut rhs = self.parse_expr()
                self.expect_newline()
                return box_stmt(Stmt.SAssign(lhs, box_expr(Expr.EBinOp("&", lhs, rhs))))
            case Token.PipeEq:
                self.pos = self.pos + 1
                mut rhs = self.parse_expr()
                self.expect_newline()
                return box_stmt(Stmt.SAssign(lhs, box_expr(Expr.EBinOp("|", lhs, rhs))))
            case Token.CaretEq:
                self.pos = self.pos + 1
                mut rhs = self.parse_expr()
                self.expect_newline()
                return box_stmt(Stmt.SAssign(lhs, box_expr(Expr.EBinOp("^", lhs, rhs))))
            case Token.LtLtEq:
                self.pos = self.pos + 1
                mut rhs = self.parse_expr()
                self.expect_newline()
                return box_stmt(Stmt.SAssign(lhs, box_expr(Expr.EBinOp("<<", lhs, rhs))))
            case Token.GtGtEq:
                self.pos = self.pos + 1
                mut rhs = self.parse_expr()
                self.expect_newline()
                return box_stmt(Stmt.SAssign(lhs, box_expr(Expr.EBinOp(">>", lhs, rhs))))
            case _:
                pass
        self.expect_newline()
        return box_stmt(Stmt.SExpr(lhs))

    pub def parse_expr(self) -> Pointer[Expr]:
        return self.parse_ternary()

    pub def parse_ternary(self) -> Pointer[Expr]:
        mut left = self.parse_or_expr()
        if self.peek() == Token.Newline:
            return left
        if self.peek() == Token.KwIf:
            self.pos = self.pos + 1
            mut cond = self.parse_or_expr()
            if self.peek() == Token.KwElse:
                self.pos = self.pos + 1
            mut else_e = self.parse_ternary()
            return box_expr(Expr.EIfElse(cond, left, else_e))
        return left

    pub def parse_or_expr(self) -> Pointer[Expr]:
        mut left = self.parse_and_expr()
        while self.peek() == Token.KwOr:
            self.pos = self.pos + 1
            self.skip_newlines_and_indent()
            right = self.parse_and_expr()
            left = box_expr(Expr.EBinOp("or", left, right))
        return left

    pub def parse_and_expr(self) -> Pointer[Expr]:
        mut left = self.parse_not_expr()
        while self.peek() == Token.KwAnd:
            self.pos = self.pos + 1
            self.skip_newlines_and_indent()
            right = self.parse_not_expr()
            left = box_expr(Expr.EBinOp("and", left, right))
        return left

    pub def parse_not_expr(self) -> Pointer[Expr]:
        match self.peek():
            case Token.KwNot:
                self.pos = self.pos + 1
                return box_expr(Expr.EUnaryOp("not", self.parse_not_expr()))
            case _:
                pass
        return self.parse_comparison()

    pub def parse_comparison(self) -> Pointer[Expr]:
        mut left = self.parse_bitor_expr()
        # Handle 'not in' compound operator before the standard match
        if self.peek() == Token.KwNot:
            mut saved_pos = self.pos
            self.pos = self.pos + 1
            if self.peek() == Token.KwIn:
                self.pos = self.pos + 1
                return box_expr(Expr.EUnaryOp("not", box_expr(Expr.EBinOp("in", left, self.parse_bitor_expr()))))
            self.pos = saved_pos
        match self.peek():
            case Token.EqEq:
                self.pos = self.pos + 1
                left = box_expr(Expr.EBinOp("==", left, self.parse_bitor_expr()))
            case Token.NotEq:
                self.pos = self.pos + 1
                left = box_expr(Expr.EBinOp("!=", left, self.parse_bitor_expr()))
            case Token.Lt:
                self.pos = self.pos + 1
                left = box_expr(Expr.EBinOp("<", left, self.parse_bitor_expr()))
            case Token.Gt:
                self.pos = self.pos + 1
                left = box_expr(Expr.EBinOp(">", left, self.parse_bitor_expr()))
            case Token.LtEq:
                self.pos = self.pos + 1
                left = box_expr(Expr.EBinOp("<=", left, self.parse_bitor_expr()))
            case Token.GtEq:
                self.pos = self.pos + 1
                left = box_expr(Expr.EBinOp(">=", left, self.parse_bitor_expr()))
            case Token.KwIs:
                self.pos = self.pos + 1
                left = box_expr(Expr.EBinOp("is", left, self.parse_bitor_expr()))
            case Token.KwIn:
                self.pos = self.pos + 1
                left = box_expr(Expr.EBinOp("in", left, self.parse_bitor_expr()))
            case _:
                pass
        return left

    pub def parse_bitor_expr(self) -> Pointer[Expr]:
        mut left = self.parse_bitxor_expr()
        while self.peek() == Token.Pipe:
            self.pos = self.pos + 1
            left = box_expr(Expr.EBinOp("|", left, self.parse_bitxor_expr()))
        return left

    pub def parse_bitxor_expr(self) -> Pointer[Expr]:
        mut left = self.parse_bitand_expr()
        while self.peek() == Token.Caret:
            self.pos = self.pos + 1
            left = box_expr(Expr.EBinOp("^", left, self.parse_bitand_expr()))
        return left

    pub def parse_bitand_expr(self) -> Pointer[Expr]:
        mut left = self.parse_shift_expr()
        while self.peek() == Token.Amp:
            self.pos = self.pos + 1
            left = box_expr(Expr.EBinOp("&", left, self.parse_shift_expr()))
        return left

    pub def parse_shift_expr(self) -> Pointer[Expr]:
        mut left = self.parse_additive()
        while True:
            match self.peek():
                case Token.LtLt:
                    self.pos = self.pos + 1
                    left = box_expr(Expr.EBinOp("<<", left, self.parse_additive()))
                case Token.GtGt:
                    self.pos = self.pos + 1
                    left = box_expr(Expr.EBinOp(">>", left, self.parse_additive()))
                case _: break
        return left

    pub def parse_additive(self) -> Pointer[Expr]:
        mut left = self.parse_multiplicative()
        while True:
            match self.peek():
                case Token.Plus:
                    self.pos = self.pos + 1
                    self.skip_newlines_and_indent()
                    left = box_expr(Expr.EBinOp("+", left, self.parse_multiplicative()))
                case Token.Minus:
                    self.pos = self.pos + 1
                    self.skip_newlines_and_indent()
                    left = box_expr(Expr.EBinOp("-", left, self.parse_multiplicative()))
                case _: break
        return left

    pub def parse_multiplicative(self) -> Pointer[Expr]:
        mut left = self.parse_power()
        while True:
            match self.peek():
                case Token.Star:
                    self.pos = self.pos + 1
                    left = box_expr(Expr.EBinOp("*", left, self.parse_power()))
                case Token.Slash:
                    self.pos = self.pos + 1
                    left = box_expr(Expr.EBinOp("/", left, self.parse_power()))
                case Token.Percent:
                    self.pos = self.pos + 1
                    left = box_expr(Expr.EBinOp("%", left, self.parse_power()))
                case Token.FloorDiv:
                    self.pos = self.pos + 1
                    left = box_expr(Expr.EBinOp("//", left, self.parse_power()))
                case _: break
        return left

    pub def parse_power(self) -> Pointer[Expr]:
        mut base = self.parse_unary()
        if self.peek() == Token.StarStar:
            self.pos = self.pos + 1
            mut exp = self.parse_power()
            return box_expr(Expr.EBinOp("**", base, exp))
        return base

    pub def parse_unary(self) -> Pointer[Expr]:
        match self.peek():
            case Token.Minus:
                self.pos = self.pos + 1
                return box_expr(Expr.EUnaryOp("-", self.parse_unary()))
            case Token.Tilde:
                self.pos = self.pos + 1
                return box_expr(Expr.EUnaryOp("~", self.parse_unary()))
            case Token.Amp:
                self.pos = self.pos + 1
                return box_expr(Expr.EUnaryOp("&", self.parse_unary()))
            case Token.Star:
                self.pos = self.pos + 1
                return box_expr(Expr.EUnaryOp("*", self.parse_unary()))
            case _:
                pass
        return self.parse_postfix()

    pub def parse_postfix(self) -> Pointer[Expr]:
        mut e = self.parse_primary()
        while True:
            match self.peek():
                case Token.Dot:
                    self.pos = self.pos + 1
                    mut attr = self.consume_ident()
                    match self.peek():
                        case Token.LParen:
                            self.pos = self.pos + 1
                            e = box_expr(Expr.EMethodCall(e, attr, self.parse_arg_list()))
                        case _:
                            e = box_expr(Expr.EPropAccess(e, attr))
                case Token.LParen:
                    self.pos = self.pos + 1
                    e = box_expr(Expr.ECall(e, self.parse_arg_list()))
                case Token.LBracket:
                    mut ix_oln = self.cur_line()
                    mut ix_ocol = self.cur_col()
                    self.pos = self.pos + 1
                    # A generic argument that is itself a function-pointer type
                    # (e.g. `Vec[def(HttpConn) -> bool].init(4)`) cannot be
                    # parsed as a value expression - `def` doesn't start one.
                    # Parse it as a type and carry it via ETypeArg.
                    mut idx: Pointer[Expr] = 0 as Pointer[Expr]
                    if self.peek() == Token.KwDef:
                        idx = box_expr(Expr.ETypeArg(box_asttype(self.parse_type())))
                    else:
                        idx = self.parse_expr()
                    # Collect extra comma-separated type args (e.g. Map[str, T]).
                    # A subsequent arg may itself be a function-pointer type
                    # (e.g. `Map[str, def(int) -> bool].init(4)`), which `def`
                    # cannot start as a value expression - parse it as a type.
                    # These were previously PARSED AND DISCARDED, which collapsed
                    # `Map[K, V]` to `Map[K]` and lost the value type V (so the
                    # codegen couldn't tell a Map[*,str] needed the strval free
                    # path -> leak). Keep them: a multi-arg index becomes an
                    # ETuple of all the type args, which the type lowering reads.
                    mut _ti_extra = Vec[Pointer[Expr]].init(2)
                    while self.peek() == Token.Comma:
                        self.pos = self.pos + 1
                        self.skip_newlines_and_indent()
                        if self.peek() == Token.KwDef:
                            _ti_extra.push(box_expr(Expr.ETypeArg(box_asttype(self.parse_type()))))
                        else:
                            _ti_extra.push(self.parse_expr())
                    self.expect_rbracket(ix_oln, ix_ocol, "this index")
                    if _ti_extra.len > 0:
                        mut _ti_all = Vec[Pointer[Expr]].init(_ti_extra.len + 1)
                        _ti_all.push(idx)
                        mut _tj = 0
                        while _tj < _ti_extra.len:
                            _ti_all.push(_ti_extra.get(_tj))
                            _tj = _tj + 1
                        idx = box_expr(Expr.ETuple(_ti_all))
                    e = box_expr(Expr.EIndex(e, idx))
                case Token.Question:
                    self.pos = self.pos + 1
                    e = box_expr(Expr.ETryExpr(e))
                case Token.KwAs:
                    self.pos = self.pos + 1
                    e = box_expr(Expr.ECast(e, box_asttype(self.parse_type())))
                case _: break
        return e

    # Render a diagnostic at an EXPLICIT location (line/col) rather than the
    # current token. Used to point an "unclosed delimiter" error back at the
    # OPENING bracket, not at end-of-file where the parser finally gives up.
    pub def emit_diag_at(self, ln: int, col: int, msg: str, hint: str):
        print(c_red("error") + ": " + c_bold(msg))
        mut loc = ""
        if self.current_file.len() > 0:
            loc = self.current_file
        mut head = loc + ":" + str(ln)
        if col > 0:
            head = head + ":" + str(col)
        print("  " + c_cyan("-->") + " " + head)
        if self.src_text.len() > 0 and ln > 0:
            mut srcline = _nth_source_line(self.src_text, ln)
            if srcline.len() > 0:
                mut gnum = "   " + str(ln) + " | "
                mut gbar = _spaces(gnum.len() - 2) + "| "
                print(c_dim(gnum) + srcline)
                if col > 0:
                    print(c_dim(gbar) + _spaces(col - 1) + c_red("^"))
        if hint.len() > 0:
            print("  " + c_green("= help") + ": " + hint)
        self.error_count = self.error_count + 1

    # Consume an expected closing bracket, or emit a fatal diagnostic pointing at
    # the OPENING bracket (oln:ocol). Silently skipping a missing closer (the old
    # behavior) let malformed source — e.g. an unclosed `(` — slip through to the
    # C backend instead of stopping here.
    pub def expect_rparen(self, oln: int, ocol: int, what: str):
        match self.peek():
            case Token.RParen:
                self.pos = self.pos + 1
            case _:
                self.emit_diag_at(oln, ocol, "unclosed '(' — " + what + " is never closed", "add the matching ')'.")
    pub def expect_rbracket(self, oln: int, ocol: int, what: str):
        match self.peek():
            case Token.RBracket:
                self.pos = self.pos + 1
            case _:
                self.emit_diag_at(oln, ocol, "unclosed '[' — " + what + " is never closed", "add the matching ']'.")
    pub def expect_rbrace(self, oln: int, ocol: int, what: str):
        match self.peek():
            case Token.RBrace:
                self.pos = self.pos + 1
            case _:
                self.emit_diag_at(oln, ocol, "unclosed '{' — " + what + " is never closed", "add the matching '}'.")

    pub def parse_arg_list(self) -> Vec[Pointer[Expr]]:
        # The caller already consumed the '(' — point an unclosed-call error back
        # at it (the token at pos-1), not at wherever parsing finally stops.
        mut oln = 0
        mut ocol = 0
        if self.pos > 0:
            oln = self.lines.get(self.pos - 1)
            ocol = self.cols.get(self.pos - 1)
        mut el = Vec[Pointer[Expr]].init(4)
        mut going = True
        while going:
            self.skip_newlines_and_indent()
            match self.peek():
                case Token.RParen | Token.Eof:
                    going = False
                case _:
                    pass
            if going:
                el.push(self.parse_expr())
                match self.peek():
                    case Token.Comma:
                        self.pos = self.pos + 1
                        self.skip_newlines_and_indent()
                    case _:
                        going = False
        self.expect_rparen(oln, ocol, "this call's argument list")
        return el

    pub def parse_primary(self) -> Pointer[Expr]:
        match self.peek():
            case Token.IntLit(v):
                self.pos = self.pos + 1
                return box_expr(Expr.ELitInt(v))
            case Token.FloatLit(v):
                self.pos = self.pos + 1
                return box_expr(Expr.ELitFloat(v))
            case Token.StrLit(s):
                self.pos = self.pos + 1
                return box_expr(Expr.ELitStr(s))
            case Token.TripleStrLit(s):
                self.pos = self.pos + 1
                return box_expr(Expr.ELitStr(s))
            case Token.RawStrLit(s):
                self.pos = self.pos + 1
                return box_expr(Expr.ERawStr(s))
            case Token.ByteStrLit(s):
                self.pos = self.pos + 1
                return box_expr(Expr.ELitBytes(s))
            case Token.FStrLit(s):
                self.pos = self.pos + 1
                return self.parse_fstring(s)
            case Token.CharLit(v):
                self.pos = self.pos + 1
                return box_expr(Expr.ELitChar(v))
            case Token.BoolLit(v):
                self.pos = self.pos + 1
                return box_expr(Expr.ELitBool(v))
            case Token.KwTrue:
                self.pos = self.pos + 1
                return box_expr(Expr.ELitBool(True))
            case Token.KwFalse:
                self.pos = self.pos + 1
                return box_expr(Expr.ELitBool(False))
            case Token.KwNone:
                self.pos = self.pos + 1
                return box_expr(Expr.ELitNone)
            case Token.KwInt:
                self.pos = self.pos + 1
                return box_expr(Expr.EIdent("int"))
            case Token.KwFloat:
                self.pos = self.pos + 1
                return box_expr(Expr.EIdent("float"))
            case Token.KwBool:
                self.pos = self.pos + 1
                return box_expr(Expr.EIdent("bool"))
            case Token.KwStr | Token.KwString:
                self.pos = self.pos + 1
                return box_expr(Expr.EIdent("str"))
            case Token.KwChar:
                self.pos = self.pos + 1
                return box_expr(Expr.EIdent("char"))
            case Token.KwVoid:
                self.pos = self.pos + 1
                return box_expr(Expr.EIdent("void"))
            case Token.KwSuper:
                self.pos = self.pos + 1
                mut super_base: str = ""
                if self.peek() == Token.LParen:
                    self.pos = self.pos + 1
                    super_base = self.consume_ident()
                    if self.peek() == Token.RParen:
                        self.pos = self.pos + 1
                    if self.peek() == Token.Dot:
                        self.pos = self.pos + 1
                        mut super_method: str = self.consume_ident()
                        if self.peek() == Token.LParen:
                            self.pos = self.pos + 1
                            mut super_args = self.parse_arg_list()
                            return box_expr(Expr.ESuperMethodCall(super_base, super_method, super_args))
                        else:
                            return box_expr(Expr.ESuperPropAccess(super_base, super_method))
                if self.peek() == Token.Dot:
                    self.pos = self.pos + 1
                    mut super_next: str = self.consume_ident()
                    if self.peek() == Token.Dot:
                        self.pos = self.pos + 1
                        super_base = super_next
                        mut super_method2: str = self.consume_ident()
                        if self.peek() == Token.LParen:
                            self.pos = self.pos + 1
                            mut super_args2 = self.parse_arg_list()
                            return box_expr(Expr.ESuperMethodCall(super_base, super_method2, super_args2))
                        else:
                            return box_expr(Expr.ESuperPropAccess(super_base, super_method2))
                    else:
                        if self.peek() == Token.LParen:
                            self.pos = self.pos + 1
                            mut super_args3 = self.parse_arg_list()
                            return box_expr(Expr.ESuperMethodCall("", super_next, super_args3))
                        else:
                            return box_expr(Expr.ESuperPropAccess("", super_next))
                return box_expr(Expr.EIdent("super"))
            case Token.Ident(name):
                self.pos = self.pos + 1
                return box_expr(Expr.EIdent(name))
            case Token.KwSizeOf:
                self.pos = self.pos + 1
                match self.peek():
                    case Token.LParen:
                        self.pos = self.pos + 1
                    case _:
                        pass
                mut ty = box_asttype(self.parse_type())
                match self.peek():
                    case Token.RParen:
                        self.pos = self.pos + 1
                    case _:
                        pass
                return box_expr(Expr.ESizeOf(ty))
            case Token.LParen:
                mut p_oln = self.cur_line()
                mut p_ocol = self.cur_col()
                self.pos = self.pos + 1
                self.skip_newlines()
                if self.peek() == Token.RParen:
                    self.pos = self.pos + 1
                    return box_expr(Expr.ETuple(Vec[Pointer[Expr]].init(0)))
                mut e = self.parse_expr()
                self.skip_newlines()
                if self.peek() == Token.Comma:
                    self.pos = self.pos + 1
                    self.skip_newlines()
                    mut items = Vec[Pointer[Expr]].init(2)
                    items.push(e)
                    while self.peek() != Token.RParen and self.peek() != Token.Eof:
                        items.push(self.parse_expr())
                        self.skip_newlines()
                        if self.peek() == Token.Comma:
                            self.pos = self.pos + 1
                            self.skip_newlines()
                        else:
                            break
                    self.expect_rparen(p_oln, p_ocol, "this tuple")
                    return box_expr(Expr.ETuple(items))
                else:
                    self.expect_rparen(p_oln, p_ocol, "this parenthesized expression")
                    return e
            case Token.LBracket:
                mut lb_oln = self.cur_line()
                mut lb_ocol = self.cur_col()
                self.pos = self.pos + 1
                self.skip_newlines()
                if self.peek() == Token.RBracket:
                    self.pos = self.pos + 1
                    return box_expr(Expr.EList(Vec[Pointer[Expr]].init(0)))
                mut first = self.parse_or_expr()
                self.skip_newlines()
                if self.peek() == Token.KwFor:
                    mut generators = Vec[Pointer[Comprehension]].init(2)
                    while self.peek() == Token.KwFor:
                        self.pos = self.pos + 1
                        mut target = self.consume_ident()
                        match self.peek():
                            case Token.KwIn:
                                self.pos = self.pos + 1
                            case _:
                                pass
                        mut iter = self.parse_or_expr()
                        mut ifs = Vec[Pointer[Expr]].init(2)
                        while self.peek() == Token.KwIf:
                            self.pos = self.pos + 1
                            ifs.push(self.parse_or_expr())
                        mut c = Comprehension.init(target, iter)
                        c.ifs = ifs
                        unsafe:
                            mut c_ptr = alloc[Comprehension](1)
                            c_ptr.write(c)
                            generators.push(c_ptr)
                    self.expect_rbracket(lb_oln, lb_ocol, "this list comprehension")
                    return box_expr(Expr.EListComp(first, generators))
                mut items = Vec[Pointer[Expr]].init(2)
                items.push(first)
                if self.peek() == Token.Comma:
                    self.pos = self.pos + 1
                    self.skip_newlines()
                    while self.peek() != Token.RBracket and self.peek() != Token.Eof:
                        items.push(self.parse_expr())
                        self.skip_newlines()
                        if self.peek() == Token.Comma:
                            self.pos = self.pos + 1
                            self.skip_newlines()
                        else:
                            break
                self.expect_rbracket(lb_oln, lb_ocol, "this list")
                return box_expr(Expr.EList(items))
            case Token.LBrace:
                mut br_oln = self.cur_line()
                mut br_ocol = self.cur_col()
                self.pos = self.pos + 1
                self.skip_newlines()
                mut keys = Vec[Pointer[Expr]].init(2)
                mut vals = Vec[Pointer[Expr]].init(2)
                mut set_items = Vec[Pointer[Expr]].init(2)
                mut is_set = False
                if self.peek() != Token.RBrace:
                    mut first = self.parse_expr()
                    self.skip_newlines()
                    if self.peek() == Token.Colon:
                        self.pos = self.pos + 1
                        self.skip_newlines()
                        mut value = self.parse_expr()
                        keys.push(first)
                        vals.push(value)
                        self.skip_newlines()
                        if self.peek() == Token.Comma:
                            self.pos = self.pos + 1
                        self.skip_newlines()
                        while self.peek() != Token.RBrace and self.peek() != Token.Eof:
                            mut key = self.parse_expr()
                            self.skip_newlines()
                            match self.peek():
                                case Token.Colon:
                                    self.pos = self.pos + 1
                                case _:
                                    pass
                            self.skip_newlines()
                            mut v = self.parse_expr()
                            keys.push(key)
                            vals.push(v)
                            self.skip_newlines()
                            if self.peek() == Token.Comma:
                                self.pos = self.pos + 1
                            else:
                                break
                            self.skip_newlines()
                    else:
                        is_set = True
                        set_items.push(first)
                        self.skip_newlines()
                        if self.peek() == Token.Comma:
                            self.pos = self.pos + 1
                        self.skip_newlines()
                        while self.peek() != Token.RBrace and self.peek() != Token.Eof:
                            set_items.push(self.parse_expr())
                            self.skip_newlines()
                            if self.peek() == Token.Comma:
                                self.pos = self.pos + 1
                            else:
                                break
                            self.skip_newlines()
                self.skip_newlines()
                self.expect_rbrace(br_oln, br_ocol, "this dict/set literal")
                if is_set:
                    return box_expr(Expr.ESet(set_items))
                else:
                    return box_expr(Expr.EDict(keys, vals))
            case Token.KwTry:
                mut st = self.parse_try_stmt()
                match st.read():
                    case Stmt.STry(try_body, catches, finally_b):
                        return box_expr(Expr.ETry(try_body, catches, finally_b))
                    case _:
                        pass
            case Token.KwAwait:
                self.pos = self.pos + 1
                return box_expr(Expr.EAwait(self.parse_expr()))
            case Token.KwYield:
                self.pos = self.pos + 1
                return box_expr(Expr.EYield(self.parse_expr()))
            case Token.KwDef | Token.KwAsync:
                mut is_async = False
                if self.peek() == Token.KwAsync:
                    self.pos = self.pos + 1
                    is_async = True
                match self.peek():
                    case Token.KwDef:
                        self.pos = self.pos + 1
                    case _:
                        pass
                match self.peek():
                    case Token.LParen:
                        self.pos = self.pos + 1
                    case _:
                        pass
                mut params = self.parse_param_list()
                if self.peek() == Token.RParen:
                    self.pos = self.pos + 1
                mut return_type = Pointer[AstType](0)
                if self.peek() == Token.Arrow:
                    self.pos = self.pos + 1
                    return_type = box_asttype(self.parse_type())
                match self.peek():
                    case Token.Colon:
                        self.pos = self.pos + 1
                    case _:
                        pass
                mut body = self.parse_block()
                return box_expr(Expr.EClosure(params, return_type, body, is_async))
            case Token.FStrLit(raw):
                self.pos = self.pos + 1
                return self.parse_fstring(raw)
            case _:
                pass
        if not self.at_end():
            mut tok_desc = "token"
            mut hint = "check for a typo, a missing ':' or unbalanced parentheses/brackets near this point."
            match self.peek():
                case Token.Newline:
                    tok_desc = "end of line"
                    hint = "an expression was expected before the end of this line - check for a missing value or trailing operator."
                case Token.Indent:
                    tok_desc = "indentation"
                    hint = "check that this line's indentation matches the surrounding block."
                case Token.Dedent:
                    tok_desc = "dedent"
                    hint = "check that this block is properly indented and closed."
                case Token.Ident(n):
                    tok_desc = "identifier '" + n + "'"
                    hint = "an operator, ':' or end of statement was expected before '" + n + "'."
                case Token.KwMut: tok_desc = "keyword 'mut'"
                case Token.KwConst: tok_desc = "keyword 'const'"
                case Token.KwPub: tok_desc = "keyword 'pub'"
                case Token.KwReturn: tok_desc = "keyword 'return'"
                case Token.KwIf: tok_desc = "keyword 'if'"
                case Token.KwWhile: tok_desc = "keyword 'while'"
                case Token.Comma:
                    tok_desc = "','"
                    hint = "remove the extra ',' or add the missing item before it."
                case Token.Colon:
                    tok_desc = "':'"
                    hint = "remove the extra ':' or check the statement before it is complete."
                case Token.RParen:
                    tok_desc = "')'"
                    hint = "check for an extra ')' or a missing matching '('."
                case Token.RBracket:
                    tok_desc = "']'"
                    hint = "check for an extra ']' or a missing matching '['."
                case Token.RBrace:
                    tok_desc = "'}'"
                    hint = "check for an extra '}' or a missing matching '{'."
                case Token.Error(em):
                    # A lexer-level error (unknown char, inconsistent indentation):
                    # report its own message verbatim rather than "unexpected token".
                    self.emit_diag(em, "")
                    self.pos = self.pos + 1
                    return box_expr(Expr.ELitNone)
                case _: pass
            self.emit_diag("unexpected " + tok_desc + " in expression", hint)
            self.pos = self.pos + 1
        return box_expr(Expr.ELitNone)

    pub def parse_fstring(self, raw: str) -> Pointer[Expr]:
        mut fl = Vec[FStringPart].init(4)
        mut p = raw as Pointer[char]
        mut i = 0
        mut sb = StringBuilder.init(64)
        
        while True:
            mut c = p.offset(i).read() as int
            if c == 0: break
            
            if c == 123: # '{'
                # Push previous text part
                if sb.len() > 0:
                    fl.push(FStringPart.init_text(sb.to_string().as_str()))
                    sb = StringBuilder.init(64)
                
                i = i + 1
                mut expr_sb = StringBuilder.init(64)
                mut depth = 1
                while depth > 0:
                    mut ec = p.offset(i).read() as int
                    if ec == 0: break
                    if ec == 123: depth = depth + 1
                    if ec == 125: depth = depth - 1
                    if depth > 0: expr_sb.append_char(ec)
                    i = i + 1
                
                # Parse the expression inside {}.
                # Detect optional format spec: {expr:spec}  e.g. {x:.2f} {n:>10}
                mut expr_str  = expr_sb.to_string().as_str()
                mut fmt_spec  = ""
                mut colon_pos = _find_fmt_colon(expr_str)
                if colon_pos >= 0:
                    mut _fs = expr_str.slice(colon_pos + 1, expr_str.len())
                    fmt_spec = _fs.trim()
                    mut _es = expr_str.slice(0, colon_pos)
                    expr_str = _es.trim()
                mut lexer = Lexer.init(expr_str)
                mut _fstr_tokens = lexer.tokenize()
                if _fstr_tokens.len > 0:
                    mut parser = Parser.init(_fstr_tokens, lexer.token_lines)
                    mut e = parser.parse_expr()
                    if fmt_spec.len() > 0:
                        fl.push(FStringPart.init_expr_fmt(e, fmt_spec))
                    else:
                        fl.push(FStringPart.init_expr(e))
            else:
                sb.append_char(c)
                i = i + 1
        
        if sb.len() > 0:
            fl.push(FStringPart.init_text(sb.to_string().as_str()))
            
        return box_expr(Expr.EFString(fl))

    pub def parse_program(self) -> Program:
        mut prog = Program.init()
        self.skip_newlines_and_indent()
        while not self.at_end():
            # Skip blank lines and block-closing dedents between top-level items.
            # A stray INDENT here means a declaration/statement is indented under
            # nothing (no `:`-opened block above it) — a fatal structural error,
            # not something to silently swallow.
            mut sk = True
            while sk:
                sk = False
                match self.peek():
                    case Token.Newline | Token.Dedent:
                        self.pos = self.pos + 1
                        sk = True
                    case Token.Indent:
                        self.emit_diag("unexpected indentation", "this line is indented but no block was opened above it (a statement ending in ':' and its own line) — remove the extra indentation.")
                        self.pos = self.pos + 1
                        sk = True
                    case _:
                        pass
            if not self.at_end():
                prog.push(self.parse_decl())
        return prog

    pub def parse_decl(self) -> Pointer[Decl]:
        mut decorators = Vec[Decorator].init(0)
        while self.peek() == Token.At:
            self.pos = self.pos + 1
            name = self.consume_ident()
            mut d = Decorator.init(name)
            if self.peek() == Token.LParen:
                self.pos = self.pos + 1
                d.args = self.parse_arg_list()
            decorators.push(d)
            self.expect_newline()

        mut is_public = False
        mut is_export = False
        # Leading visibility modifiers: `pub` and/or `export` in any order.
        # `export` implies public (the symbol must be visible to be exported).
        mut _scan_mods = True
        while _scan_mods:
            _scan_mods = False
            match self.peek():
                case Token.KwPub:
                    is_public = True
                    self.pos = self.pos + 1
                    _scan_mods = True
                case Token.KwExport:
                    is_export = True
                    is_public = True
                    self.pos = self.pos + 1
                    _scan_mods = True
                case _:
                    pass
        match self.peek():
            case Token.KwFrom:
                return self.parse_from_import()
            case Token.KwImport:
                return self.parse_import()
            case Token.Ident(type_kw):
                # `type Name = ExistingType` - type alias declaration
                if type_kw == "type":
                    self.pos = self.pos + 1
                    mut alias_name = self.consume_ident()
                    if self.peek() == Token.Eq:
                        self.pos = self.pos + 1
                        mut target_ty = self.parse_type()
                        self.expect_newline()
                        return box_decl(Decl.DTypeAlias(alias_name, box_asttype(target_ty)))
            case Token.KwDef:
                mut _fline = self.cur_line()
                mut f = self.parse_function_def(False)
                f.line = _fline
                f.is_public = is_public
                f.is_export = is_export
                f.decorators = decorators
                return box_decl(Decl.DFunction(f))
            case Token.KwClass:
                mut _cline = self.cur_line()
                mut c_ptr = self.parse_class_decl()
                match c_ptr.read():
                    case Decl.DClass(c):
                        c.line = _cline
                        c.is_public = is_public
                        c.is_class = true
                        c.decorators = decorators
                        unsafe: c_ptr.write(Decl.DClass(c))
                    case _:
                        pass
                return c_ptr
            case Token.KwEnum:
                mut _eline = self.cur_line()
                mut e_ptr = self.parse_enum_decl()
                match e_ptr.read():
                    case Decl.DEnum(e):
                        e.line = _eline
                        e.is_public = is_public
                        e.decorators = decorators
                        unsafe: e_ptr.write(Decl.DEnum(e))
                    case _:
                        pass
                return e_ptr
            case Token.KwInterface:
                mut _iline = self.cur_line()
                mut i_ptr = self.parse_interface_decl()
                match i_ptr.read():
                    case Decl.DInterface(i):
                        i.line = _iline
                        i.is_public = is_public
                        i.decorators = decorators
                        unsafe: i_ptr.write(Decl.DInterface(i))
                    case _:
                        pass
                return i_ptr
            case Token.KwExtend:
                return self.parse_extend_decl()
            case Token.KwDecorator:
                self.pos = self.pos + 1   # consume 'decorator'
                mut _dl = self.cur_line()
                mut _df = self.parse_function_def(False)
                _df.line = _dl
                _df.is_public = is_public
                return box_decl(Decl.DDecoratorDef(_df))
            case Token.KwExtern:
                return self.parse_extern_decl()
            case Token.KwAsync:
                self.pos = self.pos + 1
                match self.peek():
                    case Token.KwDef:
                        mut f = self.parse_function_def(False)
                        f.is_async = True
                        f.is_public = is_public
                        f.is_export = is_export
                        f.decorators = decorators
                        return box_decl(Decl.DFunction(f))
                    case _:
                        pass
            case _:
                pass
        return box_decl(Decl.DTopLevelStmt(self.parse_stmt()))

    # Parse:
    #   from module import Name
    #   from module import Name as Alias
    #   from module import (A, B as C, D)          <- parenthesised, single-line
    #   from module import [A, B as C, D]           <- bracket list, single-line
    #   from module import [                        <- bracket list, multi-line
    #       A,
    #       B as C,
    #       D,
    #   ]
    pub def parse_from_import(self) -> Pointer[Decl]:
        self.pos = self.pos + 1
        mut path = self.consume_module_ident()
        while self.peek() == Token.Dot:
            self.pos = self.pos + 1
            path = path + "." + self.consume_module_ident()
        match self.peek():
            case Token.KwImport:
                self.pos = self.pos + 1
            case _:
                pass
        mut il     = Vec[ImportItem].init(4)
        mut multi  = false
        match self.peek():
            case Token.LParen | Token.LBracket:
                self.pos = self.pos + 1
                multi = true
            case _:
                pass
        mut going = true
        while going:
            # Inside a bracket/paren block skip newlines AND indent/dedent tokens
            # so that multi-line imports like [ \n  A, \n  B \n] work naturally.
            if multi:
                self.skip_newlines_and_indent()
            else:
                self.skip_newlines()
            match self.peek():
                case Token.RParen | Token.RBracket | Token.Eof:
                    going = false
                case Token.Newline | Token.Dedent:
                    if not multi:
                        going = false
                case _:
                    pass
            if going:
                mut item_name = self.consume_ident()
                if item_name != "":
                    mut item = ImportItem.init(item_name)
                    # Optional per-item alias:  Name as Alias
                    if self.peek() == Token.KwAs:
                        self.pos = self.pos + 1
                        item.alias = self.consume_ident()
                    il.push(item)
                    if self.peek() == Token.Comma:
                        self.pos = self.pos + 1
                    elif not multi:
                        going = false
                else:
                    going = false
        # Consume the closing ) or ]
        if multi:
            match self.peek():
                case Token.RParen | Token.RBracket:
                    self.pos = self.pos + 1
                case _:
                    pass
        self.expect_newline()
        return box_decl(Decl.DFromImport(path, il))

    pub def parse_import(self) -> Pointer[Decl]:
        self.pos = self.pos + 1
        mut path = self.consume_module_ident()
        while self.peek() == Token.Dot:
            self.pos = self.pos + 1
            path = path + "." + self.consume_module_ident()
        mut alias = ""
        if self.peek() == Token.KwAs:
            self.pos = self.pos + 1
            alias = self.consume_ident()
        self.expect_newline()
        return box_decl(Decl.DImport(path, alias))

    pub def parse_function_def(self, is_method: bool) -> FunctionDef:
        self.pos = self.pos + 1
        mut name = self.consume_ident()
        mut f = FunctionDef.init(name)
        if self.peek() == Token.LBracket:
            self.pos = self.pos + 1
            while self.peek() != Token.RBracket:
                f.generics.push(self.consume_ident())
                if self.peek() == Token.Comma:
                    self.pos = self.pos + 1
            if self.peek() == Token.RBracket:
                self.pos = self.pos + 1
        if self.peek() == Token.LParen:
            self.pos = self.pos + 1
            f.params = self.parse_param_list()
            if self.peek() == Token.RParen:
                self.pos = self.pos + 1
        match self.peek():
            case Token.KwThrows:
                self.pos = self.pos + 1
                f.throws_ty = box_asttype(self.parse_type())
            case _:
                pass
        if self.peek() == Token.Arrow:
            self.pos = self.pos + 1
            mut ret_t = self.parse_type()
            if self.peek() == Token.KwFrom:
                # Region annotation on the return borrow. Single source `from a`, or
                # multi-source `from a, b` (the returned ref is valid for the SHORTER
                # of the named regions — their intersection). Stored comma-joined.
                self.pos = self.pos + 1
                ret_t.from_param = self.consume_ident()
                ret_t.from_regions.push(ret_t.from_param)
                while self.peek() == Token.Comma:
                    self.pos = self.pos + 1
                    mut rgn2 = self.consume_ident()
                    ret_t.from_param = ret_t.from_param + "," + rgn2
                    ret_t.from_regions.push(rgn2)
            f.ret_ty = box_asttype(ret_t)
        # Gap 4: optional `where` outlives-bounds clause (optional parens, one or more).
        # May sit on the signature line OR break to a continuation line, and the
        # parenthesized form may span lines with a trailing comma:
        #   where a outlives b
        #   -> T from b \n    where a outlives b:
        #   where (a outlives b, c outlives d)
        #   where ( \n    a outlives b, \n    c outlives d, \n  ):
        mut w_is = false
        match self.peek():
            case Token.Ident(wkw0):
                if wkw0 == "where": w_is = true
            case _: pass
        if not w_is and self.peek() == Token.Newline:
            # Continuation line: look past NEWLINE/INDENT for a `where` keyword.
            # Consuming the leading INDENT lets the body (at the clause's indent)
            # parse normally as the block opened by that indent.
            mut scan = self.pos
            mut scanning = true
            while scanning:
                match self.tokens.get(scan):
                    case Token.Newline | Token.Indent:
                        scan = scan + 1
                    case _:
                        scanning = false
            match self.tokens.get(scan):
                case Token.Ident(wkw1):
                    if wkw1 == "where":
                        w_is = true
                        self.pos = scan
                case _: pass
        if w_is:
            self.pos = self.pos + 1   # consume `where`
            mut w_paren = false
            if self.peek() == Token.LParen:
                self.pos = self.pos + 1
                w_paren = true
                self.skip_newlines_and_indent()
            mut w_more = true
            while w_more:
                if w_paren: self.skip_newlines_and_indent()
                if w_paren and self.peek() == Token.RParen:
                    w_more = false        # trailing comma before `)`
                else:
                    mut w_a  = self.consume_ident()    # region a
                    mut w_kw = self.consume_ident()    # `outlives`
                    mut w_b  = self.consume_ident()    # region b
                    f.outlives_a.push(w_a)
                    f.outlives_b.push(w_b)
                    if w_paren: self.skip_newlines_and_indent()
                    if w_paren and self.peek() == Token.Comma:
                        self.pos = self.pos + 1
                    else:
                        w_more = false
            if w_paren:
                self.skip_newlines_and_indent()
                if self.peek() == Token.RParen:
                    self.pos = self.pos + 1
        if self.peek() == Token.Colon:
            self.pos = self.pos + 1
            f.body = self.parse_block()
        else:
            self.expect_newline()
            f.body = Block.init()
        return f

    pub def parse_class_decl(self) -> Pointer[Decl]:
        self.pos = self.pos + 1
        mut name = self.consume_ident()
        mut c = ClassDef.init(name)
        if self.peek() == Token.LBracket:
            self.pos = self.pos + 1
            while self.peek() != Token.RBracket:
                c.generics.push(self.consume_ident())
                if self.peek() == Token.Comma:
                    self.pos = self.pos + 1
            if self.peek() == Token.RBracket:
                self.pos = self.pos + 1
        # Region (lifetime) parameters: `class Parser from src:` — names the region
        # this type's `ref`-typed fields borrow for. Parsed and accepted; field-level
        # borrows + the M-2 move-while-borrowed check provide conservative enforcement.
        if self.peek() == Token.KwFrom:
            self.pos = self.pos + 1
            c.region_params.push(self.consume_ident())
            while self.peek() == Token.Comma:
                self.pos = self.pos + 1
                c.region_params.push(self.consume_ident())
        if self.peek() == Token.KwExtends:
            self.pos = self.pos + 1
            c.base_classes.push(self.consume_ident())
            while self.peek() == Token.Comma:
                self.pos = self.pos + 1
                c.base_classes.push(self.consume_ident())
        if self.peek() == Token.KwImplements:
            self.pos = self.pos + 1
            while True:
                c.iface_names.push(self.consume_ident())
                if self.peek() == Token.LBracket:
                    self.pos = self.pos + 1
                    while self.peek() != Token.RBracket and self.peek() != Token.Eof:
                        self.pos = self.pos + 1
                    if self.peek() == Token.RBracket: self.pos = self.pos + 1
                if self.peek() == Token.Comma:
                    self.pos = self.pos + 1
                else: break
        if self.peek() == Token.Colon:
            self.pos = self.pos + 1
        self.skip_newlines()
        match self.peek():
            case Token.Indent:
                self.pos = self.pos + 1
            case _:
                pass
        mut going = True
        while going:
            self.skip_newlines()
            # A triple-quoted string at the top of the class body is its
            # docstring (captured for `inspect`), not an executable statement.
            if c.docstring == "":
                match self.peek():
                    case Token.TripleStrLit(_ds):
                        c.docstring = _ds
                        self.pos = self.pos + 1
                        self.skip_newlines()
                    case _:
                        pass
            mut decorators = Vec[Decorator].init(0)
            while self.peek() == Token.At:
                self.pos = self.pos + 1
                dname = self.consume_ident()
                mut d = Decorator.init(dname)
                if self.peek() == Token.LParen:
                    self.pos = self.pos + 1
                    d.args = self.parse_arg_list()
                decorators.push(d)
                self.expect_newline()

            mut is_p = False
            match self.peek():
                case Token.KwPub:
                    is_p = True
                    self.pos = self.pos + 1
                case _:
                    pass
            match self.peek():
                case Token.Dedent | Token.Eof:
                    going = False
                case Token.KwDef:
                    mut _mline = self.cur_line()
                    mut m = self.parse_function_def(True)
                    m.line = _mline
                    m.is_public = is_p
                    m.decorators = decorators
                    c.methods.push(m)
                case Token.KwAsync:
                    self.pos = self.pos + 1
                    match self.peek():
                        case Token.KwDef:
                            mut _mline = self.cur_line()
                            mut m = self.parse_function_def(True)
                            m.line = _mline
                            m.is_async = True
                            m.is_public = is_p
                            m.decorators = decorators
                            c.methods.push(m)
                        case _:
                            pass
                case Token.Ident(fname):
                    self.pos = self.pos + 1
                    mut ty_ptr = Pointer[AstType](0)
                    if self.peek() == Token.Colon:
                        self.pos = self.pos + 1
                        mut fty = self.parse_type()
                        # Field-level region: `text: ref str from src` — the field
                        # borrows for region `src` (a class region param). The type
                        # is already erased to its inner T (is_borrow set); record
                        # the region name(s) for checking.
                        if self.peek() == Token.KwFrom:
                            self.pos = self.pos + 1
                            fty.from_param = self.consume_ident()
                            fty.from_regions.push(fty.from_param)
                            while self.peek() == Token.Comma:
                                self.pos = self.pos + 1
                                mut frgn2 = self.consume_ident()
                                fty.from_param = fty.from_param + "," + frgn2
                                fty.from_regions.push(frgn2)
                        ty_ptr = box_asttype(fty)
                    mut fld = FieldDef.init(fname, ty_ptr)
                    c.fields.push(fld)
                    self.expect_newline()
                case Token.KwPass:
                    self.pos = self.pos + 1
                    self.expect_newline()
                case _:
                    self.pos = self.pos + 1
        if self.peek() == Token.Dedent:
            self.pos = self.pos + 1
        return box_decl(Decl.DClass(c))

    pub def parse_enum_decl(self) -> Pointer[Decl]:
        self.pos = self.pos + 1
        mut name = self.consume_ident()
        mut e = EnumDef.init(name)
        # Region (lifetime) parameters: `enum Token from src:` — names the region
        # variant payloads written `ref T from src` borrow for. Erased for codegen;
        # only the L-2 region-name check (under --strict) consumes them.
        if self.peek() == Token.KwFrom:
            self.pos = self.pos + 1
            e.region_params.push(self.consume_ident())
            while self.peek() == Token.Comma:
                self.pos = self.pos + 1
                e.region_params.push(self.consume_ident())
        if self.peek() == Token.KwImplements:
            self.pos = self.pos + 1
            while True:
                e.iface_names.push(self.consume_ident())
                if self.peek() == Token.Comma:
                    self.pos = self.pos + 1
                else: break
        if self.peek() == Token.Colon:
            self.pos = self.pos + 1
        self.skip_newlines()
        match self.peek():
            case Token.Indent:
                self.pos = self.pos + 1
            case _:
                pass
        mut going = True
        while going:
            self.skip_newlines()
            mut decorators = Vec[Decorator].init(0)
            while self.peek() == Token.At:
                self.pos = self.pos + 1
                dname = self.consume_ident()
                mut d = Decorator.init(dname)
                if self.peek() == Token.LParen:
                    self.pos = self.pos + 1
                    d.args = self.parse_arg_list()
                decorators.push(d)
                self.expect_newline()

            mut is_p = False
            match self.peek():
                case Token.KwPub:
                    is_p = True
                    self.pos = self.pos + 1
                case _:
                    pass
            match self.peek():
                case Token.Dedent | Token.Eof:
                    going = False
                case Token.Ident(vname):
                    self.pos = self.pos + 1
                    mut vd = VariantDef.init(vname)
                    if self.peek() == Token.LParen:
                        self.pos = self.pos + 1
                        vd.fields = self.parse_param_list()
                        if self.peek() == Token.RParen:
                            self.pos = self.pos + 1
                    e.variants.push(vd)
                    self.expect_newline()
                case Token.KwDef:
                    mut m = self.parse_function_def(True)
                    m.is_public = is_p
                    m.decorators = decorators
                    e.methods.push(m)
                case Token.KwPass:
                    self.pos = self.pos + 1
                    self.expect_newline()
                case _:
                    self.pos = self.pos + 1
        if self.peek() == Token.Dedent:
            self.pos = self.pos + 1
        return box_decl(Decl.DEnum(e))

    pub def parse_interface_decl(self) -> Pointer[Decl]:
        self.pos = self.pos + 1
        mut name = self.consume_ident()
        mut i = InterfaceDef.init(name)
        # Generic type parameters: interface Container[T]:
        if self.peek() == Token.LBracket:
            self.pos = self.pos + 1
            while self.peek() != Token.RBracket and self.peek() != Token.Eof:
                mut gname = self.consume_ident()
                if gname != "": i.generics.push(gname)
                if self.peek() == Token.Comma: self.pos = self.pos + 1
            if self.peek() == Token.RBracket: self.pos = self.pos + 1
        # Region (lifetime) parameters: `interface View from r:` — method signatures
        # may return `ref T from r`. Erased for codegen; drives the L-2 check.
        if self.peek() == Token.KwFrom:
            self.pos = self.pos + 1
            i.region_params.push(self.consume_ident())
            while self.peek() == Token.Comma:
                self.pos = self.pos + 1
                i.region_params.push(self.consume_ident())
        if self.peek() == Token.Colon:
            self.pos = self.pos + 1
        self.skip_newlines()
        match self.peek():
            case Token.Indent:
                self.pos = self.pos + 1
            case _:
                pass
        mut going = True
        while going:
            self.skip_newlines()
            mut is_p = False
            match self.peek():
                case Token.KwPub:
                    is_p = True
                    self.pos = self.pos + 1
                case _:
                    pass
            match self.peek():
                case Token.Dedent | Token.Eof:
                    going = False
                case Token.KwDef:
                    mut m = self.parse_function_def(True)
                    m.is_public = is_p
                    i.methods.push(m)
                case Token.KwPass:
                    self.pos = self.pos + 1
                    self.expect_newline()
                case _:
                    self.pos = self.pos + 1
        if self.peek() == Token.Dedent:
            self.pos = self.pos + 1
        return box_decl(Decl.DInterface(i))

    pub def parse_extend_decl(self) -> Pointer[Decl]:
        self.pos = self.pos + 1
        mut target = self.consume_ident()
        # Impl-block region (lifetime) re-declaration: `extend View from r:` —
        # Rust's `impl<'a> View<'a>`. Accepted for surface symmetry; the regions
        # the methods reference are already those of the extended type's decl, so
        # the names are simply consumed (erased) here.
        if self.peek() == Token.KwFrom:
            self.pos = self.pos + 1
            mut _erg = self.consume_ident()
            while self.peek() == Token.Comma:
                self.pos = self.pos + 1
                _erg = self.consume_ident()
        if self.peek() == Token.Colon:
            self.pos = self.pos + 1
        self.skip_newlines()
        match self.peek():
            case Token.Indent:
                self.pos = self.pos + 1
            case _:
                pass
        mut fl = Vec[FunctionDef].init(4)
        mut going = True
        while going:
            self.skip_newlines()
            mut decorators = Vec[Decorator].init(0)
            while self.peek() == Token.At:
                self.pos = self.pos + 1
                dname = self.consume_ident()
                mut d = Decorator.init(dname)
                if self.peek() == Token.LParen:
                    self.pos = self.pos + 1
                    d.args = self.parse_arg_list()
                decorators.push(d)
                self.expect_newline()

            mut is_p = False
            match self.peek():
                case Token.KwPub:
                    is_p = True
                    self.pos = self.pos + 1
                case _:
                    pass
            match self.peek():
                case Token.Dedent | Token.Eof:
                    going = False
                case Token.KwDef:
                    mut m = self.parse_function_def(True)
                    m.is_public = is_p
                    m.decorators = decorators
                    fl.push(m)
                case Token.KwPass:
                    self.pos = self.pos + 1
                    self.expect_newline()
                case _:
                    self.pos = self.pos + 1
        if self.peek() == Token.Dedent:
            self.pos = self.pos + 1
        mut d = Decl.DExtend(target, fl)
        return box_decl(d)

    pub def parse_extern_decl(self) -> Pointer[Decl]:
        self.pos = self.pos + 1
        mut abi = "C"
        match self.peek():
            case Token.StrLit(s):
                self.pos = self.pos + 1
                abi = s
            case _:
                pass
        if self.peek() == Token.Colon:
            self.pos = self.pos + 1
        self.skip_newlines()
        match self.peek():
            case Token.Indent:
                self.pos = self.pos + 1
            case _:
                pass
        mut fl = Vec[FunctionDef].init(4)
        mut going = True
        while going:
            self.skip_newlines()
            mut is_p = False
            match self.peek():
                case Token.KwPub:
                    is_p = True
                    self.pos = self.pos + 1
                case _:
                    pass
            match self.peek():
                case Token.Dedent | Token.Eof:
                    going = False
                case Token.KwDef:
                    mut m = self.parse_function_def(False)
                    m.is_public = is_p
                    # Trailing `args...` in an extern block matches C's `...`
                    # variadic signature (e.g. `extern "C": def printf(fmt: str, args...)`
                    # -> `int printf(char* fmt, ...)`), not a List[T] collection.
                    if m.params.len > 0:
                        mut _ext_last = m.params.get(m.params.len - 1)
                        if _ext_last.is_variadic:
                            m.params.pop()
                            m.is_variadic = true
                    fl.push(m)
                case _:
                    self.pos = self.pos + 1
        if self.peek() == Token.Dedent:
            self.pos = self.pos + 1
        return box_decl(Decl.DExtern(abi, fl))


# -- f-string format spec helper -----------------------------------------------
# Find the colon that separates {expr:spec}, skipping colons inside nested
# brackets/parens (e.g. {dict["k"]:>10} should split at the outer colon).
pub def _find_fmt_colon(s: str) -> int:
    mut i = 0
    mut n = s.len()
    mut depth = 0
    while i < n:
        mut c = s.char_at(i)
        if c == 40 or c == 91 or c == 123: depth = depth + 1  # ( [ {
        elif c == 41 or c == 93 or c == 125: depth = depth - 1  # ) ] }
        elif c == 58 and depth == 0: return i  # ':' at top level
        i = i + 1
    return -1
