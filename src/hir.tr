# compiler/src/hir.tr — High-level Intermediate Representation

from core.vec import Vec
from core.alloc import alloc, dealloc
from core.string import StringObj
from ast import AstType, Decorator, Pattern, Ownership

# ─── Expressions ──────────────────────────────────────────────────────────────

pub enum HirExpr:
    ELitInt(val: int, ty: AstType)
    ELitFloat(val: float, ty: AstType)
    ELitStr(val: str, ty: AstType)
    ELitBytes(val: str, ty: AstType)
    ERawStr(val: str, ty: AstType)
    ELitChar(val: int, ty: AstType)
    ELitBool(val: bool, ty: AstType)
    ELitNone(ty: AstType)
    EIdent(name: str, ty: AstType, is_move: bool)
    EBinOp(op: str, left: Pointer[HirExpr], right: Pointer[HirExpr], ty: AstType)
    EUnaryOp(op: str, expr: Pointer[HirExpr], ty: AstType)
    ECall(callee: Pointer[HirExpr], args: Vec[Pointer[HirExpr]], ty: AstType)
    EMethodCall(obj: Pointer[HirExpr], method: str, args: Vec[Pointer[HirExpr]], ty: AstType)
    EPropAccess(obj: Pointer[HirExpr], prop: str, ty: AstType)
    EIndex(obj: Pointer[HirExpr], index: Pointer[HirExpr], ty: AstType)
    ECast(expr: Pointer[HirExpr], target_ty: AstType)
    EFString(parts: Vec[HirFStringPart], ty: AstType)
    ETryExpr(expr: Pointer[HirExpr], ty: AstType)
    EClosure(params: Vec[HirParam], ret_ty: AstType, body: HirBlock, is_async: bool, captures: Vec[HirParam])
    ESuperMethodCall(base_class: str, method: str, args: Vec[Pointer[HirExpr]], ty: AstType)
    ESuperPropAccess(base_class: str, prop: str, ty: AstType)
    EList(items: Vec[Pointer[HirExpr]], ty: AstType)
    ESet(items: Vec[Pointer[HirExpr]], ty: AstType)
    EDict(keys: Vec[Pointer[HirExpr]], vals: Vec[Pointer[HirExpr]], ty: AstType)
    ETuple(items: Vec[Pointer[HirExpr]], ty: AstType)
    EListComp(element: Pointer[HirExpr], generators: Vec[Pointer[HirComprehension]], ty: AstType)
    EGeneratorExpr(element: Pointer[HirExpr], generators: Vec[Pointer[HirComprehension]], ty: AstType)
    ESlice(start: Pointer[HirExpr], stop: Pointer[HirExpr], step: Pointer[HirExpr], ty: AstType)
    EAwait(expr: Pointer[HirExpr], ty: AstType)
    EYield(expr: Pointer[HirExpr], ty: AstType)
    ETry(try_body: HirBlock, catches: Vec[Pointer[HirCatchClause]], finally_b: HirBlock, ty: AstType)
    ERange(start: Pointer[HirExpr], end: Pointer[HirExpr], inclusive: bool, ty: AstType)
    ESizeOf(target_ty: AstType, ty: AstType)
    EIfElse(cond: Pointer[HirExpr], then_e: Pointer[HirExpr], else_e: Pointer[HirExpr], ty: AstType)


pub class HirComprehension:
    pub target: str
    pub iter: Pointer[HirExpr]
    pub ifs: Vec[Pointer[HirExpr]]
    pub is_async: bool

pub class HirCatchClause:
    pub err_name: str
    pub err_type: AstType
    pub body: HirBlock

pub class HirFStringPart:
    pub is_expr: bool
    pub text: str
    pub expr: Pointer[HirExpr]

extend HirFStringPart:
    pub def init() -> HirFStringPart:
        mut p = HirFStringPart()
        p.is_expr = false
        p.text = ""
        p.expr = Pointer[HirExpr](0)
        return p

# ─── Match arms ─────────────────────────────────────────────────────────────

pub class HirMatchArm:
    pub pat: Pattern
    pub body: HirBlock

extend HirMatchArm:
    pub def init(pat: Pattern, body: HirBlock) -> HirMatchArm:
        mut a = HirMatchArm()
        a.pat = pat
        a.body = body
        return a

# ─── Statements ───────────────────────────────────────────────────────────────

pub enum HirStmt:
    SExpr(expr: Pointer[HirExpr])
    SLet(name: str, ownership: Ownership, is_mut: bool, is_const: bool, is_shared: bool, ty: AstType, val: Pointer[HirExpr])
    SAssign(target: Pointer[HirExpr], val: Pointer[HirExpr])
    SReturn(val: Pointer[HirExpr])    
    SBreak
    SContinue
    SPass
    SRaise(val: Pointer[HirExpr])
    SUnsafe(body: HirBlock)
    SIf(cond: Pointer[HirExpr], then_b: HirBlock, else_b: HirBlock)
    SWhile(cond: Pointer[HirExpr], body: HirBlock)
    SFor(var: str, iter: Pointer[HirExpr], body: HirBlock)
    SForUnpack(vars: Vec[str], iter: Pointer[HirExpr], body: HirBlock)
    SMatch(expr: Pointer[HirExpr], arms: Vec[HirMatchArm])
    STry(try_body: HirBlock, catches: Vec[Pointer[HirCatchClause]], finally_b: HirBlock)
    SAssert(cond: Pointer[HirExpr], msg: Pointer[HirExpr])
    SWith(items: Vec[Pointer[HirExpr]], aliases: Vec[str], body: HirBlock)
    SAsm(code: str, outputs: str, inputs: str, clobbers: str)
    SSpawn(expr: Pointer[HirExpr])
    STaskGroup(body: HirBlock)
    SGpuBlock(body: HirBlock)
    SFree(name: str)
    SMultiLet(names: Vec[str], is_mut: bool, val: Pointer[HirExpr])

pub class HirBlock:
    pub stmts: Vec[Pointer[HirStmt]]

extend HirBlock:
    pub def init() -> HirBlock:
        mut b = HirBlock()
        b.stmts = Vec[Pointer[HirStmt]].init(8)
        return b

    pub def push(self, s: Pointer[HirStmt]):
        self.stmts.push(s)

# ─── Declarations ─────────────────────────────────────────────────────────────

pub class HirParam:
    pub name: str
    pub ty: AstType

pub class HirFunction:
    pub name: str
    pub class_name: str              # set when this is a class/enum method
    pub generics: Vec[str]
    pub params: Vec[HirParam]
    pub ret_ty: AstType
    pub throws_ty: AstType           # non-empty name = function throws
    pub body: HirBlock
    pub decorators: Vec[Decorator]
    pub is_async: bool
    pub is_extern: bool
    pub is_public: bool
    pub is_static: bool
    pub is_variadic: bool

pub class HirField:
    pub name: str
    pub ty: AstType
    pub is_public: bool

pub class HirClass:
    pub name: str
    pub generics: Vec[str]
    pub base_classes: Vec[str]
    pub iface_names: Vec[str]
    pub fields: Vec[HirField]
    pub methods: Vec[HirFunction]
    pub decorators: Vec[Decorator]
    pub is_public: bool
    pub is_class: bool

pub class HirVariant:
    pub name: str
    pub fields: Vec[HirParam]

pub class HirEnum:
    pub name: str
    pub generics: Vec[str]
    pub iface_names: Vec[str]
    pub variants: Vec[HirVariant]
    pub methods: Vec[HirFunction]
    pub decorators: Vec[Decorator]
    pub is_public: bool

pub class HirInterface:
    pub name: str
    pub generics: Vec[str]
    pub methods: Vec[HirFunction]
    pub is_public: bool

pub class HirProgram:
    pub functions:      Vec[HirFunction]
    pub classes:        Vec[HirClass]
    pub enums:          Vec[HirEnum]
    pub interfaces:     Vec[HirInterface]
    pub top_level_stmts: Vec[Pointer[HirStmt]]
    pub extern_funcs:   Vec[HirFunction]   # extern "C" declarations

extend HirProgram:
    pub def init() -> HirProgram:
        mut p = HirProgram()
        p.functions = Vec[HirFunction].init(16)
        p.classes = Vec[HirClass].init(16)
        p.enums = Vec[HirEnum].init(4)
        p.interfaces = Vec[HirInterface].init(4)
        p.top_level_stmts = Vec[Pointer[HirStmt]].init(16)
        p.extern_funcs = Vec[HirFunction].init(4)
        return p

# ─── Helpers ──────────────────────────────────────────────────────────────────

pub def box_hirexpr(e: HirExpr) -> Pointer[HirExpr]:
    mut p = alloc[HirExpr](1)
    p.write(e)
    return p

pub def box_hirstmt(s: HirStmt) -> Pointer[HirStmt]:
    mut p = alloc[HirStmt](1)
    p.write(s)
    return p

pub def hir_expr_type(e: Pointer[HirExpr]) -> AstType:
    if e as usize == 0 as usize: return AstType.init("void")
    match e.read():
        case HirExpr.ELitInt(_, ty): return ty
        case HirExpr.ELitFloat(_, ty): return ty
        case HirExpr.ELitStr(_, ty): return ty
        case HirExpr.ELitBytes(_, ty): return ty
        case HirExpr.ERawStr(_, ty): return ty
        case HirExpr.ELitChar(_, ty): return ty
        case HirExpr.ELitBool(_, ty): return ty
        case HirExpr.ELitNone(ty): return ty
        case HirExpr.EIdent(_, ty, _): return ty
        case HirExpr.EBinOp(_, _, _, ty): return ty
        case HirExpr.EUnaryOp(_, _, ty): return ty
        case HirExpr.ECall(_, _, ty): return ty
        case HirExpr.EMethodCall(_, _, _, ty): return ty
        case HirExpr.EPropAccess(_, _, ty): return ty
        case HirExpr.EIndex(_, _, ty): return ty
        case HirExpr.ECast(_, ty): return ty
        case HirExpr.EFString(_, ty): return ty
        case HirExpr.ETryExpr(_, ty): return ty
        case HirExpr.EClosure(_, _, _, _, _): return AstType.init("lambda")
        case HirExpr.ESuperMethodCall(_, _, _, ty): return ty
        case HirExpr.ESuperPropAccess(_, _, ty): return ty
        case HirExpr.EList(_, ty): return ty
        case HirExpr.ESet(_, ty): return ty
        case HirExpr.EDict(_, _, ty): return ty
        case HirExpr.ETuple(_, ty): return ty
        case HirExpr.EListComp(_, _, ty): return ty
        case HirExpr.EGeneratorExpr(_, _, ty): return ty
        case HirExpr.ESlice(_, _, _, ty): return ty
        case HirExpr.EAwait(_, ty): return ty
        case HirExpr.EYield(_, ty): return ty
        case HirExpr.ETry(_, _, _, ty): return ty
        case HirExpr.ERange(_, _, _, ty): return ty
        case HirExpr.ESizeOf(_, ty): return ty
        case HirExpr.EIfElse(_, _, _, ty): return ty
    return AstType.init("void")

pub def hir_stmt_ownership(s: Pointer[HirStmt]) -> Ownership:
    return Ownership.Own

pub def _tr_str_len(s: str) -> int:
    unsafe:
        mut p = s as Pointer[char]
        mut i = 0
        while (p.offset(i).read() as int) != 0:
            i = i + 1
        return i

# Force generation of generic vector types
pub def _dummy_instantiations():
    mut v1 = Vec[Pointer[HirComprehension]].init(0)
    mut v2 = Vec[Pointer[HirCatchClause]].init(0)
    mut v3 = Vec[HirMatchArm].init(0)
    mut v4 = Vec[HirFStringPart].init(0)
    mut v5 = Vec[HirParam].init(0)
    mut v6 = Vec[HirField].init(0)
    mut v7 = Vec[HirVariant].init(0)
    mut v8 = Vec[HirFunction].init(0)
    mut v9 = Vec[HirClass].init(0)
    mut v10 = Vec[HirEnum].init(0)
    mut v11 = Vec[HirInterface].init(0)
