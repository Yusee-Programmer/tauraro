# compiler/src/ast.tr - AST node types for the Tauraro self-hosted compiler.

from core.vec import Vec
from core.alloc import alloc, dealloc

# --- Type annotations ---------------------------------------------------------

# @copy: AstType nodes are arena-allocated and immutable after construction.
# They are freely aliased throughout the compiler (assigned to fields, reused after
# assignment) and never individually freed, so sharing them is safe. The @copy
# opt-in tells the move-checker to treat assignment as a shared copy, not a
# destructive move - so the compiler's own code obeys the same rules it enforces.
@copy
pub class AstType:
    pub name: str
    pub args: Vec[Pointer[AstType]]
    pub from_param: str  # 'from X' lifetime annotation - empty means none

extend AstType:
    pub def init(name: str) -> AstType:
        mut t = AstType()
        t.name = name
        t.args = Vec[Pointer[AstType]].init(0)
        t.from_param = ""
        return t

    pub def init_generic(name: str, arg: Pointer[AstType]) -> AstType:
        mut t = AstType()
        t.name = name
        t.args = Vec[Pointer[AstType]].init(1)
        t.args.push(arg)
        t.from_param = ""
        return t

pub class GenericConstraint:
    pub target: str
    pub bounds: Vec[Pointer[AstType]]

extend GenericConstraint:
    pub def init(target: str) -> GenericConstraint:
        mut g = GenericConstraint()
        g.target = target
        g.bounds = Vec[Pointer[AstType]].init(1)
        return g

# --- Decorators ---------------------------------------------------------------

pub class Decorator:
    pub name: str
    pub args: Vec[Pointer[Expr]]

extend Decorator:
    pub def init(name: str) -> Decorator:
        mut d = Decorator()
        d.name = name
        d.args = Vec[Pointer[Expr]].init(0)
        return d

# --- Patterns -----------------------------------------------------------------

pub enum Pattern:
    PWild
    PBind(name: str)
    PLitInt(val: int)
    PLitStr(val: str)
    PLitBool(val: bool)
    PVariant(type_name: str, variant: str)
    PVariantBind(type_name: str, variant: str, field: str)
    PVariantBindMany(type_name: str, variant: str, fields: Vec[str])
    PTuple(first: str, second: str)
    POr(patterns: Vec[Pattern])

pub enum Ownership:
    Own
    Shared

pub class Comprehension:
    pub target: str
    pub iter: Pointer[Expr]
    pub ifs: Vec[Pointer[Expr]]
    pub is_async: bool

extend Comprehension:
    pub def init(target: str, iter: Pointer[Expr]) -> Comprehension:
        mut c = Comprehension()
        c.target = target
        c.iter = iter
        c.ifs = Vec[Pointer[Expr]].init(0)
        c.is_async = false
        return c

pub class CatchClause:
    pub err_name: str
    pub err_type: Pointer[AstType]
    pub body: Pointer[Block]

extend CatchClause:
    pub def init(err_name: str, body: Pointer[Block]) -> CatchClause:
        mut c = CatchClause()
        c.err_name = err_name
        c.err_type = Pointer[AstType](0)
        c.body = body
        return c
# --- Match arms ---------------------------------------------------------------

pub class MatchArm:
    pub pat: Pattern
    pub guard: Pointer[Expr]    
    pub body: Pointer[Block]

extend MatchArm:
    pub def init(pat: Pattern, body: Pointer[Block]) -> MatchArm:
        mut a = MatchArm()
        a.pat = pat
        a.guard = Pointer[Expr](0)
        a.body = body
        return a

# --- F-string parts -----------------------------------------------------------

pub class FStringPart:
    pub is_expr:  bool
    pub text:     str
    pub expr:     Pointer[Expr]
    pub fmt_spec: str    # e.g. ".2f", ">10", "05d" - empty means default

extend FStringPart:
    pub def init_text(s: str) -> FStringPart:
        mut p = FStringPart()
        p.is_expr  = false
        p.text     = s
        p.expr     = Pointer[Expr](0)
        p.fmt_spec = ""
        return p

    pub def init_expr(e: Pointer[Expr]) -> FStringPart:
        mut p = FStringPart()
        p.is_expr  = true
        p.text     = ""
        p.expr     = e
        p.fmt_spec = ""
        return p

    pub def init_expr_fmt(e: Pointer[Expr], spec: str) -> FStringPart:
        mut p = FStringPart()
        p.is_expr  = true
        p.text     = ""
        p.expr     = e
        p.fmt_spec = spec
        return p

# --- Expressions --------------------------------------------------------------

pub enum Expr:
    ELitInt(val: int)
    ELitFloat(val: float)
    ELitStr(val: str)
    ELitBool(val: bool)
    ELitChar(val: int)
    ELitBytes(val: str)
    ERawStr(val: str)
    ELitNone
    EIdent(name: str)
    EBinOp(op: str, left: Pointer[Expr], right: Pointer[Expr])
    EUnaryOp(op: str, expr: Pointer[Expr])
    ECall(callee: Pointer[Expr], args: Vec[Pointer[Expr]])
    EMethodCall(obj: Pointer[Expr], method: str, args: Vec[Pointer[Expr]])
    EPropAccess(obj: Pointer[Expr], prop: str)
    EIndex(obj: Pointer[Expr], index: Pointer[Expr])
    ECast(expr: Pointer[Expr], ty: Pointer[AstType])
    EFString(parts: Vec[FStringPart])
    ETryExpr(expr: Pointer[Expr])
    EClosure(params: Vec[Param], ret_ty: Pointer[AstType], body: Block, is_async: bool)
    ESuperMethodCall(base_class: str, method: str, args: Vec[Pointer[Expr]])
    ESuperPropAccess(base_class: str, prop: str)
    EList(items: Vec[Pointer[Expr]])
    ESet(items: Vec[Pointer[Expr]])
    EDict(keys: Vec[Pointer[Expr]], vals: Vec[Pointer[Expr]])
    ETuple(items: Vec[Pointer[Expr]])
    EListComp(element: Pointer[Expr], generators: Vec[Pointer[Comprehension]])
    EGeneratorExpr(element: Pointer[Expr], generators: Vec[Pointer[Comprehension]])
    ESlice(start: Pointer[Expr], stop: Pointer[Expr], step: Pointer[Expr])
    EAwait(expr: Pointer[Expr])
    EYield(expr: Pointer[Expr])
    ETry(try_body: Block, catches: Vec[Pointer[CatchClause]], finally_b: Block)
    ERange(start: Pointer[Expr], end: Pointer[Expr], inclusive: bool)
    ESizeOf(ty: Pointer[AstType])
    EIfElse(cond: Pointer[Expr], then_expr: Pointer[Expr], else_expr: Pointer[Expr])
    ETypeArg(ty: Pointer[AstType])

# --- Chan-select arms ---------------------------------------------------------

pub class ChanSelectArm:
    pub kind: int                   # 0=recv, 1=send, 2=timeout, 3=default
    pub chan_expr: Pointer[Expr]
    pub val_expr: Pointer[Expr]     # send value
    pub var_name: str               # recv binding name
    pub timeout_ms: Pointer[Expr]
    pub body: Block

extend ChanSelectArm:
    pub def init_recv(chan: Pointer[Expr], var: str, body: Block) -> ChanSelectArm:
        mut a = ChanSelectArm()
        a.kind = 0; a.chan_expr = chan; a.val_expr = Pointer[Expr](0)
        a.var_name = var; a.timeout_ms = Pointer[Expr](0); a.body = body
        return a
    pub def init_send(chan: Pointer[Expr], val: Pointer[Expr], body: Block) -> ChanSelectArm:
        mut a = ChanSelectArm()
        a.kind = 1; a.chan_expr = chan; a.val_expr = val
        a.var_name = ""; a.timeout_ms = Pointer[Expr](0); a.body = body
        return a
    pub def init_timeout(ms: Pointer[Expr], body: Block) -> ChanSelectArm:
        mut a = ChanSelectArm()
        a.kind = 2; a.chan_expr = Pointer[Expr](0); a.val_expr = Pointer[Expr](0)
        a.var_name = ""; a.timeout_ms = ms; a.body = body
        return a
    pub def init_default(body: Block) -> ChanSelectArm:
        mut a = ChanSelectArm()
        a.kind = 3; a.chan_expr = Pointer[Expr](0); a.val_expr = Pointer[Expr](0)
        a.var_name = ""; a.timeout_ms = Pointer[Expr](0); a.body = body
        return a

# --- Statements ---------------------------------------------------------------

pub enum Stmt:
    SExpr(expr: Pointer[Expr])
    SLet(name: str, ownership: Ownership, is_mut: bool, is_const: bool, is_shared: bool, ty: Pointer[AstType], val: Pointer[Expr])
    SMultiLet(names: Vec[str], is_mut: bool, val: Pointer[Expr])
    SAssign(target: Pointer[Expr], val: Pointer[Expr])
    SReturn(val: Pointer[Expr])
    SBreak
    SContinue
    SPass
    SRaise(val: Pointer[Expr])
    SUnsafe(body: Block)
    SIf(cond: Pointer[Expr], then_b: Block, elifs: Vec[ElifClause], else_b: Block)
    SWhile(cond: Pointer[Expr], body: Block, decorators: Vec[Decorator])
    SFor(var: str, iter: Pointer[Expr], body: Block, decorators: Vec[Decorator])
    SForUnpack(vars: Vec[str], iter: Pointer[Expr], body: Block)
    SMatch(expr: Pointer[Expr], arms: Vec[MatchArm])
    STry(try_body: Block, catches: Vec[Pointer[CatchClause]], finally_b: Block)
    SAssert(cond: Pointer[Expr], msg: Pointer[Expr])
    SWith(items: Vec[Pointer[Expr]], aliases: Vec[str], body: Block)
    SAsm(code: str, outputs: str, inputs: str, clobbers: str)
    SSpawn(expr: Pointer[Expr])
    STaskGroup(body: Block)
    SGpuBlock(body: Block)
    SChanSelect(cases: Vec[Pointer[ChanSelectArm]])
    SDefer(stmt: Pointer[Stmt])   # defer stmt - run at function exit, LIFO order
    SLine(n: int)
    SLocalDecl(decl: Pointer[Decl])   # nested class/def/enum/interface/extend - main() only

pub class Block:
    pub stmts: Vec[Pointer[Stmt]]

extend Block:
    pub def init() -> Block:
        mut b = Block()
        b.stmts = Vec[Pointer[Stmt]].init(8)
        return b

    pub def push(self, s: Pointer[Stmt]):
        self.stmts.push(s)

    pub def len(self) -> int:
        return self.stmts.len

    pub def get(self, i: int) -> Pointer[Stmt]:
        return self.stmts.get(i)

pub class ElifClause:
    pub cond: Pointer[Expr]
    pub body: Pointer[Block]

extend ElifClause:
    pub def init(cond: Pointer[Expr], body: Pointer[Block]) -> ElifClause:
        mut c = ElifClause()
        c.cond = cond
        c.body = body
        return c

# --- Function parameters ------------------------------------------------------

pub class Param:
    pub name: str
    pub ty: Pointer[AstType]
    pub is_ref: bool      # 'ref T' parameter - immutable borrow, not a copy
    pub is_mut_ref: bool  # 'mut ref T' parameter - mutable borrow
    pub is_variadic: bool # 'name...' or 'name: T...' - collects trailing call args into List[T]

extend Param:
    pub def init(name: str, ty: Pointer[AstType]) -> Param:
        mut p = Param()
        p.name = name
        p.ty = ty
        p.is_ref = false
        p.is_mut_ref = false
        p.is_variadic = false
        return p

# --- Top-level declarations ---------------------------------------------------

pub class FunctionDef:
    pub name: str
    pub generics: Vec[str]
    pub params: Vec[Param]
    pub ret_ty: Pointer[AstType]     
    pub throws_ty: Pointer[AstType]  
    pub decorators: Vec[Decorator]
    pub constraints: Vec[GenericConstraint]
    pub is_variadic: bool
    pub is_async: bool
    pub is_extern: bool
    pub is_public: bool
    pub is_export: bool   # `export def` - emit a C-ABI dllexport/visibility wrapper for FFI
    pub body: Block
    pub line: int

extend FunctionDef:
    pub def init(name: str) -> FunctionDef:
        mut f = FunctionDef()
        f.name = name
        f.generics = Vec[str].init(0)
        f.params = Vec[Param].init(4)
        f.ret_ty = Pointer[AstType](0)
        f.throws_ty = Pointer[AstType](0)
        f.decorators = Vec[Decorator].init(0)
        f.constraints = Vec[GenericConstraint].init(0)
        f.is_variadic = false
        f.is_async = false
        f.is_extern = false
        f.is_public = false
        f.is_export = false
        f.body = Block.init()
        f.line = 0
        return f

pub class FieldDef:
    pub name: str
    pub ty: Pointer[AstType]
    pub default_val: Pointer[Expr]  

extend FieldDef:
    pub def init(name: str, ty: Pointer[AstType]) -> FieldDef:
        mut fd = FieldDef()
        fd.name = name
        fd.ty = ty
        fd.default_val = Pointer[Expr](0)
        return fd

pub class ClassDef:
    pub name: str
    pub generics: Vec[str]
    pub base_classes: Vec[str]
    pub iface_names: Vec[str]
    pub fields: Vec[FieldDef]
    pub methods: Vec[FunctionDef]
    pub decorators: Vec[Decorator]
    pub constraints: Vec[GenericConstraint]
    pub is_public: bool
    pub is_class: bool
    pub line: int
    pub docstring: str

extend ClassDef:
    pub def init(name: str) -> ClassDef:
        mut c = ClassDef()
        c.name = name
        c.generics = Vec[str].init(0)
        c.base_classes = Vec[str].init(0)
        c.iface_names = Vec[str].init(0)
        c.fields = Vec[FieldDef].init(4)
        c.methods = Vec[FunctionDef].init(8)
        c.decorators = Vec[Decorator].init(0)
        c.constraints = Vec[GenericConstraint].init(0)
        c.is_public = false
        c.is_class = true
        c.line = 0
        c.docstring = ""
        return c

pub class VariantDef:
    pub name: str
    pub fields: Vec[Param]

extend VariantDef:
    pub def init(name: str) -> VariantDef:
        mut v = VariantDef()
        v.name = name
        v.fields = Vec[Param].init(4)
        return v

pub class EnumDef:
    pub name: str
    pub generics: Vec[str]
    pub iface_names: Vec[str]
    pub variants: Vec[VariantDef]
    pub methods: Vec[FunctionDef]
    pub decorators: Vec[Decorator]
    pub is_public: bool
    pub line: int

extend EnumDef:
    pub def init(name: str) -> EnumDef:
        mut e = EnumDef()
        e.name = name
        e.generics = Vec[str].init(0)
        e.iface_names = Vec[str].init(0)
        e.variants = Vec[VariantDef].init(8)
        e.methods = Vec[FunctionDef].init(4)
        e.decorators = Vec[Decorator].init(0)
        e.is_public = false
        e.line = 0
        return e

pub class InterfaceDef:
    pub name: str
    pub generics: Vec[str]
    pub methods: Vec[FunctionDef]
    pub is_public: bool
    pub line: int
    pub decorators: Vec[Decorator]

extend InterfaceDef:
    pub def init(name: str) -> InterfaceDef:
        mut i = InterfaceDef()
        i.name = name
        i.generics = Vec[str].init(0)
        i.methods = Vec[FunctionDef].init(4)
        i.is_public = false
        i.line = 0
        i.decorators = Vec[Decorator].init(0)
        return i

pub class ImportItem:
    pub name: str
    pub alias: str    

extend ImportItem:
    pub def init(name: str) -> ImportItem:
        mut it = ImportItem()
        it.name = name
        it.alias = ""
        return it

pub enum Decl:
    DFunction(func: FunctionDef)
    DClass(cls: ClassDef)
    DEnum(enm: EnumDef)
    DInterface(iface: InterfaceDef)
    DExtend(target: str, methods: Vec[FunctionDef])
    DImport(path: str, alias: str)
    DFromImport(path: str, items: Vec[ImportItem])
    DExtern(abi: str, functions: Vec[FunctionDef])
    DTopLevelStmt(stmt: Pointer[Stmt])
    DActor(cls: ClassDef)
    DDecoratorDef(func: FunctionDef)
    DTypeAlias(name: str, target: Pointer[AstType])   # type Name = ExistingType

pub class Program:
    pub decls: Vec[Pointer[Decl]]

extend Program:
    pub def init() -> Program:
        mut p = Program()
        p.decls = Vec[Pointer[Decl]].init(16)
        return p

    pub def push(self, d: Pointer[Decl]):
        self.decls.push(d)

    pub def len(self) -> int:
        return self.decls.len

    pub def get(self, i: int) -> Pointer[Decl]:
        return self.decls.get(i)


pub def _dummy_instantiations():
    mut v1 = Vec[Pointer[Comprehension]].init(0)
    mut v2 = Vec[Pointer[CatchClause]].init(0)
    mut v3 = Vec[Pattern].init(0)
    mut v4 = Vec[ImportItem].init(0)
    mut v5 = Vec[Decorator].init(0)
    mut v6 = Vec[Param].init(0)
    mut v7 = Vec[VariantDef].init(0)
    mut v8 = Vec[FunctionDef].init(0)
    mut v9 = Vec[FieldDef].init(0)
    mut v10 = Vec[Pointer[Stmt]].init(0)
    mut v11 = Vec[Pointer[Expr]].init(0)
    mut v12 = Vec[Pointer[Decl]].init(0)
