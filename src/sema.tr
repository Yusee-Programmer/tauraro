                                elif (type_name == "Thread" or type_name == "ThreadPool" or type_name == "Atomic" or type_name == "ThreadLocal") and (variant == "spawn" or variant == "new" or variant == "init"):
                                    ret_ty = AstType.init(type_name)
                                elif variant == "init" or variant == "new":
                                    if type_name == "Pointer" or type_name == "List" or type_name == "Vec" or type_name == "Map" or type_name == "Dict":
                                        ret_ty = AstType.init(type_name)
                                    elif self.classes.contains(type_name):
                                        ret_ty = AstType.init(type_name)
                            case Expr.EIndex(base2, idx2):
                                if variant == "init" or variant == "new":
                                    match base2.read():
                                        case Expr.EIdent(gn2):
                                            if gn2 == "Pointer" or gn2 == "List" or gn2 == "Vec" or gn2 == "Map" or gn2 == "Dict":
                                                match idx2.read():
                                                    case Expr.EIdent(tn2):
                                                        ret_ty = AstType.init(gn2)
                                                        ret_ty.args.push(box_asttype(AstType.init(tn2)))
                                                    case _:
                                                        ret_ty = AstType.init(gn2)
                                            elif self.classes.contains(gn2):
                                                ret_ty = AstType.init(gn2)
                                                match idx2.read():
                                                    case Expr.EIdent(targ_cb): ret_ty.args.push(box_asttype(AstType.init(targ_cb)))
                                                    case _: pass
                                        case _: pass
                            case _: pass
