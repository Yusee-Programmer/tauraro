                    mut _hty_n = hobj_ty.name
                    mut _is_builtin_dispatch = _hty_n == "Thread" or _hty_n == "Atomic" or _hty_n == "ThreadLocal" or _hty_n == "ThreadPool" or _hty_n == "Mutex" or _hty_n == "RwLock" or _hty_n == "Chan" or _hty_n == "Channel" or _hty_n == "Shared" or _hty_n == "Weak" or _hty_n == "StringBuilder" or _hty_n == "OS" or _hty_n == "Process" or _hty_n == "Env" or _hty_n == "Hash" or _hty_n == "File"
