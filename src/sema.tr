                if self.type_aliases.contains(hobj_ty.name):
                    mut _alias_base = self.type_aliases.get(hobj_ty.name)
                    mut _alias_ty = AstType.init(_alias_base)
                    if self.type_alias_elem.contains(hobj_ty.name):
                        mut _elem_name = self.type_alias_elem.get(hobj_ty.name)
                        _alias_ty = AstType.init_generic(_alias_base, box_asttype(AstType.init(_elem_name)))
                    hobj_ty = _alias_ty
                # Callable-field call: obj.f(args) where f is a def(...)-typed
                # FIELD (not a method) -> lower to field access + indirect call.
                if self.classes.contains(hobj_ty.name):
                    mut _cf_cls = self.classes.get(hobj_ty.name)
                    mut _cf_i = 0
                    mut _cf_ty = AstType.init("void")
                    mut _cf_found = false
                    while _cf_i < _cf_cls.fields.len:
                        mut _cf_fld = _cf_cls.fields.get(_cf_i)
                        if _cf_fld.name == method and _cf_fld.ty as usize != 0 as usize:
                            _cf_ty = _cf_fld.ty.read()
                            _cf_found = true
                        _cf_i = _cf_i + 1
                    if _cf_found and _cf_ty.name == "def":
                        mut _cf_ret = AstType.init("void")
                        if _cf_ty.args.len > 0: _cf_ret = _cf_ty.args.get(_cf_ty.args.len - 1).read()
                        mut _cf_prop = box_hirexpr(HirExpr.EPropAccess(hobj, method, _cf_ty))
                        return box_hirexpr(HirExpr.ECall(_cf_prop, hl, _cf_ret))
                # Phase C: error if mutating a container that has an active borrow
                if method == "push" or method == "pop" or method == "insert" or method == "remove":
                    mut pc_obj_nm = ""
                    match obj.read():
                        case Expr.EIdent(pc_src): pc_obj_nm = pc_src
                        case _: pass
                    if pc_obj_nm != "" and self.container_borrows.contains(pc_obj_nm):
                        mut pc_borrow_var = self.container_borrows.get(pc_obj_nm)
                        self.error("[M-4] Cannot mutate '" + pc_obj_nm + "' while '" + pc_borrow_var + "' holds a reference into it.\n      FIX: Finish using '" + pc_borrow_var + "' before modifying '" + pc_obj_nm + "', or copy it first: 'mut copy = " + pc_borrow_var + "'.")
                # Get receiver identifier name for built-in module dispatch
                mut _bm_obj_nm = ""
                match obj.read():
                    case Expr.EIdent(_bm_n): _bm_obj_nm = _bm_n
                    case _: pass
                mut ret_ty = AstType.init("void")
                # Built-in module static type inference: OS, Process, Env, Hash, File
                if _bm_obj_nm == "OS" or hobj_ty.name == "OS":
                    if method == "cwd" or method == "platform": ret_ty = AstType.init("str")
                    elif method == "is_windows" or method == "is_linux" or method == "is_darwin" or method == "is_macos": ret_ty = AstType.init("bool")
                elif _bm_obj_nm == "Process" or hobj_ty.name == "Process":
                    if method == "system" or method == "exit": ret_ty = AstType.init("int")
                    elif method == "shell_output": ret_ty = AstType.init("str")
                elif _bm_obj_nm == "Env" or hobj_ty.name == "Env":
                    if method == "get_var" or method == "cwd": ret_ty = AstType.init("str")
                elif _bm_obj_nm == "Hash" or hobj_ty.name == "Hash":
                    if method == "sha256" or method == "md5": ret_ty = AstType.init("str")
                # [P-1] writing through a raw pointer can corrupt memory and must be
                # confined to an 'unsafe:' block. Constructing a Pointer[T], taking
                # an address with '&', '.offset()' (address arithmetic), and
                # '.read()' (dereferencing to get a value) remain safe everywhere -
                # they cannot by themselves corrupt memory.
                if hobj_ty.name == "Pointer" and method == "write" and not self.in_unsafe:
                    self.error("[P-1] '.write()' on a Pointer mutates raw memory and must be inside an 'unsafe:' block.\n      FIX: Wrap this call in 'unsafe:', e.g.\n          unsafe:\n              ... .write(...) ...")
                if method == "init" or method == "new":
                    # Preserve generic args so Vec[T].init(n) keeps the T info
                    if hobj_ty.name == "void" or hobj_ty.name == "":
                        # Built-in types used as static receivers (e.g. Atomic.new, Thread.new)
                        # resolve to void; recover type from the receiver identifier name.
                        match hobj.read():
                            case HirExpr.EIdent(recv_nm, _, _): ret_ty = AstType.init(recv_nm)
                            # Vec[T].init(n) / List[T].init(n) - EIndex object, recover with generic arg
                            case HirExpr.EIndex(idx_base, idx_arg, _):
                                match idx_base.read():
                                    case HirExpr.EIdent(gn, _, _):
                                        ret_ty = AstType.init(gn)
                                        match idx_arg.read():
                                            case HirExpr.EIdent(tn, _, _): ret_ty.args.push(box_asttype(AstType.init(tn)))
                                            case _: pass
                                    case _: ret_ty = hobj_ty
                            case _: ret_ty = hobj_ty
                    else:
                        ret_ty = hobj_ty
                elif method == "offset": ret_ty = hobj_ty
                # List/Vec aggregate methods - return element type or int
                elif (hobj_ty.name == "List" or hobj_ty.name == "Vec") and (method == "sum" or method == "min" or method == "max" or method == "min_val" or method == "max_val"):
                    if hobj_ty.args.len > 0: ret_ty = hobj_ty.args.get(0).read()
                    else: ret_ty = AstType.init("int")
                elif (hobj_ty.name == "List" or hobj_ty.name == "Vec") and (method == "any" or method == "all" or method == "is_empty"): ret_ty = AstType.init("bool")
                elif (hobj_ty.name == "List" or hobj_ty.name == "Vec") and (method == "first" or method == "last"):
                    if hobj_ty.args.len > 0: ret_ty = hobj_ty.args.get(0).read()
                    else: ret_ty = AstType.init("void")
                elif (hobj_ty.name == "List" or hobj_ty.name == "Vec") and (method == "reversed" or method == "reversed_copy"): ret_ty = hobj_ty
                elif (hobj_ty.name == "List" or hobj_ty.name == "Vec") and (method == "clone" or method == "copy"): ret_ty = hobj_ty
                elif (hobj_ty.name == "List" or hobj_ty.name == "Vec") and method == "reverse": ret_ty = AstType.init("void")
                elif (hobj_ty.name == "List" or hobj_ty.name == "Vec") and (method == "index_of" or method == "last_index_of" or method == "count"): ret_ty = AstType.init("int")
                elif (hobj_ty.name == "List" or hobj_ty.name == "Vec") and method == "join": ret_ty = AstType.init("str")
                elif method == "read":
                    if hobj_ty.name == "Pointer" and hobj_ty.args.len > 0: ret_ty = hobj_ty.args.get(0).read()
                    else: ret_ty = AstType.init("int")
                elif method == "as_str" or method == "to_str": ret_ty = AstType.init("str")
                elif method == "len" or method == "__len__": ret_ty = AstType.init("int")
                elif method == "checked_add" or method == "checked_sub" or method == "checked_mul":
                    # Returns Option[int] - integer checked arithmetic
                    ret_ty = AstType.init_generic("Option", box_asttype(AstType.init("int")))
                elif method == "abs" or method == "min" or method == "max" or method == "pow" or method == "sign" or method == "clamp" or method == "gcd" or method == "lcm":
                    ret_ty = hobj_ty  # same numeric type
                # Float math methods - return float
                elif hobj_ty.name == "float" or hobj_ty.name == "f64" or hobj_ty.name == "f32":
                    if method == "floor" or method == "ceil" or method == "round" or method == "sqrt" or method == "fabs" or method == "log" or method == "log2" or method == "log10" or method == "exp" or method == "sin" or method == "cos" or method == "tan" or method == "asin" or method == "acos" or method == "atan" or method == "atan2" or method == "pow":
