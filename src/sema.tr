# compiler/sema.tr - Semantic analyzer for the Tauraro self-hosted compiler.

from core.vec import Vec
from core.map import Map
from core.alloc import alloc, dealloc
from core.io import _tr_exit, write_file, append_file
from ast import Program, Decl, Expr, Stmt, AstType, Block, MatchArm, Pattern, FunctionDef, ClassDef, EnumDef, InterfaceDef, Param, Decorator, FStringPart, Ownership, CatchClause, Comprehension, ChanSelectArm
from hir import HirProgram, HirFunction, HirClass, HirEnum, HirInterface, HirStmt, HirExpr, HirBlock, HirParam, HirField, HirVariant, HirFStringPart, HirComprehension, HirCatchClause, HirMatchArm, box_hirexpr, box_hirstmt, hir_expr_type, HirChanSelectArm


pub enum SymbolKind:
    SFunction
    SClass
    SEnum
    SVariable
    SInterface

pub class Symbol:
    pub name: str
    pub kind: SymbolKind
    pub ty: Pointer[AstType]
    pub scope_depth: int
    pub is_mut: bool
    pub is_const: bool
    pub is_shared: bool
    pub is_moved: bool
    pub active_borrows: int
    pub borrowed_by: Vec[str]
    pub is_init: bool
    pub is_param: bool
    pub is_maybe_moved: bool  # moved in SOME but not ALL branches
    pub is_maybe_init: bool   # init in SOME but not ALL branches
    pub ptr_region: int       # 0=LOCAL, 1=HEAP(alloc), 2=PARAM, 3=GLOBAL
    pub is_freed: bool        # [M-6] dealloc() was called on this pointer
    pub decl_block_depth: int # auto-drop: nested-block depth (if/while bodies) at declaration; only depth==0 is droppable by the enclosing scope
    pub decl_block_id: int    # auto-drop: id of the innermost if/while C block open at declaration within the current scope; 0 = scope top-level
    pub str_escaped: bool     # auto-drop: a `str` local passed as a call/method-call ARGUMENT - may be aliased into a legacy List_str/Dict/Set (#52 not yet migrated); excluded from auto-drop to avoid UAF
    pub coll_escaped: bool    # auto-drop: a List/Vec/Dict/Map/Set local that is ever read in a non-receiver position (call/method arg, assigned to another var, returned, stored in a literal) - raw unrefcounted pointer, so any alias must disable auto-free to avoid UAF

extend Symbol:
    pub def init(name: str, kind: SymbolKind, ty: Pointer[AstType]) -> Symbol:
        mut s = Symbol()
        s.name = name
        s.kind = kind
        s.ty = ty
        s.scope_depth = 0
        s.is_mut = false
        s.is_const = false
        s.is_shared = false
        s.is_moved = false
        s.active_borrows = 0
        s.borrowed_by = Vec[str].init(0)
        s.is_init = true
        s.is_param = false
        s.is_maybe_moved = false
        s.is_maybe_init = false
        s.ptr_region = 0
        s.is_freed = false
        s.decl_block_depth = 0
        s.decl_block_id = 0
        s.str_escaped = false
        s.coll_escaped = false
        return s

pub class Scope:
    pub variables: Map[str, Symbol]
    pub decl_order: Vec[str]

extend Scope:
    pub def init() -> Scope:
        mut s = Scope()
        s.variables = Map[str, Symbol].init(32)
        s.decl_order = Vec[str].init(8)
        return s

pub class Sema:
    pub globals:            Map[str, Symbol]
    pub scopes:             Vec[Scope]
    pub errors:             Vec[str]
    pub warnings:           Vec[str]
    pub classes:            Map[str, ClassDef]
    pub enums:              Map[str, EnumDef]
    pub interfaces:         Map[str, InterfaceDef]
    pub type_aliases:        Map[str, str]   # alias_name -> resolved base name
    pub type_alias_elem:     Map[str, str]   # alias_name -> first generic arg name (for List/Map)
    pub current_file:        str             # path of source file currently being analysed
    pub current_func_name:  str
    pub current_class_name: str
    pub current_scope_depth: int
    pub in_async_fn:        bool
    pub assign_froms:       Map[str, int] # block-local last use tracking
    pub fn_sigs:            Map[str, AstType] # top-level fn name -> def(...)->R type, for first-class function references
    # Nested declarations (class/def/enum/interface inside main()) hoisted to file scope.
    pub nested_classes:     Vec[HirClass]
    pub nested_functions:   Vec[HirFunction]
    pub nested_enums:       Vec[HirEnum]
    pub nested_interfaces:  Vec[HirInterface]
    pub current_line:       int
    pub current_func_generics: Vec[str]
    pub closure_boundary: int           # scope depth just before entering a closure (-1 = not in closure)
    pub closure_caps:     Vec[HirParam] # captures accumulated for the current innermost closure
    pub closure_cap_set:  Map[str, bool] # dedup set for capture names
    pub in_assign_target: bool          # Phase D: suppress is_init check on assignment LHS
    pub container_borrows: Map[str, str] # Phase C: container_var -> borrowing_var
    pub capturing_moves: bool           # Fix 1: branch snapshot - are we tracking move deltas?
    pub branch_moved_buf: Vec[str]      # Fix 1: names moved in current branch
    pub capturing_inits: bool           # Fix 4: branch snapshot for init deltas
    pub branch_init_buf: Vec[str]       # Fix 4: names init'd in current branch
    pub copy_classes: Map[str, bool]    # Fix 3: auto-inferred Copy classes (all-primitive fields)
    pub in_unsafe: bool                 # Gap 6: inside an unsafe: block
    pub current_func_ret_from: str      # Gap 1: 'from' lifetime param of current function return
    pub strict_mode: bool               # --strict: alloc outside unsafe -> hard [U-1] error
    pub decorator_names: Map[str, bool]  # decorator def registry (name -> true)
    pub variadic_fns:    Map[str, str]   # fn name -> index of trailing variadic param (= fixed-arg count, as string)
    pub variadic_elem_ty: Map[str, Pointer[AstType]] # fn name -> element type of the variadic List[T] param
    pub fn_defs:         Map[str, FunctionDef]  # top-level fn name -> full definition, for inspect(T)
    pub loop_scope_base: Vec[int]  # auto-drop: scope-stack depth marking the start of each enclosing loop's scopes
    pub block_depth: int  # auto-drop: nested-C-block depth (if/while bodies sharing a Scope); 0 = directly in the owning scope's top-level block
    pub block_depth_stack: Vec[int]  # auto-drop: saved block_depth per scope, restored on exit_scope
    pub next_block_id: int       # auto-drop: monotonic id, incremented each time an if/while/etc body block opens
    pub block_stack: Vec[int]    # auto-drop: ids of currently-open if/while bodies, innermost last
    pub block_stack_base: Vec[int] # auto-drop: block_stack.len at each enter_scope, restored on exit_scope

extend Sema:
    pub def build_ast_type(self, e: Pointer[Expr]) -> Pointer[AstType]:
        if e as usize == 0 as usize: return Pointer[AstType](0)
        match e.read():
            case Expr.EIdent(n):
                return box_asttype(AstType.init(n))
            case Expr.EIndex(obj, idx):
                match obj.read():
                    case Expr.EIdent(on):
                        mut at = AstType.init(on)
                        at.args = Vec[Pointer[AstType]].init(1)
                        at.args.push(self.build_ast_type(idx))
                        return box_asttype(at)
                    case _: pass
            case _: pass
        return box_asttype(AstType.init("void"))

    pub def init() -> Sema:
        mut s = Sema()
        s.globals            = Map[str, Symbol].init(1024)
        s.scopes             = Vec[Scope].init(16)
        s.errors             = Vec[str].init(16)
        s.warnings           = Vec[str].init(8)
        s.classes            = Map[str, ClassDef].init(128)
        s.enums              = Map[str, EnumDef].init(64)
        s.interfaces         = Map[str, InterfaceDef].init(32)
        s.type_aliases    = Map[str, str].init(32)
        s.type_alias_elem = Map[str, str].init(32)
        s.current_file    = ""
        s.current_func_name  = ""
        s.current_class_name = ""
        s.current_scope_depth = 0
        s.in_async_fn        = false
        s.assign_froms       = Map[str, int].init(32)
        s.fn_sigs            = Map[str, AstType].init(64)
        s.nested_classes     = Vec[HirClass].init(4)
        s.nested_functions   = Vec[HirFunction].init(4)
        s.nested_enums       = Vec[HirEnum].init(4)
        s.nested_interfaces  = Vec[HirInterface].init(4)
        s.current_line       = 0
        s.current_func_generics = Vec[str].init(0)
        s.closure_boundary  = -1
        s.closure_caps      = Vec[HirParam].init(0)
        s.closure_cap_set   = Map[str, bool].init(0)
        s.in_assign_target  = false
        s.container_borrows = Map[str, str].init(16)
        s.capturing_moves   = false
        s.branch_moved_buf  = Vec[str].init(0)
        s.capturing_inits   = false
        s.branch_init_buf   = Vec[str].init(0)
        s.copy_classes           = Map[str, bool].init(32)
        s.in_unsafe              = false
        s.current_func_ret_from  = ""
        s.strict_mode            = false
        s.decorator_names        = Map[str, bool].init(16)
        s.variadic_fns           = Map[str, str].init(8)
        s.variadic_elem_ty       = Map[str, Pointer[AstType]].init(8)
        s.fn_defs                = Map[str, FunctionDef].init(32)
        s.loop_scope_base        = Vec[int].init(8)
        s.block_depth            = 0
        s.block_depth_stack      = Vec[int].init(8)
        s.next_block_id          = 0
        s.block_stack            = Vec[int].init(8)
        s.block_stack_base       = Vec[int].init(8)

        # -- Built-in functions -------------------------------------------------
        s.globals.insert("print",    Symbol.init("print",    SymbolKind.SFunction, box_asttype(AstType.init("void"))))
        s.globals.insert("input",    Symbol.init("input",    SymbolKind.SFunction, box_asttype(AstType.init("str"))))
        s.globals.insert("len",      Symbol.init("len",      SymbolKind.SFunction, box_asttype(AstType.init("int"))))
        s.globals.insert("range",    Symbol.init("range",    SymbolKind.SFunction, box_asttype(AstType.init("List"))))
        s.globals.insert("type",     Symbol.init("type",     SymbolKind.SFunction, box_asttype(AstType.init("str"))))
        s.globals.insert("str",      Symbol.init("str",      SymbolKind.SFunction, box_asttype(AstType.init("str"))))
        s.globals.insert("int",      Symbol.init("int",      SymbolKind.SFunction, box_asttype(AstType.init("int"))))
        s.globals.insert("float",    Symbol.init("float",    SymbolKind.SFunction, box_asttype(AstType.init("float"))))
        s.globals.insert("bool",     Symbol.init("bool",     SymbolKind.SFunction, box_asttype(AstType.init("bool"))))
        s.globals.insert("ord",      Symbol.init("ord",      SymbolKind.SFunction, box_asttype(AstType.init("int"))))
        s.globals.insert("chr",      Symbol.init("chr",      SymbolKind.SFunction, box_asttype(AstType.init("char"))))
        s.globals.insert("abs",      Symbol.init("abs",      SymbolKind.SFunction, box_asttype(AstType.init("int"))))
        s.globals.insert("max",      Symbol.init("max",      SymbolKind.SFunction, box_asttype(AstType.init("int"))))
        s.globals.insert("min",      Symbol.init("min",      SymbolKind.SFunction, box_asttype(AstType.init("int"))))
        s.globals.insert("sum",      Symbol.init("sum",      SymbolKind.SFunction, box_asttype(AstType.init("int"))))
        s.globals.insert("round",    Symbol.init("round",    SymbolKind.SFunction, box_asttype(AstType.init("float"))))
        s.globals.insert("sorted",   Symbol.init("sorted",   SymbolKind.SFunction, box_asttype(AstType.init("List"))))
        s.globals.insert("reversed", Symbol.init("reversed", SymbolKind.SFunction, box_asttype(AstType.init("List"))))
        s.globals.insert("iter",     Symbol.init("iter",     SymbolKind.SFunction, box_asttype(AstType.init("List"))))
        s.globals.insert("enumerate",Symbol.init("enumerate",SymbolKind.SFunction, box_asttype(AstType.init("List"))))
        s.globals.insert("zip",      Symbol.init("zip",      SymbolKind.SFunction, box_asttype(AstType.init("List"))))
        s.globals.insert("map",      Symbol.init("map",      SymbolKind.SFunction, box_asttype(AstType.init("List"))))
        s.globals.insert("filter",   Symbol.init("filter",   SymbolKind.SFunction, box_asttype(AstType.init("List"))))
        s.globals.insert("all",      Symbol.init("all",      SymbolKind.SFunction, box_asttype(AstType.init("bool"))))
        s.globals.insert("any",      Symbol.init("any",      SymbolKind.SFunction, box_asttype(AstType.init("bool"))))
        s.globals.insert("assert",    Symbol.init("assert",    SymbolKind.SFunction, box_asttype(AstType.init("void"))))
        s.globals.insert("assert_eq", Symbol.init("assert_eq", SymbolKind.SFunction, box_asttype(AstType.init("void"))))
        s.globals.insert("assert_ne", Symbol.init("assert_ne", SymbolKind.SFunction, box_asttype(AstType.init("void"))))
        s.globals.insert("assert_lt", Symbol.init("assert_lt", SymbolKind.SFunction, box_asttype(AstType.init("void"))))
        s.globals.insert("assert_le", Symbol.init("assert_le", SymbolKind.SFunction, box_asttype(AstType.init("void"))))
        s.globals.insert("assert_gt", Symbol.init("assert_gt", SymbolKind.SFunction, box_asttype(AstType.init("void"))))
        s.globals.insert("assert_ge", Symbol.init("assert_ge", SymbolKind.SFunction, box_asttype(AstType.init("void"))))
        s.globals.insert("Some",     Symbol.init("Some",     SymbolKind.SFunction, box_asttype(AstType.init("Option"))))
        s.globals.insert("Ok",       Symbol.init("Ok",       SymbolKind.SFunction, box_asttype(AstType.init("Result"))))
        s.globals.insert("Err",      Symbol.init("Err",      SymbolKind.SFunction, box_asttype(AstType.init("Result"))))
        s.globals.insert("_tr_exit",   Symbol.init("_tr_exit",   SymbolKind.SFunction, box_asttype(AstType.init("void"))))
        s.globals.insert("_tr_strlen", Symbol.init("_tr_strlen", SymbolKind.SFunction, box_asttype(AstType.init("int"))))
        s.globals.insert("read_file",  Symbol.init("read_file",  SymbolKind.SFunction, box_asttype(AstType.init("str"))))
        s.globals.insert("write_file", Symbol.init("write_file", SymbolKind.SFunction, box_asttype(AstType.init("void"))))
        s.globals.insert("file_exists",Symbol.init("file_exists",SymbolKind.SFunction, box_asttype(AstType.init("bool"))))
        s.globals.insert("_tr_system", Symbol.init("_tr_system", SymbolKind.SFunction, box_asttype(AstType.init("int"))))

        # -- Built-in container classes ------------------------------------------
        # Vec is NOT a built-in - it is the OOP class imported from core.vec.
        # List is the only built-in C-backed array type.
        s.globals.insert("List",         Symbol.init("List",         SymbolKind.SClass, box_asttype(AstType.init("List"))))
        s.globals.insert("Pointer",      Symbol.init("Pointer",      SymbolKind.SClass, box_asttype(AstType.init("Pointer"))))
        s.globals.insert("StringBuilder",Symbol.init("StringBuilder",SymbolKind.SClass, box_asttype(AstType.init("StringBuilder"))))
        s.globals.insert("StringObj",    Symbol.init("StringObj",    SymbolKind.SClass, box_asttype(AstType.init("StringObj"))))
        # Map is not a builtin - import from std/core. Dict is the builtin associative type.
        s.globals.insert("Dict",         Symbol.init("Dict",         SymbolKind.SClass, box_asttype(AstType.init("Dict"))))
        s.globals.insert("Set",          Symbol.init("Set",          SymbolKind.SClass, box_asttype(AstType.init("Set"))))
        s.globals.insert("Box",          Symbol.init("Box",          SymbolKind.SClass, box_asttype(AstType.init("Box"))))

        # -- Result / Option enums -----------------------------------------------
        s.globals.insert("Option", Symbol.init("Option", SymbolKind.SEnum, box_asttype(AstType.init("Option"))))
        s.globals.insert("Result", Symbol.init("Result", SymbolKind.SEnum, box_asttype(AstType.init("Result"))))

        # -- Exception hierarchy -------------------------------------------------
        s.globals.insert("Exception",  Symbol.init("Exception",  SymbolKind.SClass, box_asttype(AstType.init("Exception"))))
        s.globals.insert("Error",      Symbol.init("Error",      SymbolKind.SClass, box_asttype(AstType.init("Error"))))
        s.globals.insert("ValueError", Symbol.init("ValueError", SymbolKind.SClass, box_asttype(AstType.init("ValueError"))))
        s.globals.insert("TypeError",  Symbol.init("TypeError",  SymbolKind.SClass, box_asttype(AstType.init("TypeError"))))
        s.globals.insert("IndexError", Symbol.init("IndexError", SymbolKind.SClass, box_asttype(AstType.init("IndexError"))))
        s.globals.insert("IOError",    Symbol.init("IOError",    SymbolKind.SClass, box_asttype(AstType.init("IOError"))))
        s.globals.insert("KeyError",   Symbol.init("KeyError",   SymbolKind.SClass, box_asttype(AstType.init("KeyError"))))

        # -- Concurrency / async types -------------------------------------------
        s.globals.insert("Task",      Symbol.init("Task",      SymbolKind.SClass, box_asttype(AstType.init("Task"))))
        s.globals.insert("Future",    Symbol.init("Future",    SymbolKind.SClass, box_asttype(AstType.init("Future"))))
        s.globals.insert("Channel",   Symbol.init("Channel",   SymbolKind.SClass, box_asttype(AstType.init("Channel"))))
        s.globals.insert("Chan",      Symbol.init("Chan",      SymbolKind.SClass, box_asttype(AstType.init("Chan"))))
        s.globals.insert("Mutex",     Symbol.init("Mutex",     SymbolKind.SClass, box_asttype(AstType.init("Mutex"))))
        s.globals.insert("RwLock",    Symbol.init("RwLock",    SymbolKind.SClass, box_asttype(AstType.init("RwLock"))))
        s.globals.insert("ThreadPool", Symbol.init("ThreadPool", SymbolKind.SClass, box_asttype(AstType.init("ThreadPool"))))
        s.globals.insert("Thread",     Symbol.init("Thread",     SymbolKind.SClass, box_asttype(AstType.init("Thread"))))
        s.globals.insert("Atomic",     Symbol.init("Atomic",     SymbolKind.SClass, box_asttype(AstType.init("Atomic"))))
        s.globals.insert("ThreadLocal", Symbol.init("ThreadLocal", SymbolKind.SClass, box_asttype(AstType.init("ThreadLocal"))))
        s.globals.insert("await_all", Symbol.init("await_all", SymbolKind.SFunction, box_asttype(AstType.init("void"))))
        s.globals.insert("Arc",       Symbol.init("Arc",       SymbolKind.SClass, box_asttype(AstType.init("Arc"))))
        s.globals.insert("Rc",        Symbol.init("Rc",        SymbolKind.SClass, box_asttype(AstType.init("Rc"))))
        s.globals.insert("WaitGroup", Symbol.init("WaitGroup", SymbolKind.SClass, box_asttype(AstType.init("WaitGroup"))))

        # -- Ownership / shared types (Phase 4) ---------------------------------
        s.globals.insert("Shared", Symbol.init("Shared", SymbolKind.SClass, box_asttype(AstType.init("Shared"))))
        s.globals.insert("Weak",   Symbol.init("Weak",   SymbolKind.SClass, box_asttype(AstType.init("Weak"))))

        return s

    # -- #9: inspect(T) reflection helper -----------------------------------

    pub def io_ty_str(self, ty: AstType) -> str:
        mut s = ty.name
        if s == "": s = "void"
        if ty.args.len > 0:
            s = s + "["
            mut i = 0
            while i < ty.args.len:
                if i > 0: s = s + ", "
                s = s + self.io_ty_str(ty.args.get(i).read())
                i = i + 1
            s = s + "]"
        return s

    # First non-SLine statement of a body that is a bare string literal is its docstring.
    pub def io_doc_of(self, body: Block) -> str:
        mut i = 0
        while i < body.stmts.len:
            match body.stmts.get(i).read():
                case Stmt.SLine(_): pass
                case Stmt.SExpr(e):
                    if e as usize != 0 as usize:
                        match e.read():
                            case Expr.ELitStr(s): return s
                            case _: pass
                    return ""
                case _: return ""
            i = i + 1
        return ""

    pub def io_func_sig(self, f: FunctionDef) -> str:
        mut s = "def " + f.name + "("
        mut i = 0
        while i < f.params.len:
            if i > 0: s = s + ", "
            mut p = f.params.get(i)
            s = s + p.name
            if p.ty as usize != 0 as usize:
                s = s + ": " + self.io_ty_str(p.ty.read())
            if p.is_variadic: s = s + "..."
            i = i + 1
        s = s + ")"
        if f.ret_ty as usize != 0 as usize:
            mut rt = f.ret_ty.read()
            if rt.name != "" and rt.name != "void" and rt.name != "None":
                s = s + " -> " + self.io_ty_str(rt)
        if f.throws_ty as usize != 0 as usize:
            if f.throws_ty.read().name != "":
                s = s + " throws " + self.io_ty_str(f.throws_ty.read())
        mut doc = self.io_doc_of(f.body)
        if doc != "":
            s = s + "\n        \"\"\"" + doc + "\"\"\""
        return s

    # Builds a Python help()-style description for a class/enum/interface/
    # function name, or a short note for builtin types. Used by inspect(T).
    pub def build_inspect_str(self, name: str) -> str:
        if self.classes.contains(name):
            mut c = self.classes.get(name)
            mut s = "class " + c.name
            if c.base_classes.len > 0:
                s = s + "(extends "
                mut bi = 0
                while bi < c.base_classes.len:
                    if bi > 0: s = s + ", "
                    s = s + c.base_classes.get(bi)
                    bi = bi + 1
                s = s + ")"
            s = s + ":\n"
            if c.fields.len > 0:
                s = s + "  fields:\n"
                mut fi = 0
                while fi < c.fields.len:
                    mut fld = c.fields.get(fi)
                    s = s + "    " + fld.name
                    if fld.ty as usize != 0 as usize:
                        s = s + ": " + self.io_ty_str(fld.ty.read())
                    s = s + "\n"
                    fi = fi + 1
            if c.methods.len > 0:
                s = s + "  methods:\n"
                mut mi = 0
                while mi < c.methods.len:
                    s = s + "    " + self.io_func_sig(c.methods.get(mi)) + "\n"
                    mi = mi + 1
            return s
        elif self.enums.contains(name):
            mut e = self.enums.get(name)
            mut s = "enum " + e.name + ":\n"
            if e.variants.len > 0:
                s = s + "  variants:\n"
                mut vi = 0
                while vi < e.variants.len:
                    mut v = e.variants.get(vi)
                    s = s + "    " + v.name
                    if v.fields.len > 0:
                        s = s + "("
                        mut vfi = 0
                        while vfi < v.fields.len:
                            if vfi > 0: s = s + ", "
                            mut vf = v.fields.get(vfi)
                            if vf.ty as usize != 0 as usize:
                                s = s + self.io_ty_str(vf.ty.read())
                            vfi = vfi + 1
                        s = s + ")"
                    s = s + "\n"
                    vi = vi + 1
            if e.methods.len > 0:
                s = s + "  methods:\n"
                mut mi = 0
                while mi < e.methods.len:
                    s = s + "    " + self.io_func_sig(e.methods.get(mi)) + "\n"
                    mi = mi + 1
            return s
        elif self.interfaces.contains(name):
            mut iface = self.interfaces.get(name)
            mut s = "interface " + iface.name + ":\n"
            if iface.methods.len > 0:
                s = s + "  methods:\n"
                mut mi = 0
                while mi < iface.methods.len:
                    s = s + "    " + self.io_func_sig(iface.methods.get(mi)) + "\n"
                    mi = mi + 1
            return s
        elif self.fn_defs.contains(name):
            return self.io_func_sig(self.fn_defs.get(name))
        elif name == "int":
            return "int: 64-bit signed integer (C long long)."
        elif name == "float":
            return "float: 64-bit floating point number (C double)."
        elif name == "bool":
            return "bool: true/false (C _Bool)."
        elif name == "str":
            return "str: immutable byte string (C char*)."
        elif name == "char":
            return "char: single byte character (C char)."
        elif name == "List":
            return "List[T]: growable, ordered, indexable sequence of T."
        elif name == "Dict":
            return "Dict[K, V]: hash map from K to V."
        elif name == "Set":
            return "Set[T]: unordered collection of unique T values."
        elif name == "Option":
            return "Option[T]: either Some(T) or None."
        elif name == "Result":
            return "Result[T, E]: either Ok(T) or Err(E)."
        elif name == "Pointer":
            return "Pointer[T]: raw pointer to a T (C T*); use unsafe: for arithmetic."
        else:
            return "No info available for '" + name + "'."

    pub def error(self, msg: str):
        mut loc = ""
        if self.current_file.len() > 0:
            loc = self.current_file + ":"
        if self.current_line > 0:
            self.errors.push(loc + str(self.current_line) + ": " + msg)
        else:
            self.errors.push(msg)

    # -- Thread-safety / Sendable checks --------------------------------------

    pub def is_sendable_type(self, ty_name: str) -> bool:
        if ty_name == "int" or ty_name == "float" or ty_name == "bool" or ty_name == "char" or ty_name == "str": return true
        if ty_name == "void" or ty_name == "" or ty_name == "auto" or ty_name == "usize" or ty_name == "isize": return true
        if ty_name == "Atomic" or ty_name == "Mutex" or ty_name == "RwLock": return true
        if ty_name == "Chan" or ty_name == "Channel" or ty_name == "ThreadPool": return true
        if ty_name == "Thread" or ty_name == "ThreadLocal": return true
        if ty_name == "Shared" or ty_name == "Weak": return true   # ref-counted pointers are Sendable
        # Known non-thread-safe collections
        if ty_name == "List" or ty_name == "Vec" or ty_name == "Dict" or ty_name == "Map": return false
        # User-defined class: allow if it implements Sendable
        if self.classes.contains(ty_name):
            mut cls = self.classes.get(ty_name)
            if not _is_invalid_ptr(cls.iface_names as usize):
                mut ii = 0
                while ii < cls.iface_names.len:
                    if cls.iface_names.get(ii) == "Sendable": return true
                    ii = ii + 1
            # User class without Sendable - hard error (strict mode)
            return false
        # Unknown type - conservative: assume not sendable
        return false

    # Recursively checks cls_name and its base classes for a method named `method`.
    pub def class_method_exists(self, cls_name: str, method: str) -> bool:
        if not self.classes.contains(cls_name): return false
        mut cls = self.classes.get(cls_name)
        mut mi = 0
        while mi < cls.methods.len:
            if cls.methods.get(mi).name == method: return true
            mi = mi + 1
        mut bi = 0
        while bi < cls.base_classes.len:
            if self.class_method_exists(cls.base_classes.get(bi), method): return true
            bi = bi + 1
        return false

    # Universal methods dispatched generically by codegen for any type
    # (conversions, dunders, container protocol) - never reported as missing.
    pub def is_universal_method(self, method: str) -> bool:
        if method == "init" or method == "new" or method == "free": return true
        if method == "to_str" or method == "to_string" or method == "as_str": return true
        if method == "len" or method == "length" or method == "__len__": return true
        if method == "clone" or method == "copy": return true
        if method == "__getitem__" or method == "get_index" or method == "__setitem__": return true
        if method == "__eq__" or method == "__ne__": return true
        if method == "__lt__" or method == "__gt__" or method == "__le__" or method == "__ge__": return true
        if method == "__add__" or method == "__sub__" or method == "__mul__" or method == "__div__" or method == "__mod__": return true
        if method == "__hash__" or method == "__iter__" or method == "__next__" or method == "__contains__": return true
        if method == "__str__" or method == "__repr__" or method == "__enter__" or method == "__exit__": return true
        return false

    pub def check_spawn_sendable(self, e: Pointer[HirExpr]):
        if _is_invalid_ptr(e as usize): return
        match e.read():
            case HirExpr.ECall(_, cs_args, _):
                mut csi = 0
                while csi < cs_args.len:
                    mut arg_ty = hir_expr_type(cs_args.get(csi))
                    if (arg_ty.name == "Shared" or arg_ty.name == "Weak") and arg_ty.args.len > 0:
                        mut inner_nm = arg_ty.args.get(0).read().name
                        if not self.is_sendable_type(inner_nm):
                            self.error("[T-1] 'Shared[" + inner_nm + "]' cannot safely cross thread boundaries because '" + inner_nm + "' is not Sendable.\n      FIX: Add 'implements Sendable' to '" + inner_nm + "' and ensure all mutable fields use Atomic[T] or Mutex[T].")
                    elif not self.is_sendable_type(arg_ty.name):
                        self.error("[T-1] Type '" + arg_ty.name + "' is not Sendable and cannot be safely shared across threads.\n      FIX: Wrap in Mutex[" + arg_ty.name + "] for exclusive access, or Atomic[T] for counters/flags.\n      Or add 'implements Sendable' to '" + arg_ty.name + "' to confirm it is thread-safe.")
                    csi = csi + 1
            case HirExpr.EMethodCall(_, _, cs_margs, _):
                mut csmi = 0
                while csmi < cs_margs.len:
                    mut arg_ty2 = hir_expr_type(cs_margs.get(csmi))
                    if (arg_ty2.name == "Shared" or arg_ty2.name == "Weak") and arg_ty2.args.len > 0:
                        mut inner_nm2 = arg_ty2.args.get(0).read().name
                        if not self.is_sendable_type(inner_nm2):
                            self.error("[T-1] 'Shared[" + inner_nm2 + "]' cannot safely cross thread boundaries because '" + inner_nm2 + "' is not Sendable.\n      FIX: Add 'implements Sendable' to '" + inner_nm2 + "' and protect mutable fields with Atomic[T] or Mutex[T].")
                    elif not self.is_sendable_type(arg_ty2.name):
                        self.error("[T-1] Type '" + arg_ty2.name + "' is not Sendable and cannot be safely shared across threads.\n      FIX: Wrap in Mutex[" + arg_ty2.name + "].")
                    csmi = csmi + 1
            case _: pass

    pub def check_class_sendable_fields(self, c: ClassDef):
        # Does the class carry the explicit unsafe-thread-safety assertion?
        # `implements Sendable, UnsafeSendable` is Tauraro's `unsafe impl Send`:
        # it lets a class hold a raw, opaque `Pointer` handle (whose contents the
        # compiler cannot reason about) while still crossing thread boundaries.
        # It is greppable and deliberate - not a silent blanket exemption.
        mut has_unsafe = false
        mut ui = 0
        while ui < c.iface_names.len:
            if c.iface_names.get(ui) == "UnsafeSendable": has_unsafe = true
            ui = ui + 1
        mut cfi = 0
        while cfi < c.fields.len:
            mut fd = c.fields.get(cfi)
            if fd.ty as usize != 0 as usize:
                mut fty = fd.ty.read()
                if fty.name == "Pointer":
                    # A raw Pointer field is only allowed in a Sendable class when
                    # the author has explicitly opted in via UnsafeSendable.
                    if not has_unsafe:
                        self.error("[T-2] Class '" + c.name + "' declares 'implements Sendable' but holds a raw 'Pointer' field '" + fd.name + "', which the compiler cannot prove thread-safe.\n      FIX: If '" + c.name + "' wraps an internally-synchronized handle, assert it explicitly: 'implements Sendable, UnsafeSendable'.\n      Otherwise wrap the data in Mutex[T]/Atomic[T], or drop 'implements Sendable'.")
                elif not self.is_sendable_type(fty.name):
                    self.error("[T-2] Class '" + c.name + "' declares 'implements Sendable' but field '" + fd.name + ": " + fty.name + "' is not Sendable.\n      FIX: Wrap '" + fd.name + "' in Mutex[" + fty.name + "] for exclusive access, RwLock[" + fty.name + "] for reader-writer, or Atomic[T] for numeric/flag types.\n      Or remove 'implements Sendable' if '" + c.name + "' is only used on one thread.")
                elif fty.name == "int" or fty.name == "float" or fty.name == "bool":
                    self.warnings.push("[T-3] Sendable class '" + c.name + "' has primitive field '" + fd.name + ": " + fty.name + "' that may cause data races if mutated from multiple threads.\n      FIX: Use 'Atomic[" + fty.name + "]' for safe concurrent mutation, or ensure this field is written only before the object is shared across threads.")
            cfi = cfi + 1

    # -- Phase 1-3: Ownership / borrow tracking -------------------------------

    pub def mark_moved(self, name: str):
        mut i = self.scopes.len - 1
        while i >= 0:
            if self.scopes.get(i).variables.contains(name):
                mut sym = self.scopes.get(i).variables.get(name)
                if not sym.is_moved:
                    sym.is_moved = true
                    self.scopes.get(i).variables.insert(name, sym)
                    if self.capturing_moves:
                        self.branch_moved_buf.push(name)
                return
            i = i - 1
        if self.globals.contains(name):
            mut sym = self.globals.get(name)
            if not sym.is_moved:
                sym.is_moved = true
                self.globals.insert(name, sym)
                if self.capturing_moves:
                    self.branch_moved_buf.push(name)

    pub def mark_freed(self, name: str):
        mut mf_i = self.scopes.len - 1
        while mf_i >= 0:
            if self.scopes.get(mf_i).variables.contains(name):
                mut mf_sym = self.scopes.get(mf_i).variables.get(name)
                mf_sym.is_freed = true
                mf_sym.is_moved = true
                self.scopes.get(mf_i).variables.insert(name, mf_sym)
                if self.capturing_moves:
                    self.branch_moved_buf.push(name)
                return
            mf_i = mf_i - 1
        if self.globals.contains(name):
            mut mf_sym = self.globals.get(name)
            mf_sym.is_freed = true
            mf_sym.is_moved = true
            self.globals.insert(name, mf_sym)
            if self.capturing_moves:
                self.branch_moved_buf.push(name)

    pub def check_not_moved(self, name: str, ty_name: str):
        if self.is_primitive_name(ty_name): return
        mut sym = self.resolve(name)
        if sym.name != "" and sym.is_moved:
            self.error("[M-1] '" + name + "' was moved and cannot be used again.\n      FIX: Use the variable that now owns it, or call .clone() to copy before moving.")

    pub def mark_borrow(self, name: str):
        mut i = self.scopes.len - 1
        while i >= 0:
            if self.scopes.get(i).variables.contains(name):
                mut sym = self.scopes.get(i).variables.get(name)
                sym.active_borrows = sym.active_borrows + 1
                self.scopes.get(i).variables.insert(name, sym)
                return
            i = i - 1
        if self.globals.contains(name):
            mut sym = self.globals.get(name)
            sym.active_borrows = sym.active_borrows + 1
            self.globals.insert(name, sym)

    pub def unmark_borrow(self, name: str):
        mut i = self.scopes.len - 1
        while i >= 0:
            if self.scopes.get(i).variables.contains(name):
                mut sym = self.scopes.get(i).variables.get(name)
                if sym.active_borrows > 0:
                    sym.active_borrows = sym.active_borrows - 1
                self.scopes.get(i).variables.insert(name, sym)
                return
            i = i - 1
        if self.globals.contains(name):
            mut sym = self.globals.get(name)
            if sym.active_borrows > 0:
                sym.active_borrows = sym.active_borrows - 1
            self.globals.insert(name, sym)

    pub def check_no_active_borrows(self, name: str, ty_name: str):
        if self.is_primitive_name(ty_name): return
        mut sym = self.resolve(name)
        if sym.name != "" and sym.active_borrows > 0:
            self.error("[M-2] Cannot move '" + name + "' while it is borrowed.\n      FIX: The borrow must end before '" + name + "' can be moved.")

    # Phase D: mark a variable as initialized (e.g. after assignment)
    pub def mark_init(self, name: str):
        mut mi_i = self.scopes.len - 1
        while mi_i >= 0:
            if self.scopes.get(mi_i).variables.contains(name):
                mut mi_sym = self.scopes.get(mi_i).variables.get(name)
                if not mi_sym.is_init:
                    # Track the transition uninit->init so we can roll it back per-branch
                    mi_sym.is_init = true
                    mi_sym.is_maybe_init = false
                    self.scopes.get(mi_i).variables.insert(name, mi_sym)
                    if self.capturing_inits:
                        self.branch_init_buf.push(name)
                return
            mi_i = mi_i - 1
        if self.globals.contains(name):
            mut mi_sym = self.globals.get(name)
            if not mi_sym.is_init:
                mi_sym.is_init = true
                mi_sym.is_maybe_init = false
                self.globals.insert(name, mi_sym)
                if self.capturing_inits:
                    self.branch_init_buf.push(name)

    # Phase C: remove any container borrow where var_name is the borrow key
    pub def clear_container_borrow(self, var_name: str):
        if self.container_borrows.contains(var_name):
            self.container_borrows.remove(var_name)

    # Fix 1: reverse of mark_moved - used to roll back per-branch move state
    pub def unmark_moved(self, name: str):
        mut i = self.scopes.len - 1
        while i >= 0:
            if self.scopes.get(i).variables.contains(name):
                mut sym = self.scopes.get(i).variables.get(name)
                sym.is_moved = false
                # A branch-local '.free()'/dealloc() also set is_freed; if this
                # branch's effects are being rolled back (the branch did not
                # uniformly take effect), is_freed must roll back too, or the
                # merged maybe-moved state would permanently and incorrectly
                # report [M-6] on later uses along paths that never freed it.
                sym.is_freed = false
                self.scopes.get(i).variables.insert(name, sym)
                return
            i = i - 1
        if self.globals.contains(name):
            mut sym = self.globals.get(name)
            sym.is_moved = false
            sym.is_freed = false
            self.globals.insert(name, sym)

    # Fix 1: mark as maybe-moved (moved in some branches, not all) - sticky warning flag
    pub def mark_maybe_moved(self, name: str):
        mut i = self.scopes.len - 1
        while i >= 0:
            if self.scopes.get(i).variables.contains(name):
                mut sym = self.scopes.get(i).variables.get(name)
                sym.is_maybe_moved = true
                self.scopes.get(i).variables.insert(name, sym)
                return
            i = i - 1
        if self.globals.contains(name):
            mut sym = self.globals.get(name)
            sym.is_maybe_moved = true
            self.globals.insert(name, sym)

    # Fix 4: reverse of mark_init - used to roll back per-branch init state
    pub def unmark_init(self, name: str):
        mut mi_i = self.scopes.len - 1
        while mi_i >= 0:
            if self.scopes.get(mi_i).variables.contains(name):
                mut mi_sym = self.scopes.get(mi_i).variables.get(name)
                mi_sym.is_init = false
                self.scopes.get(mi_i).variables.insert(name, mi_sym)
                return
            mi_i = mi_i - 1
        if self.globals.contains(name):
            mut mi_sym = self.globals.get(name)
            mi_sym.is_init = false
            self.globals.insert(name, mi_sym)

    # Fix 4: mark as maybe-init (init in some branches, not all)
    pub def mark_maybe_init(self, name: str):
        mut mi_i = self.scopes.len - 1
        while mi_i >= 0:
            if self.scopes.get(mi_i).variables.contains(name):
                mut mi_sym = self.scopes.get(mi_i).variables.get(name)
                mi_sym.is_maybe_init = true
                self.scopes.get(mi_i).variables.insert(name, mi_sym)
                return
            mi_i = mi_i - 1
        if self.globals.contains(name):
            mut mi_sym = self.globals.get(name)
            mi_sym.is_maybe_init = true
            self.globals.insert(name, mi_sym)

    # Fix 1/4: linear scan of a Vec[str] for membership (no built-in set)
    pub def vec_str_contains(self, v: Vec[str], s: str) -> bool:
        mut vi = 0
        while vi < v.len:
            if v.get(vi) == s: return true
            vi = vi + 1
        return false

    # Fix 3: lazy recursive check - classes with only primitive/copy fields are Copy
    # Inserts false as a sentinel to break self-referential cycles before recursing
    # True if a decorator list contains @copy (the explicit copy/share opt-in).
    pub def has_copy_decorator(self, decs: Vec[Decorator]) -> bool:
        mut i = 0
        while i < decs.len:
            if decs.get(i).name == "copy": return true
            i = i + 1
        return false

    pub def is_copy_class(self, name: str) -> bool:
        if self.is_primitive_name(name): return true
        if self.copy_classes.contains(name): return self.copy_classes.get(name)
        if not self.classes.contains(name): return false
        # Insert false sentinel to break cycles (self-referential structs are not Copy)
        self.copy_classes.insert(name, false)
        mut cls = self.classes.get(name)
        if cls.fields.len == 0: return false   # empty/opaque class - not Copy
        mut all_copy = true
        mut fi = 0
        while fi < cls.fields.len:
            mut fd = cls.fields.get(fi)
            if fd.ty as usize != 0 as usize:
                mut fty = fd.ty.read()
                if not self.is_copy_class(fty.name):
                    all_copy = false
            fi = fi + 1
        self.copy_classes.insert(name, all_copy)
        return all_copy

    pub def enter_scope(self):
        mut s_obj = Scope.init()
        self.scopes.push(s_obj)
        self.current_scope_depth = self.current_scope_depth + 1
        # auto-drop: each new scope starts its own C block, so reset the
        # nested-if/while block-depth counter; restored on exit_scope.
        self.block_depth_stack.push(self.block_depth)
        self.block_depth = 0
        self.block_stack_base.push(self.block_stack.len)

    pub def exit_scope(self):
        self.scopes.pop()
        self.current_scope_depth = self.current_scope_depth - 1
        self.block_depth = self.block_depth_stack.get(self.block_depth_stack.len - 1)
        self.block_depth_stack.pop()
        mut base = self.block_stack_base.get(self.block_stack_base.len - 1)
        while self.block_stack.len > base:
            self.block_stack.pop()
        self.block_stack_base.pop()

    # -- Auto-drop: compiler-inserted .free() for owned class-typed locals -----

    # True for element/key types whose List_<sfx>/Dict free function fully
    # releases the stored values (primitives, or `str` via List_TrStr_free /
    # Dict_free's strdup'd keys). Used to gate collection auto-drop to
    # specializations with a known-correct, fully-releasing free function.
    pub def _coll_elem_droppable(self, n: str) -> bool:
        if n == "str": return true
        if n == "int" or n == "float" or n == "bool" or n == "char": return true
        if n == "i8" or n == "i16" or n == "i32" or n == "i64": return true
        if n == "u8" or n == "u16" or n == "u32" or n == "u64" or n == "usize": return true
        if n == "f32" or n == "f64": return true
        return false

    # A local is auto-dropped at scope exit if it is a user-defined class with a
    # 'free' method, was never moved/returned/borrowed-out, was never freed
    # manually, and was definitely initialized on every path.
    pub def is_droppable_sym(self, sym: Symbol) -> bool:
        if sym.kind != SymbolKind.SVariable: return false
        if sym.is_param: return false
        if sym.is_shared: return false
        if sym.ty as usize == 0 as usize: return false
        mut tn = sym.ty.read().name
        # `str` locals get retain/release auto-drop, gated by the same
        # block-id "visible" check compute_scope_drops uses for class-typed
        # locals (sibling if/while branches are correctly disambiguated).
        # str_escaped (passed as a call/method-call argument - may be
        # shallow-aliased into a legacy List_str/Dict/Set, #52 not yet
        # migrated) is excluded to avoid use-after-free.
        if tn == "str":
            if sym.str_escaped: return false
            if sym.is_moved or sym.is_maybe_moved or sym.is_freed: return false
            if sym.active_borrows > 0: return false
            if not sym.is_init or sym.is_maybe_init: return false
            return true
        # List/Vec/Dict/Map/Set locals: raw unrefcounted heap pointers, so only
        # auto-drop when this local NEVER appears in a non-receiver position
        # (coll_escaped) - i.e. no other name can alias the same pointer - and
        # only for "POD" specializations where the runtime free function fully
        # releases all stored elements/keys/values (see _coll_elem_droppable).
        # Dict/Map[*, str] is excluded: boxed TrStr values aren't released by
        # Dict_free (#54, pre-existing gap, not made worse here).
        if tn == "List" or tn == "Vec" or tn == "Dict" or tn == "Map" or tn == "Set":
            if sym.coll_escaped: return false
            if sym.is_moved or sym.is_maybe_moved or sym.is_freed: return false
            if sym.active_borrows > 0: return false
            if not sym.is_init or sym.is_maybe_init: return false
            mut targs = sym.ty.read().args
            if tn == "Dict" or tn == "Map":
                if targs.len < 2: return false
                mut kt = targs.get(0).read().name
                mut vt = targs.get(1).read().name
                if not self._coll_elem_droppable(kt): return false
                # vt == "str": values are _tr_str_box(TrStr)-allocated; the
                # codegen-side Dict_free_strval/_tr_idict_free_strval (#54)
                # unbox+release each value, so this is safe.
                if not self._coll_elem_droppable(vt): return false
                return true
            else:
                if targs.len < 1: return false
                mut et = targs.get(0).read().name
                if not self._coll_elem_droppable(et): return false
                return true
        if not self.classes.contains(tn): return false
        if tn == "Vec" or tn == "Map" or tn == "List" or tn == "Dict" or tn == "Box" or tn == "Mutex" or tn == "RwLock" or tn == "Atomic" or tn == "Shared" or tn == "Option" or tn == "Result" or tn == "Chan": return false
        # StringBuilder/StringObj methods like as_str()/to_str() can return a
        # pointer that aliases the instance's own internal buffer; auto-freeing
        # the instance would dangle that alias. Require an explicit .free().
        if tn == "StringBuilder" or tn == "StringObj": return false
        if sym.is_moved or sym.is_maybe_moved or sym.is_freed: return false
        if sym.active_borrows > 0: return false
        if not sym.is_init or sym.is_maybe_init: return false
        mut cls = self.classes.get(tn)
        mut mi = 0
        while mi < cls.methods.len:
            if cls.methods.get(mi).name == "free": return true
            mi = mi + 1
        return false

    # Open a new if/while/etc body block, assigning it a fresh monotonic id.
    pub def open_block(self):
        self.next_block_id = self.next_block_id + 1
        self.block_stack.push(self.next_block_id)

    # Close the innermost currently-open if/while/etc body block.
    pub def close_block(self):
        self.block_stack.pop()

    # True if `id` is one of the currently-open if/while body blocks.
    pub def block_stack_contains(self, id: int) -> bool:
        mut i = 0
        while i < self.block_stack.len:
            if self.block_stack.get(i) == id: return true
            i = i + 1
        return false

    # All droppable locals declared directly in scope `scope_idx` whose declaration
    # block is still "open" (i.e. not inside an if/while body that has already
    # closed its C block), as SAutoDrop stmts. `is_innermost` is true only for the
    # current (innermost) scope, where `self.block_stack` reflects open blocks.
    pub def compute_scope_drops(self, scope_idx: int, is_innermost: bool) -> Vec[Pointer[HirStmt]]:
        mut out = Vec[Pointer[HirStmt]].init(2)
        if scope_idx < 0 or scope_idx >= self.scopes.len: return out
        mut scope = self.scopes.get(scope_idx)
        mut ki = 0
        while ki < scope.decl_order.len:
            mut nm = scope.decl_order.get(ki)
            mut sym = scope.variables.get(nm)
            mut visible = sym.decl_block_id == 0
            if not visible and is_innermost:
                visible = self.block_stack_contains(sym.decl_block_id)
            if visible:
                if self.is_droppable_sym(sym):
                    out.push(box_hirstmt(HirStmt.SAutoDrop(nm, sym.ty.read().name)))
            ki = ki + 1
        return out

    # Append SAutoDrop stmts to `hb` for every droppable local in scopes
    # [from_idx .. self.scopes.len-1], innermost scope first.
    pub def append_drops_from(self, hb: HirBlock, from_idx: int):
        self.append_drops_from_excl(hb, from_idx, "")

    # Same as append_drops_from, but skips a variable named `exclude` (used for
    # `return x` where x is itself the droppable local - ownership transfers to
    # the caller instead of being freed).
    pub def append_drops_from_excl(self, hb: HirBlock, from_idx: int, exclude: str):
        mut excl_list = Vec[str].init(1)
        if exclude != "": excl_list.push(exclude)
        self.append_drops_from_excl_multi(hb, from_idx, excl_list)

    # Same as append_drops_from_excl, but skips every name in `excludes` (used
    # for `return EXPR` where EXPR reads one or more droppable locals - those
    # locals must stay alive until the return value is computed, so they are
    # excluded from THIS exit point's auto-drops; ownership of any local
    # actually returned transfers to the caller, the rest simply leak on this
    # path rather than risk a use-after-free in the return expression).
    pub def append_drops_from_excl_multi(self, hb: HirBlock, from_idx: int, excludes: Vec[str]):
        mut idx = self.scopes.len - 1
        while idx >= from_idx:
            mut is_innermost = idx == self.scopes.len - 1
            mut drops = self.compute_scope_drops(idx, is_innermost)
            mut di = 0
            while di < drops.len:
                mut d = drops.get(di)
                mut skip = false
                match d.read():
                    case HirStmt.SAutoDrop(dn, _):
                        mut ei = 0
                        while ei < excludes.len:
                            if excludes.get(ei) == dn: skip = true
                            ei = ei + 1
                    case _: pass
                if not skip: hb.push(d)
                di = di + 1
            idx = idx - 1

    # Collect the names of every EIdent referenced anywhere inside `e` into
    # `out` (best-effort recursive walk over the common HirExpr shapes). Used
    # to find `str` locals that a `return EXPR` reads, so they aren't
    # auto-dropped before EXPR is evaluated.
    pub def collect_idents(self, e: Pointer[HirExpr], out: Vec[str]):
        if e as usize == 0 as usize: return
        if _is_invalid_ptr(e as usize): return
        match e.read():
            case HirExpr.EIdent(nm, _, _): out.push(nm)
            case HirExpr.EBinOp(_, l, r, _):
                self.collect_idents(l, out)
                self.collect_idents(r, out)
            case HirExpr.EUnaryOp(_, inner, _): self.collect_idents(inner, out)
            case HirExpr.ECall(callee, args, _):
                self.collect_idents(callee, out)
                mut i = 0
                while i < args.len:
                    self.collect_idents(args.get(i), out)
                    i = i + 1
            case HirExpr.EMethodCall(obj, _, args, _):
                self.collect_idents(obj, out)
                mut i = 0
                while i < args.len:
                    self.collect_idents(args.get(i), out)
                    i = i + 1
            case HirExpr.EPropAccess(obj, _, _): self.collect_idents(obj, out)
            case HirExpr.EIndex(obj, idx, _):
                self.collect_idents(obj, out)
                self.collect_idents(idx, out)
            case HirExpr.ECast(inner, _): self.collect_idents(inner, out)
            case HirExpr.ETryExpr(inner, _): self.collect_idents(inner, out)
            case HirExpr.EIfElse(c, t, f, _):
                self.collect_idents(c, out)
                self.collect_idents(t, out)
                self.collect_idents(f, out)
            case HirExpr.EList(items, _):
                mut i = 0
                while i < items.len:
                    self.collect_idents(items.get(i), out)
                    i = i + 1
            case HirExpr.ESet(items, _):
                mut i = 0
                while i < items.len:
                    self.collect_idents(items.get(i), out)
                    i = i + 1
            case HirExpr.ETuple(items, _):
                mut i = 0
                while i < items.len:
                    self.collect_idents(items.get(i), out)
                    i = i + 1
            case HirExpr.EDict(keys, vals, _):
                mut i = 0
                while i < keys.len:
                    self.collect_idents(keys.get(i), out)
                    self.collect_idents(vals.get(i), out)
                    i = i + 1
            case HirExpr.ERange(s, en, _, _):
                self.collect_idents(s, out)
                self.collect_idents(en, out)
            case HirExpr.EAwait(inner, _): self.collect_idents(inner, out)
            case HirExpr.EAwaitTimeout(inner, to, _):
                self.collect_idents(inner, out)
                self.collect_idents(to, out)
            case HirExpr.EYield(inner, _): self.collect_idents(inner, out)
            case _: pass

    # True if `name` is a declared local/param variable in any open scope.
    pub def is_local_var(self, name: str) -> bool:
        mut i = self.scopes.len - 1
        while i >= 0:
            if self.scopes.get(i).variables.contains(name): return true
            i = i - 1
        return false

    pub def mark_str_escaped(self, name: str):
        mut i = self.scopes.len - 1
        while i >= 0:
            if self.scopes.get(i).variables.contains(name):
                mut sym = self.scopes.get(i).variables.get(name)
                sym.str_escaped = true
                self.scopes.get(i).variables.insert(name, sym)
                return
            i = i - 1

    # If `e` is a bare `str`-typed identifier, mark its symbol as escaped (it
    # is being passed as a call/method-call ARGUMENT, so a copy of it may be
    # stored - shallow-aliased - inside a legacy List_str/Dict/Set element,
    # which doesn't retain; #52 not yet migrated). Excluding it from auto-drop
    # turns a potential use-after-free into a leak.
    pub def mark_str_arg(self, e: Pointer[HirExpr]):
        if e as usize == 0 as usize: return
        if _is_invalid_ptr(e as usize): return
        match e.read():
            case HirExpr.EIdent(nm, _, _):
                if hir_expr_type(e).name == "str": self.mark_str_escaped(nm)
            case _: pass

    # Recursively scan a lowered expression for ECall/EMethodCall argument
    # lists and mark any bare `str` identifier arguments as escaped.
    pub def mark_escaped_str_args(self, e: Pointer[HirExpr]):
        if e as usize == 0 as usize: return
        if _is_invalid_ptr(e as usize): return
        match e.read():
            case HirExpr.EBinOp(_, l, r, _):
                self.mark_escaped_str_args(l)
                self.mark_escaped_str_args(r)
            case HirExpr.EUnaryOp(_, inner, _): self.mark_escaped_str_args(inner)
            case HirExpr.ECall(callee, args, _):
                self.mark_escaped_str_args(callee)
                # Only class-constructor calls risk storing a str arg into a
                # struct field with extended lifetime (no retain). Plain
                # function/static-method calls (e.g. all of Str.*/Fmt.*) only
                # read their `str` params (params are never auto-dropped, see
                # is_droppable_sym's is_param check) - the caller keeps sole
                # ownership and remains safe to auto-drop at scope exit.
                mut _call_is_ctor = false
                mut _call_is_c_free = false
                match callee.read():
                    case HirExpr.EIdent(_cnm, _, _):
                        if self.classes.contains(_cnm): _call_is_ctor = true
                        if _cnm == "_tr_c_free": _call_is_c_free = true
                    case _: pass
                mut i = 0
                while i < args.len:
                    if _call_is_ctor: self.mark_str_arg(args.get(i))
                    if _call_is_c_free:
                        # `unsafe: _tr_c_free(x as Pointer[char])` manually frees
                        # x's underlying TrStr.data - the std-lib idiom for
                        # releasing strings returned by Str.slice/to_lower/
                        # to_owned/etc, predating #53's auto-drop. If `x` is a
                        # bare str-typed local, mark it escaped so #53 doesn't
                        # ALSO insert a scope-exit _tr_str_release(x), which
                        # would double-free x.data (and x.rc).
                        match args.get(i).read():
                            case HirExpr.ECast(_cf_inner, _):
                                self.mark_str_arg(_cf_inner)
                            case _: pass
                    self.mark_escaped_str_args(args.get(i))
                    i = i + 1
            case HirExpr.EMethodCall(obj, mname, args, _):
                self.mark_escaped_str_args(obj)
                # Since #52 (List_TrStr migration), pushing a str into
                # List[str]/Vec[str] (append/push/extend/set/insert),
                # Set[str].add(), or using a str as a Dict/Map key
                # (insert/set arg 0) all retain-on-insert (List_TrStr_append,
                # _tr_dict_set's strdup), so the str local does NOT alias the
                # collection's storage - safe to keep eligible for auto-drop.
                # As of Phase 5 (Tier2b), Dict/Map VALUE args (arg 1) also
                # retain-on-box (dict_val_arg -> _tr_str_box(_tr_str_retain)),
                # so they too are safe to leave eligible for auto-drop.
                mut obj_ty = hir_expr_type(obj)
                # Static-method call on a class name (e.g. `Str.to_upper(s)`,
                # `Fmt.int_to_str(n)`): `obj` is the class identifier itself,
                # not an instance, so there is no `self` to stash the arg
                # into a field - same reasoning as the ECall non-constructor
                # case above, safe to leave args eligible for auto-drop.
                mut _is_static_call = false
                match obj.read():
                    case HirExpr.EIdent(_ocnm, _, _):
                        if self.classes.contains(_ocnm) and not self.is_local_var(_ocnm): _is_static_call = true
                    case _: pass
                mut i = 0
                while i < args.len:
                    mut skip_mark = _is_static_call
                    if obj_ty.name == "List" or obj_ty.name == "Vec":
                        if mname == "append" or mname == "push" or mname == "extend" or mname == "set" or mname == "insert":
                            skip_mark = true
                    elif obj_ty.name == "Set":
                        if mname == "add" or mname == "contains" or mname == "remove":
                            skip_mark = true
                    elif obj_ty.name == "Map" or obj_ty.name == "Dict":
                        # Both key (i==0, strdup'd) and value (i==1, boxed
                        # with retain) take independent references on insert/
                        # set, so neither aliases the caller's local.
                        if (mname == "insert" or mname == "set") and (i == 0 or i == 1):
                            skip_mark = true
                        # get/get_or/contains/remove/pop only look up the key
                        # (i==0) - never store it - so the caller's local
                        # remains sole owner and stays auto-drop eligible.
                        elif (mname == "get" or mname == "get_or" or mname == "contains" or mname == "remove" or mname == "pop") and i == 0:
                            skip_mark = true
                    if not skip_mark:
                        self.mark_str_arg(args.get(i))
                    self.mark_escaped_str_args(args.get(i))
                    i = i + 1
            case HirExpr.EPropAccess(obj, _, _): self.mark_escaped_str_args(obj)
            case HirExpr.EIndex(obj, idx, _):
                self.mark_escaped_str_args(obj)
                self.mark_escaped_str_args(idx)
            case HirExpr.ECast(inner, _): self.mark_escaped_str_args(inner)
            case HirExpr.ETryExpr(inner, _): self.mark_escaped_str_args(inner)
            case HirExpr.EIfElse(c, t, f, _):
                self.mark_escaped_str_args(c)
                self.mark_escaped_str_args(t)
                self.mark_escaped_str_args(f)
            case HirExpr.EList(items, _):
                mut i = 0
                while i < items.len:
                    self.mark_escaped_str_args(items.get(i))
                    i = i + 1
            case HirExpr.ESet(items, _):
                mut i = 0
                while i < items.len:
                    self.mark_escaped_str_args(items.get(i))
                    i = i + 1
            case HirExpr.ETuple(items, _):
                mut i = 0
                while i < items.len:
                    self.mark_escaped_str_args(items.get(i))
                    i = i + 1
            case HirExpr.EDict(keys, vals, _):
                mut i = 0
                while i < keys.len:
                    self.mark_escaped_str_args(keys.get(i))
                    self.mark_escaped_str_args(vals.get(i))
                    i = i + 1
            case HirExpr.ERange(s, en, _, _):
                self.mark_escaped_str_args(s)
                self.mark_escaped_str_args(en)
            case HirExpr.EAwait(inner, _): self.mark_escaped_str_args(inner)
            case HirExpr.EAwaitTimeout(inner, to, _):
                self.mark_escaped_str_args(inner)
                self.mark_escaped_str_args(to)
            case HirExpr.EYield(inner, _): self.mark_escaped_str_args(inner)
            # f-string interpolations only read/format their operands (no
            # storage), so just recurse for nested escapes.
            case HirExpr.EFString(parts, _):
                mut i = 0
                while i < parts.len:
                    mut part = parts.get(i)
                    if part.is_expr: self.mark_escaped_str_args(part.expr)
                    i = i + 1
            # A closure capturing a `str` local holds a reference that may
            # outlive the enclosing scope (the closure itself may be stored
            # or returned), so captured str locals are excluded from
            # auto-drop. The closure body's own statements are independently
            # walked by lower_block when the body is lowered.
            case HirExpr.EClosure(_, _, _, _, captures):
                mut i = 0
                while i < captures.len:
                    mut cap = captures.get(i)
                    if cap.ty.name == "str": self.mark_str_escaped(cap.name)
                    i = i + 1
            # `super.method(args)` may stash a str arg into a base-class
            # field, same reasoning as constructor calls in ECall.
            case HirExpr.ESuperMethodCall(_, _, args, _):
                mut i = 0
                while i < args.len:
                    self.mark_str_arg(args.get(i))
                    self.mark_escaped_str_args(args.get(i))
                    i = i + 1
            case HirExpr.ESuperPropAccess(_, _, _): pass
            # The comprehension element may be a bare str identifier stored
            # into the resulting List[str]/Set[str] - mark it escaped, same
            # as EList items. Source/filter exprs are only read.
            case HirExpr.EListComp(element, generators, _):
                self.mark_str_arg(element)
                self.mark_escaped_str_args(element)
                mut i = 0
                while i < generators.len:
                    mut gen = generators.get(i).read()
                    self.mark_escaped_str_args(gen.iter)
                    mut j = 0
                    while j < gen.ifs.len:
                        self.mark_escaped_str_args(gen.ifs.get(j))
                        j = j + 1
                    i = i + 1
            case HirExpr.EGeneratorExpr(element, generators, _):
                self.mark_str_arg(element)
                self.mark_escaped_str_args(element)
                mut i = 0
                while i < generators.len:
                    mut gen = generators.get(i).read()
                    self.mark_escaped_str_args(gen.iter)
                    mut j = 0
                    while j < gen.ifs.len:
                        self.mark_escaped_str_args(gen.ifs.get(j))
                        j = j + 1
                    i = i + 1
            case HirExpr.ESlice(start, stop, step, _):
                self.mark_escaped_str_args(start)
                self.mark_escaped_str_args(stop)
                self.mark_escaped_str_args(step)
            # ETry's try/catch/finally blocks are walked statement-by-statement
            # by lower_block when each block is lowered, so no recursion is
            # needed here.
            case HirExpr.ETry(_, _, _, _): pass
            # Leaf/literal variants - nothing to recurse into or mark.
            case HirExpr.ELitInt(_, _): pass
            case HirExpr.ELitFloat(_, _): pass
            case HirExpr.ELitStr(_, _): pass
            case HirExpr.ELitBytes(_, _): pass
            case HirExpr.ERawStr(_, _): pass
            case HirExpr.ELitChar(_, _): pass
            case HirExpr.ELitBool(_, _): pass
            case HirExpr.ELitNone(_): pass
            case HirExpr.ESizeOf(_, _): pass
            case HirExpr.EIdent(_, _, _): pass

    pub def mark_coll_escaped(self, name: str):
        mut i = self.scopes.len - 1
        while i >= 0:
            if self.scopes.get(i).variables.contains(name):
                mut sym = self.scopes.get(i).variables.get(name)
                sym.coll_escaped = true
                self.scopes.get(i).variables.insert(name, sym)
                return
            i = i - 1

    # If `e` is a bare List/Vec/Dict/Map/Set-typed identifier, mark its symbol
    # as escaped: it is being read in a non-receiver position (call/method
    # arg, assignment/let RHS, return value, literal element), so another
    # name may now hold/alias the same raw pointer. Auto-freeing it would
    # risk a use-after-free or double-free, so it's excluded from auto-drop
    # entirely (becomes a leak instead, same trade-off as str_escaped).
    pub def mark_coll_arg(self, e: Pointer[HirExpr]):
        if e as usize == 0 as usize: return
        if _is_invalid_ptr(e as usize): return
        match e.read():
            case HirExpr.EIdent(nm, _, _):
                mut tn = hir_expr_type(e).name
                if tn == "List" or tn == "Vec" or tn == "Dict" or tn == "Map" or tn == "Set": self.mark_coll_escaped(nm)
            case _: pass

    # Recursively scan a lowered expression for any bare List/Vec/Dict/Map/Set
    # identifier appearing in a non-receiver position and mark it escaped.
    # Unlike mark_escaped_str_args, there are NO retain-on-insert exceptions:
    # collections are raw unrefcounted pointers, so passing one as an argument
    # (even append/insert) may store/capture the pointer itself.
    pub def mark_escaped_coll_args(self, e: Pointer[HirExpr]):
        if e as usize == 0 as usize: return
        if _is_invalid_ptr(e as usize): return
        match e.read():
            case HirExpr.EBinOp(_, l, r, _):
                self.mark_coll_arg(l)
                self.mark_escaped_coll_args(l)
                self.mark_coll_arg(r)
                self.mark_escaped_coll_args(r)
            case HirExpr.EUnaryOp(_, inner, _):
                self.mark_coll_arg(inner)
                self.mark_escaped_coll_args(inner)
            case HirExpr.ECall(callee, args, _):
                self.mark_escaped_coll_args(callee)
                mut i = 0
                while i < args.len:
                    self.mark_coll_arg(args.get(i))
                    self.mark_escaped_coll_args(args.get(i))
                    i = i + 1
            case HirExpr.EMethodCall(obj, method, args, _):
                # `obj` is the receiver (e.g. `l.append(...)`) - reading it to
                # invoke a method on it doesn't alias the pointer elsewhere,
                # so it is NOT marked here (only recursed into, for nested
                # exprs). Every argument, however, IS marked.
                #
                # EXCEPTION (#54): for Dict[K,str]/Map[K,str], .get()/.get_or()/
                # .values()/.items() return TrStr(s) via _tr_str_unbox() that
                # SHARE the refcount/data pointer with the boxed value still
                # stored in the dict (non-destructive unbox, no retain). If the
                # dict were auto-dropped (Dict_free_strval/_tr_idict_free_strval
                # releases each boxed value), and the unboxed TrStr also gets
                # released via its own str-local auto-drop, that's a double
                # release. So reading a str value out of such a dict marks the
                # dict itself escaped (leak instead of double-free).
                if method == "get" or method == "get_or" or method == "values" or method == "items":
                    match obj.read():
                        case HirExpr.EIdent(_, _, _):
                            mut obj_ty = hir_expr_type(obj)
                            if obj_ty.name == "Dict" or obj_ty.name == "Map":
                                if obj_ty.args.len > 1:
                                    mut obj_vt = obj_ty.args.get(1).read().name
                                    if obj_vt == "str" or obj_vt == "String":
                                        self.mark_coll_arg(obj)
                        case _: pass
                # Static-method call on a class name (e.g. `Str.join(parts, sep)`):
                # `obj` is the class identifier itself, not an instance, so the
                # callee has no `self` to stash a List/Vec/Dict/Map/Set argument
                # into - it can only read from it (e.g. _tr_trstr_join memcpy's
                # each element's bytes out). Safe to leave such args eligible
                # for auto-drop, same reasoning as the str_escaped exception
                # for static calls above.
                mut _coll_static_call = false
                match obj.read():
                    case HirExpr.EIdent(_ocnm2, _, _):
                        if self.classes.contains(_ocnm2) and not self.is_local_var(_ocnm2): _coll_static_call = true
                    case _: pass
                self.mark_escaped_coll_args(obj)
                mut i = 0
                while i < args.len:
                    if not _coll_static_call: self.mark_coll_arg(args.get(i))
                    self.mark_escaped_coll_args(args.get(i))
                    i = i + 1
            case HirExpr.EPropAccess(obj, _, _): self.mark_escaped_coll_args(obj)
            case HirExpr.EIndex(obj, idx, _):
                self.mark_escaped_coll_args(obj)
                self.mark_coll_arg(idx)
                self.mark_escaped_coll_args(idx)
            case HirExpr.ECast(inner, _):
                self.mark_coll_arg(inner)
                self.mark_escaped_coll_args(inner)
            case HirExpr.ETryExpr(inner, _):
                self.mark_coll_arg(inner)
                self.mark_escaped_coll_args(inner)
            case HirExpr.EIfElse(c, t, f, _):
                self.mark_escaped_coll_args(c)
                self.mark_coll_arg(t)
                self.mark_escaped_coll_args(t)
                self.mark_coll_arg(f)
                self.mark_escaped_coll_args(f)
            case HirExpr.EList(items, _):
                mut i = 0
                while i < items.len:
                    self.mark_coll_arg(items.get(i))
                    self.mark_escaped_coll_args(items.get(i))
                    i = i + 1
            case HirExpr.ESet(items, _):
                mut i = 0
                while i < items.len:
                    self.mark_coll_arg(items.get(i))
                    self.mark_escaped_coll_args(items.get(i))
                    i = i + 1
            case HirExpr.ETuple(items, _):
                mut i = 0
                while i < items.len:
                    self.mark_coll_arg(items.get(i))
                    self.mark_escaped_coll_args(items.get(i))
                    i = i + 1
            case HirExpr.EDict(keys, vals, _):
                mut i = 0
                while i < keys.len:
                    self.mark_coll_arg(keys.get(i))
                    self.mark_escaped_coll_args(keys.get(i))
                    self.mark_coll_arg(vals.get(i))
                    self.mark_escaped_coll_args(vals.get(i))
                    i = i + 1
            case HirExpr.ERange(s, en, _, _):
                self.mark_escaped_coll_args(s)
                self.mark_escaped_coll_args(en)
            case HirExpr.EAwait(inner, _):
                self.mark_coll_arg(inner)
                self.mark_escaped_coll_args(inner)
            case HirExpr.EAwaitTimeout(inner, to, _):
                self.mark_coll_arg(inner)
                self.mark_escaped_coll_args(inner)
                self.mark_escaped_coll_args(to)
            case HirExpr.EYield(inner, _):
                self.mark_coll_arg(inner)
                self.mark_escaped_coll_args(inner)
            # f-string interpolations only read/format their operands (no
            # storage of the collection pointer itself), so just recurse.
            case HirExpr.EFString(parts, _):
                mut i = 0
                while i < parts.len:
                    mut part = parts.get(i)
                    if part.is_expr: self.mark_escaped_coll_args(part.expr)
                    i = i + 1
            # A closure capturing a List/Vec/Dict/Map/Set local holds an
            # aliasing reference that may outlive the enclosing scope, so
            # the captured collection is excluded from auto-drop. The
            # closure body's own statements are independently walked by
            # lower_block when the body is lowered.
            case HirExpr.EClosure(_, _, _, _, captures):
                mut i = 0
                while i < captures.len:
                    mut cap = captures.get(i)
                    mut ctn = cap.ty.name
                    if ctn == "List" or ctn == "Vec" or ctn == "Dict" or ctn == "Map" or ctn == "Set":
                        self.mark_coll_escaped(cap.name)
                    i = i + 1
            # `super.method(args)` may stash a collection arg into a
            # base-class field, same reasoning as ECall args.
            case HirExpr.ESuperMethodCall(_, _, args, _):
                mut i = 0
                while i < args.len:
                    self.mark_coll_arg(args.get(i))
                    self.mark_escaped_coll_args(args.get(i))
                    i = i + 1
            case HirExpr.ESuperPropAccess(_, _, _): pass
            # The comprehension element may be a bare List/Dict/etc.
            # identifier stored into the resulting collection - mark it
            # escaped, same as EList items. Source/filter exprs are only
            # iterated/read.
            case HirExpr.EListComp(element, generators, _):
                self.mark_coll_arg(element)
                self.mark_escaped_coll_args(element)
                mut i = 0
                while i < generators.len:
                    mut gen = generators.get(i).read()
                    self.mark_escaped_coll_args(gen.iter)
                    mut j = 0
                    while j < gen.ifs.len:
                        self.mark_escaped_coll_args(gen.ifs.get(j))
                        j = j + 1
                    i = i + 1
            case HirExpr.EGeneratorExpr(element, generators, _):
                self.mark_coll_arg(element)
                self.mark_escaped_coll_args(element)
                mut i = 0
                while i < generators.len:
                    mut gen = generators.get(i).read()
                    self.mark_escaped_coll_args(gen.iter)
                    mut j = 0
                    while j < gen.ifs.len:
                        self.mark_escaped_coll_args(gen.ifs.get(j))
                        j = j + 1
                    i = i + 1
            case HirExpr.ESlice(start, stop, step, _):
                self.mark_coll_arg(start)
                self.mark_escaped_coll_args(start)
                self.mark_coll_arg(stop)
                self.mark_escaped_coll_args(stop)
                self.mark_coll_arg(step)
                self.mark_escaped_coll_args(step)
            # ETry's try/catch/finally blocks are walked statement-by-statement
            # by lower_block when each block is lowered, so no recursion is
            # needed here.
            case HirExpr.ETry(_, _, _, _): pass
            # Leaf/literal variants - nothing to recurse into or mark.
            case HirExpr.ELitInt(_, _): pass
            case HirExpr.ELitFloat(_, _): pass
            case HirExpr.ELitStr(_, _): pass
            case HirExpr.ELitBytes(_, _): pass
            case HirExpr.ERawStr(_, _): pass
            case HirExpr.ELitChar(_, _): pass
            case HirExpr.ELitBool(_, _): pass
            case HirExpr.ELitNone(_): pass
            case HirExpr.ESizeOf(_, _): pass
            case HirExpr.EIdent(_, _, _): pass

    # True if `b`'s last statement already transfers control (return/break/continue),
    # meaning any needed auto-drops were already injected by lower_block at that point.
    pub def block_ends_in_jump(self, b: HirBlock) -> bool:
        if b.stmts.len == 0: return false
        mut last = b.stmts.get(b.stmts.len - 1)
        if last as usize == 0 as usize: return false
        match last.read():
            case HirStmt.SReturn(_): return true
            case HirStmt.SBreak: return true
            case HirStmt.SContinue: return true
            case _: return false

    # Append SAutoDrop stmts to `hb` for droppable locals of the current
    # (innermost) scope that were declared directly inside the if/while body
    # block `block_id` (e.g. a `mut s = ...` re-declared each loop iteration
    # in an SWhile body that shares its enclosing scope). Skipped if `hb`
    # already ends in a jump (return/break/continue already drained drops).
    pub def append_block_local_drops(self, hb: HirBlock, block_id: int):
        if self.block_ends_in_jump(hb): return
        if self.scopes.len == 0: return
        mut scope = self.scopes.get(self.scopes.len - 1)
        mut ki = 0
        while ki < scope.decl_order.len:
            mut nm = scope.decl_order.get(ki)
            mut sym = scope.variables.get(nm)
            if sym.decl_block_id == block_id and self.is_droppable_sym(sym):
                hb.push(box_hirstmt(HirStmt.SAutoDrop(nm, sym.ty.read().name)))
            ki = ki + 1

    # Append end-of-scope drops for the current top scope to `hb`, unless its
    # last statement already jumped out (and thus already drained this scope).
    pub def finalize_scope_drops(self, hb: HirBlock):
        if not self.block_ends_in_jump(hb):
            self.append_drops_from(hb, self.scopes.len - 1)

    pub def declare(self, name: str, kind: SymbolKind, ty: Pointer[AstType], is_mut: bool):
        # Rule N-1: Reserved name protection (skip 'self', internal '_*' names, short generics)
        if name != "self" and name != "_" and _tr_strlen(name) > 1:
            mut cat = self.is_reserved_error(name)
            if cat != "":
                self.error("[N-1] '" + name + "' is a " + cat + " and cannot be used as a name. Choose a different name (e.g. 'my_" + name + "').")
            else:
                # Class members (fields and methods) are exempt - names are scoped to the class.
                # Local variables (SVariable) are also exempt - local shadowing is intentional.
                # Only top-level function/type declarations are checked.
                mut is_toplevel_decl = self.current_class_name == "" and kind != SymbolKind.SVariable
                if is_toplevel_decl:
                    mut kcat = self.is_reserved_keyword(name)
                    if kcat != "":
                        self.error("[N-1] '" + name + "' is a " + kcat + " and is reserved. Choose a different name (e.g. 'my_" + name + "').")
        mut sym = Symbol.init(name, kind, ty)
        sym.scope_depth = self.current_scope_depth
        sym.is_mut = is_mut
        sym.decl_block_depth = self.block_depth
        mut bsbase = 0
        if self.block_stack_base.len > 0: bsbase = self.block_stack_base.get(self.block_stack_base.len - 1)
        if self.block_stack.len > bsbase:
            sym.decl_block_id = self.block_stack.get(self.block_stack.len - 1)
        else:
            sym.decl_block_id = 0

        if self.scopes.len > 0:
            mut decl_scope = self.scopes.get(self.scopes.len - 1)
            if not decl_scope.variables.contains(name): decl_scope.decl_order.push(name)
            decl_scope.variables.insert(name, sym)
        else:
            self.globals.insert(name, sym)

    pub def resolve(self, name: str) -> Symbol:
        mut i = self.scopes.len - 1
        while i >= 0:
            mut scope = self.scopes.get(i)
            if scope.variables.contains(name):
                return scope.variables.get(name)
            i = i - 1

        if self.globals.contains(name):
            return self.globals.get(name)

        return Symbol.init("", SymbolKind.SVariable, box_asttype(AstType.init("void")))

    pub def analyze(self, prog: Program) -> HirProgram:
        mut hp = HirProgram.init()

        # Pre-register every class/actor name so `extend T:` blocks attach their
        # methods regardless of declaration/import order. Without this, an
        # `extend T` processed before T's own `class T` decl (e.g. T lives in a
        # module the entry file imports *after* the extending module) silently
        # drops its methods, because register_decl only attaches when
        # self.classes already contains the target. Inserting the same ClassDef
        # objects up front makes attachment order-independent.
        mut ppi = 0
        while ppi < prog.decls.len:
            match prog.decls.get(ppi).read():
                case Decl.DClass(c):
                    if not self.classes.contains(c.name): self.classes.insert(c.name, c)
                case Decl.DActor(c):
                    if not self.classes.contains(c.name): self.classes.insert(c.name, c)
                case _: pass
            ppi = ppi + 1

        mut i = 0
        while i < prog.decls.len:
            self.register_decl(prog.decls.get(i))
            i = i + 1

        i = 0
        while i < prog.decls.len:
            mut d = prog.decls.get(i)
            match d.read():
                case Decl.DFunction(f):
                    hp.functions.push(self.lower_func(f))
                case Decl.DClass(c):
                    hp.classes.push(self.lower_class(c))
                case Decl.DActor(c):
                    hp.classes.push(self.lower_class(c))
                case Decl.DEnum(e):
                    hp.enums.push(self.lower_enum(e))
                case Decl.DInterface(i_def):
                    hp.interfaces.push(self.lower_interface(i_def))
                case Decl.DExtend(target, methods):
                    self.current_class_name = target
                    mut hi = 0
                    while hi < methods.len:
                        mut f = methods.get(hi)
                        hp.functions.push(self.lower_func(f))
                        hi = hi + 1
                    self.current_class_name = ""
                case Decl.DTopLevelStmt(s):
                    hp.top_level_stmts.push(self.lower_stmt(s))
                case Decl.DExtern(_, functions):
                    mut ei = 0
                    while ei < functions.len:
                        mut ef = functions.get(ei)
                        mut hef = self.lower_func(ef)
                        hef.is_extern = true
                        hp.extern_funcs.push(hef)
                        ei = ei + 1
                case Decl.DDecoratorDef(f):
                    mut hdf = self.lower_func(f)
                    hdf.is_decorator = true
                    hp.decorator_defs.push(hdf)
                case Decl.DTypeAlias(alias_name, target_ty):
                    # Emit type alias info into HirProgram so codegen can emit a typedef.
                    hp.type_alias_names.push(alias_name)
                    mut ta_ty_ptr = box_asttype(AstType.init("void"))
                    if target_ty as usize != 0 as usize: ta_ty_ptr = target_ty
                    hp.type_alias_types.push(ta_ty_ptr)
                case _: pass
            i = i + 1

        # Hoist nested declarations (class/def/enum/interface inside main()) to
        # file scope so codegen emits them as ordinary top-level definitions.
        mut nci = 0
        while nci < self.nested_classes.len:
            hp.classes.push(self.nested_classes.get(nci))
            nci = nci + 1
        mut nfi = 0
        while nfi < self.nested_functions.len:
            hp.functions.push(self.nested_functions.get(nfi))
            nfi = nfi + 1
        mut nei = 0
        while nei < self.nested_enums.len:
            hp.enums.push(self.nested_enums.get(nei))
            nei = nei + 1
        mut nii = 0
        while nii < self.nested_interfaces.len:
            hp.interfaces.push(self.nested_interfaces.get(nii))
            nii = nii + 1
        return hp

    pub def register_decl(self, d: Pointer[Decl]):
        match d.read():
            case Decl.DFunction(f):
                mut _f_ret = box_asttype(AstType.init("void"))
                if f.ret_ty as usize != 0 as usize: _f_ret = f.ret_ty
                # A 'throws' function's call-site type is Result[V, Err], so that
                # `mut r = throwing_fn(...)` infers `r: Result[V, Err]` and
                # r.is_ok / r.unwrap() / r.unwrap_err() dispatch correctly.
                mut _decl_ret = _f_ret
                if f.throws_ty as usize != 0 as usize:
                    if f.throws_ty.read().name != "":
                        mut _result_ty = AstType.init("Result")
                        _result_ty.args.push(_f_ret)
                        _result_ty.args.push(f.throws_ty)
                        _decl_ret = box_asttype(_result_ty)
                self.declare(f.name, SymbolKind.SFunction, _decl_ret, false)
                # Record the full signature so the function can be used as a
                # first-class value (def(...)->R): EIdent yields this type, and
                # calling such a value recovers the return type (last arg).
                mut _fnty = AstType.init("def")
                mut _pi = 0
                while _pi < f.params.len:
                    _fnty.args.push(f.params.get(_pi).ty)
                    _pi = _pi + 1
                _fnty.args.push(_f_ret)
                self.fn_sigs.insert(f.name, _fnty)
                self.fn_defs.insert(f.name, f)
                # #14: trailing variadic param `def f(args...)` / `def f(args: T...)`
                # collects trailing call args into a List[T] literal at call sites.
                if f.params.len > 0:
                    mut _vp = f.params.get(f.params.len - 1)
                    if _vp.is_variadic:
                        mut _velem_ty = AstType.init("int")
                        if _vp.ty as usize != 0 as usize: _velem_ty = _vp.ty.read()
                        self.variadic_fns.insert(f.name, (f.params.len - 1).to_str())
                        self.variadic_elem_ty.insert(f.name, box_asttype(_velem_ty))
            case Decl.DClass(c):
                self.declare(c.name, SymbolKind.SClass, box_asttype(AstType.init(c.name)), false)
                self.classes.insert(c.name, c)
                # @copy opt-in: treat as a freely-shareable value (exempt from move tracking)
                if self.has_copy_decorator(c.decorators): self.copy_classes.insert(c.name, true)
            case Decl.DActor(c):
                self.declare(c.name, SymbolKind.SClass, box_asttype(AstType.init(c.name)), false)
                self.classes.insert(c.name, c)
                if self.has_copy_decorator(c.decorators): self.copy_classes.insert(c.name, true)
            case Decl.DEnum(e):
                self.declare(e.name, SymbolKind.SEnum, box_asttype(AstType.init(e.name)), false)
                self.enums.insert(e.name, e)
                if self.has_copy_decorator(e.decorators): self.copy_classes.insert(e.name, true)
            case Decl.DInterface(i):
                self.declare(i.name, SymbolKind.SInterface, box_asttype(AstType.init(i.name)), false)
                self.interfaces.insert(i.name, i)
                if self.has_copy_decorator(i.decorators): self.copy_classes.insert(i.name, true)
            case Decl.DExtend(target, methods):
                mut hi = 0
                while hi < methods.len:
                    mut f = methods.get(hi)
                    mut _m_ret = box_asttype(AstType.init("void"))
                    if f.ret_ty as usize != 0 as usize: _m_ret = f.ret_ty
                    # For overloaded methods, register with a param-count suffix so each
                    # overload gets a distinct symbol in the global scope.
                    mut _decl_key = target + "_" + f.name
                    if self.globals.contains(_decl_key):
                        # Count non-self params to build unique overload key.
                        mut _pc = 0
                        mut _pci = 0
                        while _pci < f.params.len:
                            if f.params.get(_pci).name != "self": _pc = _pc + 1
                            _pci = _pci + 1
                        _decl_key = _decl_key + "_" + _pc.to_str() + "arg"
                    self.declare(_decl_key, SymbolKind.SFunction, _m_ret, false)
                    if self.classes.contains(target):
                        self.classes.get(target).methods.push(f)
                    hi = hi + 1
            case Decl.DExtern(abi, functions):
                mut ei = 0
                while ei < functions.len:
                    mut f = functions.get(ei)
                    mut _e_ret = box_asttype(AstType.init("void"))
                    if f.ret_ty as usize != 0 as usize: _e_ret = f.ret_ty
                    self.declare(f.name, SymbolKind.SFunction, _e_ret, false)
                    ei = ei + 1
            case Decl.DDecoratorDef(f):
                self.decorator_names.insert(f.name, true)
                self.declare(f.name, SymbolKind.SFunction, box_asttype(AstType.init("void")), false)
            case Decl.DTypeAlias(alias_name, target_ty):
                # Register type alias: `type Name = ExistingType`
                # The alias name becomes a valid type name resolving to the target.
                mut alias_ty = box_asttype(AstType.init("void"))
                if target_ty as usize != 0 as usize: alias_ty = target_ty
                self.declare(alias_name, SymbolKind.SClass, alias_ty, false)
                # Also register as a type alias mapping so type_to_c can resolve it.
                mut resolved_name = ""
                if target_ty as usize != 0 as usize: resolved_name = target_ty.read().name
                if resolved_name.len() > 0:
                    self.type_aliases.insert(alias_name, resolved_name)
                    # Store first generic arg (element type) for List/Map aliases.
                    if target_ty as usize != 0 as usize:
                        mut ta_t = target_ty.read()
                        if ta_t.args.len > 0:
                            self.type_alias_elem.insert(alias_name, ta_t.args.get(0).read().name)
            case _: pass

    pub def lower_func(self, f: FunctionDef) -> HirFunction:
        self.current_line = f.line
        # Rule N-1: Function name check
        # Top-level functions cannot shadow reserved built-ins.
        # Methods (current_class_name != "") are exempt - len/abs/etc. are valid method names.
        if f.name != "main" and f.name != "" and _tr_strlen(f.name) > 1:
            mut fn_cat = self.is_reserved_error(f.name)
            if fn_cat != "":
                self.error("[N-1] '" + f.name + "' is a " + fn_cat + " and cannot be used as a function name.")
            elif self.current_class_name == "":
                mut fn_kcat = self.is_reserved_keyword(f.name)
                if fn_kcat != "":
                    self.error("[N-1] '" + f.name + "' is a " + fn_kcat + " and is reserved. Choose a different function name.")
        # Save async context, set function context
        mut saved_async = self.in_async_fn
        self.in_async_fn = f.is_async
        self.current_func_name = f.name
        mut saved_func_generics = self.current_func_generics
        self.current_func_generics = f.generics
        # Phase C: clear container-borrow state - it must not leak between functions
        self.container_borrows = Map[str, str].init(16)
        # Gap 1: capture 'from' lifetime param for escape-analysis check in SReturn
        mut saved_ret_from = self.current_func_ret_from
        self.current_func_ret_from = ""
        if f.ret_ty as usize != 0 as usize:
            self.current_func_ret_from = f.ret_ty.read().from_param
        # Auto-infer 'from' when no explicit annotation: if return is Pointer/ref and there is
        # exactly one non-primitive parameter, that parameter is the inferred lifetime source.
        # This covers the common single-param borrow pattern without requiring any annotation.
        if self.current_func_ret_from == "" and f.ret_ty as usize != 0 as usize:
            mut infer_ret_nm = f.ret_ty.read().name
            if infer_ret_nm == "Pointer" or infer_ret_nm == "ref" or infer_ret_nm == "mut_ref":
                mut infer_from = ""
                mut infer_count = 0
                mut infer_i = 0
                while infer_i < f.params.len:
                    mut infer_p = f.params.get(infer_i)
                    if infer_p.name != "self" and infer_p.ty as usize != 0 as usize:
                        mut infer_pty = infer_p.ty.read()
                        if not self.is_primitive_name(infer_pty.name):
                            infer_from = infer_p.name
                            infer_count = infer_count + 1
                    infer_i = infer_i + 1
                if infer_count == 1:
                    self.current_func_ret_from = infer_from
        self.enter_scope()

        mut hparams = Vec[HirParam].init(4)
        mut j = 0
        while j < f.params.len:
            mut p = f.params.get(j)
            mut p_ty = AstType.init("int")
            if p.ty as usize != 0 as usize:
                p_ty = p.ty.read()
            elif p.name == "self" and self.current_class_name != "":
                p_ty = AstType.init(self.current_class_name)
            if p.is_variadic:
                # `args...` / `args: T...` -> the parameter itself is a List[T]
                # built from the trailing call args.
                mut _vp_ty = AstType.init("List")
                _vp_ty.args.push(box_asttype(p_ty))
                p_ty = _vp_ty

            self.declare(p.name, SymbolKind.SVariable, box_asttype(p_ty), false)
            # Phase B: mark as parameter so return-of-local-pointer check is skipped
            if self.scopes.len > 0:
                mut pb_scope = self.scopes.get(self.scopes.len - 1)
                if pb_scope.variables.contains(p.name):
                    mut pb_sym = pb_scope.variables.get(p.name)
                    pb_sym.is_param = true
                    pb_sym.ptr_region = 2  # PARAM region
                    pb_scope.variables.insert(p.name, pb_sym)

            mut hp = HirParam()
            hp.name = p.name
            hp.ty = p_ty
            hparams.push(hp)
            j = j + 1

        mut hf = HirFunction()
        hf.name = f.name
        hf.class_name = self.current_class_name
        hf.generics = f.generics
        hf.params = hparams
        hf.ret_ty = AstType.init("None")
        if f.ret_ty as usize != 0 as usize: hf.ret_ty = f.ret_ty.read()
        hf.throws_ty = AstType.init("")
        if f.throws_ty as usize != 0 as usize: hf.throws_ty = f.throws_ty.read()
        hf.body = self.lower_block(f.body)
        hf.decorators = f.decorators
        hf.is_async = f.is_async
        hf.is_extern = f.is_extern
        hf.is_public = f.is_public
        hf.is_export = f.is_export
        mut _has_self = false
        mut _si = 0
        while _si < hparams.len:
            if hparams.get(_si).name == "self": _has_self = true
            _si = _si + 1
        hf.is_static = self.current_class_name != "" and not _has_self
        hf.is_variadic = f.is_variadic
        hf.is_decorator = false

        # Rule F-3: Definite return check for non-void, non-extern functions
        # Skip for interface method signatures (empty body = no stmts)
        if not f.is_extern and f.body.stmts.len > 0 and f.ret_ty as usize != 0 as usize:
            mut ret_nm = f.ret_ty.read().name
            if ret_nm != "void" and ret_nm != "None" and ret_nm != "" and f.name != "init" and f.name != "new":
                if not self.block_returns(f.body):
                    self.current_line = f.line
                    self.error("[F-3] Function '" + f.name + "' returns '" + ret_nm + "' but is missing a return statement on at least one code path. FIX: Add a return at the end, or ensure all if/elif/else branches return.")

        self.finalize_scope_drops(hf.body)
        self.exit_scope()
        # Restore async context and lifetime context
        self.in_async_fn = saved_async
        self.current_func_name = ""
        self.current_func_generics = saved_func_generics
        self.current_func_ret_from = saved_ret_from
        return hf

    pub def lower_class(self, c: ClassDef) -> HirClass:
        self.current_line = c.line
        self.current_class_name = c.name
        mut hfields = Vec[HirField].init(4)
        mut i = 0
        while i < c.fields.len:
            mut f = c.fields.get(i)
            mut hf = HirField()
            hf.name = f.name
            mut f_ty = AstType.init("int")
            if f.ty as usize != 0 as usize: f_ty = f.ty.read()
            hf.ty = f_ty
            hfields.push(hf)
            i = i + 1

        # Phase F: detect self-referential Shared[ClassName] fields (creates ref cycle -> leak)
        mut pf_i = 0
        while pf_i < c.fields.len:
            mut pf_f = c.fields.get(pf_i)
            if pf_f.ty as usize != 0 as usize:
                mut pf_ty = pf_f.ty.read()
                if pf_ty.name == "Shared" and pf_ty.args.len > 0:
                    mut pf_inner = pf_ty.args.get(0).read()
                    if pf_inner.name == c.name:
                        self.error("[S-1] '" + c.name + "' has a 'Shared[" + c.name + "]' field '" + pf_f.name + "' - this creates a reference cycle that leaks memory.\n      FIX: Use 'Weak[" + c.name + "]' for back-references to break the cycle.")
            pf_i = pf_i + 1

        mut hmethods = Vec[HirFunction].init(4)
        i = 0
        while i < c.methods.len:
            mut hm = self.lower_func(c.methods.get(i))
            hmethods.push(hm)
            i = i + 1
            
        # -- Interface completeness + signature checks -------------------------
        mut _ifc_i = 0
        while _ifc_i < c.iface_names.len:
            mut _ifc_nm = c.iface_names.get(_ifc_i)
            if _ifc_nm == "Sendable":
                # Validate all fields are Sendable; pass generics (T fields allowed)
                if c.generics.len == 0:
                    self.check_class_sendable_fields(c)
            elif not self.interfaces.contains(_ifc_nm):
                self.error("[I-1] Class '" + c.name + "' declares 'implements " + _ifc_nm + "' but interface '" + _ifc_nm + "' is not defined.\n      FIX: Define 'interface " + _ifc_nm + ":' before this class, or check for typos.")
            else:
                mut _idef = self.interfaces.get(_ifc_nm)
                mut _im_i = 0
                while _im_i < _idef.methods.len:
                    mut _imeth = _idef.methods.get(_im_i)
                    mut _found = false
                    mut _cm_i = 0
                    while _cm_i < c.methods.len:
                        mut _cmeth = c.methods.get(_cm_i)
                        if _cmeth.name == _imeth.name:
                            _found = true
                            # Return type check
                            mut _iret = "void"
                            if _imeth.ret_ty as usize != 0 as usize:
                                _iret = _imeth.ret_ty.read().name
                            mut _cret = "void"
                            if _cmeth.ret_ty as usize != 0 as usize:
                                _cret = _cmeth.ret_ty.read().name
                            # Allow generics (single-letter type param) to match anything
                            mut _iret_is_generic = _ifc_i >= 0 and _idef.generics.len > 0 and _iret != "void" and _iret != ""
                            mut _gi = 0
                            while _gi < _idef.generics.len:
                                if _idef.generics.get(_gi) == _iret: _iret_is_generic = true
                                _gi = _gi + 1
                            if not _iret_is_generic and _iret != "void" and _iret != "" and _cret != _iret:
                                self.error("[I-3] Class '" + c.name + "': method '" + _cmeth.name + "' returns '" + _cret + "' but interface '" + _ifc_nm + "' declares '-> " + _iret + "'.\n      FIX: Change return type to '-> " + _iret + "'.")
                            # Non-self param count check
                            mut _ip_cnt = 0
                            mut _ip_i = 0
                            while _ip_i < _imeth.params.len:
                                if _imeth.params.get(_ip_i).name != "self": _ip_cnt = _ip_cnt + 1
                                _ip_i = _ip_i + 1
                            mut _cp_cnt = 0
                            mut _cp_i = 0
                            while _cp_i < _cmeth.params.len:
                                if _cmeth.params.get(_cp_i).name != "self": _cp_cnt = _cp_cnt + 1
                                _cp_i = _cp_i + 1
                            if _ip_cnt != _cp_cnt:
                                self.error("[I-3] Class '" + c.name + "': method '" + _cmeth.name + "' has " + str(_cp_cnt) + " parameter(s) but interface '" + _ifc_nm + "' requires " + str(_ip_cnt) + ".\n      FIX: Match the parameter list in '" + _ifc_nm + "' exactly.")
                        _cm_i = _cm_i + 1
                    if not _found:
                        mut _sig = "pub def " + _imeth.name + "(self"
                        mut _pi = 0
                        while _pi < _imeth.params.len:
                            mut _p = _imeth.params.get(_pi)
                            if _p.name != "self":
                                mut _pty = "int"
                                if _p.ty as usize != 0 as usize: _pty = _p.ty.read().name
                                _sig = _sig + ", " + _p.name + ": " + _pty
                            _pi = _pi + 1
                        mut _iret2 = "void"
                        if _imeth.ret_ty as usize != 0 as usize: _iret2 = _imeth.ret_ty.read().name
                        _sig = _sig + ") -> " + _iret2 + ":"
                        self.error("[I-2] Class '" + c.name + "' implements '" + _ifc_nm + "' but is missing method '" + _imeth.name + "'.\n      FIX: Add to 'extend " + c.name + ":'  " + _sig)
                    _im_i = _im_i + 1
            _ifc_i = _ifc_i + 1

        mut hc = HirClass()
        hc.name = c.name
        hc.generics = c.generics
        hc.fields = hfields
        hc.methods = hmethods
        hc.base_classes = c.base_classes
        hc.iface_names = c.iface_names
        hc.decorators = c.decorators
        hc.is_public = c.is_public
        hc.is_class = c.is_class

        self.current_class_name = ""
        return hc

    pub def lower_enum(self, e: EnumDef) -> HirEnum:
        self.current_class_name = e.name
        mut hvariants = Vec[HirVariant].init(4)
        mut i = 0
        while i < e.variants.len:
            mut v = e.variants.get(i)
            mut hfields = Vec[HirParam].init(4)
            mut j = 0
            while j < v.fields.len:
                mut p = v.fields.get(j)
                mut hp = HirParam()
                hp.name = p.name
                # Tuple-variant fields written as a bare type (e.g. `Err(str)`)
                # parse as an unnamed param: `p.name` holds the type name and
                # `p.ty` is null. Recover the real type from `p.name` instead
                # of defaulting to "int" (which silently broke str/bool/etc).
                mut p_ty = AstType.init(p.name)
                if p.ty as usize != 0 as usize: p_ty = p.ty.read()
                hp.ty = p_ty
                hfields.push(hp)
                j = j + 1
                
            mut hv = HirVariant()
            hv.name = v.name
            hv.fields = hfields
            hvariants.push(hv)
            i = i + 1
            
        mut hmethods = Vec[HirFunction].init(4)
        i = 0
        while i < e.methods.len:
            mut hm = self.lower_func(e.methods.get(i))
            hmethods.push(hm)
            i = i + 1
            
        mut he = HirEnum()
        he.name = e.name
        he.variants = hvariants
        he.methods = hmethods
        he.iface_names = e.iface_names
        he.decorators = e.decorators
        he.is_public = e.is_public
        
        self.current_class_name = ""
        return he

    pub def lower_interface(self, i_def: InterfaceDef) -> HirInterface:
        mut hmethods = Vec[HirFunction].init(4)
        mut i = 0
        while i < i_def.methods.len:
            mut hm = self.lower_func(i_def.methods.get(i))
            hmethods.push(hm)
            i = i + 1
            
        mut hi = HirInterface()
        hi.name = i_def.name
        hi.generics = i_def.generics
        hi.methods = hmethods
        return hi

    pub def lower_block(self, b: Block) -> HirBlock:
        mut hb = HirBlock.init()
        mut i = 0
        while i < b.stmts.len:
            mut orig_ptr = b.stmts.get(i)
            mut _hs = self.lower_stmt(orig_ptr)
            # Mark any `str` local passed as a call/method-call argument in
            # this statement as "escaped" (excluded from auto-drop) - see
            # mark_escaped_str_args.
            match _hs.read():
                case HirStmt.SExpr(_es_e):
                    self.mark_escaped_str_args(_es_e)
                    self.mark_escaped_coll_args(_es_e)
                case HirStmt.SLet(_, _, _, _, _, _, _sl_v):
                    self.mark_escaped_str_args(_sl_v)
                    self.mark_coll_arg(_sl_v)
                    self.mark_escaped_coll_args(_sl_v)
                case HirStmt.SAssign(_sa_t, _sa_v):
                    self.mark_escaped_str_args(_sa_t)
                    self.mark_escaped_str_args(_sa_v)
                    self.mark_escaped_coll_args(_sa_t)
                    self.mark_coll_arg(_sa_v)
                    self.mark_escaped_coll_args(_sa_v)
                case HirStmt.SReturn(_sr_e):
                    self.mark_escaped_str_args(_sr_e)
                    self.mark_coll_arg(_sr_e)
                    self.mark_escaped_coll_args(_sr_e)
                case HirStmt.SIf(_si_c, _, _):
                    self.mark_escaped_str_args(_si_c)
                    self.mark_escaped_coll_args(_si_c)
                case HirStmt.SWhile(_sw_c, _):
                    self.mark_escaped_str_args(_sw_c)
                    self.mark_escaped_coll_args(_sw_c)
                case HirStmt.SFor(_, _sf_iter, _):
                    self.mark_escaped_coll_args(_sf_iter)
                case HirStmt.SForUnpack(_, _sfu_iter, _):
                    self.mark_escaped_coll_args(_sfu_iter)
                case _: pass
            # Auto-drop: inject SAutoDrop stmts for all currently-open scopes
            # right before a control-transfer statement, so owned locals are
            # freed on every exit path (not just normal fall-through).
            if orig_ptr as usize != 0 as usize:
                match orig_ptr.read():
                    case Stmt.SReturn(_):
                        # `return EXPR` transfers ownership of any directly-returned
                        # local to the caller, and may also READ other droppable
                        # locals (e.g. `return a + b`). Exclude every local
                        # referenced by the (lowered) return expression from this
                        # exit point's auto-drops, so a buffer isn't released
                        # before it's read; such locals simply leak on this path
                        # instead of risking a use-after-free.
                        mut ret_excl = Vec[str].init(2)
                        match _hs.read():
                            case HirStmt.SReturn(lowered_ret):
                                self.collect_idents(lowered_ret, ret_excl)
                            case _: pass
                        self.append_drops_from_excl_multi(hb, 0, ret_excl)
                    case Stmt.SBreak:
                        if self.loop_scope_base.len > 0:
                            self.append_drops_from(hb, self.loop_scope_base.get(self.loop_scope_base.len - 1))
                    case Stmt.SContinue:
                        if self.loop_scope_base.len > 0:
                            self.append_drops_from(hb, self.loop_scope_base.get(self.loop_scope_base.len - 1))
                    case _: pass
            hb.push(_hs)
            i = i + 1
        return hb

    pub def lower_stmt(self, s_ptr: Pointer[Stmt]) -> Pointer[HirStmt]:
        if s_ptr as usize == 0 as usize: return Pointer[HirStmt](0)
        s = s_ptr.read()
        match s:
            case Stmt.SExpr(e):
                mut h_s_expr = box_hirstmt(HirStmt.SExpr(self.lower_expr(e)))
                # Rule T-4: Result returned by throws-function must be handled
                if e as usize != 0 as usize:
                    match e.read():
                        case Expr.ECall(callee, args):
                            if callee as usize != 0 as usize:
                                match callee.read():
                                    case Expr.EIdent(fn_name):
                                        mut fn_sym = self.resolve(fn_name)
                                        if fn_sym.kind == SymbolKind.SFunction and fn_sym.ty.read().name == "Result":
                                            self.error("[T-4] '" + fn_name + "()' returns a Result and its error must be handled. FIX: Assign the result and match on it, use '?' to propagate, or '_ = " + fn_name + "(...)' to explicitly discard.")
                                    case _: pass
                        case _: pass
                return h_s_expr
            case Stmt.SReturn(e):
                # Gap 1: [L-1] escape check - returning a LOCAL-region Pointer without 'from' annotation
                if e as usize != 0 as usize and not self.in_unsafe and self.current_func_ret_from == "":
                    match e.read():
                        case Expr.EIdent(ret_name):
                            mut ret_sym = self.resolve(ret_name)
                            if ret_sym.name != "" and ret_sym.ptr_region == 0:
                                if ret_sym.ty as usize != 0 as usize:
                                    if ret_sym.ty.read().name == "Pointer":
                                        self.error("[L-1] '" + ret_name + "' is a local Pointer that may not outlive this function call. Returning it is unsafe.\n      FIX: Annotate the return type with 'from <param>' if the pointer borrows from a parameter, or wrap the allocation in 'unsafe:' if it is heap-allocated.")
                        case _: pass
                return box_hirstmt(HirStmt.SReturn(self.lower_expr(e)))
            case Stmt.SLet(name, ownership, is_mut, is_const, is_shared, ty_ptr, val_ptr):
                # Rule M-7: none must not be assigned to a non-Optional type
                if ty_ptr as usize != 0 as usize and val_ptr as usize != 0 as usize:
                    match val_ptr.read():
                        case Expr.ELitNone:
                            mut m7_ty_name = ty_ptr.read().name
                            if m7_ty_name != "Option" and m7_ty_name != "None" and m7_ty_name != "void" and m7_ty_name != "" and m7_ty_name != "Pointer":
                                self.error("[M-7] Cannot assign 'none' to '" + name + "' which has type '" + m7_ty_name + "'. Only Option[T] can hold 'none'. FIX: Use 'Option[" + m7_ty_name + "]' as the type, or give '" + name + "' a real initial value.")
                        case _: pass
                mut ty = AstType.init("void")
                if ty_ptr as usize != 0 as usize: ty = ty_ptr.read()
                mut hval = self.lower_expr(val_ptr)
                if ty.name == "void" or ty.name == "None": ty = hir_expr_type(hval)
                # Phase 1: plain-identifier RHS of non-primitive type = ownership move
                # Skip for shared lets (shared = clone via refcount, not a move)
                # Phase 1: plain variable-to-variable move (mut newvar = old_obj)
                # Field/index access is NOT a move in Tauraro (C value semantics copy fields)
                if val_ptr as usize != 0 as usize and not is_shared:
                    match val_ptr.read():
                        case Expr.EIdent(m1_src):
                            mut m1_sym = self.resolve(m1_src)
                            mut m1_ty = m1_sym.ty.read()
                            # Shared + primitive + Copy-class sources are exempt from move tracking
                            if not self.is_primitive(m1_ty) and not self.is_copy_class(m1_ty.name) and m1_sym.name != "" and not m1_sym.is_shared:
                                self.check_not_moved(m1_src, m1_ty.name)
                                self.check_no_active_borrows(m1_src, m1_ty.name)
                                self.mark_moved(m1_src)
                        case _: pass
                self.declare(name, SymbolKind.SVariable, box_asttype(ty), is_mut)
                # Gap 1: infer ptr_region for Pointer-typed variables.
                # Conservative rule: any call-expression RHS is assumed HEAP (functions may alloc).
                # Only a variable without initializer OR initialized with Pointer[T](0) is LOCAL.
                if val_ptr as usize != 0 as usize and ty.name == "Pointer":
                    mut heap_rhs = false
                    match val_ptr.read():
                        case Expr.ECall(_, _): heap_rhs = true
                        case Expr.EMethodCall(_, _, _): heap_rhs = true
                        case _: pass
                    if heap_rhs:
                        if self.scopes.len > 0:
                            mut alloc_scope = self.scopes.get(self.scopes.len - 1)
                            if alloc_scope.variables.contains(name):
                                mut alloc_sym = alloc_scope.variables.get(name)
                                alloc_sym.ptr_region = 1  # HEAP (function call result)
                                alloc_scope.variables.insert(name, alloc_sym)
                # Phase D: variable declared without a value - mark as uninitialised
                if val_ptr as usize == 0 as usize:
                    if self.scopes.len > 0:
                        mut pd_scope = self.scopes.get(self.scopes.len - 1)
                        if pd_scope.variables.contains(name):
                            mut pd_sym = pd_scope.variables.get(name)
                            pd_sym.is_init = false
                            pd_scope.variables.insert(name, pd_sym)
                # Phase C: track borrow if RHS is vec.get / vec.first / vec.last on a non-primitive
                if val_ptr as usize != 0 as usize:
                    mut pc_cont_nm = ""
                    mut pc_meth = ""
                    match val_ptr.read():
                        case Expr.EMethodCall(pc_obj, pc_m, _):
                            pc_meth = pc_m
                            match pc_obj.read():
                                case Expr.EIdent(pc_src): pc_cont_nm = pc_src
                                case _: pass
                        case _: pass
                    if pc_cont_nm != "" and (pc_meth == "get" or pc_meth == "first" or pc_meth == "last"):
                        mut pc_cont_sym = self.resolve(pc_cont_nm)
                        mut pc_cont_ty = pc_cont_sym.ty.read()
                        if pc_cont_ty.name == "Vec" or pc_cont_ty.name == "List":
                            if not self.is_primitive(hir_expr_type(hval)):
                                self.container_borrows.insert(pc_cont_nm, name)
                return box_hirstmt(HirStmt.SLet(name, ownership, is_mut, is_const, is_shared, ty, hval))
            case Stmt.SAssign(target, val):
                self.in_assign_target = true
                mut htgt = self.lower_expr(target)
                self.in_assign_target = false
                mut hv = self.lower_expr(val)
                # First assignment to an undeclared name (bare `name = expr`, no
                # `mut`): implicitly declare it with the inferred type so its
                # methods/fields resolve (e.g. `obj = Foo(); obj.bar()`).
                if target as usize != 0 as usize:
                    match target.read():
                        case Expr.EIdent(sa_decl_name):
                            mut sa_existing = self.resolve(sa_decl_name)
                            if sa_existing.name == "":
                                # Bare `name = expr` with no prior declaration and no `mut`:
                                # declares an IMMUTABLE binding (Rust-like default).
                                self.declare(sa_decl_name, SymbolKind.SVariable, box_asttype(hir_expr_type(hv)), false)
                            elif sa_existing.kind == SymbolKind.SVariable and not sa_existing.is_mut:
                                self.error("[M-8] Cannot assign to '" + sa_decl_name + "' a second time because it is immutable.\n      FIX: Declare it as 'mut " + sa_decl_name + " = ...' if it needs to change.")
                        case _: pass
                # Phase 1 SAssign: plain-variable RHS of non-primitive non-Copy type = ownership move
                # Lower first (EIdent checks current is_moved), then mark moved for subsequent uses.
                # SAssign is guarded by branch snapshots (Fix 1) so sibling else-branches correctly
                # roll back and re-check - no false positives across if/else chains.
                # Skip for generic type parameters (unknown type = possibly Copy; conservative).
                if val as usize != 0 as usize:
                    match val.read():
                        case Expr.EIdent(sa_src):
                            mut sa_sym = self.resolve(sa_src)
                            mut sa_ty = sa_sym.ty.read()
                            mut sa_is_known = self.classes.contains(sa_ty.name) or self.enums.contains(sa_ty.name)
                            if sa_is_known and not self.is_primitive(sa_ty) and not self.is_copy_class(sa_ty.name) and sa_sym.name != "" and not sa_sym.is_shared:
                                self.check_no_active_borrows(sa_src, sa_ty.name)
                                self.mark_moved(sa_src)
                        case _: pass
                # Phase D: mark assignment target as initialised after any assignment
                if target as usize != 0 as usize:
                    match target.read():
                        case Expr.EIdent(pd_tgt): self.mark_init(pd_tgt)
                        case _: pass
                # Phase C: clear container borrow when the borrowing variable is reassigned
                if target as usize != 0 as usize:
                    match target.read():
                        case Expr.EIdent(pc_tgt): self.clear_container_borrow(pc_tgt)
                        case _: pass
                return box_hirstmt(HirStmt.SAssign(htgt, hv))
            case Stmt.SIf(cond, then_b, elifs, else_b):
                # Rule T-5: numeric variable used directly as boolean condition
                if cond as usize != 0 as usize:
                    match cond.read():
                        case Expr.EIdent(t5_name):
                            mut t5_sym = self.resolve(t5_name)
                            mut t5_ty = t5_sym.ty.read().name
                            if t5_ty == "int" or t5_ty == "i64" or t5_ty == "i32" or t5_ty == "float" or t5_ty == "f64":
                                self.error("[T-5] '" + t5_name + "' is a number (" + t5_ty + ") and cannot be used as an 'if' condition. FIX: Write 'if " + t5_name + " != 0:' to explicitly check for non-zero.")
                        case _: pass
                # Fix 1+4: branch-scoped snapshot - save parent capturing state
                mut si_outer_cap_m = self.capturing_moves
                mut si_outer_buf_m = self.branch_moved_buf
                mut si_outer_cap_i = self.capturing_inits
                mut si_outer_buf_i = self.branch_init_buf
                # -- Then branch (with fresh capture buffers) --
                self.capturing_moves = true
                self.capturing_inits = true
                self.branch_moved_buf = Vec[str].init(4)
                self.branch_init_buf = Vec[str].init(4)
                mut hcond = self.lower_expr(cond)
                self.block_depth = self.block_depth + 1
                self.open_block()
                mut hthen = self.lower_block(then_b)
                self.block_depth = self.block_depth - 1
                self.close_block()
                mut si_then_moved = self.branch_moved_buf
                mut si_then_inited = self.branch_init_buf
                # Roll back then-branch moves/inits so else-branch sees clean slate
                mut si_uti = 0
                while si_uti < si_then_moved.len:
                    self.unmark_moved(si_then_moved.get(si_uti))
                    si_uti = si_uti + 1
                mut si_uii = 0
                while si_uii < si_then_inited.len:
                    self.unmark_init(si_then_inited.get(si_uii))
                    si_uii = si_uii + 1
                # -- Else/elif branch (fresh capture buffers, same capturing=true) --
                self.branch_moved_buf = Vec[str].init(4)
                self.branch_init_buf = Vec[str].init(4)
                mut helse = HirBlock.init()
                self.block_depth = self.block_depth + 1
                self.open_block()
                if elifs.len > 0:
                    mut base_else = self.lower_block(else_b)
                    mut chain = base_else
                    mut k = elifs.len - 1
                    while k >= 0:
                        mut elif_c = elifs.get(k)
                        mut elif_cond = self.lower_expr(elif_c.cond)
                        mut elif_body = self.lower_block(elif_c.body.read())
                        mut nested = HirBlock.init()
                        nested.push(box_hirstmt(HirStmt.SIf(elif_cond, elif_body, chain)))
                        chain = nested
                        k = k - 1
                    helse = chain
                else:
                    helse = self.lower_block(else_b)
                self.block_depth = self.block_depth - 1
                self.close_block()
                mut si_else_moved = self.branch_moved_buf
                mut si_else_inited = self.branch_init_buf
                # Roll back else-branch moves/inits
                mut si_uei = 0
                while si_uei < si_else_moved.len:
                    self.unmark_moved(si_else_moved.get(si_uei))
                    si_uei = si_uei + 1
                mut si_uei2 = 0
                while si_uei2 < si_else_inited.len:
                    self.unmark_init(si_else_inited.get(si_uei2))
                    si_uei2 = si_uei2 + 1
                # Restore parent capturing state before applying merged results
                self.capturing_moves = si_outer_cap_m
                self.branch_moved_buf = si_outer_buf_m
                self.capturing_inits = si_outer_cap_i
                self.branch_init_buf = si_outer_buf_i
                # A branch that ends in return/break/continue never reaches the
                # fall-through code after this 'if', so its moves/inits/frees
                # must not be merged into the continuation state at all - only
                # the surviving (non-jumping) branch's effects apply, and they
                # apply definitively (not "maybe") since it's the only path left.
                mut si_then_jumps = self.block_ends_in_jump(hthen)
                mut si_else_jumps = self.block_ends_in_jump(helse)
                if si_then_jumps and not si_else_jumps:
                    mut si_ei0 = 0
                    while si_ei0 < si_else_moved.len:
                        self.mark_moved(si_else_moved.get(si_ei0))
                        si_ei0 = si_ei0 + 1
                    mut si_ini0 = 0
                    while si_ini0 < si_else_inited.len:
                        self.mark_init(si_else_inited.get(si_ini0))
                        si_ini0 = si_ini0 + 1
                elif si_else_jumps and not si_then_jumps:
                    mut si_mi0 = 0
                    while si_mi0 < si_then_moved.len:
                        self.mark_moved(si_then_moved.get(si_mi0))
                        si_mi0 = si_mi0 + 1
                    mut si_ti0 = 0
                    while si_ti0 < si_then_inited.len:
                        self.mark_init(si_then_inited.get(si_ti0))
                        si_ti0 = si_ti0 + 1
                elif si_then_jumps and si_else_jumps:
                    pass # no fall-through; nothing to merge
                else:
                    # -- Merge move state: both->definitive, one-only->maybe --
                    mut si_mi = 0
                    while si_mi < si_then_moved.len:
                        mut si_mn = si_then_moved.get(si_mi)
                        if self.vec_str_contains(si_else_moved, si_mn):
                            self.mark_moved(si_mn)
                        else:
                            self.mark_maybe_moved(si_mn)
                        si_mi = si_mi + 1
                    mut si_ei = 0
                    while si_ei < si_else_moved.len:
                        mut si_en = si_else_moved.get(si_ei)
                        if not self.vec_str_contains(si_then_moved, si_en):
                            self.mark_maybe_moved(si_en)
                        si_ei = si_ei + 1
                    # -- Merge init state: both->definitive, one-only->maybe --
                    mut si_ini = 0
                    while si_ini < si_then_inited.len:
                        mut si_inn = si_then_inited.get(si_ini)
                        if self.vec_str_contains(si_else_inited, si_inn):
                            self.mark_init(si_inn)
                        else:
                            self.mark_maybe_init(si_inn)
                        si_ini = si_ini + 1
                return box_hirstmt(HirStmt.SIf(hcond, hthen, helse))
            case Stmt.SWhile(cond, body, decorators):
                mut sw_cond = self.lower_expr(cond)
                # Fix 1+4: loop body might not run -> all moves/inits are "maybe"
                mut sw_outer_cap_m = self.capturing_moves
                mut sw_outer_buf_m = self.branch_moved_buf
                mut sw_outer_cap_i = self.capturing_inits
                mut sw_outer_buf_i = self.branch_init_buf
                self.capturing_moves = true
                self.capturing_inits = true
                self.branch_moved_buf = Vec[str].init(4)
                self.branch_init_buf = Vec[str].init(4)
                # SWhile bodies share the enclosing scope (no enter_scope/exit_scope),
                # so push a base equal to the current depth: break/continue inside
                # the loop drain nothing extra (no per-iteration scope to drain).
                self.loop_scope_base.push(self.scopes.len)
                self.block_depth = self.block_depth + 1
                self.open_block()
                mut sw_block_id = self.block_stack.get(self.block_stack.len - 1)
                mut sw_body = self.lower_block(body)
                self.append_block_local_drops(sw_body, sw_block_id)
                self.block_depth = self.block_depth - 1
                self.close_block()
                self.loop_scope_base.pop()
                mut sw_loop_moved = self.branch_moved_buf
                mut sw_loop_inited = self.branch_init_buf
                self.capturing_moves = sw_outer_cap_m
                self.branch_moved_buf = sw_outer_buf_m
                self.capturing_inits = sw_outer_cap_i
                self.branch_init_buf = sw_outer_buf_i
                mut sw_mi = 0
                while sw_mi < sw_loop_moved.len:
                    self.unmark_moved(sw_loop_moved.get(sw_mi))
                    self.mark_maybe_moved(sw_loop_moved.get(sw_mi))
                    sw_mi = sw_mi + 1
                mut sw_ii = 0
                while sw_ii < sw_loop_inited.len:
                    self.unmark_init(sw_loop_inited.get(sw_ii))
                    self.mark_maybe_init(sw_loop_inited.get(sw_ii))
                    sw_ii = sw_ii + 1
                return box_hirstmt(HirStmt.SWhile(sw_cond, sw_body))
            case Stmt.SFor(var, iter, body, decorators):
                self.enter_scope()
                mut h_iter_for = self.lower_expr(iter)
                mut var_ty_for = AstType.init("int")
                mut iter_hn = hir_expr_type(h_iter_for).name
                mut iter_hal = hir_expr_type(h_iter_for).args.len
                if (iter_hn == "List" or iter_hn == "Vec") and iter_hal > 0:
                    var_ty_for = hir_expr_type(h_iter_for).args.get(0).read()
                elif iter_hn == "Chan" and iter_hal > 0:
                    var_ty_for = hir_expr_type(h_iter_for).args.get(0).read()
                elif iter_hn == "str":
                    var_ty_for = AstType.init("char")
                self.declare(var, SymbolKind.SVariable, box_asttype(var_ty_for), false)
                # Fix 1+4: for-loop body might not run -> moves/inits are "maybe"
                mut sf_outer_cap_m = self.capturing_moves
                mut sf_outer_buf_m = self.branch_moved_buf
                mut sf_outer_cap_i = self.capturing_inits
                mut sf_outer_buf_i = self.branch_init_buf
                self.capturing_moves = true
                self.capturing_inits = true
                self.branch_moved_buf = Vec[str].init(4)
                self.branch_init_buf = Vec[str].init(4)
                self.loop_scope_base.push(self.scopes.len - 1)
                mut sf_body = self.lower_block(body)
                self.loop_scope_base.pop()
                mut sf_loop_moved = self.branch_moved_buf
                mut sf_loop_inited = self.branch_init_buf
                self.capturing_moves = sf_outer_cap_m
                self.branch_moved_buf = sf_outer_buf_m
                self.capturing_inits = sf_outer_cap_i
                self.branch_init_buf = sf_outer_buf_i
                mut sf_mi = 0
                while sf_mi < sf_loop_moved.len:
                    self.unmark_moved(sf_loop_moved.get(sf_mi))
                    self.mark_maybe_moved(sf_loop_moved.get(sf_mi))
                    sf_mi = sf_mi + 1
                mut sf_ii = 0
                while sf_ii < sf_loop_inited.len:
                    self.unmark_init(sf_loop_inited.get(sf_ii))
                    self.mark_maybe_init(sf_loop_inited.get(sf_ii))
                    sf_ii = sf_ii + 1
                self.finalize_scope_drops(sf_body)
                mut hstmt = box_hirstmt(HirStmt.SFor(var, h_iter_for, sf_body))
                self.exit_scope()
                return hstmt
            case Stmt.SForUnpack(vars, iter, body):
                self.enter_scope()
                mut h_iter_fu = self.lower_expr(iter)
                # Infer per-variable types from the iterator kind
                mut fu_tys = Vec[AstType].init(vars.len)
                mut fu_ti = 0
                while fu_ti < vars.len:
                    fu_tys.push(AstType.init("int"))
                    fu_ti = fu_ti + 1
                match h_iter_fu.read():
                    case HirExpr.ECall(fu_callee, fu_args, _):
                        match fu_callee.read():
                            case HirExpr.EIdent(fu_fn, _, _):
                                if fu_fn == "enumerate" and fu_args.len == 1 and vars.len >= 2:
                                    # var0=index(int), var1=element type of collection
                                    mut fu_col_ty_n = hir_expr_type(fu_args.get(0)).name
                                    mut fu_col_al = hir_expr_type(fu_args.get(0)).args.len
                                    if (fu_col_ty_n == "List" or fu_col_ty_n == "Vec") and fu_col_al > 0:
                                        fu_tys.set(1, hir_expr_type(fu_args.get(0)).args.get(0).read())
                                elif fu_fn == "zip" and fu_args.len == 2 and vars.len >= 2:
                                    # var0=elem type of a, var1=elem type of b
                                    mut fu_a_n = hir_expr_type(fu_args.get(0)).name
                                    mut fu_a_al = hir_expr_type(fu_args.get(0)).args.len
                                    mut fu_b_n = hir_expr_type(fu_args.get(1)).name
                                    mut fu_b_al = hir_expr_type(fu_args.get(1)).args.len
                                    if (fu_a_n == "List" or fu_a_n == "Vec") and fu_a_al > 0:
                                        fu_tys.set(0, hir_expr_type(fu_args.get(0)).args.get(0).read())
                                    if (fu_b_n == "List" or fu_b_n == "Vec") and fu_b_al > 0:
                                        fu_tys.set(1, hir_expr_type(fu_args.get(1)).args.get(0).read())
                            case _: pass
                    case HirExpr.EMethodCall(fu_obj, fu_meth, _, _):
                        if fu_meth == "items" and vars.len >= 2:
                            mut fu_dty_n = hir_expr_type(fu_obj).name
                            mut fu_dty_al = hir_expr_type(fu_obj).args.len
                            if (fu_dty_n == "Dict" or fu_dty_n == "Map") and fu_dty_al >= 2:
                                fu_tys.set(0, hir_expr_type(fu_obj).args.get(0).read())
                                fu_tys.set(1, hir_expr_type(fu_obj).args.get(1).read())
                    case _: pass
                mut vi_fu = 0
                while vi_fu < vars.len:
                    self.declare(vars.get(vi_fu), SymbolKind.SVariable, box_asttype(fu_tys.get(vi_fu)), false)
                    vi_fu = vi_fu + 1
                mut hblk_fu = self.lower_block(body)
                self.finalize_scope_drops(hblk_fu)
                self.exit_scope()
                return box_hirstmt(HirStmt.SForUnpack(vars, h_iter_fu, hblk_fu))
            case Stmt.SMatch(subj, arms):
                mut hsubj = self.lower_expr(subj)
                mut ex_ty_name = hir_expr_type(hsubj).name
                mut h_arms = Vec[HirMatchArm].init(4)
                mut ex_has_wild = false
                mut ex_covered = Vec[str].init(8)
                mut k = 0
                while k < arms.len:
                    mut arm = arms.get(k)
                    # Collect exhaustiveness info from the pattern
                    match arm.pat:
                        case Pattern.PWild: ex_has_wild = true
                        case Pattern.PBind(_): ex_has_wild = true
                        case Pattern.PVariant(_, ex_vn): ex_covered.push(ex_vn)
                        case Pattern.PVariantBind(_, ex_vn2, _): ex_covered.push(ex_vn2)
                        case Pattern.PVariantBindMany(_, ex_vn3, _): ex_covered.push(ex_vn3)
                        case _: pass
                    self.enter_scope()
                    # Use the subject's type for PBind so `case x if x.method():` works.
                    mut _subj_ty = hir_expr_type(hsubj)
                    self.declare_pattern_binds_typed(arm.pat, _subj_ty)
                    mut h_arm = HirMatchArm.init(arm.pat, self.lower_block(arm.body.read()))
                    # Lower guard expression if present
                    if arm.guard as usize != 0 as usize:
                        h_arm.guard = self.lower_expr(arm.guard)
                    self.finalize_scope_drops(h_arm.body)
                    h_arms.push(h_arm)
                    self.exit_scope()
                    k = k + 1
                # [E-1] Exhaustiveness check - only for known enum types
                if not ex_has_wild and self.enums.contains(ex_ty_name):
                    mut ex_edef = self.enums.get(ex_ty_name)
                    mut ex_missing = Vec[str].init(4)
                    mut ex_vi = 0
                    while ex_vi < ex_edef.variants.len:
                        mut ex_vname = ex_edef.variants.get(ex_vi).name
                        if not ex_covered.contains(ex_vname):
                            ex_missing.push(ex_vname)
                        ex_vi = ex_vi + 1
                    if ex_missing.len > 0:
                        mut ex_msg = "[E-1] Non-exhaustive match on '" + ex_ty_name + "': missing variant"
                        if ex_missing.len > 1: ex_msg = ex_msg + "s"
                        ex_msg = ex_msg + ": "
                        mut ex_mi = 0
                        while ex_mi < ex_missing.len:
                            if ex_mi > 0: ex_msg = ex_msg + ", "
                            ex_msg = ex_msg + ex_missing.get(ex_mi)
                            ex_mi = ex_mi + 1
                        ex_msg = ex_msg + ".\n      FIX: Add a 'case " + ex_ty_name + ".VariantName:' arm for each missing variant, or add 'case _:' to handle all remaining cases."
                        self.error(ex_msg)
                return box_hirstmt(HirStmt.SMatch(hsubj, h_arms))
            case Stmt.STry(try_body, catches, finally_b):
                self.block_depth = self.block_depth + 1
                self.open_block()
                mut h_try_body = self.lower_block(try_body)
                mut h_catches = Vec[Pointer[HirCatchClause]].init(catches.len)
                mut k = 0
                while k < catches.len:
                    mut cc = catches.get(k).read()
                    mut hcc_val = HirCatchClause()
                    hcc_val.err_name = cc.err_name
                    hcc_val.err_type = AstType.init("str")
                    if cc.err_type as usize != 0 as usize: hcc_val.err_type = cc.err_type.read()
                    hcc_val.body = self.lower_block(cc.body.read())
                    unsafe:
                        mut hcc = alloc[HirCatchClause](1)
                        hcc.write(hcc_val)
                        h_catches.push(hcc)
                    k = k + 1
                mut h_finally_b = self.lower_block(finally_b)
                self.block_depth = self.block_depth - 1
                self.close_block()
                return box_hirstmt(HirStmt.STry(h_try_body, h_catches, h_finally_b))
            case Stmt.SRaise(e): return box_hirstmt(HirStmt.SRaise(self.lower_expr(e)))
            case Stmt.SAssert(cond, msg): return box_hirstmt(HirStmt.SAssert(self.lower_expr(cond), self.lower_expr(msg)))
            case Stmt.SDefer(inner):
                return box_hirstmt(HirStmt.SDefer(self.lower_stmt(inner)))
            case Stmt.SWith(items, aliases, body):
                self.enter_scope()
                mut h_items = Vec[Pointer[HirExpr]].init(items.len)
                mut k = 0
                while k < items.len:
                    mut h_wi = self.lower_expr(items.get(k))
                    h_items.push(h_wi)
                    # Declare the alias so body can reference it
                    if k < aliases.len and aliases.get(k) != "":
                        mut wi_ty = hir_expr_type(h_wi)
                        self.declare(aliases.get(k), SymbolKind.SVariable, box_asttype(wi_ty), true)
                    k = k + 1
                mut h_with_body = self.lower_block(body)
                self.finalize_scope_drops(h_with_body)
                self.exit_scope()
                return box_hirstmt(HirStmt.SWith(h_items, aliases, h_with_body))
            case Stmt.SAsm(code, outputs, inputs, clobbers):
                return box_hirstmt(HirStmt.SAsm(code, outputs, inputs, clobbers))
            case Stmt.SSpawn(e):
                if not self.in_async_fn:
                    self.error("[C-5] 'spawn:' used outside an async function. FIX: Declare '" + self.current_func_name + "' as 'async def " + self.current_func_name + "(...)' to use spawn inside it.")
                mut spawn_lowered = self.lower_expr(e)
                self.check_spawn_sendable(spawn_lowered)
                return box_hirstmt(HirStmt.SSpawn(spawn_lowered))
            case Stmt.STaskGroup(body):
                if not self.in_async_fn:
                    self.error("[C-6] 'taskgroup:' used outside an async function. FIX: Declare '" + self.current_func_name + "' as 'async def " + self.current_func_name + "(...)' to use taskgroup inside it.")
                self.block_depth = self.block_depth + 1
                self.open_block()
                mut h_tg_body = self.lower_block(body)
                self.block_depth = self.block_depth - 1
                self.close_block()
                return box_hirstmt(HirStmt.STaskGroup(h_tg_body))
            case Stmt.SChanSelect(cs_cases):
                mut hcs_cases = Vec[Pointer[HirChanSelectArm]].init(cs_cases.len)
                mut csi2 = 0
                while csi2 < cs_cases.len:
                    mut arm = cs_cases.get(csi2).read()
                    mut harm = Pointer[HirChanSelectArm](0)
                    unsafe: harm = alloc[HirChanSelectArm](1)
                    mut harm_v = HirChanSelectArm()
                    harm_v.kind = arm.kind
                    harm_v.var_name = arm.var_name
                    if arm.chan_expr as usize != 0 as usize:
                        harm_v.chan_expr = self.lower_expr(arm.chan_expr)
                    else:
                        harm_v.chan_expr = Pointer[HirExpr](0)
                    if arm.val_expr as usize != 0 as usize:
                        harm_v.val_expr = self.lower_expr(arm.val_expr)
                    else:
                        harm_v.val_expr = Pointer[HirExpr](0)
                    if arm.timeout_ms as usize != 0 as usize:
                        harm_v.timeout_ms = self.lower_expr(arm.timeout_ms)
                    else:
                        harm_v.timeout_ms = Pointer[HirExpr](0)
                    # For recv arms, declare the binding variable
                    self.enter_scope()
                    if arm.kind == 0 and arm.var_name != "":
                        mut recv_ty = AstType.init("int")
                        if arm.chan_expr as usize != 0 as usize:
                            mut chan_hir = harm_v.chan_expr
                            mut chan_ty = hir_expr_type(chan_hir)
                            if not _is_invalid_ptr(chan_ty.args as usize) and chan_ty.args.len > 0:
                                recv_ty = chan_ty.args.get(0).read()
                        self.declare(arm.var_name, SymbolKind.SVariable, box_asttype(recv_ty), true)
                    harm_v.body = self.lower_block(arm.body)
                    self.finalize_scope_drops(harm_v.body)
                    self.exit_scope()
                    unsafe: harm.write(harm_v)
                    hcs_cases.push(harm)
                    csi2 = csi2 + 1
                return box_hirstmt(HirStmt.SChanSelect(hcs_cases))
            case Stmt.SGpuBlock(body):
                self.block_depth = self.block_depth + 1
                self.open_block()
                mut h_gpu_body = self.lower_block(body)
                self.block_depth = self.block_depth - 1
                self.close_block()
                return box_hirstmt(HirStmt.SGpuBlock(h_gpu_body))
            case Stmt.SBreak: return box_hirstmt(HirStmt.SBreak)
            case Stmt.SContinue: return box_hirstmt(HirStmt.SContinue)
            case Stmt.SPass: return box_hirstmt(HirStmt.SPass)
            case Stmt.SLocalDecl(ldecl):
                if self.current_func_name != "main":
                    self.error("[E-2] Nested class/def/enum/interface declarations are only supported inside main().\n      FIX: Move this declaration to module (top-level) scope, or declare it inside main().")
                    return box_hirstmt(HirStmt.SPass)
                self.register_decl(ldecl)
                # lower_func/lower_class reset current_func_name/current_class_name
                # to "" on exit; save+restore so main's own context survives the
                # nested-decl lowering that happens mid-way through main's body.
                mut saved_ld_func_name = self.current_func_name
                mut saved_ld_class_name = self.current_class_name
                match ldecl.read():
                    case Decl.DFunction(ld_f):
                        self.nested_functions.push(self.lower_func(ld_f))
                    case Decl.DClass(ld_c):
                        self.nested_classes.push(self.lower_class(ld_c))
                    case Decl.DActor(ld_c):
                        self.nested_classes.push(self.lower_class(ld_c))
                    case Decl.DEnum(ld_e):
                        self.nested_enums.push(self.lower_enum(ld_e))
                    case Decl.DInterface(ld_i):
                        self.nested_interfaces.push(self.lower_interface(ld_i))
                    case Decl.DExtend(ld_target, ld_methods):
                        # Methods added via 'extend' on a nested class must land in
                        # that class's HirClass.methods (codegen emits method bodies
                        # from there, not from hp.functions) - find the already-lowered
                        # nested HirClass and append to it in place.
                        self.current_class_name = ld_target
                        mut ld_ci = 0
                        mut ld_found = false
                        while ld_ci < self.nested_classes.len:
                            mut ld_nc = self.nested_classes.get(ld_ci)
                            if ld_nc.name == ld_target:
                                mut ld_hi = 0
                                while ld_hi < ld_methods.len:
                                    ld_nc.methods.push(self.lower_func(ld_methods.get(ld_hi)))
                                    ld_hi = ld_hi + 1
                                self.nested_classes.set(ld_ci, ld_nc)
                                ld_found = true
                            ld_ci = ld_ci + 1
                        if not ld_found:
                            mut ld_hi2 = 0
                            while ld_hi2 < ld_methods.len:
                                self.nested_functions.push(self.lower_func(ld_methods.get(ld_hi2)))
                                ld_hi2 = ld_hi2 + 1
                    case _: pass
                self.current_func_name = saved_ld_func_name
                self.current_class_name = saved_ld_class_name
                return box_hirstmt(HirStmt.SPass)
            case Stmt.SUnsafe(body):
                # Gap 6: track unsafe boundary
                mut saved_unsafe = self.in_unsafe
                self.in_unsafe = true
                mut unsafe_hir = self.lower_block(body)
                self.in_unsafe = saved_unsafe
                return box_hirstmt(HirStmt.SUnsafe(unsafe_hir))
            case Stmt.SMultiLet(names, is_mut, val_ptr):
                mut hval = self.lower_expr(val_ptr)
                mut val_ty = hir_expr_type(hval)
                mut i = 0
                while i < names.len:
                    mut nty = AstType.init("int")
                    if val_ty.args.len > i: nty = val_ty.args.get(i).read()
                    self.declare(names.get(i), SymbolKind.SVariable, box_asttype(nty), is_mut)
                    i = i + 1
                return box_hirstmt(HirStmt.SMultiLet(names, is_mut, hval))
            case Stmt.SLine(n):
                self.current_line = n
                # Preserve the line number into HIR so codegen can emit a
                # `#line` directive (debug builds). With line directives off
                # it renders as the same no-op comment SPass used to produce,
                # keeping non-debug output byte-identical.
                return box_hirstmt(HirStmt.SLineMarker(n))
            case _: return box_hirstmt(HirStmt.SPass)

    pub def variant_field_ty(self, type_name: str, variant_name: str, field_idx: int) -> AstType:
        if self.enums.contains(type_name):
            mut enm = self.enums.get(type_name)
            mut vi = 0
            while vi < enm.variants.len:
                mut v = enm.variants.get(vi)
                if v.name == variant_name:
                    if field_idx < v.fields.len:
                        mut fp = v.fields.get(field_idx)
                        if fp.ty as usize != 0 as usize: return fp.ty.read()
                    return AstType.init("void")
                vi = vi + 1
        return AstType.init("void")

    pub def declare_pattern_binds(self, pat: Pattern):
        self.declare_pattern_binds_typed(pat, AstType.init("int"))

    # Like declare_pattern_binds but uses subj_ty for PBind so `case x if x.method():` works.
    pub def declare_pattern_binds_typed(self, pat: Pattern, subj_ty: AstType):
        match pat:
            case Pattern.PBind(name): self.declare(name, SymbolKind.SVariable, box_asttype(subj_ty), false)
            case Pattern.PVariantBind(type_name, variant_name, field):
                mut fty = self.variant_field_ty(type_name, variant_name, 0)
                if fty.name == "void": fty = AstType.init("int")
                self.declare(field, SymbolKind.SVariable, box_asttype(fty), false)
            case Pattern.PVariantBindMany(type_name, variant_name, fields):
                mut _pi = 0
                while _pi < fields.len:
                    mut _pf = fields.get(_pi)
                    if _pf != "_":
                        mut fty = self.variant_field_ty(type_name, variant_name, _pi)
                        if fty.name == "void": fty = AstType.init("int")
                        self.declare(_pf, SymbolKind.SVariable, box_asttype(fty), false)
                    _pi = _pi + 1
            case Pattern.PTuple(first, second):
                self.declare(first, SymbolKind.SVariable, box_asttype(AstType.init("int")), false)
                self.declare(second, SymbolKind.SVariable, box_asttype(AstType.init("int")), false)
            case Pattern.POr(pats):
                mut i = 0
                while i < pats.len:
                    self.declare_pattern_binds_typed(pats.get(i), subj_ty)
                    i = i + 1
            case _: pass

    pub def str_method_ret_ty(self, method: str) -> AstType:
        if method == "split" or method == "split_to_vec" or method == "split_once":
            return AstType.init_generic("Vec", box_asttype(AstType.init("str")))
        if method == "strip": return AstType.init("str")
        if method == "trim": return AstType.init("str")
        if method == "trim_left": return AstType.init("str")
        if method == "trim_right": return AstType.init("str")
        if method == "to_upper": return AstType.init("str")
        if method == "to_lower": return AstType.init("str")
        if method == "capitalize": return AstType.init("str")
        if method == "title": return AstType.init("str")
        if method == "reverse": return AstType.init("str")
        if method == "repeat": return AstType.init("str")
        if method == "replace": return AstType.init("str")
        if method == "replace_first": return AstType.init("str")
        if method == "slice": return AstType.init("str")
        if method == "strip_prefix": return AstType.init("str")
        if method == "strip_suffix": return AstType.init("str")
        if method == "remove_char": return AstType.init("str")
        if method == "join": return AstType.init("str")
        if method == "len": return AstType.init("int")
        if method == "index_of": return AstType.init("int")
        if method == "last_index_of": return AstType.init("int")
        if method == "count": return AstType.init("int")
        if method == "char_at": return AstType.init("int")
        if method == "parse_int": return AstType.init("int")
        if method == "to_int" or method == "to_i64": return AstType.init("int")
        if method == "to_float" or method == "to_f64": return AstType.init("float")
        if method == "starts_with": return AstType.init("bool")
        if method == "ends_with": return AstType.init("bool")
        if method == "contains_char": return AstType.init("bool")
        if method == "eq": return AstType.init("bool")
        if method == "is_digit": return AstType.init("bool")
        if method == "is_alpha": return AstType.init("bool")
        if method == "is_alnum": return AstType.init("bool")
        if method == "is_space": return AstType.init("bool")
        if method == "is_upper": return AstType.init("bool")
        if method == "is_lower": return AstType.init("bool")
        if method == "parse_bool": return AstType.init("bool")
        if method == "parse_float": return AstType.init("float")
        if method == "lines": return AstType.init("Vec")
        if method == "words": return AstType.init("Vec")
        return AstType.init("void")

    pub def lower_expr(self, e_ptr: Pointer[Expr]) -> Pointer[HirExpr]:
        if e_ptr as usize == 0 as usize: return Pointer[HirExpr](0)
        e = e_ptr.read()
        match e:
            case Expr.ELitInt(v): return box_hirexpr(HirExpr.ELitInt(v, AstType.init("int")))
            case Expr.ELitFloat(v): return box_hirexpr(HirExpr.ELitFloat(v, AstType.init("float")))
            case Expr.ELitStr(v): return box_hirexpr(HirExpr.ELitStr(v, AstType.init("str")))
            case Expr.ERawStr(v): return box_hirexpr(HirExpr.ERawStr(v, AstType.init("str")))
            case Expr.ELitBytes(v): return box_hirexpr(HirExpr.ELitBytes(v, AstType.init("Bytes")))
            case Expr.ELitBool(v): return box_hirexpr(HirExpr.ELitBool(v, AstType.init("bool")))
            case Expr.ELitChar(v): return box_hirexpr(HirExpr.ELitChar(v, AstType.init("char")))
            case Expr.ELitNone: return box_hirexpr(HirExpr.ELitNone(AstType.init("None")))
            case Expr.EIdent(name):
                mut sym = self.resolve(name)
                mut ty = sym.ty.read()
                # First-class function reference: a top-level function used as a
                # value carries its def(...)->R signature (not its return type).
                if self.fn_sigs.contains(name) and sym.kind == SymbolKind.SFunction:
                    return box_hirexpr(HirExpr.EIdent(name, self.fn_sigs.get(name), false))
                # [M-6] use-after-free: dealloc() was called on this pointer
                if sym.is_freed and sym.name != "":
                    self.error("[M-6] '" + name + "' was freed by 'dealloc()' and can no longer be used.\n      FIX: Remove all uses of '" + name + "' after 'dealloc()', or restructure so the pointer is freed only when no longer needed.")
                # Phase 1: use-after-definite-move (hard error)
                elif sym.is_moved and not self.is_primitive(ty) and not self.is_copy_class(ty.name) and sym.name != "" and not sym.is_shared:
                    self.error("[M-1] '" + name + "' was moved and cannot be used again.\n      FIX: Use the variable that now owns it, or call .clone() to copy before moving.")
                # Fix 1: use-after-maybe-move - hard error (moved in some branch = definitely unsafe to use)
                elif sym.is_maybe_moved and not self.is_primitive(ty) and not self.is_copy_class(ty.name) and sym.name != "" and not sym.is_shared:
                    self.error("[M-5] '" + name + "' may have been moved on some code paths, making this use unsafe.\n      FIX: Ensure '" + name + "' is not moved before this point on any branch, or restructure so the use is inside the branch where it's still valid.")
                # Phase D: use-before-definite-init (hard error)
                if not sym.is_init and not sym.is_maybe_init and sym.name != "" and sym.kind == SymbolKind.SVariable and not self.in_assign_target:
                    self.error("[I-1] Variable '" + name + "' is used before being assigned a value.\n      FIX: Assign a value before use, e.g. 'mut " + name + " = <default>'.")
                # Fix 4: use-before-maybe-init - hard error (uninitialized on some path = unsafe)
                elif sym.is_maybe_init and not sym.is_init and sym.name != "" and sym.kind == SymbolKind.SVariable and not self.in_assign_target:
                    self.error("[I-2] '" + name + "' is not initialized on all code paths before this use.\n      FIX: Initialize '" + name + "' before the if/loop, or ensure every branch assigns a value.")
                mut is_move = false
                if self.assign_froms.contains(name) and not self.is_primitive(ty): is_move = true
                return box_hirexpr(HirExpr.EIdent(name, ty, is_move))
            case Expr.EBinOp(op, left, right):
                mut hleft = self.lower_expr(left)
                mut hright = self.lower_expr(right)
                mut bin_ty = hir_expr_type(hleft)
                if bin_ty.name == "void": bin_ty = hir_expr_type(hright)
                if op == "==" or op == "!=" or op == "<" or op == ">" or op == "<=" or op == ">=" or op == "and" or op == "or" or op == "&&" or op == "||":
                    bin_ty = AstType.init("bool")
                elif op == "*" and (hir_expr_type(hleft).name == "str" or hir_expr_type(hleft).name == "String" or hir_expr_type(hright).name == "str" or hir_expr_type(hright).name == "String"):
                    bin_ty = AstType.init("str")
                return box_hirexpr(HirExpr.EBinOp(op, hleft, hright, bin_ty))
            case Expr.EUnaryOp(op, expr):
                mut hexpr_inner = self.lower_expr(expr)
                mut inner_ty = hir_expr_type(hexpr_inner)
                mut un_ty = inner_ty
                if op == "&":
                    mut addr_ty = AstType.init("Pointer")
                    addr_ty.args.push(box_asttype(inner_ty))
                    un_ty = addr_ty
                elif op == "*":
                    if inner_ty.name == "Pointer" and inner_ty.args.len > 0:
                        un_ty = inner_ty.args.get(0).read()
                return box_hirexpr(HirExpr.EUnaryOp(op, hexpr_inner, un_ty))
            case Expr.ECall(callee, args):
                # Special built-in: await_timeout(async_expr, ms) -> EAwaitTimeout
                if callee as usize != 0 as usize:
                    match callee.read():
                        case Expr.EIdent(ato_n):
                            if ato_n == "await_timeout":
                                if not self.in_async_fn:
                                    self.error("[C-4] 'await_timeout' used outside an async function.")
                                if args.len < 2:
                                    self.error("await_timeout requires 2 arguments: await_timeout(expr, timeout_ms)")
                                    return box_hirexpr(HirExpr.ELitInt(0, AstType.init("int")))
                                mut ato_inner = self.lower_expr(args.get(0))
                                mut ato_ms = self.lower_expr(args.get(1))
                                mut ato_ty = hir_expr_type(ato_inner)
                                return box_hirexpr(HirExpr.EAwaitTimeout(ato_inner, ato_ms, ato_ty))
                            # #10: instanceOf(obj, T) - compile-time type check.
                            # Compares obj's static type name against T (a class/
                            # enum/primitive type name), evaluating to a bool literal.
                            if ato_n == "instanceOf":
                                if args.len < 2:
                                    self.error("instanceOf requires 2 arguments: instanceOf(obj, T)")
                                    return box_hirexpr(HirExpr.ELitBool(false, AstType.init("bool")))
                                mut io_obj = self.lower_expr(args.get(0))
                                mut io_obj_ty_n: str = hir_expr_type(io_obj).name
                                mut io_target_n = ""
                                match args.get(1).read():
                                    case Expr.EIdent(io_tn): io_target_n = io_tn
                                    case Expr.EIndex(io_base, _):
                                        match io_base.read():
                                            case Expr.EIdent(io_tn2): io_target_n = io_tn2
                                            case _: pass
                                    case _: pass
                                return box_hirexpr(HirExpr.ELitBool(io_obj_ty_n == io_target_n, AstType.init("bool")))
                            # #9: inspect(T) - returns a help()-style description
                            # of a class/enum/interface/function/builtin type as
                            # a string literal, computed entirely at compile time.
                            if ato_n == "inspect":
                                if args.len < 1:
                                    self.error("inspect requires 1 argument: inspect(T)")
                                    return box_hirexpr(HirExpr.ELitStr("", AstType.init("str")))
                                mut isp_target_n = ""
                                match args.get(0).read():
                                    case Expr.EIdent(isp_tn): isp_target_n = isp_tn
                                    case Expr.EIndex(isp_base, _):
                                        match isp_base.read():
                                            case Expr.EIdent(isp_tn2): isp_target_n = isp_tn2
                                            case _: pass
                                    case _: pass
                                if isp_target_n == "":
                                    mut isp_obj = self.lower_expr(args.get(0))
                                    isp_target_n = hir_expr_type(isp_obj).name
                                return box_hirexpr(HirExpr.ELitStr(self.build_inspect_str(isp_target_n), AstType.init("str")))
                        case _: pass
                # Phase 2+3: iterate AST args - mark borrows (P2) and detect aliasing (P3)
                mut p23_borrow_names = Vec[str].init(4)
                mut p23_seen = Map[str, bool].init(4)
                mut p23_k = 0
                while p23_k < args.len:
                    mut p23_arg = args.get(p23_k)
                    mut p23_nm = ""
                    if p23_arg as usize != 0 as usize:
                        match p23_arg.read():
                            case Expr.EIdent(p23_n): p23_nm = p23_n
                            case _: pass
                    if p23_nm != "":
                        mut p23_sym = self.resolve(p23_nm)
                        if not self.is_primitive(p23_sym.ty.read()) and p23_sym.name != "":
                            self.mark_borrow(p23_nm)
                            p23_borrow_names.push(p23_nm)
                            if p23_seen.contains(p23_nm):
                                self.error("[M-3] '" + p23_nm + "' appears twice in the same call, creating aliased mutable access.\n      FIX: Clone one of the arguments: " + p23_nm + ".clone()")
                            p23_seen.insert(p23_nm, true)
                    p23_k = p23_k + 1
                mut hl = Vec[Pointer[HirExpr]].init(4)
                mut k = 0
                while k < args.len:
                    hl.push(self.lower_expr(args.get(k)))
                    k = k + 1
                # Phase 2: release borrows after call
                mut p23_ui = 0
                while p23_ui < p23_borrow_names.len:
                    self.unmark_borrow(p23_borrow_names.get(p23_ui))
                    p23_ui = p23_ui + 1
                # #14: trailing variadic param - collect trailing call args into
                # a single List[T] literal matching the callee's variadic param.
                if callee as usize != 0 as usize:
                    match callee.read():
                        case Expr.EIdent(vfn_n):
                            if self.variadic_fns.contains(vfn_n):
                                mut vfixed = self.variadic_fns.get(vfn_n).to_int()
                                mut velem_ty = AstType.init("int")
                                if self.variadic_elem_ty.contains(vfn_n):
                                    velem_ty = self.variadic_elem_ty.get(vfn_n).read()
                                if hl.len >= vfixed:
                                    mut vargs = Vec[Pointer[HirExpr]].init(4)
                                    mut vi = vfixed
                                    while vi < hl.len:
                                        vargs.push(hl.get(vi))
                                        vi = vi + 1
                                    mut vlist_ty = AstType.init("List")
                                    vlist_ty.args.push(box_asttype(velem_ty))
                                    mut vnew_hl = Vec[Pointer[HirExpr]].init(vfixed + 1)
                                    mut vk = 0
                                    while vk < vfixed:
                                        vnew_hl.push(hl.get(vk))
                                        vk = vk + 1
                                    vnew_hl.push(box_hirexpr(HirExpr.EList(vargs, vlist_ty)))
                                    hl = vnew_hl
                        case _: pass
                mut hcallee = self.lower_expr(callee)
                mut ret_ty = AstType.init("void")
                if callee as usize == 0 as usize: return box_hirexpr(HirExpr.ECall(hcallee, hl, ret_ty))
                match callee.read():
                    case Expr.EIdent(n):
                        if n == "main":
                            self.error("[E-1] Explicit call to 'main()' is forbidden. The compiler automatically invokes main() as the program entry point. Remove the 'main()' call from your source.")
                            return box_hirexpr(HirExpr.ECall(hcallee, hl, ret_ty))
                        if self.classes.contains(n) or n == "StringObj" or n == "StringBuilder" or n == "List" or n == "Vec" or n == "Pointer" or n == "Map" or n == "Dict":
                            ret_ty = AstType.init(n)
                        elif self.enums.contains(n):
                            ret_ty = AstType.init(n)
                        elif n == "alloc" or n == "dealloc":
                            ret_ty = AstType.init("Pointer")
                            if not self.in_unsafe:
                                self.error("[U-1] '" + n + "' used outside an 'unsafe:' block.\n      FIX: Wrap raw memory operations in 'unsafe:' to signal manual memory management, e.g.\n          unsafe:\n              p = " + n + "[T](n)")
                        else:
                            mut _fsym = self.resolve(n)
                            ret_ty = _fsym.ty.read()
                            # Calling through a function-pointer value (def(...)->R):
                            # the call result is the signature's return type (last arg).
                            if ret_ty.name == "def" and ret_ty.args.len > 0:
                                ret_ty = ret_ty.args.get(ret_ty.args.len - 1).read()
                    case Expr.EIndex(base, idx):
                        match base.read():
                            case Expr.EIdent(gn):
                                if gn == "alloc" or gn == "dealloc":
                                    match idx.read():
                                        case Expr.EIdent(tn):
                                            ret_ty = AstType.init("Pointer")
                                            ret_ty.args.push(box_asttype(AstType.init(tn)))
                                        case _:
                                            ret_ty = AstType.init("Pointer")
                                    if not self.in_unsafe:
                                        self.error("[U-1] 'alloc'/'dealloc' used outside an 'unsafe:' block.\n      FIX: Wrap raw memory operations in 'unsafe:' to signal manual memory management, e.g.\n          unsafe:\n              p = " + gn + "[T](n)")
                                elif gn == "Pointer" or gn == "List" or gn == "Vec" or gn == "Map" or gn == "Dict":
                                    match idx.read():
                                        case Expr.EIdent(tn):
                                            ret_ty = AstType.init(gn)
                                            ret_ty.args.push(box_asttype(AstType.init(tn)))
                                        case _:
                                            ret_ty = AstType.init(gn)
                                elif self.classes.contains(gn):
                                    ret_ty = AstType.init(gn)
                                    match idx.read():
                                        case Expr.EIdent(targ_ca): ret_ty.args.push(box_asttype(AstType.init(targ_ca)))
                                        case _: pass
                                elif self.enums.contains(gn):
