                    k = k + 1
                mut hobj = self.lower_expr(obj)
                # Auto-drop: an explicit manual `.free()` call marks the variable as
                # freed so the compiler doesn't also auto-drop it (would double-free).
                # Must run AFTER lowering `obj` above, so this call's own move-check
                # doesn't see the freed state it is about to set.
                if method == "free":
                    match obj.read():
                        case Expr.EIdent(free_nm):
