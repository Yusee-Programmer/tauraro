                mut obj_is_type = obj_name == "Vec" or obj_name == "List" or obj_name == "Map" or obj_name == "Dict" or obj_name == "Set" or obj_name == "Pointer" or obj_name == "alloc" or obj_name == "dealloc" or obj_name == "resize" or obj_name == "copy" or self.classes.contains(obj_name) or self.enums.contains(obj_name)
                if is_generic and obj_is_type:
