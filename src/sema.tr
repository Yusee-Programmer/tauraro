                self.in_unsafe = true
                mut unsafe_hir = self.lower_block(body)
                self.in_unsafe = saved_unsafe
                return box_hirstmt(HirStmt.SUnsafe(unsafe_hir))
            case Stmt.SMultiLet(names, is_mut, val_ptr):
                mut hval = self.lower_expr(val_ptr)
                mut i = 0
                while i < names.len:
                    self.declare(names.get(i), SymbolKind.SVariable, box_asttype(AstType.init("int")), is_mut)
                    i = i + 1
                return box_hirstmt(HirStmt.SMultiLet(names, is_mut, hval))
            case Stmt.SLine(n):
                self.current_line = n
                return box_hirstmt(HirStmt.SPass)
            case _: return box_hirstmt(HirStmt.SPass)

    pub def variant_field_ty(self, type_name: str, variant_name: str, field_idx: int) -> AstType:
        if self.enums.contains(type_name):
            mut enm = self.enums.get(type_name)
            mut vi = 0
            while vi < enm.variants.len:
                mut v = enm.variants.get(vi)
                if v.name == variant_name:
                    if field_idx < v.fields.len:
                        mut fp = v.fields.get(field_idx)
                        if fp.ty as usize != 0 as usize: return fp.ty.read()
                    return AstType.init("void")
                vi = vi + 1
        return AstType.init("void")

    pub def declare_pattern_binds(self, pat: Pattern):
        match pat:
            case Pattern.PBind(name): self.declare(name, SymbolKind.SVariable, box_asttype(AstType.init("int")), false)
            case Pattern.PVariantBind(type_name, variant_name, field):
                mut fty = self.variant_field_ty(type_name, variant_name, 0)
                if fty.name == "void": fty = AstType.init("int")
                self.declare(field, SymbolKind.SVariable, box_asttype(fty), false)
            case Pattern.PVariantBindMany(type_name, variant_name, fields):
                mut _pi = 0
                while _pi < fields.len:
                    mut _pf = fields.get(_pi)
                    if _pf != "_":
                        mut fty = self.variant_field_ty(type_name, variant_name, _pi)
                        if fty.name == "void": fty = AstType.init("int")
                        self.declare(_pf, SymbolKind.SVariable, box_asttype(fty), false)
                    _pi = _pi + 1
            case Pattern.PTuple(first, second):
                self.declare(first, SymbolKind.SVariable, box_asttype(AstType.init("int")), false)
                self.declare(second, SymbolKind.SVariable, box_asttype(AstType.init("int")), false)
            case Pattern.POr(pats):
                mut i = 0
                while i < pats.len:
                    self.declare_pattern_binds(pats.get(i))
                    i = i + 1
            case _: pass

    pub def lower_expr(self, e_ptr: Pointer[Expr]) -> Pointer[HirExpr]:
        if e_ptr as usize == 0 as usize: return Pointer[HirExpr](0)
        e = e_ptr.read()
        match e:
            case Expr.ELitInt(v): return box_hirexpr(HirExpr.ELitInt(v, AstType.init("int")))
            case Expr.ELitFloat(v): return box_hirexpr(HirExpr.ELitFloat(v, AstType.init("float")))
            case Expr.ELitStr(v): return box_hirexpr(HirExpr.ELitStr(v, AstType.init("str")))
            case Expr.ERawStr(v): return box_hirexpr(HirExpr.ERawStr(v, AstType.init("str")))
            case Expr.ELitBytes(v): return box_hirexpr(HirExpr.ELitBytes(v, AstType.init("Bytes")))
            case Expr.ELitBool(v): return box_hirexpr(HirExpr.ELitBool(v, AstType.init("bool")))
            case Expr.ELitChar(v): return box_hirexpr(HirExpr.ELitChar(v, AstType.init("char")))
            case Expr.ELitNone: return box_hirexpr(HirExpr.ELitNone(AstType.init("None")))
            case Expr.EIdent(name):
                mut sym = self.resolve(name)
                mut ty = sym.ty.read()
                # [M-6] use-after-free: dealloc() was called on this pointer
                if sym.is_freed and sym.name != "":
                    self.error("[M-6] '" + name + "' was freed by 'dealloc()' and can no longer be used.\n      FIX: Remove all uses of '" + name + "' after 'dealloc()', or restructure so the pointer is freed only when no longer needed.")
                # Phase 1: use-after-definite-move (hard error)
                elif sym.is_moved and not self.is_primitive(ty) and not self.is_copy_class(ty.name) and sym.name != "" and not sym.is_shared:
                    self.error("[M-1] '" + name + "' was moved and cannot be used again.\n      FIX: Use the variable that now owns it, or call .clone() to copy before moving.")
                # Fix 1: use-after-maybe-move — hard error (moved in some branch = definitely unsafe to use)
                elif sym.is_maybe_moved and not self.is_primitive(ty) and not self.is_copy_class(ty.name) and sym.name != "" and not sym.is_shared:
                    self.error("[M-5] '" + name + "' may have been moved on some code paths, making this use unsafe.\n      FIX: Ensure '" + name + "' is not moved before this point on any branch, or restructure so the use is inside the branch where it's still valid.")
                # Phase D: use-before-definite-init (hard error)
                if not sym.is_init and not sym.is_maybe_init and sym.name != "" and sym.kind == SymbolKind.SVariable and not self.in_assign_target:
                    self.error("[I-1] Variable '" + name + "' is used before being assigned a value.\n      FIX: Assign a value before use, e.g. 'mut " + name + " = <default>'.")
                # Fix 4: use-before-maybe-init — hard error (uninitialized on some path = unsafe)
                elif sym.is_maybe_init and not sym.is_init and sym.name != "" and sym.kind == SymbolKind.SVariable and not self.in_assign_target:
                    self.error("[I-2] '" + name + "' is not initialized on all code paths before this use.\n      FIX: Initialize '" + name + "' before the if/loop, or ensure every branch assigns a value.")
                mut is_move = false
                if self.assign_froms.contains(name) and not self.is_primitive(ty): is_move = true
                return box_hirexpr(HirExpr.EIdent(name, ty, is_move))
            case Expr.EBinOp(op, left, right):
                mut hleft = self.lower_expr(left)
                mut hright = self.lower_expr(right)
                mut bin_ty = hir_expr_type(hleft)
                if bin_ty.name == "void": bin_ty = hir_expr_type(hright)
                if op == "==" or op == "!=" or op == "<" or op == ">" or op == "<=" or op == ">=" or op == "and" or op == "or" or op == "&&" or op == "||":
                    bin_ty = AstType.init("bool")
                return box_hirexpr(HirExpr.EBinOp(op, hleft, hright, bin_ty))
            case Expr.EUnaryOp(op, expr):
                mut hexpr_inner = self.lower_expr(expr)
                return box_hirexpr(HirExpr.EUnaryOp(op, hexpr_inner, hir_expr_type(hexpr_inner)))
            case Expr.ECall(callee, args):
                # Special built-in: await_timeout(async_expr, ms) → EAwaitTimeout
                if callee as usize != 0 as usize:
                    match callee.read():
                        case Expr.EIdent(ato_n):
                            if ato_n == "await_timeout":
                                if not self.in_async_fn:
                                    self.error("[C-4] 'await_timeout' used outside an async function.")
                                if args.len < 2:
                                    self.error("await_timeout requires 2 arguments: await_timeout(expr, timeout_ms)")
                                    return box_hirexpr(HirExpr.ELitInt(0, AstType.init("int")))
                                mut ato_inner = self.lower_expr(args.get(0))
                                mut ato_ms = self.lower_expr(args.get(1))
                                mut ato_ty = hir_expr_type(ato_inner)
                                return box_hirexpr(HirExpr.EAwaitTimeout(ato_inner, ato_ms, ato_ty))
                        case _: pass
                # Phase 2+3: iterate AST args — mark borrows (P2) and detect aliasing (P3)
                mut p23_borrow_names = Vec[str].init(4)
                mut p23_seen = Map[str, bool].init(4)
                mut p23_k = 0
                while p23_k < args.len:
                    mut p23_arg = args.get(p23_k)
                    mut p23_nm = ""
                    if p23_arg as usize != 0 as usize:
                        match p23_arg.read():
                            case Expr.EIdent(p23_n): p23_nm = p23_n
                            case _: pass
                    if p23_nm != "":
                        mut p23_sym = self.resolve(p23_nm)
                        if not self.is_primitive(p23_sym.ty.read()) and p23_sym.name != "":
                            self.mark_borrow(p23_nm)
                            p23_borrow_names.push(p23_nm)
                            if p23_seen.contains(p23_nm):
                                self.error("[M-3] '" + p23_nm + "' appears twice in the same call, creating aliased mutable access.\n      FIX: Clone one of the arguments: " + p23_nm + ".clone()")
                            p23_seen.insert(p23_nm, true)
                    p23_k = p23_k + 1
                mut hl = Vec[Pointer[HirExpr]].init(4)
                mut k = 0
                while k < args.len:
                    hl.push(self.lower_expr(args.get(k)))
                    k = k + 1
                # Phase 2: release borrows after call
                mut p23_ui = 0
                while p23_ui < p23_borrow_names.len:
                    self.unmark_borrow(p23_borrow_names.get(p23_ui))
                    p23_ui = p23_ui + 1
                mut hcallee = self.lower_expr(callee)
                mut ret_ty = AstType.init("void")
                if callee as usize == 0 as usize: return box_hirexpr(HirExpr.ECall(hcallee, hl, ret_ty))
                match callee.read():
                    case Expr.EIdent(n):
                        if n == "main":
                            self.error("[E-1] Explicit call to 'main()' is forbidden. The compiler automatically invokes main() as the program entry point. Remove the 'main()' call from your source.")
                            return box_hirexpr(HirExpr.ECall(hcallee, hl, ret_ty))
                        if self.classes.contains(n) or n == "StringObj" or n == "StringBuilder" or n == "List" or n == "Vec" or n == "Pointer" or n == "Map" or n == "Dict":
                            ret_ty = AstType.init(n)
                        elif self.enums.contains(n):
                            ret_ty = AstType.init(n)
                        elif n == "alloc" or n == "dealloc":
                            ret_ty = AstType.init("Pointer")
                        else:
                            mut _fsym = self.resolve(n)
                            ret_ty = _fsym.ty.read()
                    case Expr.EIndex(base, idx):
                        match base.read():
                            case Expr.EIdent(gn):
                                if gn == "alloc" or gn == "dealloc":
                                    match idx.read():
                                        case Expr.EIdent(tn):
                                            ret_ty = AstType.init("Pointer")
                                            ret_ty.args.push(box_asttype(AstType.init(tn)))
                                        case _:
                                            ret_ty = AstType.init("Pointer")
                                    if self.strict_mode and not self.in_unsafe:
                                        self.error("[U-1] 'alloc'/'dealloc' used outside an 'unsafe:' block.\n      FIX: Wrap raw memory operations in 'unsafe:' to signal manual memory management.\n      Or remove --strict to allow this pattern.")
                                elif gn == "Pointer" or gn == "List" or gn == "Vec" or gn == "Map" or gn == "Dict":
                                    match idx.read():
                                        case Expr.EIdent(tn):
                                            ret_ty = AstType.init(gn)
                                            ret_ty.args.push(box_asttype(AstType.init(tn)))
                                        case _:
                                            ret_ty = AstType.init(gn)
                                elif self.classes.contains(gn):
                                    ret_ty = AstType.init(gn)
                                    match idx.read():
                                        case Expr.EIdent(targ_ca): ret_ty.args.push(box_asttype(AstType.init(targ_ca)))
                                        case _: pass
                                elif self.enums.contains(gn):
                                    ret_ty = AstType.init(gn)
                                else:
                                    # Generic function call: fname[T](args) — mangle callee name
                                    match idx.read():
                                        case Expr.EIdent(farg_c):
                                            mut fret = AstType.init(farg_c)
                                            ret_ty = fret
                                            hcallee = box_hirexpr(HirExpr.EIdent(gn + "__MONO_" + farg_c, fret, false))
                                        case _: pass
                            case _: pass
                    case Expr.EPropAccess(obj, variant):
                        match obj.read():
                            case Expr.EIdent(type_name):
                                if self.enums.contains(type_name):
                                    ret_ty = AstType.init(type_name)
                                elif variant == "init" or variant == "new":
                                    if type_name == "Pointer" or type_name == "List" or type_name == "Vec" or type_name == "Map" or type_name == "Dict":
                                        ret_ty = AstType.init(type_name)
                                    elif self.classes.contains(type_name):
                                        ret_ty = AstType.init(type_name)
                            case Expr.EIndex(base2, idx2):
                                if variant == "init" or variant == "new":
                                    match base2.read():
                                        case Expr.EIdent(gn2):
                                            if gn2 == "Pointer" or gn2 == "List" or gn2 == "Vec" or gn2 == "Map" or gn2 == "Dict":
                                                match idx2.read():
                                                    case Expr.EIdent(tn2):
                                                        ret_ty = AstType.init(gn2)
                                                        ret_ty.args.push(box_asttype(AstType.init(tn2)))
                                                    case _:
                                                        ret_ty = AstType.init(gn2)
                                            elif self.classes.contains(gn2):
                                                ret_ty = AstType.init(gn2)
                                                match idx2.read():
                                                    case Expr.EIdent(targ_cb): ret_ty.args.push(box_asttype(AstType.init(targ_cb)))
                                                    case _: pass
                                        case _: pass
                            case _: pass
                    case _: pass
                # await_all: all sub-calls run concurrently — each sub-call's args must be Sendable
                if callee as usize != 0 as usize:
                    match callee.read():
                        case Expr.EIdent(aa_nm):
                            if aa_nm == "await_all":
                                mut aa_i = 0
                                while aa_i < hl.len:
                                    self.check_spawn_sendable(hl.get(aa_i))
                                    aa_i = aa_i + 1
                        case _: pass
                # [M-6] dealloc tracking: mark pointer as freed to catch use-after-free and double-free
                if callee as usize != 0 as usize:
                    match callee.read():
                        case Expr.EIdent(df_nm):
                            if df_nm == "dealloc" and args.len > 0:
                                mut df_arg0 = args.get(0)
                                if df_arg0 as usize != 0 as usize:
                                    match df_arg0.read():
                                        case Expr.EIdent(df_ptr):
                                            mut df_sym = self.resolve(df_ptr)
                                            if df_sym.name != "":
                                                self.mark_freed(df_ptr)
                                        case _: pass
                        case _: pass
                return box_hirexpr(HirExpr.ECall(hcallee, hl, ret_ty))
            case Expr.EMethodCall(obj, method, args):
                if method == "__index__" and args.len > 0:
                    return self.lower_expr(box_expr(Expr.EIndex(obj, args.get(0))))
                mut hl = Vec[Pointer[HirExpr]].init(4)
                mut k = 0
                while k < args.len:
                    hl.push(self.lower_expr(args.get(k)))
                    k = k + 1
                mut hobj = self.lower_expr(obj)
                mut hobj_ty = hir_expr_type(hobj)
                # Phase C: error if mutating a container that has an active borrow
                if method == "push" or method == "pop" or method == "insert" or method == "remove":
                    mut pc_obj_nm = ""
                    match obj.read():
                        case Expr.EIdent(pc_src): pc_obj_nm = pc_src
                        case _: pass
                    if pc_obj_nm != "" and self.container_borrows.contains(pc_obj_nm):
                        mut pc_borrow_var = self.container_borrows.get(pc_obj_nm)
                        self.error("[M-4] Cannot mutate '" + pc_obj_nm + "' while '" + pc_borrow_var + "' holds a reference into it.\n      FIX: Finish using '" + pc_borrow_var + "' before modifying '" + pc_obj_nm + "', or copy it first: 'mut copy = " + pc_borrow_var + "'.")
                mut ret_ty = AstType.init("void")
                if method == "init" or method == "new":
                    # Preserve generic args so Vec[T].init(n) keeps the T info
                    if hobj_ty.name == "void" or hobj_ty.name == "":
                        # Built-in types used as static receivers (e.g. Atomic.new, Thread.new)
                        # resolve to void; recover type from the receiver identifier name.
                        match hobj.read():
                            case HirExpr.EIdent(recv_nm, _, _): ret_ty = AstType.init(recv_nm)
                            case _: ret_ty = hobj_ty
                    else:
                        ret_ty = hobj_ty
                elif method == "offset": ret_ty = hobj_ty
                elif method == "read":
                    if hobj_ty.name == "Pointer" and hobj_ty.args.len > 0: ret_ty = hobj_ty.args.get(0).read()
                    else: ret_ty = AstType.init("int")
                elif method == "as_str" or method == "to_str": ret_ty = AstType.init("str")
                elif method == "len" or method == "__len__": ret_ty = AstType.init("int")
                elif method == "get" or method == "pop":
                    if (hobj_ty.name == "List" or hobj_ty.name == "Vec") and hobj_ty.args.len > 0:
                        ret_ty = hobj_ty.args.get(0).read()
                    elif (hobj_ty.name == "Map" or hobj_ty.name == "Dict") and hobj_ty.args.len > 1:
                        ret_ty = hobj_ty.args.get(1).read()
                    elif hobj_ty.args.len > 0:
                        ret_ty = hobj_ty.args.get(0).read()
                    elif self.classes.contains(hobj_ty.name):
                        mut _gcls = self.classes.get(hobj_ty.name)
                        mut _gmi = 0
                        while _gmi < _gcls.methods.len:
                            mut _gmdef = _gcls.methods.get(_gmi)
                            if _gmdef.name == method:
                                if _gmdef.ret_ty as usize != 0 as usize:
                                    ret_ty = _gmdef.ret_ty.read()
                            _gmi = _gmi + 1
                elif method == "alloc": ret_ty = hobj_ty
                elif method == "contains": ret_ty = AstType.init("bool")
                # Thread built-in method return types
                elif method == "spawn" and (hobj_ty.name == "Thread" or hobj_ty.name == "void"):
                    ret_ty = AstType.init("Thread")
                    # Check all args (skip fn name at index 0) are Sendable
                    mut _tsi = 1
                    while _tsi < hl.len:
                        mut _tsa_ty = hir_expr_type(hl.get(_tsi))
                        if not self.is_sendable_type(_tsa_ty.name):
                            self.error("[T-1] Type '" + _tsa_ty.name + "' is not Sendable and cannot be passed to Thread.spawn.\n      FIX: Wrap in Mutex[" + _tsa_ty.name + "] for exclusive access, or add 'implements Sendable' to '" + _tsa_ty.name + "' to confirm it is thread-safe.")
                        _tsi = _tsi + 1
                # ThreadPool.spawn arg Sendable check
                elif method == "spawn" and hobj_ty.name == "ThreadPool":
                    ret_ty = AstType.init("void")
                    # Check all args (skip fn name at index 0) are Sendable
                    mut _psi = 1
                    while _psi < hl.len:
                        mut _psa_ty = hir_expr_type(hl.get(_psi))
                        if not self.is_sendable_type(_psa_ty.name):
                            self.error("[T-1] Type '" + _psa_ty.name + "' is not Sendable and cannot be passed to ThreadPool.spawn.\n      FIX: Wrap in Mutex[" + _psa_ty.name + "] for exclusive access, or add 'implements Sendable' to '" + _psa_ty.name + "' to confirm it is thread-safe.")
                        _psi = _psi + 1
                # Atomic built-in method return types
                elif hobj_ty.name == "Atomic":
                    if method == "load" or method == "get" or method == "add" or method == "sub" or method == "swap" or method == "exchange" or method == "fetch_add" or method == "fetch_sub" or method == "load_relaxed" or method == "load_acquire" or method == "load_seqcst" or method == "add_relaxed" or method == "add_release" or method == "add_acqrel" or method == "sub_relaxed" or method == "sub_release":
                        ret_ty = AstType.init("int")
                    elif method == "cas" or method == "compare_exchange" or method == "cas_weak" or method == "cas_acqrel":
                        ret_ty = AstType.init("bool")
                    elif method == "store" or method == "set" or method == "store_relaxed" or method == "store_release" or method == "store_seqcst":
                        ret_ty = AstType.init("void")
                # Chan[T] method return types
                elif hobj_ty.name == "Chan":
                    if method == "recv" or method == "try_recv":
                        if hobj_ty.args.len > 0: ret_ty = hobj_ty.args.get(0).read()
                        else: ret_ty = AstType.init("int")
                    elif method == "len" or method == "cap": ret_ty = AstType.init("int")
                    elif method == "is_closed" or method == "try_send": ret_ty = AstType.init("bool")
                    elif method == "send_timeout": ret_ty = AstType.init("bool")
                    elif method == "recv_timeout":
                        if hobj_ty.args.len > 0: ret_ty = hobj_ty.args.get(0).read()
                        else: ret_ty = AstType.init("int")
                # Mutex[T] method return types
                elif hobj_ty.name == "Mutex":
                    if method == "lock" or method == "get":
                        if hobj_ty.args.len > 0: ret_ty = hobj_ty.args.get(0).read()
                        else: ret_ty = AstType.init("int")
                # RwLock[T] method return types
                elif hobj_ty.name == "RwLock":
                    if method == "read" or method == "read_lock" or method == "write" or method == "write_lock":
                        if hobj_ty.args.len > 0: ret_ty = hobj_ty.args.get(0).read()
                        else: ret_ty = AstType.init("int")
                elif hobj_ty.name == "StringBuilder" and method == "to_string": ret_ty = AstType.init("StringObj")
                # Phase 4: Shared[T] method return types
                # Note: s1's HIR type is the inner T (not Shared[T]), so these branches
                # are reached only when an explicit Shared[T] annotation is used.
                elif hobj_ty.name == "Shared":
                    if method == "clone": ret_ty = hobj_ty
                    elif method == "is_null": ret_ty = AstType.init("bool")
                    elif method == "downgrade":
                        mut weak_ty = AstType.init("Weak")
                        if hobj_ty.args.len > 0:
                            weak_ty.args = Vec[Pointer[AstType]].init(1)
                            weak_ty.args.push(box_asttype(hobj_ty.args.get(0).read()))
                        ret_ty = weak_ty
                    elif method == "drop": ret_ty = AstType.init("void")
                # Phase 4: Weak[T] method return types
                elif hobj_ty.name == "Weak":
                    if method == "upgrade":
                        mut opt_ty = AstType.init("Option")
                        if hobj_ty.args.len > 0:
                            opt_ty.args = Vec[Pointer[AstType]].init(1)
                            opt_ty.args.push(box_asttype(hobj_ty.args.get(0).read()))
                        ret_ty = opt_ty
                    elif method == "is_alive": ret_ty = AstType.init("bool")
                elif self.interfaces as usize != 0 as usize and self.interfaces.contains(hobj_ty.name):
                    mut _iface_def = self.interfaces.get(hobj_ty.name)
                    mut _imi = 0
                    while _imi < _iface_def.methods.len:
                        mut _imdef = _iface_def.methods.get(_imi)
                        if _imdef.name == method:
                            if _imdef.ret_ty as usize != 0 as usize:
                                ret_ty = _imdef.ret_ty.read()
                        _imi = _imi + 1
                    # Substitute generic type params: T→concrete when interface has type args
                    if _iface_def.generics.len > 0 and hobj_ty.args.len > 0:
                        mut _gi5 = 0
                        while _gi5 < _iface_def.generics.len:
                            if _iface_def.generics.get(_gi5) == ret_ty.name:
                                if _gi5 < hobj_ty.args.len:
                                    ret_ty = hobj_ty.args.get(_gi5).read()
                            _gi5 = _gi5 + 1
                elif self.enums.contains(hobj_ty.name):
                    ret_ty = AstType.init(hobj_ty.name)
                elif self.classes.contains(hobj_ty.name):
                    mut _cls = self.classes.get(hobj_ty.name)
                    mut _mi = 0
                    while _mi < _cls.methods.len:
                        mut _mdef = _cls.methods.get(_mi)
                        if _mdef.name == method:
                            if _mdef.ret_ty as usize != 0 as usize:
                                ret_ty = _mdef.ret_ty.read()
                        _mi = _mi + 1
                    # Substitute generic type params: T→concrete when object has type args
                    if _cls.generics.len > 0 and hobj_ty.args.len > 0:
                        mut _gi4 = 0
                        while _gi4 < _cls.generics.len:
                            if _cls.generics.get(_gi4) == ret_ty.name:
                                if _gi4 < hobj_ty.args.len:
                                    ret_ty = hobj_ty.args.get(_gi4).read()
                            _gi4 = _gi4 + 1
                return box_hirexpr(HirExpr.EMethodCall(hobj, method, hl, ret_ty))
            case Expr.EPropAccess(obj, prop):
                mut hobj = self.lower_expr(obj)
                mut hobj_ty_n: str = hir_expr_type(hobj).name
                mut hobj_ty_full = hir_expr_type(hobj)
                mut ret_ty = AstType.init("void")
                if hobj_ty_n == "Result":
                    if prop == "is_err" or prop == "is_ok": ret_ty = AstType.init("bool")
                    elif prop == "ok" and hobj_ty_full.args.len > 0: ret_ty = hobj_ty_full.args.get(0).read()
                    elif prop == "err" and hobj_ty_full.args.len > 1: ret_ty = hobj_ty_full.args.get(1).read()
                elif hobj_ty_n == "Option":
                    if prop == "is_some" or prop == "is_none": ret_ty = AstType.init("bool")
                    elif (prop == "value" or prop == "val") and hobj_ty_full.args.len > 0: ret_ty = hobj_ty_full.args.get(0).read()
                elif hobj_ty_n == "StringObj":
                    if prop == "data": ret_ty = AstType.init("Pointer")
                    elif prop == "length" or prop == "capacity": ret_ty = AstType.init("int")
                elif hobj_ty_n == "StringBuilder":
                    if prop == "buf": ret_ty = AstType.init("StringObj")
                elif hobj_ty_n == "Vec" or hobj_ty_n == "List":
                    if prop == "len" or prop == "length" or prop == "capacity": ret_ty = AstType.init("int")
                    elif prop == "data": ret_ty = AstType.init("Pointer")
                elif hobj_ty_n == "Map" or hobj_ty_n == "Dict" or hobj_ty_n == "Set":
                    if prop == "len" or prop == "length" or prop == "capacity": ret_ty = AstType.init("int")
                elif self.classes.contains(hobj_ty_n):
                    mut _cls = self.classes.get(hobj_ty_n)
                    mut _fi = 0
                    while _fi < _cls.fields.len:
                        mut _fld = _cls.fields.get(_fi)
                        if _fld.name == prop:
                            if _fld.ty as usize != 0 as usize: ret_ty = _fld.ty.read()
                        _fi = _fi + 1
                if ret_ty.name == "void" and (prop == "len" or prop == "length" or prop == "capacity"):
                    ret_ty = AstType.init("int")
                return box_hirexpr(HirExpr.EPropAccess(hobj, prop, ret_ty))
            case Expr.EIndex(obj, idx_inner):
                mut hexpr_obj = self.lower_expr(obj)
                mut obj_ty_n: str = hir_expr_type(hexpr_obj).name
                mut obj_name = ""
                match obj.read():
                    case Expr.EIdent(n): obj_name = n
                    case _: pass
                mut is_generic = false
                mut generic_arg_n: str = ""
                if idx_inner as usize == 0 as usize:
                    return hexpr_obj
                match idx_inner.read():
                    case Expr.EIdent(iname):
                        mut is_param = false
                        if self.current_class_name != "":
                            if self.classes.contains(self.current_class_name):
                                mut cc = self.classes.get(self.current_class_name)
                                mut ci = 0
                                while ci < cc.generics.len:
                                    if cc.generics.get(ci) == iname: is_param = true
                                    ci = ci + 1
                        mut fi = 0
                        while fi < self.current_func_generics.len:
                            if self.current_func_generics.get(fi) == iname: is_param = true
                            fi = fi + 1

                        if self.is_primitive_name(iname) or iname == "str" or iname == "Str" or is_param or _tr_strlen(iname) == 1 or self.classes.contains(iname) or iname == "StringObj" or iname == "StringBuilder" or self.enums.contains(iname) or iname == "Vec" or iname == "List" or iname == "Map":
                            is_generic = true
                            generic_arg_n = iname
                    case Expr.EIndex(_, _):
                        is_generic = true
                        mut nested_ty = self.build_ast_type(idx_inner)
                        if nested_ty as usize != 0 as usize:
                            generic_arg_n = nested_ty.read().name
                    case _: pass
                if is_generic:
                    # For Vec[T] or List[T] — return the base expr but annotate its type with the generic arg
                    if (obj_ty_n == "Vec" or obj_ty_n == "List" or obj_ty_n == "Map" or obj_ty_n == "Pointer") and generic_arg_n != "":
                        mut container_ty = AstType.init(obj_ty_n)
                        container_ty.args = Vec[Pointer[AstType]].init(1)
                        container_ty.args.push(box_asttype(AstType.init(generic_arg_n)))
                        if obj_name == "alloc" or obj_name == "dealloc" or obj_name == "resize" or obj_name == "copy":
                             return box_hirexpr(HirExpr.EIndex(hexpr_obj, self.lower_expr(idx_inner), container_ty))
                        return box_hirexpr(HirExpr.EIdent(obj_ty_n, container_ty, false))
                    # User-defined generic class or enum: preserve the concrete type arg
                    if (self.classes.contains(obj_name) or self.enums.contains(obj_name)) and generic_arg_n != "":
                        mut cls_ty = AstType.init(obj_name)
                        cls_ty.args = Vec[Pointer[AstType]].init(1)
                        cls_ty.args.push(box_asttype(AstType.init(generic_arg_n)))
                        return box_hirexpr(HirExpr.EIdent(obj_name, cls_ty, false))
                    return hexpr_obj
                if not self.is_primitive_name(obj_ty_n) and obj_ty_n != "str" and obj_ty_n != "Pointer" and obj_ty_n != "List" and obj_ty_n != "Vec":
                    mut call_args = Vec[Pointer[HirExpr]].init(1)
                    call_args.push(self.lower_expr(idx_inner))
                    return box_hirexpr(HirExpr.EMethodCall(hexpr_obj, "get_index", call_args, AstType.init("void")))
                # EIndex type is the element type, not the container type
                mut elem_ty = AstType.init("void")
                if obj_ty_n == "List" or obj_ty_n == "Vec":
                    if hir_expr_type(hexpr_obj).args.len > 0:
                        elem_ty = hir_expr_type(hexpr_obj).args.get(0).read()
                elif obj_ty_n == "Pointer":
                    if hir_expr_type(hexpr_obj).args.len > 0:
                        elem_ty = hir_expr_type(hexpr_obj).args.get(0).read()
                elif obj_ty_n == "str": elem_ty = AstType.init("char")
                return box_hirexpr(HirExpr.EIndex(hexpr_obj, self.lower_expr(idx_inner), elem_ty))
            case Expr.ESizeOf(ty):
                if ty as usize == 0 as usize: return box_hirexpr(HirExpr.ESizeOf(AstType.init("void"), AstType.init("int")))
                return box_hirexpr(HirExpr.ESizeOf(ty.read(), AstType.init("int")))
            case Expr.ECast(expr, ty):
                if ty as usize == 0 as usize: return self.lower_expr(expr)
                return box_hirexpr(HirExpr.ECast(self.lower_expr(expr), ty.read()))
            case Expr.EFString(parts):
                mut hparts = Vec[HirFStringPart].init(4)
                mut m = 0
                while m < parts.len:
                    mut p_ast = parts.get(m)
                    mut hp = HirFStringPart.init()
                    hp.is_expr = p_ast.is_expr
                    hp.text = p_ast.text
                    hp.expr = self.lower_expr(p_ast.expr)
                    hparts.push(hp)
                    m = m + 1
                return box_hirexpr(HirExpr.EFString(hparts, AstType.init("str")))
            case Expr.ETuple(items):
                mut hitems = Vec[Pointer[HirExpr]].init(items.len)
                mut n = 0
                while n < items.len:
                    hitems.push(self.lower_expr(items.get(n)))
                    n = n + 1
                return box_hirexpr(HirExpr.ETuple(hitems, AstType.init("Tuple")))
            case Expr.EList(items):
                mut hitems = Vec[Pointer[HirExpr]].init(items.len)
                mut n = 0
                while n < items.len:
                    hitems.push(self.lower_expr(items.get(n)))
                    n = n + 1
                mut list_ty = AstType.init("List")
                if hitems.len > 0:
                    list_ty.args = Vec[Pointer[AstType]].init(1)
                    list_ty.args.push(box_asttype(hir_expr_type(hitems.get(0))))
                return box_hirexpr(HirExpr.EList(hitems, list_ty))
            case Expr.EClosure(params, ret_ty, body, is_async):
                self.enter_scope()
                mut hparams = Vec[HirParam].init(params.len)
                mut l = 0
                while l < params.len:
                    mut pa = params.get(l)
                    mut pa_ty = AstType.init("int")
                    if pa.ty as usize != 0 as usize: pa_ty = pa.ty.read()
                    self.declare(pa.name, SymbolKind.SVariable, box_asttype(pa_ty), false)
                    mut hpa = HirParam()
                    hpa.name = pa.name
                    hpa.ty = pa_ty
                    hparams.push(hpa)
                    l = l + 1
                mut r_ty = AstType.init("void")
                if ret_ty as usize != 0 as usize: r_ty = ret_ty.read()
                mut hexpr = HirExpr.EClosure(hparams, r_ty, self.lower_block(body), is_async, Vec[HirParam].init(0))
                self.exit_scope()
                return box_hirexpr(hexpr)
            case Expr.EIfElse(cond, then_e, else_e):
                mut hcond = self.lower_expr(cond)
                mut hthen = self.lower_expr(then_e)
                mut helse = self.lower_expr(else_e)
                mut ite_ty = hir_expr_type(hthen)
                return box_hirexpr(HirExpr.EIfElse(hcond, hthen, helse, ite_ty))
            case Expr.ETryExpr(inner):
                mut hinner = self.lower_expr(inner)
                mut inner_ty = hir_expr_type(hinner)
                # ? extracts the Ok type from a Result[T,E]
                mut ok_ty = AstType.init("void")
                if inner_ty.name == "Result" and inner_ty.args.len > 0:
                    ok_ty = inner_ty.args.get(0).read()
                elif inner_ty.name != "void":
                    ok_ty = inner_ty
                return box_hirexpr(HirExpr.ETryExpr(hinner, ok_ty))
            case Expr.EAwait(inner_await):
                # Rule C-4: await only valid inside async def
                if not self.in_async_fn:
                    self.error("[C-4] 'await' used outside an async function. FIX: Declare '" + self.current_func_name + "' as 'async def " + self.current_func_name + "(...)' to use await inside it.")
                mut hinner_await = self.lower_expr(inner_await)
                mut await_ty = hir_expr_type(hinner_await)
                return box_hirexpr(HirExpr.EAwait(hinner_await, await_ty))
            case Expr.EDict(keys, vals):
                mut h_keys = Vec[Pointer[HirExpr]].init(keys.len)
                mut h_vals = Vec[Pointer[HirExpr]].init(vals.len)
                mut di = 0
                while di < keys.len:
                    h_keys.push(self.lower_expr(keys.get(di)))
                    h_vals.push(self.lower_expr(vals.get(di)))
                    di = di + 1
                return box_hirexpr(HirExpr.EDict(h_keys, h_vals, AstType.init("Dict")))
            case Expr.EListComp(element, generators):
                self.enter_scope()
                mut hgens = Vec[Pointer[HirComprehension]].init(generators.len)
                mut gc: int = 0
                while gc < generators.len:
                    mut gen_ast: Comprehension = generators.get(gc).read()
                    mut hgen_ptr = alloc[HirComprehension](1)
                    mut hgen_val = HirComprehension()
                    hgen_val.target = gen_ast.target
                    mut h_iter_lc = self.lower_expr(gen_ast.iter)
                    hgen_val.iter = h_iter_lc
                    mut lc_itn = hir_expr_type(h_iter_lc).name
                    mut lc_ial = hir_expr_type(h_iter_lc).args.len
                    mut lc_elem_ty = AstType.init("int")
                    if (lc_itn == "List" or lc_itn == "Vec") and lc_ial > 0:
                        lc_elem_ty = hir_expr_type(h_iter_lc).args.get(0).read()
                    elif lc_itn == "str":
                        lc_elem_ty = AstType.init("char")
                    self.declare(gen_ast.target, SymbolKind.SVariable, box_asttype(lc_elem_ty), false)
                    mut hifs = Vec[Pointer[HirExpr]].init(gen_ast.ifs.len)
                    mut lc_fi = 0
                    while lc_fi < gen_ast.ifs.len:
                        hifs.push(self.lower_expr(gen_ast.ifs.get(lc_fi)))
                        lc_fi = lc_fi + 1
                    hgen_val.ifs = hifs
                    hgen_val.is_async = gen_ast.is_async
                    hgen_ptr.write(hgen_val)
                    hgens.push(hgen_ptr)
                    gc = gc + 1
                mut h_lc_elem = self.lower_expr(element)
                mut lc_elem_hty = hir_expr_type(h_lc_elem)
                mut comp_ty = AstType.init("List")
                comp_ty.args = Vec[Pointer[AstType]].init(1)
                comp_ty.args.push(box_asttype(lc_elem_hty))
                self.exit_scope()
                return box_hirexpr(HirExpr.EListComp(h_lc_elem, hgens, comp_ty))
            case Expr.EGeneratorExpr(element, generators):
                self.enter_scope()
                mut hgens2 = Vec[Pointer[HirComprehension]].init(generators.len)
                mut gc2: int = 0
                while gc2 < generators.len:
                    mut gen_ast2: Comprehension = generators.get(gc2).read()
                    mut hgen_ptr2 = alloc[HirComprehension](1)
                    mut hgen_val2 = HirComprehension()
                    hgen_val2.target = gen_ast2.target
                    mut h_iter_ge = self.lower_expr(gen_ast2.iter)
                    hgen_val2.iter = h_iter_ge
                    mut ge_itn = hir_expr_type(h_iter_ge).name
                    mut ge_ial = hir_expr_type(h_iter_ge).args.len
                    mut ge_elem_ty = AstType.init("int")
                    if (ge_itn == "List" or ge_itn == "Vec") and ge_ial > 0:
                        ge_elem_ty = hir_expr_type(h_iter_ge).args.get(0).read()
                    elif ge_itn == "str":
                        ge_elem_ty = AstType.init("char")
                    self.declare(gen_ast2.target, SymbolKind.SVariable, box_asttype(ge_elem_ty), false)
                    mut hifs2 = Vec[Pointer[HirExpr]].init(gen_ast2.ifs.len)
                    mut ge_fi = 0
                    while ge_fi < gen_ast2.ifs.len:
                        hifs2.push(self.lower_expr(gen_ast2.ifs.get(ge_fi)))
                        ge_fi = ge_fi + 1
                    hgen_val2.ifs = hifs2
                    hgen_val2.is_async = gen_ast2.is_async
                    hgen_ptr2.write(hgen_val2)
                    hgens2.push(hgen_ptr2)
                    gc2 = gc2 + 1
                mut h_ge_elem = self.lower_expr(element)
                mut ge_elem_hty = hir_expr_type(h_ge_elem)
                mut gen_ty = AstType.init("List")
                gen_ty.args = Vec[Pointer[AstType]].init(1)
                gen_ty.args.push(box_asttype(ge_elem_hty))
                self.exit_scope()
                return box_hirexpr(HirExpr.EGeneratorExpr(h_ge_elem, hgens2, gen_ty))
            case Expr.ESuperMethodCall(base_class, method, args):
                mut h_super_args = Vec[Pointer[HirExpr]].init(4)
                mut k_smc: int = 0
                while k_smc < args.len:
                    h_super_args.push(self.lower_expr(args.get(k_smc)))
                    k_smc = k_smc + 1
                # Infer base class from current class if not explicit
                mut resolved_base: str = base_class
                if resolved_base == "" and self.current_class_name != "":
                    if self.classes.contains(self.current_class_name):
                        mut cur_cls: ClassDef = self.classes.get(self.current_class_name)
                        if cur_cls.base_classes.len > 0:
                            resolved_base = cur_cls.base_classes.get(0)
                mut super_ret_ty = AstType.init("void")
                if self.classes.contains(resolved_base):
                    mut bc_def: ClassDef = self.classes.get(resolved_base)
                    mut k_smc2: int = 0
                    while k_smc2 < bc_def.methods.len:
                        if bc_def.methods.get(k_smc2).name == method:
                            if bc_def.methods.get(k_smc2).ret_ty as usize != 0 as usize:
                                super_ret_ty = bc_def.methods.get(k_smc2).ret_ty.read()
                        k_smc2 = k_smc2 + 1
                return box_hirexpr(HirExpr.ESuperMethodCall(resolved_base, method, h_super_args, super_ret_ty))
            case Expr.ESuperPropAccess(base_class, prop):
                mut resolved_base2: str = base_class
                if resolved_base2 == "" and self.current_class_name != "":
                    if self.classes.contains(self.current_class_name):
                        mut cur_cls2: ClassDef = self.classes.get(self.current_class_name)
                        if cur_cls2.base_classes.len > 0:
                            resolved_base2 = cur_cls2.base_classes.get(0)
                mut super_field_ty = AstType.init("void")
                if self.classes.contains(resolved_base2):
                    mut bc_def2: ClassDef = self.classes.get(resolved_base2)
                    mut k_spa: int = 0
                    while k_spa < bc_def2.fields.len:
                        if bc_def2.fields.get(k_spa).name == prop:
                            if bc_def2.fields.get(k_spa).ty as usize != 0 as usize:
                                super_field_ty = bc_def2.fields.get(k_spa).ty.read()
                        k_spa = k_spa + 1
                return box_hirexpr(HirExpr.ESuperPropAccess(resolved_base2, prop, super_field_ty))
            case _: return box_hirexpr(HirExpr.ELitNone(AstType.init("None")))

    # ── Rule N-1: Reserved name helpers ───────────────────────────────────────
    pub def is_reserved_error(self, name: str) -> str:
        if name == "true" or name == "True" or name == "gaskiya": return "built-in boolean constant 'true'"
        if name == "false" or name == "False" or name == "karya": return "built-in boolean constant 'false'"
        if name == "none" or name == "None" or name == "babu": return "built-in null constant 'none'"
        if name == "Some": return "built-in Option constructor 'Some'"
        if name == "Ok": return "built-in Result constructor 'Ok'"
        if name == "Err": return "built-in Result constructor 'Err'"
        return ""

    pub def is_reserved_warn(self, name: str) -> str:
        if name == "print": return "built-in print function"
        if name == "input": return "built-in input function"
        if name == "range": return "built-in range function"
        if name == "len" or name == "tsawon": return "built-in len function"
        if name == "type" or name == "zuwa_rubutu": return "built-in type/str function"
        if name == "abs" or name == "max" or name == "min" or name == "sum": return "built-in math function"
        if name == "str" or name == "int" or name == "float" or name == "bool": return "built-in type-conversion function"
        if name == "List" or name == "Dict" or name == "Vec": return "built-in container type"
        if name == "Option" or name == "Result": return "built-in enum type"
        if name == "Exception" or name == "Error": return "built-in exception class"
        return ""

    # ── Rule F-3: Definite return check ───────────────────────────────────────
    pub def block_returns(self, b: Block) -> bool:
        if b.stmts.len == 0: return false
        mut last_s = b.stmts.get(b.stmts.len - 1)
        if last_s as usize == 0 as usize: return false
        match last_s.read():
            case Stmt.SReturn(_): return true
            case Stmt.SRaise(_): return true
            case Stmt.SUnsafe(body): return self.block_returns(body)
            case Stmt.SIf(cond, then_b, elifs, else_b):
                if else_b.stmts.len == 0: return false
                return self.block_returns(then_b) and self.block_returns(else_b)
            case Stmt.SMatch(subj, arms):
                # Exhaustive if there is a wildcard/bind arm and every arm body returns.
                mut has_wild = false
                mut all_ret = true
                mut mi = 0
                while mi < arms.len:
                    mut arm = arms.get(mi)
                    match arm.pat:
                        case Pattern.PWild: has_wild = true
                        case Pattern.PBind(_): has_wild = true
                        case _: pass
                    if arm.body as usize != 0 as usize:
                        if not self.block_returns(arm.body.read()):
                            all_ret = false
                    mi = mi + 1
                return has_wild and all_ret
            case _: return false

    pub def is_primitive(self, ty: AstType) -> bool: return self.is_primitive_name(ty.name)
    pub def is_primitive_name(self, name: str) -> bool:
        if name == "int" or name == "float" or name == "bool" or name == "char" or name == "void" or name == "None": return true
        if name == "i64" or name == "i32" or name == "i16" or name == "i8": return true
        if name == "u64" or name == "u32" or name == "u16" or name == "u8" or name == "usize": return true
        if name == "f64" or name == "f32" or name == "lambda": return true
        # Built-in reference-counted / shared types — exempt from ownership-move tracking.
        # These types carry their own reference counting or atomic synchronisation;
        # passing them to multiple functions or spawned threads is always safe.
        if name == "str" or name == "Str" or name == "StringObj" or name == "Bytes": return true
        if name == "Chan" or name == "Channel": return true
        if name == "Mutex" or name == "RwLock" or name == "Atomic": return true
        if name == "Thread" or name == "ThreadPool" or name == "ThreadLocal": return true
        if name == "Pointer": return true
        # Gap 4: 'ref T' and 'mut ref T' params are borrow annotations, not owning values
        if name == "ref" or name == "mut_ref": return true
        return false

pub def box_asttype(t: AstType) -> Pointer[AstType]:
    mut p = alloc[AstType](1)
    p.write(t)
    return p

pub def box_symbol(s: Symbol) -> Pointer[Symbol]:
    mut p = alloc[Symbol](1)
    p.write(s)
    return p
