# compiler/src/resolver.tr — Module Resolver for the Tauraro self-hosted compiler.
#
# Unity Build model: every imported file is parsed and its declarations are
# merged into a single flat list consumed by the sema + codegen.
#
# Module lookup order for `from a.b.c import X`:
#   1. <search_path>/a/b/c/mod.tr   ← package directory with index file
#   2. <search_path>/a/b/c.tr       ← single-file module (fallback)
#
# Visibility: declarations without `pub` are treated as private to their
# source file.  When collecting decls from an imported (non-root) file only
# `pub` declarations are added to the merged list; the root file always
# contributes all of its declarations.

from core.io import read_file, file_exists
from core.vec import Vec
from core.map import Map
from core.string import StringObj, StringBuilder
from lexer import Lexer
from parser import Parser
from ast import Program, Decl, FunctionDef, ClassDef, EnumDef, InterfaceDef, ImportItem

# ─── Visibility helper ────────────────────────────────────────────────────────

pub def decl_is_pub(d: Decl) -> bool:
    match d:
        case Decl.DFunction(f):
            return f.is_public
        case Decl.DClass(c):
            return c.is_public
        case Decl.DEnum(e):
            return e.is_public
        case Decl.DInterface(i):
            return i.is_public
        case Decl.DActor(c):
            return c.is_public
        case Decl.DExtern(abi, funcs):
            return true   # extern declarations are always public
        case Decl.DExtend(target, methods):
            return true   # extends add to existing public types
        case Decl.DDecoratorDef(f):
            return f.is_public
        case _:
            return false  # DImport/DFromImport/DTopLevelStmt filtered elsewhere

# ─── ModuleResolver ───────────────────────────────────────────────────────────

pub class ModuleResolver:
    pub visited:          Map[str, bool]
    pub all_decls:        Vec[Pointer[Decl]]
    pub search_paths:     Vec[str]
    # Module tracking: parallel arrays, one entry per resolved non-root module
    pub mod_dot_paths:    Vec[str]   # "compiler.src.resolver"
    pub mod_file_paths:   Vec[str]   # "compiler/src/resolver.tr"
    pub all_decl_modules: Vec[str]   # dotted path for each all_decls entry ("" = root)
    pub current_mod:      str        # dotted path of module currently being loaded

extend ModuleResolver:
    pub def init() -> ModuleResolver:
        mut r = ModuleResolver()
        r.visited          = Map[str, bool].init(128)
        r.all_decls        = Vec[Pointer[Decl]].init(1024)
        r.search_paths     = Vec[str].init(8)
        r.mod_dot_paths    = Vec[str].init(32)
        r.mod_file_paths   = Vec[str].init(32)
        r.all_decl_modules = Vec[str].init(1024)
        r.current_mod      = ""
        r.search_paths.push(".")
        r.search_paths.push("tauraro")
        r.search_paths.push("..")
        r.search_paths.push("../..")
        r.search_paths.push("std")
        return r

    pub def add_search_path(self, p: str):
        self.search_paths.push(p)

    # Entry point.  The root file's private declarations ARE included.
    pub def resolve_main(self, main_path: str) -> Program:
        # Add the directory of main_path to search paths so that sibling
        # modules (e.g. "from resolver import ...") are found by the resolver.
        # We find the last '/' or '\' in the path and keep that prefix.
        # Note: we build via char-by-char string concat to avoid the spurious-free
        # bug that occurs with StringBuilder.to_string().as_str() (the sb's buffer
        # is freed when sb goes out of scope, leaving a dangling char*).
        mut dir_end = 0
        mut ci = 0
        mut mp = main_path as Pointer[char]
        while mp.offset(ci).read() as int != 0:
            mut ch = mp.offset(ci).read() as int
            if ch == 47 or ch == 92:  # '/' or '\'
                dir_end = ci
            ci = ci + 1
        if dir_end > 0:
            # Use unsafe slice to copy the directory prefix without a StringBuilder.
            mut dir_str = ""
            unsafe:
                dir_str = _tr_str_slice(main_path, 0, dir_end)
            self.search_paths.push(dir_str)
            # Also add parent and grandparent of the source file directory.
            # This allows finding the repo-root std lib (e.g. core/) when the
            # binary is run from a different CWD with an absolute source path.
            mut par_end = 0
            mut pj = 0
            mut dp = dir_str as Pointer[char]
            while dp.offset(pj).read() as int != 0:
                mut dch = dp.offset(pj).read() as int
                if dch == 47 or dch == 92: par_end = pj
                pj = pj + 1
            if par_end > 0:
                mut parent_dir = ""
                unsafe:
                    parent_dir = _tr_str_slice(dir_str, 0, par_end)
                self.search_paths.push(parent_dir)
                mut gp_end = 0
                mut gj = 0
                mut gp_p = parent_dir as Pointer[char]
                while gp_p.offset(gj).read() as int != 0:
                    mut gch = gp_p.offset(gj).read() as int
                    if gch == 47 or gch == 92: gp_end = gj
                    gj = gj + 1
                if gp_end > 0:
                    mut gp_dir = ""
                    unsafe:
                        gp_dir = _tr_str_slice(parent_dir, 0, gp_end)
                    self.search_paths.push(gp_dir)
        self.resolve_file(main_path, true)
        mut p = Program.init()
        mut i = 0
        while i < self.all_decls.len:
            p.push(self.all_decls.get(i))
            i = i + 1
        return p

    # Resolve a file from disk.
    # is_root = true  → include all declarations (the user's entry file)
    # is_root = false → include only pub declarations (imported dependency)
    pub def resolve_file(self, path: str, is_root: bool):
        if self.visited.contains(path): return
        self.visited.insert(path, true)

        mut source = read_file(path)
        if source == "":
            # Try appending .tr if extension missing
            mut p_ptr = path as Pointer[char]
            mut slen = 0
            while p_ptr.offset(slen).read() as int != 0:
                slen = slen + 1
            mut has_tr = false
            if slen >= 3:
                if p_ptr.offset(slen - 3).read() as int == 46:
                    if p_ptr.offset(slen - 2).read() as int == 116:
                        if p_ptr.offset(slen - 1).read() as int == 114:
                            has_tr = true
            if not has_tr:
                source = read_file(path + ".tr")
            if source == "": return

        mut lexer   = Lexer.init(source)
        mut tokens  = lexer.tokenize()
        mut parser  = Parser.init(tokens, lexer.token_lines)
        mut prog    = parser.parse_program()

        # Scan declarations: load imported modules first, then collect decls.
        mut i = 0
        while i < prog.len():
            mut decl_ptr = prog.get(i)
            match decl_ptr.read():
                case Decl.DImport(mod_path, alias):
                    self.resolve_module_path(mod_path)
                case Decl.DFromImport(mod_path, items):
                    self.resolve_module_path(mod_path)
                case _:
                    # Always collect ALL declarations from a module — including private
                    # helpers (def without pub). Private functions are only called within
                    # their own module's generated .c file, so they MUST be in all_decls
                    # for generate_module_c to emit their bodies. Filtering them out here
                    # causes "implicit declaration" / missing-body GCC errors.
                    self.all_decls.push(decl_ptr)
                    self.all_decl_modules.push(self.current_mod)
            i = i + 1

    # Compatibility shim — resolve_recursive kept so existing callers compile.
    pub def resolve_recursive(self, path: str):
        self.resolve_file(path, false)

    # Convert a dotted module path (e.g. "std.collections.vec") to a filesystem
    # path and search for the file in self.search_paths.
    #
    # Lookup order per search path:
    #   1. <base>/<dir>/mod.tr   ← package with index file
    #   2. <base>/<dir>.tr       ← single-file module
    pub def resolve_module_path(self, mod_path: str):
        # Build directory path: dots → slashes (no extension yet)
        mut n = 0
        mut p = mod_path as Pointer[char]
        while p.offset(n).read() as int != 0: n = n + 1
        mut dir_path = _tr_str_slice(mod_path, 0, n)
        mut bp = dir_path as Pointer[char]
        mut j = 0
        while j < n:
            if bp.offset(j).read() as int == 46: bp.offset(j).write(47 as char)  # '.' → '/'
            j = j + 1

        # Save/restore current_mod so recursive resolution doesn't corrupt parent tracking.
        mut saved_mod = self.current_mod
        self.current_mod = mod_path

        # Try each search path in order.
        mut sidx = 0
        while sidx < self.search_paths.len:
            mut base = self.search_paths.get(sidx)

            # 1. Package directory: <base>/<dir>/mod.tr
            mut pkg_path = base + "/" + dir_path + "/mod.tr"
            if file_exists(pkg_path):
                mut already = self.visited.contains(pkg_path)
                self.resolve_file(pkg_path, false)
                if not already:
                    self.mod_dot_paths.push(mod_path)
                    self.mod_file_paths.push(StringObj.init(pkg_path).as_str())
                self.current_mod = saved_mod
                return
 
            # 2. Single-file module: <base>/<dir>.tr
            mut flat_path = base + "/" + dir_path + ".tr"
            if file_exists(flat_path):
                mut already = self.visited.contains(flat_path)
                self.resolve_file(flat_path, false)
                if not already:
                    self.mod_dot_paths.push(mod_path)
                    self.mod_file_paths.push(StringObj.init(flat_path).as_str())
                self.current_mod = saved_mod
                return

            sidx = sidx + 1

        self.current_mod = saved_mod
        # Module not found on any search path — silently skip.
        # (The sema will emit an "unknown symbol" error if the import is used.)
