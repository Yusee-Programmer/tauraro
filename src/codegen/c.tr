# compiler/src/codegen/c.tr - C code generator for the Tauraro self-hosted compiler.
# Generates brutally optimized C from HIR with zero-cost abstractions.

from core.vec import Vec
from core.map import Map
from core.string import StringBuilder
from core.alloc import alloc
from core.io import write_file
from hir import HirProgram, HirFunction, HirClass, HirEnum, HirInterface, HirStmt, HirExpr, HirBlock, HirParam, HirField, HirVariant, HirFStringPart, HirComprehension, HirCatchClause, HirMatchArm, HirChanSelectArm, _tr_str_len, hir_expr_type
from ast import AstType, Decorator, Pattern, Ownership, Decl

extern "C":
    def _tr_float_to_c_lit(n: float) -> str

# --- Helpers ------------------------------------------------------------------

pub def _c_dot_to_safe(s: str) -> str:
    mut n = 0
    mut p = s as Pointer[char]
    while p.offset(n).read() as int != 0: n = n + 1
    mut buf = _tr_str_slice(s, 0, n)
    mut bp = buf as Pointer[char]
    mut j = 0
    while j < n:
        if bp.offset(j).read() as int == 46: bp.offset(j).write(95 as char)
        j = j + 1
    return buf

pub def _indent_str(n: int) -> str:
    mut s = ""
    mut i = 0
    while i < n:
        s = s + "    "
        i = i + 1
    return s

pub def _is_invalid_ptr(addr: usize) -> bool:
    if addr < 0x10000 as usize: return true
    if addr > 0x0000ffffffffffff as usize: return true
    if addr == 0xabababab as usize or addr == 0xfeeefeee as usize: return true
    if addr == 0xbaadf00d as usize or addr == 0xcccccccc as usize: return true
    if addr == 0xcdcdcdcd as usize or addr == 0xdddddddd as usize: return true
    if addr == 0xfeeefeeefeeefeee as usize or addr == 0xabababababababab as usize: return true
    if addr == 0xbaadf00dbaadf00d as usize or addr == 0xcccccccccccccccc as usize: return true
    if addr % 8 as usize != 0 as usize: return true
    return false


pub def _is_str_type(n: str) -> bool:
    return n == "str" or n == "String"

pub def _is_int_type(n: str) -> bool:
    if n == "int" or n == "i64" or n == "i32" or n == "i16" or n == "i8": return true
    if n == "u64" or n == "u32" or n == "u16" or n == "u8": return true
    if n == "usize" or n == "isize" or n == "long long": return true
    return false

pub def _is_float_type(n: str) -> bool:
    return n == "float" or n == "f64" or n == "f32" or n == "double"

pub def _safe_c_varname(n: str) -> str:
    if _is_c_keyword(n): return "_tr_v_" + n
    return n

pub def _is_c_keyword(n: str) -> bool:
    # C language keywords
    if n == "double" or n == "float" or n == "int" or n == "char": return true
    if n == "long" or n == "short" or n == "void" or n == "unsigned": return true
    if n == "signed" or n == "register" or n == "inline" or n == "auto": return true
    if n == "struct" or n == "union" or n == "enum" or n == "extern": return true
    if n == "static" or n == "volatile" or n == "const" or n == "restrict": return true
    if n == "typedef" or n == "sizeof" or n == "alignof" or n == "typeof": return true
    if n == "goto" or n == "switch" or n == "case" or n == "default": return true
    if n == "do" or n == "for" or n == "while" or n == "if" or n == "else": return true
    if n == "break" or n == "continue" or n == "return": return true
    # C stdlib / POSIX names that conflict with common method names
    if n == "exit" or n == "abort" or n == "remove" or n == "rename": return true
    if n == "read" or n == "write" or n == "open" or n == "close": return true
    if n == "send" or n == "recv" or n == "bind" or n == "connect": return true
    if n == "accept" or n == "listen" or n == "socket": return true
    if n == "time" or n == "sleep" or n == "signal" or n == "raise": return true
    if n == "stat" or n == "mkdir" or n == "rmdir" or n == "unlink": return true
    if n == "malloc" or n == "free" or n == "calloc" or n == "realloc": return true
    if n == "printf" or n == "scanf" or n == "puts" or n == "gets": return true
    if n == "strlen" or n == "strcpy" or n == "strcat" or n == "strcmp": return true
    if n == "system" or n == "getenv" or n == "setenv" or n == "putenv": return true
    if n == "fopen" or n == "fclose" or n == "fread" or n == "fwrite": return true
    if n == "fseek" or n == "ftell" or n == "rewind" or n == "feof": return true
    if n == "index" or n == "count" or n == "new" or n == "delete": return true
    return false

pub def _starts_with_tr(s: str) -> bool:
    mut p = s as Pointer[char]
    if p as int == 0: return false
    if p.offset(0).read() as int == 0: return false
    if p.offset(0).read() as int == 95: # '_'
        if p.offset(1).read() as int == 0: return false
        if p.offset(1).read() as int == 116: # 't'
            if p.offset(2).read() as int == 0: return false
            if p.offset(2).read() as int == 114: # 'r'
                if p.offset(3).read() as int == 0: return false
                if p.offset(3).read() as int == 95: # '_'
                    return true
    return false

pub def _is_primitive(n: str) -> bool:
    if _is_int_type(n) or _is_float_type(n): return true
    if n == "bool" or n == "char" or n == "void" or n == "None": return true
    return false

pub def _escape_str_for_c(s: str) -> str:
    mut sb = StringBuilder.init(64)
    mut p = s as Pointer[char]
    mut i = 0
    while True:
        mut c = p.offset(i).read() as int
        if c == 0: break
        if c == 34: sb.append("\\\"")
        elif c == 92: sb.append("\\\\")
        elif c == 10: sb.append("\\n")
        elif c == 13: sb.append("\\r")
        elif c == 9: sb.append("\\t")
        else: sb.append_char(c)
        i = i + 1
    return sb.to_string().as_str()

# --- CGenerator class ---------------------------------------------------------

pub class CGenerator:
    pub buf:            StringBuilder
    pub fwd_buf:        StringBuilder   # forward declarations
    pub struct_buf:     StringBuilder   # struct definitions
    pub list_types_buf: StringBuilder   # value-type List_T definitions (emitted after structs)
    pub proto_buf:      StringBuilder   # function prototypes
    pub mono_buf:       StringBuilder   # monomorphized generic class code
    pub temp_count:     int
    pub classes:        Map[str, HirClass]
    pub enums:          Map[str, HirEnum]
    pub interfaces:     Map[str, HirInterface]
    pub functions:      Map[str, HirFunction]
    pub decl_vars:      Map[str, bool]
    pub type_subst:     Map[str, str]   # T -> "long long" during mono gen
    pub mono_done:      Map[str, bool]  # "Vec_i64" -> true (prevents duplicate gen)
    pub list_type_done: Map[str, bool]  # "Token" -> true (prevents duplicate list gen)
    pub list_fwd_done:  Map[str, bool]  # "Token" -> true (prevents duplicate fwd decl)
    pub cur_class:      str
    pub cur_func:       str
    pub closure_count:  int
    pub emitted_fns:    Map[str, bool]   # tracks emitted free-standing fn names to prevent duplicates
    pub spawn_wrappers:  Map[str, bool]   # fn_name -> true once wrapper emitted
    pub async_wrappers:  Map[str, bool]   # fn_name -> true once async wrapper emitted
    pub prescanned_fns:  Map[str, bool]   # fn key -> true once body prescanned (prevents re-scan after heap churn)
    pub shared_vars:     Map[str, str]    # var_name -> type_name (for _TrSharedBox unwrap)
    pub cur_throws_ty:   str              # non-empty = current function has throws annotation
    pub in_task_group:   int              # depth counter for task_group nesting
    pub in_gpu_block:    int              # depth counter for gpu: block nesting
    pub value_types:     Map[str, bool]  # classes with is_class=false - no * in C type
    pub closure_cap_set: Map[str, bool]  # captured var names for the current closure being generated
    pub closure_env_var: str             # env var name inside a closure body (empty = not in closure body)
    pub decorator_defs:   Map[str, HirFunction]  # user-defined decorator registry
    pub overloaded_sigs:  Map[str, bool]          # "ClassName_method" keys where multiple overloads exist
    pub type_alias_map:   Map[str, str]           # alias_name -> resolved C type string
    pub defer_stack:      Vec[str]                # deferred C statements for current function (LIFO)

    pub def init() -> CGenerator:
        mut g = CGenerator()
        g.buf           = StringBuilder.init(65536)
        g.fwd_buf       = StringBuilder.init(4096)
        g.struct_buf    = StringBuilder.init(16384)
        g.list_types_buf = StringBuilder.init(2048)
        g.proto_buf     = StringBuilder.init(8192)
        g.mono_buf      = StringBuilder.init(8192)
        g.temp_count    = 0
        g.classes       = Map[str, HirClass].init(128)
        g.enums         = Map[str, HirEnum].init(64)
        g.interfaces    = Map[str, HirInterface].init(32)
        g.functions     = Map[str, HirFunction].init(256)
        g.decl_vars     = Map[str, bool].init(64)
        g.type_subst    = Map[str, str].init(8)
        g.mono_done     = Map[str, bool].init(32)
        g.list_type_done = Map[str, bool].init(16)
        g.list_fwd_done  = Map[str, bool].init(16)
        g.cur_class     = ""
        g.cur_func      = ""
        g.closure_count = 0
        g.emitted_fns   = Map[str, bool].init(256)
        g.spawn_wrappers = Map[str, bool].init(16)
        g.async_wrappers = Map[str, bool].init(16)
        g.prescanned_fns = Map[str, bool].init(256)
        g.shared_vars    = Map[str, str].init(16)
        g.cur_throws_ty  = ""
        g.in_task_group  = 0
        g.in_gpu_block   = 0
        g.value_types    = Map[str, bool].init(32)
        g.closure_cap_set = Map[str, bool].init(0)
        g.closure_env_var = ""
        g.decorator_defs  = Map[str, HirFunction].init(16)
        g.overloaded_sigs = Map[str, bool].init(32)
        g.type_alias_map  = Map[str, str].init(16)
        g.defer_stack     = Vec[str].init(0)
        return g

    pub def next_temp(self) -> str:
        self.temp_count = self.temp_count + 1
        return "_t" + self.temp_count.to_str()

    # Call before generating a function body to reset the defer stack.
    pub def reset_defer_stack(self):
        self.defer_stack = Vec[str].init(0)

    # Emit a function body, then flush any defers that the body did not already
    # flush via an explicit trailing 'return'. defer statements run on function
    # exit; a void function that falls off the end must still run its defers.
    pub def gen_func_body(self, body: HirBlock, indent: int):
        self.reset_defer_stack()
        self.gen_block(body, indent)
        if self.defer_stack.len > 0:
            mut ends_in_return = false
            if body.stmts.len > 0:
                match body.stmts.get(body.stmts.len - 1).read():
                    case HirStmt.SReturn(_): ends_in_return = true
                    case _: pass
            if not ends_in_return:
                mut fdi = self.defer_stack.len - 1
                while fdi >= 0:
                    self.w(self.defer_stack.get(fdi))
                    if fdi == 0: break
                    fdi = fdi - 1

    pub def seed_params(self, f: HirFunction):
        mut pi = 0
        while pi < f.params.len:
            self.decl_vars.insert(f.params.get(pi).name, true)
            pi = pi + 1

    pub def w(self, s: str): self.buf.append(s)
    pub def wf(self, s: str): self.fwd_buf.append(s)
    pub def ws(self, s: str): self.struct_buf.append(s)
    pub def wp(self, s: str): self.proto_buf.append(s)
    pub def wlt(self, s: str): self.list_types_buf.append(s)

    pub def ensure_list_type(self, n: str):
        if self.list_type_done.contains(n): return
        self.list_type_done.insert(n, true)
        self.wlt("typedef struct List_" + n + " { " + n + "* data; size_t len; size_t capacity; } List_" + n + ";\n")
        self.wlt("static inline List_" + n + "* List_" + n + "_new(void) { List_" + n + "* l=(List_" + n + "*)malloc(sizeof(List_" + n + ")); l->data=(" + n + "*)malloc(sizeof(" + n + ")*8); l->len=0; l->capacity=8; return l; }\n")
        self.wlt("static inline void List_" + n + "_append(List_" + n + "* l, " + n + " val) { if(l->len==l->capacity){ l->capacity*=2; l->data=(" + n + "*)realloc(l->data,sizeof(" + n + ")*l->capacity); } l->data[l->len++]=val; }\n")
        self.wlt("static inline " + n + " List_" + n + "_get(List_" + n + "* l, long long i) { _tr_bounds_check(i, l->len); return l->data[i]; }\n")
        self.wlt("static inline " + n + " List_" + n + "_pop(List_" + n + "* l) { if(!l||l->len==0) return (" + n + "){0}; l->len--; return l->data[l->len]; }\n")
        self.wlt("static inline void List_" + n + "_free(List_" + n + "* l) { if(l){ free(l->data); free(l); } }\n")

    pub def check_and_emit_list_fwd(self, ty: AstType):
        if ty as usize == 0 as usize: return
        if ty.name == "List" or ty.name == "Vec":
            if ty.args.len > 0:
                mut elem = ty.args.get(0).read()
                if self.enums.contains(elem.name):
                    if not self.list_fwd_done.contains(elem.name):
                        self.list_fwd_done.insert(elem.name, true)
                        self.w("typedef struct List_" + elem.name + " List_" + elem.name + ";\n")

    pub def emit_list_fwd_decls(self, prog: HirProgram):
        mut ci = 0
        while ci < prog.classes.len:
            mut cls = prog.classes.get(ci)
            mut fi = 0
            while fi < cls.fields.len:
                self.check_and_emit_list_fwd(cls.fields.get(fi).ty)
                fi = fi + 1
            ci = ci + 1
        mut ei = 0
        while ei < prog.enums.len:
            mut enm = prog.enums.get(ei)
            mut vi = 0
            while vi < enm.variants.len:
                mut v = enm.variants.get(vi)
                mut vfi = 0
                while vfi < v.fields.len:
                    self.check_and_emit_list_fwd(v.fields.get(vfi).ty)
                    vfi = vfi + 1
                vi = vi + 1
            ei = ei + 1

    # -- Type mapping ----------------------------------------------------------

    pub def type_to_c(self, ty: AstType) -> str:
        if ty as usize == 0 as usize: return "void"
        mut n: str = ty.name
        if n == "" or n == "void" or n == "None": return "void"

        # Gap 4: 'ref T' and 'mut ref T' are transparent wrappers - map to inner type
        if (n == "ref" or n == "mut_ref") and ty.args.len > 0:
            return self.type_to_c(ty.args.get(0).read())

        # Function-pointer type (def(...)->R): stored as a void* function pointer.
        # Zero-cost: the call site casts back to the exact signature before calling.
        if n == "def": return "void*"

        # Check active type substitution first (used during monomorphization)
        if self.type_subst.contains(n): return self.type_subst.get(n)

        # Resolve user type aliases: `type Name = Target` -> resolve to Target C type
        if self.type_alias_map.contains(n): return self.type_alias_map.get(n)

        if n == "int" or n == "i64" or n == "isize": return "long long"
        if n == "i32": return "int"
        if n == "i16": return "short"
        if n == "i8": return "signed char"
        if n == "u64" or n == "usize": return "unsigned long long"
        if n == "u32": return "unsigned int"
        if n == "u16": return "unsigned short"
        if n == "u8": return "unsigned char"
        if n == "f64" or n == "float": return "double"
        if n == "f32": return "float"
        if n == "bool": return "bool"
        if n == "char": return "char"
        if _is_str_type(n): return "char*"

        # FFI / C interop types
        if n == "c_int": return "int"
        if n == "c_long": return "long"
        if n == "c_longlong": return "long long"
        if n == "c_uint": return "unsigned int"
        if n == "c_ulong": return "unsigned long"
        if n == "c_ulonglong": return "unsigned long long"
        if n == "c_short": return "short"
        if n == "c_ushort": return "unsigned short"
        if n == "c_char": return "char"
        if n == "c_uchar": return "unsigned char"
        if n == "c_schar": return "signed char"
        if n == "c_float": return "float"
        if n == "c_double": return "double"
        if n == "c_ldouble": return "long double"
        if n == "c_void_ptr" or n == "RawPtr": return "void*"
        if n == "c_size_t": return "size_t"
        if n == "c_ssize_t": return "ssize_t"
        if n == "c_ptrdiff_t": return "ptrdiff_t"
        if n == "c_intptr_t": return "intptr_t"
        if n == "c_uintptr_t": return "uintptr_t"
        if n == "c_int8_t": return "int8_t"
        if n == "c_int16_t": return "int16_t"
        if n == "c_int32_t": return "int32_t"
        if n == "c_int64_t": return "int64_t"
        if n == "c_uint8_t": return "uint8_t"
        if n == "c_uint16_t": return "uint16_t"
        if n == "c_uint32_t": return "uint32_t"
        if n == "c_uint64_t": return "uint64_t"
        if n == "CFile" or n == "c_FILE": return "FILE*"
        if n == "CString": return "char*"

        # Check if it's a generic type parameter in current function
        if self.cur_func != "":
            if self.functions.contains(self.cur_func):
                mut f = self.functions.get(self.cur_func)
                mut gi = 0
                while gi < f.generics.len:
                    if f.generics.get(gi) == n: return "void*"
                    gi = gi + 1

        # Check if it's a generic type parameter in the current class
        if self.cur_class != "":
            mut base_cls_n = self.cur_class
            mut u_idx = 0
            mut cp = self.cur_class as Pointer[char]
            while cp.offset(u_idx).read() as int != 0:
                if cp.offset(u_idx).read() as int == 95: # '_'
                    base_cls_n = _tr_str_slice(self.cur_class, 0, u_idx)
                    break
                u_idx = u_idx + 1
            if self.classes.contains(base_cls_n):
                mut cls_def = self.classes.get(base_cls_n)
                mut gi = 0
                while gi < cls_def.generics.len:
                    if cls_def.generics.get(gi) == n: return "void*"
                    gi = gi + 1

        if n == "Pointer":
            if ty.args.len > 0:
                mut inner = ty.args.get(0).read()
                mut it = self.type_to_c(inner)
                if it == "void" or it == "void*": return "void*"
                return it + "*"
            return "void*"

        # User-defined generic class takes precedence over built-in Vec/Map/List
        # Exclude built-in concurrency types - they always map to their runtime _Tr* handles
        if self.classes.contains(n) and n != "Vec" and n != "Map" and n != "Dict" and n != "List" and not self.is_rt_concurrency_type(n):
            mut ucls = self.classes.get(n)
            mut is_val = self.value_types.contains(n)
            if ucls.generics.len > 0 and ty.args.len > 0:
                mut sfx = self.type_args_suffix(ty.args)
                self.ensure_mono(ucls, ty.args)
                if is_val: return n + "_" + sfx
                return n + "_" + sfx + "*"
            # Inside a monomorphized body, synthesize suffix from active type_subst
            if ucls.generics.len > 0:
                mut sfx2 = self.synth_class_suffix(ucls)
                if sfx2 != "":
                    if is_val: return n + "_" + sfx2
                    return n + "_" + sfx2 + "*"
            if is_val: return n
            return n + "*"

        if n == "List":
            if ty.args.len > 0:
                mut elem = ty.args.get(0).read()
                mut sfx = self.list_elem_suffix(elem.name)
                if sfx == "ptr": return "List_ptr*"
                return "List_" + sfx + "*"
            return "List_ptr*"

        if n == "Vec":
            if ty.args.len > 0:
                mut elem = ty.args.get(0).read()
                mut sfx = self.list_elem_suffix(elem.name)
                if sfx == "ptr": return "List_ptr*"
                return "List_" + sfx + "*"
            return "List_ptr*"

        if n == "Map" or n == "Dict":
            # Map[K, V] / Dict[K, V]: first type arg is the key type.
            # int key -> TrIDict*, anything else (str, ...) -> TrMap*.
            if ty.args.len > 0:
                mut ka = ty.args.get(0).read()
                if _is_int_type(ka.name) or ka.name == "int" or ka.name == "i64" or ka.name == "usize":
                    return "TrIDict*"
            return "TrMap*"

        if n == "Set":
            # Set[int] -> int-keyed set; everything else -> string-keyed set
            if ty.args.len > 0:
                mut se = ty.args.get(0).read()
                if _is_int_type(se.name) or se.name == "int" or se.name == "i64" or se.name == "usize":
                    return "_TrISet*"
            return "_TrSet*"

        if n == "Chan": return "_TrChan*"
        if n == "Mutex": return "_TrMutexBox*"
        if n == "RwLock": return "_TrRWLBox*"
        if n == "ThreadPool": return "_TrThreadPool*"
        if n == "Thread": return "_TrThreadObj*"
        if n == "Atomic": return "_TrAtomic*"
        if n == "ThreadLocal": return "_TrTLS*"
        if n == "Shared": return "_TrSharedBox*"
        if n == "Weak": return "_TrWeakBox*"

        if n == "Tuple" or n == "tuple": return "TrTuple"

        if n == "Result": return "Result"
        if n == "Option": return "Option"
        if n == "lambda": return "void*"
        if self.enums.contains(n): return n
        if self.interfaces.contains(n):
            mut gi_iface = self.interfaces.get(n)
            if gi_iface.generics.len > 0 and ty.args.len > 0:
                return n + "_" + self.type_args_suffix(ty.args) + "_obj"
            return n + "_obj"
        return n + "*"

    pub def type_suffix(self, n: str) -> str:
        if n == "int" or n == "i64": return "i64"
        if n == "i32": return "i32"
        if n == "i16": return "i16"
        if n == "i8": return "i8"
        if n == "u64" or n == "usize": return "u64"
        if n == "u32": return "u32"
        if n == "u16": return "u16"
        if n == "u8": return "u8"
        if n == "f64" or n == "float": return "f64"
        if n == "f32": return "f32"
        if n == "bool": return "bool"
        if n == "char": return "char"
        if _is_str_type(n): return "str"
        mut np = n as Pointer[char]
        mut nlen = 0
        while np.offset(nlen).read() as int != 0: nlen = nlen + 1
        if nlen > 0:
            if np.offset(nlen - 1).read() as int == 42: # '*'
                return _tr_str_slice(n, 0, nlen - 1) + "_ptr"
        return n

    pub def list_elem_suffix(self, n: str) -> str:
        mut actual_n = n
        if self.type_subst.contains(n):
            mut cv = self.type_subst.get(n)
            if cv == "long long": actual_n = "int"
            elif cv == "double": actual_n = "float"
            elif cv == "char*": actual_n = "str"
            elif cv == "bool": actual_n = "bool"
            elif cv == "char": actual_n = "char"
            elif cv == "unsigned long long": actual_n = "u64"
            elif cv == "unsigned int": actual_n = "u32"
            elif cv == "int": actual_n = "i32"
            elif cv == "short": actual_n = "i16"
            elif cv == "signed char": actual_n = "i8"
            elif cv == "float": actual_n = "f32"
        mut sfx = self.type_suffix(actual_n)
        if sfx == "i64" or sfx == "f64" or sfx == "str" or sfx == "bool" or sfx == "i8" or sfx == "i32" or sfx == "char" or sfx == "u8" or sfx == "u32":
            return sfx
        if self.enums.contains(actual_n):
            self.ensure_list_type(actual_n)
            return actual_n
        return "ptr"



    pub def type_args_suffix(self, args: Vec[Pointer[AstType]]) -> str:
        mut sfx = ""
        mut i = 0
        while i < args.len:
            if i > 0: sfx = sfx + "_"
            mut arg_name = args.get(i).read().name
            # Apply active type substitution (e.g., T -> long long during mono gen)
            if self.type_subst.contains(arg_name):
                mut concrete = self.type_subst.get(arg_name)
                # Map C type back to a type_suffix-friendly name
                if concrete == "long long": arg_name = "int"
                elif concrete == "double": arg_name = "float"
                elif concrete == "char*": arg_name = "str"
                elif concrete == "bool": arg_name = "bool"
                elif concrete == "char": arg_name = "char"
                elif concrete == "unsigned long long": arg_name = "u64"
                elif concrete == "unsigned int": arg_name = "u32"
                elif concrete == "int": arg_name = "i32"
                elif concrete == "short": arg_name = "i16"
                elif concrete == "signed char": arg_name = "i8"
                elif concrete == "float": arg_name = "f32"
                else: arg_name = concrete
            sfx = sfx + self.type_suffix(arg_name)
            i = i + 1
        return sfx

    # Synthesize a monomorphized suffix for a generic class using active type_subst.
    # Returns "" when not all generics are covered by type_subst (non-mono context).
    pub def synth_class_suffix(self, ucls: HirClass) -> str:
        mut sfx = ""
        mut gi = 0
        while gi < ucls.generics.len:
            mut gp = ucls.generics.get(gi)
            if not self.type_subst.contains(gp): return ""
            if gi > 0: sfx = sfx + "_"
            mut cv = self.type_subst.get(gp)
            mut tn = cv
            if cv == "long long": tn = "int"
            elif cv == "double": tn = "float"
            elif cv == "char*": tn = "str"
            elif cv == "bool": tn = "bool"
            elif cv == "char": tn = "char"
            elif cv == "unsigned long long": tn = "u64"
            elif cv == "unsigned int": tn = "u32"
            elif cv == "int": tn = "i32"
            elif cv == "short": tn = "i16"
            elif cv == "signed char": tn = "i8"
            elif cv == "float": tn = "f32"
            sfx = sfx + self.type_suffix(tn)
            gi = gi + 1
        return sfx

    # Ensure a monomorphized version of cls is generated into mono_buf.
    # Safe to call multiple times - guarded by mono_done map.
    pub def ensure_mono(self, cls: HirClass, type_args: Vec[Pointer[AstType]]):
        mut sfx = self.type_args_suffix(type_args)
        mut mono_key = cls.name + "_" + sfx
        if self.mono_done.contains(mono_key): return
        self.mono_done.insert(mono_key, true)

        mut mono_name = cls.name + "_" + sfx

        # Pre-resolve type arguments using active parent substitutions
        mut resolved_args = Vec[str].init(type_args.len)
        mut i = 0
        while i < type_args.len:
            resolved_args.push(self.type_to_c(type_args.get(i).read()))
            i = i + 1

        # Set up type substitution: generic param -> concrete C type
        mut old_subst = self.type_subst
        self.type_subst = Map[str, str].init(8)
        i = 0
        while i < cls.generics.len and i < resolved_args.len:
            mut param = cls.generics.get(i)
            mut concrete = resolved_args.get(i)
            self.type_subst.insert(param, concrete)
            i = i + 1

        # Redirect writes to mono_buf so output is collected for flushing later
        mut old_buf      = self.buf
        mut old_sbuf     = self.struct_buf
        mut old_pbuf     = self.proto_buf
        self.buf         = self.mono_buf
        self.struct_buf  = self.mono_buf
        self.proto_buf   = self.mono_buf

        # Forward declaration
        self.w("typedef struct " + mono_name + " " + mono_name + ";\n")

        # Struct body
        self.w("typedef struct " + mono_name + " {\n")
        mut fi = 0
        while fi < cls.fields.len:
            mut f = cls.fields.get(fi)
            self.w("    " + self.type_to_c(f.ty) + " " + f.name + ";\n")
            fi = fi + 1
        if cls.fields.len == 0:
            self.w("    char _pad;\n")
        self.w("} " + mono_name + ";\n\n")

        # Method prototypes then bodies
        mut mi = 0
        while mi < cls.methods.len:
            mut m = cls.methods.get(mi)
            mut old_class = self.cur_class
            mut old_func  = self.cur_func
            self.cur_class = mono_name
            self.cur_func  = m.name
            mut sig = self.get_inline_attrs(m) + self.gen_func_sig(m, mono_name)
            self.w(sig + ";\n")
            mi = mi + 1
        mi = 0
        while mi < cls.methods.len:
            mut m = cls.methods.get(mi)
            mut old_class = self.cur_class
            mut old_func  = self.cur_func
            self.cur_class = mono_name
            self.cur_func  = m.name
            self.decl_vars = Map[str, bool].init(64)
            self.seed_params(m)
            mut sig = self.get_inline_attrs(m) + self.gen_func_sig(m, mono_name)
            self.w(sig + " {\n")
            self.gen_func_body(m.body, 1)
            self.w("}\n\n")
            self.cur_class = old_class
            self.cur_func  = old_func
            mi = mi + 1

        # Generate monomorphized interface vtable + wrapper for each implemented interface.
        # type_subst is still active here so type_to_c substitutes T->concrete correctly.
        if cls.iface_names as usize != 0 as usize and not _is_invalid_ptr(cls.iface_names as usize):
            mut ifw_i = 0
            while ifw_i < cls.iface_names.len:
                mut iface_base = cls.iface_names.get(ifw_i)
                if self.interfaces.contains(iface_base):
                    mut m_iface = self.interfaces.get(iface_base)
                    if not _is_invalid_ptr(m_iface as usize):
                        mut mono_iface_name = iface_base
                        if m_iface.generics.len > 0:
                            mono_iface_name = iface_base + "_" + sfx
                        # Emit vtable struct + obj typedef once per monomorphized interface name
                        mut vtbl_done_key = "iface_obj_" + mono_iface_name
                        if not self.emitted_fns.contains(vtbl_done_key):
                            self.emitted_fns.insert(vtbl_done_key, true)
                            self.w("typedef struct _" + mono_iface_name + "_vtable {\n")
                            mut vmi = 0
                            while vmi < m_iface.methods.len:
                                mut vm2 = m_iface.methods.get(vmi)
                                mut vret2 = self.type_to_c(vm2.ret_ty)
                                self.w("    " + vret2 + " (*" + vm2.name + ")(void* self")
                                mut vpi = 0
                                while vpi < vm2.params.len:
                                    mut vp2 = vm2.params.get(vpi)
                                    if vp2.name != "self":
                                        self.w(", " + self.type_to_c(vp2.ty) + " " + vp2.name)
                                    vpi = vpi + 1
                                self.w(");\n")
                                vmi = vmi + 1
                            self.w("} " + mono_iface_name + "_vtable;\n\n")
                            self.w("typedef struct { " + mono_iface_name + "_vtable* vtable; void* data; } " + mono_iface_name + "_obj;\n\n")
                        # Emit wrapper function once per class+interface pair
                        mut wrap_done_key = "iface_wrap_" + mono_name + "_" + mono_iface_name
                        if not self.emitted_fns.contains(wrap_done_key):
                            self.emitted_fns.insert(wrap_done_key, true)
                            self.w("static inline " + mono_iface_name + "_obj " + mono_name + "_as_" + mono_iface_name + "(" + mono_name + "* self) {\n")
                            self.w("    static const " + mono_iface_name + "_vtable _vtbl_" + mono_name + "_" + mono_iface_name + " = {\n")
                            mut wm_i = 0
                            while wm_i < m_iface.methods.len:
                                mut wm2 = m_iface.methods.get(wm_i)
                                mut wret_c2 = self.type_to_c(wm2.ret_ty)
                                mut wcast2 = wret_c2 + "(*)(void*"
                                mut wp_i = 0
                                while wp_i < wm2.params.len:
                                    mut wp2 = wm2.params.get(wp_i)
                                    if wp2.name != "self":
                                        wcast2 = wcast2 + ", " + self.type_to_c(wp2.ty)
                                    wp_i = wp_i + 1
                                wcast2 = wcast2 + ")"
                                self.w("        ." + wm2.name + " = (" + wcast2 + ")(" + mono_name + "_" + wm2.name + "),\n")
                                wm_i = wm_i + 1
                            self.w("    };\n")
                            self.w("    return (" + mono_iface_name + "_obj){ .vtable = (" + mono_iface_name + "_vtable*)&_vtbl_" + mono_name + "_" + mono_iface_name + ", .data = (void*)self };\n")
                            self.w("}\n\n")
                ifw_i = ifw_i + 1

        # Save back the (possibly realloc-grown) mono buffer before restoring.
        # self.buf IS the mono buffer; without this, mono_buf.ptr becomes stale
        # after any realloc during generation and causes an access violation at flush time.
        self.mono_buf   = self.buf
        self.buf        = old_buf
        self.struct_buf = old_sbuf
        self.proto_buf  = old_pbuf
        self.type_subst = old_subst

    # Ensure a monomorphized version of a generic function is generated into mono_buf.
    pub def ensure_mono_func(self, fname: str, targ: str):
        mut mono_key = "func_" + fname + "__MONO_" + targ
        if self.mono_done.contains(mono_key): return
        self.mono_done.insert(mono_key, true)
        if not self.functions.contains(fname): return
        mut f = self.functions.get(fname)
        if f.generics.len == 0: return
        mut type_param = f.generics.get(0)
        mut concrete_c = self.type_to_c(AstType.init(targ))
        mut old_subst = self.type_subst
        self.type_subst = Map[str, str].init(4)
        self.type_subst.insert(type_param, concrete_c)
        mut old_buf = self.buf
        mut old_sbuf = self.struct_buf
        mut old_pbuf = self.proto_buf
        self.buf = self.mono_buf
        self.struct_buf = self.mono_buf
        self.proto_buf = self.mono_buf
        mut mono_fname = fname + "__MONO_" + targ
        mut ret_s = self.type_to_c(f.ret_ty)
        mut sig = ret_s + " " + mono_fname + "("
        mut first = true
        mut pi = 0
        while pi < f.params.len:
            mut p = f.params.get(pi)
            if p.name != "self":
                if not first: sig = sig + ", "
                sig = sig + self.type_to_c(p.ty) + " " + _safe_c_varname(p.name)
                first = false
            pi = pi + 1
        sig = sig + ")"
        self.w(sig + ";\n")
        mut old_class = self.cur_class
        mut old_func = self.cur_func
        self.cur_class = ""
        self.cur_func = mono_fname
        self.decl_vars = Map[str, bool].init(64)
        self.seed_params(f)
        self.w(sig + " {\n")
        self.gen_func_body(f.body, 1)
        self.w("}\n\n")
        self.cur_class = old_class
        self.cur_func = old_func
        self.mono_buf = self.buf
        self.buf = old_buf
        self.struct_buf = old_sbuf
        self.proto_buf = old_pbuf
        self.type_subst = old_subst

    # -- Attributes & signatures -----------------------------------------------

    pub def get_user_decorator_attr(self, name: str) -> str:
        if not self.decorator_defs.contains(name): return ""
        mut df = self.decorator_defs.get(name)
        # A decorator body with a single return of a string literal -> use as C attribute suffix
        if df.body.stmts.len == 1:
            match df.body.stmts.get(0).read():
                case HirStmt.SReturn(rv):
                    if rv as usize != 0 as usize:
                        match rv.read():
                            case HirExpr.ELitStr(attr_s, _):
                                return "__attribute__((" + attr_s + ")) "
                            case _: pass
                case _: pass
        return ""

    pub def get_inline_attrs(self, f: HirFunction) -> str:
        mut i = 0
        while i < f.decorators.len:
            if f.decorators.get(i).name == "inline": return "static inline __attribute__((always_inline,hot)) "
            if f.decorators.get(i).name == "hot": return "static __attribute__((hot)) "
            if f.decorators.get(i).name == "noinline": return "static __attribute__((noinline)) "
            mut user_attr = self.get_user_decorator_attr(f.decorators.get(i).name)
            if user_attr != "": return "static " + user_attr
            i = i + 1
        if f.name == "main" or f.name == "_tr_main":
            return "__attribute__((hot)) "
        if f.name == "init":
            return "static __attribute__((malloc,returns_nonnull,hot)) "
        return "static __attribute__((hot)) "

    pub def is_rt_concurrency_type(self, name: str) -> bool:
        if name == "Atomic": return true
        if name == "Thread": return true
        if name == "Mutex": return true
        if name == "RwLock": return true
        if name == "Chan": return true
        if name == "ThreadPool": return true
        if name == "ThreadLocal": return true
        return false

    # Like get_inline_attrs but without `static` - for cross-module prototypes in tauraro_types.h.
    pub def get_proto_attrs(self, f: HirFunction) -> str:
        mut i = 0
        while i < f.decorators.len:
            if f.decorators.get(i).name == "inline": return "inline __attribute__((always_inline,hot)) "
            if f.decorators.get(i).name == "hot": return "__attribute__((hot)) "
            if f.decorators.get(i).name == "noinline": return "__attribute__((noinline)) "
            mut user_attr_p = self.get_user_decorator_attr(f.decorators.get(i).name)
            if user_attr_p != "": return user_attr_p
            i = i + 1
        if f.name == "main" or f.name == "_tr_main":
            return "__attribute__((hot)) "
        if f.name == "init":
            return "__attribute__((malloc,returns_nonnull,hot)) "
        return "__attribute__((hot)) "

    pub def gen_func_sig(self, f: HirFunction, class_name: str) -> str:
        mut old_f = self.cur_func
        self.cur_func = f.name
        mut ret_ty_str = self.type_to_c(f.ret_ty)
        if f.throws_ty.name != "":
            ret_ty_str = "Result"
        mut fname = f.name
        if fname == "main": fname = "_tr_main"
        # Escape C reserved keywords used as function names
        if _is_c_keyword(fname): fname = "_tr_fn_" + fname
        if class_name != "":
            mut base_sig_key = class_name + "_" + fname
            if self.overloaded_sigs.contains(base_sig_key):
                # Mangle overloaded method: append _Narg suffix by non-self param count.
                mut param_count = 0
                mut opi = 0
                while opi < f.params.len:
                    if f.params.get(opi).name != "self": param_count = param_count + 1
                    opi = opi + 1
                fname = base_sig_key + "_" + param_count.to_str() + "arg"
            else:
                fname = base_sig_key
        mut sig = ret_ty_str + " " + fname + "("
        mut first = true

        if class_name != "" and not f.is_static:
            if self.enums.contains(class_name):
                sig = sig + class_name + " self"
            else:
                sig = sig + class_name + "* self"
            first = false

        mut i = 0
        while i < f.params.len:
            mut p = f.params.get(i)
            if p.name != "self":
                if not first: sig = sig + ", "
                sig = sig + self.type_to_c(p.ty) + " " + _safe_c_varname(p.name)
                first = false
            i = i + 1

        if f.is_variadic:
            if not first: sig = sig + ", "
            sig = sig + "..."

        sig = sig + ")"
        self.cur_func = old_f
        return sig

    # -- Struct generation -----------------------------------------------------

    pub def emit_base_fields(self, base_name: str):
        if self.classes.contains(base_name):
            mut base_cls: HirClass = self.classes.get(base_name)
            mut bfi: int = 0
            while bfi < base_cls.fields.len:
                mut bf: HirField = base_cls.fields.get(bfi)
                self.ws("    " + self.type_to_c(bf.ty) + " " + bf.name + ";\n")
                bfi = bfi + 1

    pub def gen_class_struct(self, c: HirClass):
        self.ws("#ifndef " + c.name + "_STRUCT_DEFINED\n")
        self.ws("#define " + c.name + "_STRUCT_DEFINED\n")
        self.ws("typedef struct " + c.name + " {\n")
        # Emit inherited fields first (single-level inheritance via field copying)
        mut bi: int = 0
        while bi < c.base_classes.len:
            mut base_name: str = c.base_classes.get(bi)
            self.emit_base_fields(base_name)
            bi = bi + 1
        mut i: int = 0
        while i < c.fields.len:
            mut f: HirField = c.fields.get(i)
            self.ws("    " + self.type_to_c(f.ty) + " " + f.name + ";\n")
            i = i + 1
        if c.fields.len == 0 and c.base_classes.len == 0:
            self.ws("    char _pad;\n")
        self.ws("} " + c.name + ";\n")
        self.ws("#endif\n\n")

    pub def gen_enum_struct(self, e: HirEnum):
        # Emit tag constants
        self.ws("typedef enum {\n")
        mut i = 0
        while i < e.variants.len:
            mut v = e.variants.get(i)
            self.ws("    " + e.name + "_" + v.name)
            if i < e.variants.len - 1: self.ws(",")
            self.ws("\n")
            i = i + 1
        if e.variants.len == 0:
            self.ws("    " + e.name + "_EMPTY\n")
        self.ws("} " + e.name + "_tag;\n\n")

        # Emit the tagged union struct
        self.ws("typedef struct " + e.name + " {\n")
        self.ws("    " + e.name + "_tag tag;\n")
        mut has_data = false
        i = 0
        while i < e.variants.len:
            if e.variants.get(i).fields.len > 0:
                has_data = true
            i = i + 1
        if has_data:
            self.ws("    union {\n")
            i = 0
            while i < e.variants.len:
                mut v = e.variants.get(i)
                if v.fields.len > 0:
                    self.ws("        struct {\n")
                    mut j = 0
                    while j < v.fields.len:
                        mut fld = v.fields.get(j)
                        self.ws("            " + self.type_to_c(fld.ty) + " " + fld.name + ";\n")
                        j = j + 1
                    self.ws("        } " + v.name + ";\n")
                i = i + 1
            self.ws("    } data;\n")
        self.ws("} " + e.name + ";\n\n")

        # Emit constructor macros for each variant
        i = 0
        while i < e.variants.len:
            mut v = e.variants.get(i)
            if v.fields.len == 0:
                self.ws("#define " + e.name + "_make_" + v.name + "() ((" + e.name + "){.tag=" + e.name + "_" + v.name + "})\n")
            else:
                self.ws("static inline __attribute__((always_inline)) " + e.name + " " + e.name + "_ctor_" + v.name + "(")
                mut j = 0
                while j < v.fields.len:
                    if j > 0: self.ws(", ")
                    self.ws(self.type_to_c(v.fields.get(j).ty) + " " + v.fields.get(j).name)
                    j = j + 1
                self.ws(") { " + e.name + " _r = {.tag=" + e.name + "_" + v.name + "}; ")
                j = 0
                while j < v.fields.len:
                    self.ws("_r.data." + v.name + "." + v.fields.get(j).name + " = " + v.fields.get(j).name + "; ")
                    j = j + 1
                self.ws("return _r; }\n")
            i = i + 1
        self.ws("\n")
        # Pre-generate List_EnumName so Vec[EnumType] works in prototypes
        # that appear after this struct definition. Without this, the prototype
        # uses List_EnumName before it is defined.
        if not self.list_type_done.contains(e.name):
            self.ensure_list_type(e.name)

    pub def gen_interface_vtable(self, iface: HirInterface):
        if iface.generics.len > 0: return  # monomorphized versions generated in ensure_mono
        self.ws("typedef struct _" + iface.name + "_vtable {\n")
        mut i = 0
        while i < iface.methods.len:
            mut m = iface.methods.get(i)
            mut ret = self.type_to_c(m.ret_ty)
            self.ws("    " + ret + " (*" + m.name + ")(void* self")
            mut j = 0
            while j < m.params.len:
                mut p = m.params.get(j)
                if p.name != "self":
                    self.ws(", " + self.type_to_c(p.ty) + " " + p.name)
                j = j + 1
            self.ws(");\n")
            i = i + 1
        self.ws("} " + iface.name + "_vtable;\n\n")
        if not self.emitted_fns.contains("iface_obj_" + iface.name):
            self.emitted_fns.insert("iface_obj_" + iface.name, true)
            self.ws("typedef struct { " + iface.name + "_vtable* vtable; void* data; } " + iface.name + "_obj;\n\n")

    # Build the static-inline _as_ wrap function string for one class+interface pair.
    # Called from generate_types_header (appended after all prototypes).
    pub def gen_one_iface_wrap(self, cls_name: str, iface: HirInterface) -> str:
        mut s = "static inline " + iface.name + "_obj " + cls_name + "_as_" + iface.name + "(" + cls_name + "* self) {\n"
        s = s + "    static const " + iface.name + "_vtable _vtbl_" + cls_name + "_" + iface.name + " = {\n"
        mut mi = 0
        while mi < iface.methods.len:
            mut m = iface.methods.get(mi)
            mut ret_c = self.type_to_c(m.ret_ty)
            mut cast_sig = ret_c + "(*)(void*"
            mut pi = 0
            while pi < m.params.len:
                mut p = m.params.get(pi)
                if p.name != "self":
                    cast_sig = cast_sig + ", " + self.type_to_c(p.ty)
                pi = pi + 1
            cast_sig = cast_sig + ")"
            s = s + "        ." + m.name + " = (" + cast_sig + ")(" + cls_name + "_" + m.name + "),\n"
            mi = mi + 1
        s = s + "    };\n"
        s = s + "    return (" + iface.name + "_obj){ .vtable = (" + iface.name + "_vtable*)&_vtbl_" + cls_name + "_" + iface.name + ", .data = (void*)self };\n"
        s = s + "}\n"
        return s

    # -- Expression generation -------------------------------------------------

    pub def gen_expr(self, e_ptr: Pointer[HirExpr]) -> str:
        if e_ptr as usize == 0 as usize: return "NULL"
        e = e_ptr.read()
        match e:
            case HirExpr.ELitInt(v, _): return v.to_str() + "LL"
            case HirExpr.ELitFloat(v, _): return _tr_float_to_c_lit(v)
            case HirExpr.ELitStr(v, _): return "\"" + _escape_str_for_c(v) + "\""
            case HirExpr.ERawStr(v, _): return "\"" + _escape_str_for_c(v) + "\""
            case HirExpr.ELitBytes(v, _): return "\"" + _escape_str_for_c(v) + "\""
            case HirExpr.ELitChar(v, _):
                if v == 0: return "'\\0'"
                if v == 10: return "'\\n'"
                if v == 9: return "'\\t'"
                if v == 13: return "'\\r'"
                if v == 92: return "'\\\\'"
                if v == 39: return "'\\''"
                return "'" + _tr_char_to_str(v) + "'"
            case HirExpr.ELitBool(v, _):
                if v: return "true"
                else: return "false"
            case HirExpr.ELitNone(_): return "NULL"
            case HirExpr.EIdent(n, _, _):
                if _is_c_keyword(n) and self.decl_vars.contains(n): return "_tr_v_" + n
                if n == "argv" and self.cur_func == "main": return "_tr_main_argv"
                # A top-level function used as a value (not a call target) is a
                # zero-cost function pointer: emit its address as void*.
                if self.functions.contains(n) and not self.decl_vars.contains(n): return "(void*)" + n
                return n
            case HirExpr.EBinOp(op, l, r, _): return self.gen_binop(op, l, r)
            case HirExpr.EUnaryOp(op, expr, _): return self.gen_unary(op, expr)
            case HirExpr.ECall(callee, args, call_ty): return self.gen_call(callee, args, call_ty)
            case HirExpr.EMethodCall(o, m, a, ty): return self.gen_method_call(o, m, a, ty)
            case HirExpr.EPropAccess(o, p, _): return self.gen_prop_access(o, p)
            case HirExpr.EIndex(o, idx, _): return self.gen_index(o, idx)
            case HirExpr.ESizeOf(target_ty, _):
                mut sizeof_cty = self.type_to_c(target_ty)
                mut sizeof_len = _tr_str_len(sizeof_cty)
                if sizeof_len > 0:
                    if (sizeof_cty as Pointer[char]).offset(sizeof_len - 1).read() as int == 42:
                        sizeof_cty = _tr_str_slice(sizeof_cty, 0, sizeof_len - 1)
                return "((long long)sizeof(" + sizeof_cty + "))"
            case HirExpr.ECast(expr, target_ty):
                return "((" + self.type_to_c(target_ty) + ")(" + self.gen_expr(expr) + "))"
            case HirExpr.EFString(parts, _): return self.gen_fstring(parts)
            case HirExpr.ETryExpr(expr, ok_ty):
                # Fallback: unsafe extract (proper propagation handled at statement level)
                mut inner_s2 = self.gen_expr(expr)
                mut ok_c = self.type_to_c(ok_ty)
                if ok_c == "void" or ok_c == "__auto_type": ok_c = "long long"
                if _is_int_type(ok_ty.name) or ok_ty.name == "bool":
                    return "((" + ok_c + ")(uintptr_t)((" + inner_s2 + ").data.Ok.val))"
                return "((" + ok_c + "*)((" + inner_s2 + ").data.Ok.val))"
            case HirExpr.ETuple(items, _): return self.gen_tuple(items)
            case HirExpr.EList(items, ty): return self.gen_list_literal(items, ty)
            case HirExpr.EDict(keys, vals, dict_ty): return self.gen_dict_literal(keys, vals, dict_ty)
            case HirExpr.EClosure(params, ret_ty, body, _, captures):
                return self.gen_closure(params, ret_ty, body, captures)
            case HirExpr.ERange(start, end, inclusive, _):
                return self.gen_expr(start)
            case HirExpr.ESuperMethodCall(base, method, args, _):
                mut super_mc: str = method
                if _is_c_keyword(super_mc):
                    super_mc = "_tr_fn_" + super_mc
                mut sig = base + "_" + super_mc + "((" + base + "*)self"
                mut i = 0
                while i < args.len:
                    sig = sig + ", " + self.gen_expr(args.get(i))
                    i = i + 1
                return sig + ")"
            case HirExpr.ESuperPropAccess(base, prop, _):
                return "(((" + base + "*)self)->" + prop + ")"
            case HirExpr.EAwait(expr, _):
                return self.gen_await_call(expr)
            case HirExpr.EAwaitTimeout(at_expr, at_ms, _):
                return self.gen_await_timeout_call(at_expr, at_ms)
            case HirExpr.EYield(expr, _):
                return self.gen_expr(expr)
            case HirExpr.ESet(items, _):
                mut set_ty = AstType.init("ptr")
                if items.len > 0:
                    mut first_ty_n: str = hir_expr_type(items.get(0)).name
                    set_ty = AstType.init(first_ty_n)
                return self.gen_list_literal(items, set_ty)
            case HirExpr.EListComp(element, generators, _):
                return self.gen_list_comp(element, generators)
            case HirExpr.EGeneratorExpr(element, generators, _):
                return self.gen_list_comp(element, generators)
            case HirExpr.ESlice(start, stop, step, _):
                if start as usize != 0 as usize: return self.gen_expr(start)
                return "0LL"
            case HirExpr.EIfElse(cond, then_e, else_e, ty):
                mut ts = self.gen_expr(then_e)
                mut es = self.gen_expr(else_e)
                if _is_int_type(ty.name):
                    if ts == "NULL": ts = "0LL"
                    if es == "NULL": es = "0LL"
                return "((" + self.gen_expr(cond) + ") ? (" + ts + ") : (" + es + "))"
            case _: return "0 /* unsupported expr */"

    pub def has_method(self, cls_name: str, method: str) -> bool:
        if cls_name == "" or cls_name == "void": return false
        if self.classes.contains(cls_name):
            mut cls = self.classes.get(cls_name)
            mut i = 0
            while i < cls.methods.len:
                if cls.methods.get(i).name == method: return true
                i = i + 1
            return false
        mut cp = cls_name as Pointer[char]
        mut ui = 0
        while cp.offset(ui).read() as int != 0:
            if cp.offset(ui).read() as int == 95:
                mut candidate = _tr_str_slice(cls_name, 0, ui)
                if self.classes.contains(candidate):
                    mut base_cls = self.classes.get(candidate)
                    mut bmi = 0
                    while bmi < base_cls.methods.len:
                        if base_cls.methods.get(bmi).name == method: return true
                        bmi = bmi + 1
                    return false
            ui = ui + 1
        return false

    pub def cls_method_ret_ty(self, cls_name: str, method: str) -> AstType:
        if cls_name == "" or cls_name == "void": return AstType.init("void")
        if self.classes.contains(cls_name):
            mut cls = self.classes.get(cls_name)
            mut i = 0
            while i < cls.methods.len:
                if cls.methods.get(i).name == method: return cls.methods.get(i).ret_ty
                i = i + 1
            return AstType.init("void")
        mut cp2 = cls_name as Pointer[char]
        mut ui2 = 0
        while cp2.offset(ui2).read() as int != 0:
            if cp2.offset(ui2).read() as int == 95:
                mut candidate2 = _tr_str_slice(cls_name, 0, ui2)
                if self.classes.contains(candidate2):
                    mut base_cls2 = self.classes.get(candidate2)
                    mut i2 = 0
                    while i2 < base_cls2.methods.len:
                        if base_cls2.methods.get(i2).name == method: return base_cls2.methods.get(i2).ret_ty
                        i2 = i2 + 1
                    return AstType.init("void")
            ui2 = ui2 + 1
        return AstType.init("void")

    pub def cls_method_c_call(self, cls_name: str, method: str, obj_s: str, extra_args: str) -> str:
        mut safe_m = method
        if _is_c_keyword(safe_m): safe_m = "_tr_fn_" + safe_m
        if extra_args == "":
            return cls_name + "_" + safe_m + "(" + obj_s + ")"
        return cls_name + "_" + safe_m + "(" + obj_s + ", " + extra_args + ")"

    pub def gen_cond_expr(self, cond: Pointer[HirExpr]) -> str:
        mut cond_s = self.gen_expr(cond)
        mut ty_n: str = hir_expr_type(cond).name
        if self.has_method(ty_n, "__bool__"):
            return self.cls_method_c_call(ty_n, "__bool__", cond_s, "")
        return cond_s

    pub def gen_binop(self, op: str, l: Pointer[HirExpr], r: Pointer[HirExpr]) -> str:
        mut ls = self.gen_expr(l)
        mut rs = self.gen_expr(r)
        mut lt_n: str = hir_expr_type(l).name
        mut rt_n: str = hir_expr_type(r).name
        if op == "+" and (_is_str_type(lt_n) or _is_str_type(rt_n)):
            return "_tr_str_concat(" + ls + ", " + rs + ")"
        if op == "and":
            mut lsa = ls
            mut rsa = rs
            if self.has_method(lt_n, "__bool__"): lsa = self.cls_method_c_call(lt_n, "__bool__", ls, "")
            if self.has_method(rt_n, "__bool__"): rsa = self.cls_method_c_call(rt_n, "__bool__", rs, "")
            return "(" + lsa + " && " + rsa + ")"
        if op == "or":
            mut lso = ls
            mut rso = rs
            if self.has_method(lt_n, "__bool__"): lso = self.cls_method_c_call(lt_n, "__bool__", ls, "")
            if self.has_method(rt_n, "__bool__"): rso = self.cls_method_c_call(rt_n, "__bool__", rs, "")
            return "(" + lso + " || " + rso + ")"
        if op == "is": return "(" + ls + " == " + rs + ")"
        if op == "in":
            if rt_n == "List" or rt_n == "Vec":
                mut in_sfx: str = self.list_elem_suffix(lt_n)
                return "List_" + in_sfx + "_contains(" + rs + ", " + ls + ")"
            if rt_n == "Map" or rt_n == "Dict":
                return "_tr_dict_contains(" + rs + ", " + ls + ")"
            if self.has_method(rt_n, "__contains__"):
                return self.cls_method_c_call(rt_n, "__contains__", rs, ls)
            return "_tr_contains(" + rs + ", " + ls + ")"
        # Dunder dispatch for arithmetic and comparison ops
        mut dunder = ""
        if op == "+": dunder = "__add__"
        elif op == "-": dunder = "__sub__"
        elif op == "*": dunder = "__mul__"
        elif op == "/": dunder = "__truediv__"
        elif op == "%": dunder = "__mod__"
        elif op == "**": dunder = "__pow__"
        elif op == "//": dunder = "__floordiv__"
        elif op == "==": dunder = "__eq__"
        elif op == "!=": dunder = "__ne__"
        elif op == "<": dunder = "__lt__"
        elif op == "<=": dunder = "__le__"
        elif op == ">": dunder = "__gt__"
        elif op == ">=": dunder = "__ge__"
        if dunder != "" and self.has_method(lt_n, dunder):
            return self.cls_method_c_call(lt_n, dunder, ls, rs)
        if op == "**": return "((long long)pow((double)(" + ls + "), (double)(" + rs + ")))"
        if op == "//": return "((long long)(" + ls + ") / (long long)(" + rs + "))"
        if (_is_str_type(lt_n) or _is_str_type(rt_n)) and (op == "==" or op == "!="):
            if op == "==": return "(strcmp((char*)" + ls + ", (char*)" + rs + ") == 0)"
            return "(strcmp((char*)" + ls + ", (char*)" + rs + ") != 0)"
        if self.enums.contains(lt_n) and (op == "==" or op == "!="):
            return "(" + ls + ".tag " + op + " " + rs + ".tag)"
        return "(" + ls + " " + op + " " + rs + ")"

    pub def gen_unary(self, op: str, expr: Pointer[HirExpr]) -> str:
        mut inner = self.gen_expr(expr)
        mut ty_n: str = hir_expr_type(expr).name
        if op == "not" or op == "!":
            if self.has_method(ty_n, "__bool__"):
                return "(!(" + self.cls_method_c_call(ty_n, "__bool__", inner, "") + "))"
            return "(!" + inner + ")"
        if op == "-" and self.has_method(ty_n, "__neg__"):
            return self.cls_method_c_call(ty_n, "__neg__", inner, "")
        if op == "+" and self.has_method(ty_n, "__pos__"):
            return self.cls_method_c_call(ty_n, "__pos__", inner, "")
        if op == "*" or op == "deref": return "(*" + inner + ")"
        if op == "&" or op == "ref": return "(&" + inner + ")"
        return "(" + op + inner + ")"

    pub def gen_prop_access(self, o: Pointer[HirExpr], p: str) -> str:
        mut t_n: str = hir_expr_type(o).name
        mut obj_s = self.gen_expr(o)
        # Shared var: unwrap _TrSharedBox* -> (TypeName*)obj->data
        if self.shared_vars.contains(obj_s):
            mut sh_ty = self.shared_vars.get(obj_s)
            return "((" + sh_ty + "*)(" + obj_s + "->data))->" + p
        if self.enums.contains(t_n):
            if obj_s == t_n: return t_n + "_make_" + p + "()"
            return obj_s + ".data." + p
        if t_n == "Pointer": return "(*" + obj_s + ")." + p
        if _is_str_type(t_n) and (p == "len" or p == "length"):
            return "((long long)_tr_strlen(" + obj_s + "))"
        if t_n == "StringBuilder" and (p == "len" or p == "length"):
            return "(" + obj_s + "->buf->len)"
        if t_n == "Result":
            if p == "is_err": return "(" + obj_s + ".tag == Result_Err)"
            if p == "is_ok": return "(" + obj_s + ".tag == Result_Ok)"
            if p == "ok":
                mut full_ty = hir_expr_type(o)
                if full_ty.args.len > 0:
                    mut ok_ct = self.type_to_c(full_ty.args.get(0).read())
                    return "((" + ok_ct + ")Result_unwrap(" + obj_s + "))"
                return "Result_unwrap(" + obj_s + ")"
            if p == "err":
                mut full_ty2 = hir_expr_type(o)
                if full_ty2.args.len > 1:
                    mut err_ct = self.type_to_c(full_ty2.args.get(1).read())
                    return "((" + err_ct + ")Result_unwrap_err(" + obj_s + "))"
                return "(char*)Result_unwrap_err(" + obj_s + ")"
            return obj_s + "." + p
        if t_n == "Option":
            if p == "is_some": return "(" + obj_s + ".tag == Option_Some)"
            if p == "is_none": return "(" + obj_s + ".tag == Option_None)"
            if p == "value" or p == "val":
                mut full_opt_ty = hir_expr_type(o)
                if full_opt_ty.args.len > 0:
                    mut opt_ct = self.type_to_c(full_opt_ty.args.get(0).read())
                    return "((" + opt_ct + ")Option_unwrap(" + obj_s + "))"
                return "Option_unwrap(" + obj_s + ")"
            # Handle Option.None / Option.Some as static constructors (p may be empty if None is a keyword)
            if p == "" or p == "None" or p == "none": return "((Option){.tag=Option_None})"
            if p == "Some" or p == "some": return "((Option){.tag=Option_Some})"
            return obj_s + "." + p
        if self.interfaces.contains(t_n) and self.interfaces as usize != 0 as usize:
            return obj_s + "." + p
        return obj_s + "->" + p

    pub def gen_index(self, o: Pointer[HirExpr], idx: Pointer[HirExpr]) -> str:
        mut os = self.gen_expr(o)
        mut is_idx = self.gen_expr(idx)
        mut ty_n: str = hir_expr_type(o).name
        if ty_n == "Pointer": return os + "[" + is_idx + "]"
        if ty_n == "List" or ty_n == "Vec":
            # Bounds-checked access - works as both lvalue and rvalue.
            # The comma operator in the subscript runs the check then uses the index.
            return os + "->data[(_tr_bounds_check(" + is_idx + ", " + os + "->len), " + is_idx + ")]"
        if self.classes.contains(ty_n) and ty_n != "Vec" and ty_n != "List" and ty_n != "Map" and ty_n != "Dict":
            if self.has_method(ty_n, "__getitem__"):
                return self.cls_method_c_call(ty_n, "__getitem__", os, is_idx)
            return ty_n + "_get_index(" + os + ", " + is_idx + ")"
        return os + "[" + is_idx + "]"

    pub def gen_call(self, callee: Pointer[HirExpr], args: Vec[Pointer[HirExpr]], call_ty: AstType) -> str:
        mut callee_s = self.gen_expr(callee)
        
        # Check if callee is a generic built-in call target like alloc[T] or dealloc[T]
        mut base_callee = callee_s
        mut has_generic = false
        mut generic_ty = AstType.init("void")
        # Vec[T].init(n) / List[T].init(n) - static generic constructor
        match callee.read():
            case HirExpr.EPropAccess(inner_obj, variant, _):
                if variant == "init" or variant == "new":
                    match inner_obj.read():
                        case HirExpr.EIndex(base_expr, idx_expr, _):
                            match base_expr.read():
                                case HirExpr.EIdent(gn, _, _):
                                    if gn == "Vec" or gn == "List":
                                        match idx_expr.read():
                                            case HirExpr.EIdent(elem_n, _, _):
                                                mut sfx = self.list_elem_suffix(elem_n)
                                                return "(void*)List_" + sfx + "_new()"
                                            case _: pass
                                case _: pass
                        case _: pass
            case _: pass

        match callee.read():
            case HirExpr.EIdent(raw_n, _, _):
                # Use raw identifier name (not gen_expr output) so C-keyword variable names
                # like `int`, `float`, `count` don't obscure builtin dispatch.
                base_callee = raw_n
            case HirExpr.EIndex(base_expr, idx_expr, idx_ty):
                match base_expr.read():
                    case HirExpr.EIdent(n, _, _):
                        if n == "alloc" or n == "core_alloc_alloc" or n == "dealloc" or n == "Pointer" or n == "resize" or n == "core_alloc_resize" or n == "copy" or n == "core_alloc_copy":
                            base_callee = n
                            has_generic = true
                            match idx_expr.read():
                                case HirExpr.EIdent(tname, _, _):
                                    generic_ty = AstType.init(tname)
                                case _: pass
                    case _: pass
            case _: pass

        # Mangle C reserved keywords used as call targets
        if _is_c_keyword(base_callee): base_callee = "_tr_fn_" + base_callee

        # Direct call to a known top-level function: use the plain name, not the
        # "(void*)name" value form that gen_expr emits for function references.
        match callee.read():
            case HirExpr.EIdent(_dc_n, _, _):
                if self.functions.contains(_dc_n): callee_s = base_callee
            case _: pass

        # print builtin
        if base_callee == "print":
            return self.gen_print_call(args)

        # len builtin
        if base_callee == "len":
            if args.len > 0:
                mut arg0 = args.get(0)
                mut arg0_ty_n: str = hir_expr_type(arg0).name
                if _is_str_type(arg0_ty_n): return "_tr_strlen(" + self.gen_expr(arg0) + ")"
                if self.has_method(arg0_ty_n, "__len__"):
                    return self.cls_method_c_call(arg0_ty_n, "__len__", self.gen_expr(arg0), "")
                return self.gen_expr(arg0) + "->len"
            return "0LL"

        # range builtin (used in for loops - returns range struct)
        if base_callee == "range":
            if args.len == 1:
                return "_tr_range(0, " + self.gen_expr(args.get(0)) + ", 1)"
            elif args.len == 2:
                return "_tr_range(" + self.gen_expr(args.get(0)) + ", " + self.gen_expr(args.get(1)) + ", 1)"
            elif args.len == 3:
                return "_tr_range(" + self.gen_expr(args.get(0)) + ", " + self.gen_expr(args.get(1)) + ", " + self.gen_expr(args.get(2)) + ")"
            return "_tr_range(0, 0, 1)"

        # _tr_exit
        if base_callee == "_tr_exit":
            if args.len > 0: return "exit((int)(" + self.gen_expr(args.get(0)) + "))"
            return "exit(0)"

        # ord / chr - character conversions
        if base_callee == "ord":
            if args.len > 0:
                mut ord_t_n: str = hir_expr_type(args.get(0)).name
                if ord_t_n == "char": return "((long long)(unsigned char)(" + self.gen_expr(args.get(0)) + "))"
                return "((long long)(unsigned char)(" + self.gen_expr(args.get(0)) + ")[0])"
            return "0LL"
        if base_callee == "chr":
            if args.len > 0: return "((char)(" + self.gen_expr(args.get(0)) + "))"
            return "'\\0'"

        # abs - absolute value
        if base_callee == "abs":
            if args.len > 0:
                mut abs_a = self.gen_expr(args.get(0))
                mut abs_t_n: str = hir_expr_type(args.get(0)).name
                if _is_float_type(abs_t_n): return "fabs((double)(" + abs_a + "))"
                return "llabs((long long)(" + abs_a + "))"
            return "0LL"

        # max / min - pairwise comparisons
        if base_callee == "max":
            if args.len == 2:
                mut ma = self.next_temp()
                mut mb = self.next_temp()
                return "({ __auto_type " + ma + " = " + self.gen_expr(args.get(0)) + "; __auto_type " + mb + " = " + self.gen_expr(args.get(1)) + "; " + ma + " > " + mb + " ? " + ma + " : " + mb + "; })"
            return "0LL"
        if base_callee == "min":
            if args.len == 2:
                mut mna = self.next_temp()
                mut mnb = self.next_temp()
                return "({ __auto_type " + mna + " = " + self.gen_expr(args.get(0)) + "; __auto_type " + mnb + " = " + self.gen_expr(args.get(1)) + "; " + mna + " < " + mnb + " ? " + mna + " : " + mnb + "; })"
            return "0LL"

        # assert_eq / assert_ne / assert_lt / assert_le / assert_gt / assert_ge
        # Prints both values on failure so the user sees what was expected vs got.
        if base_callee == "assert_eq" or base_callee == "assert_ne" or base_callee == "assert_lt" or base_callee == "assert_le" or base_callee == "assert_gt" or base_callee == "assert_ge":
            if args.len >= 2:
                mut _aa = self.gen_expr(args.get(0))
                mut _ab = self.gen_expr(args.get(1))
                mut _ta = self.next_temp()
                mut _tb = self.next_temp()
                mut _op = "=="
                mut _op_msg = "expected equal"
                if base_callee == "assert_ne": _op = "!="; _op_msg = "expected not-equal"
                elif base_callee == "assert_lt": _op = "<";  _op_msg = "expected less-than"
                elif base_callee == "assert_le": _op = "<="; _op_msg = "expected less-or-equal"
                elif base_callee == "assert_gt": _op = ">";  _op_msg = "expected greater-than"
                elif base_callee == "assert_ge": _op = ">="; _op_msg = "expected greater-or-equal"
                mut _ty_a = hir_expr_type(args.get(0)).name
                mut _cvt = "(long long)"
                if _is_float_type(_ty_a): _cvt = "(double)"
                elif not _is_int_type(_ty_a): _cvt = "(long long)(uintptr_t)"
                return "({ __auto_type " + _ta + " = " + _aa + "; __auto_type " + _tb + " = " + _ab + "; if (!(" + _ta + " " + _op + " " + _tb + ")) { fprintf(stderr, \"[assert_" + _op + "] " + _op_msg + ": lhs=%lld rhs=%lld\\n\", (long long)" + _ta + ", (long long)" + _tb + "); abort(); } })"
            return "(void)0"

        # checked_add / checked_sub / checked_mul - returns Option[int]
        if base_callee == "checked_add" or base_callee == "checked_mul":
            if args.len == 2:
                mut _ca = self.gen_expr(args.get(0))
                mut _cb = self.gen_expr(args.get(1))
                mut _tres = self.next_temp()
                mut _op_c = "+"
                if base_callee == "checked_mul": _op_c = "*"
                return "({ long long " + _tres + "; _Bool _ov = __builtin_add_overflow((long long)(" + _ca + "), (long long)(" + _cb + "), &" + _tres + "); _ov ? ((Option){.tag=Option_None}) : ((Option){.tag=Option_Some,.data.Some.val=(void*)(uintptr_t)" + _tres + "}); })"
            return "((Option){.tag=Option_None})"
        if base_callee == "checked_sub":
            if args.len == 2:
                mut _ca2 = self.gen_expr(args.get(0))
                mut _cb2 = self.gen_expr(args.get(1))
                mut _tres2 = self.next_temp()
                return "({ long long " + _tres2 + "; _Bool _ov = __builtin_sub_overflow((long long)(" + _ca2 + "), (long long)(" + _cb2 + "), &" + _tres2 + "); _ov ? ((Option){.tag=Option_None}) : ((Option){.tag=Option_Some,.data.Some.val=(void*)(uintptr_t)" + _tres2 + "}); })"
            return "((Option){.tag=Option_None})"

        # round - rounding a float
        if base_callee == "round":
            if args.len > 0: return "(double)round((double)(" + self.gen_expr(args.get(0)) + "))"
            return "0.0"

        # str() - convert to string
        if base_callee == "str":
            if args.len > 0:
                mut str_arg = args.get(0)
                mut str_t_n: str = hir_expr_type(str_arg).name
                if _is_int_type(str_t_n): return "_tr_int_to_str((long long)(" + self.gen_expr(str_arg) + "))"
                if _is_float_type(str_t_n): return "_tr_float_to_str((double)(" + self.gen_expr(str_arg) + "))"
                if str_t_n == "bool": return "((" + self.gen_expr(str_arg) + ") ? \"true\" : \"false\")"
                if self.has_method(str_t_n, "__str__"):
                    return self.cls_method_c_call(str_t_n, "__str__", self.gen_expr(str_arg), "")
                if self.has_method(str_t_n, "__repr__"):
                    return self.cls_method_c_call(str_t_n, "__repr__", self.gen_expr(str_arg), "")
                return "(char*)(" + self.gen_expr(str_arg) + ")"
            return "\"\""

        # repr() - detailed string representation
        if base_callee == "repr":
            if args.len > 0:
                mut repr_arg = args.get(0)
                mut repr_t_n: str = hir_expr_type(repr_arg).name
                if self.has_method(repr_t_n, "__repr__"):
                    return self.cls_method_c_call(repr_t_n, "__repr__", self.gen_expr(repr_arg), "")
                if self.has_method(repr_t_n, "__str__"):
                    return self.cls_method_c_call(repr_t_n, "__str__", self.gen_expr(repr_arg), "")
                return "(char*)(" + self.gen_expr(repr_arg) + ")"
            return "\"\""

        # int() / float() / bool() - type coercions; int/float from str -> parse
        if base_callee == "int" or base_callee == "_tr_fn_int":
            if args.len > 0:
                if _is_str_type(hir_expr_type(args.get(0)).name): return "_tr_str_to_int(" + self.gen_expr(args.get(0)) + ")"
                return "(long long)(" + self.gen_expr(args.get(0)) + ")"
            return "0LL"
        if base_callee == "float" or base_callee == "_tr_fn_float":
            if args.len > 0:
                if _is_str_type(hir_expr_type(args.get(0)).name): return "_tr_str_to_float(" + self.gen_expr(args.get(0)) + ")"
                return "(double)(" + self.gen_expr(args.get(0)) + ")"
            return "0.0"
        if base_callee == "bool":
            if args.len > 0: return "(_Bool)(" + self.gen_expr(args.get(0)) + ")"
            return "0"

        # type() - returns a string representation of the type
        if base_callee == "type":
            return "\"<object>\""

        # await_all(f1(args), f2(args), ...) - run all calls concurrently, wait for completion
        if base_callee == "await_all":
            if args.len == 0: return "0LL"
            mut aa_code = "({ _tr_tg_begin(); "
            mut aa_i = 0
            while aa_i < args.len:
                mut aa_fn = ""
                mut aa_call_args: Vec[Pointer[HirExpr]] = []
                match args.get(aa_i).read():
                    case HirExpr.ECall(aa_c, aa_a, _):
                        match aa_c.read():
                            case HirExpr.EIdent(aa_n, _, _): aa_fn = aa_n
                            case _: pass
                        aa_call_args = aa_a
                    case _: pass
                if aa_fn != "":
                    if aa_call_args.len == 0:
                        aa_code = aa_code + "_tr_tg_push(_tr_thread_start(_tr_spawn_wrap_" + aa_fn + ", NULL)); "
                    elif aa_call_args.len == 1:
                        mut aa_aty = hir_expr_type(aa_call_args.get(0)).name
                        mut aa_vcast = "(void*)(uintptr_t)(" + self.gen_expr(aa_call_args.get(0)) + ")"
                        if not _is_int_type(aa_aty) and aa_aty != "bool" and aa_aty != "char":
                            aa_vcast = "(void*)(" + self.gen_expr(aa_call_args.get(0)) + ")"
                        aa_code = aa_code + "_tr_tg_push(_tr_thread_start(_tr_spawn_wrap_" + aa_fn + ", " + aa_vcast + ")); "
                    else:
                        # multi-arg: heap-pack
                        mut aa_na = aa_call_args.len
                        aa_code = aa_code + "{ long long* _aab" + str(aa_i) + " = (long long*)malloc(" + str(aa_na + 1) + " * sizeof(long long)); "
                        mut aa_ai2 = 0
                        while aa_ai2 < aa_na:
                            mut aa_atn = hir_expr_type(aa_call_args.get(aa_ai2)).name
                            if not _is_int_type(aa_atn) and aa_atn != "bool" and aa_atn != "char":
                                aa_code = aa_code + "_aab" + str(aa_i) + "[" + str(aa_ai2 + 1) + "] = (long long)" + self.gen_expr(aa_call_args.get(aa_ai2)) + "; "
                            else:
                                aa_code = aa_code + "_aab" + str(aa_i) + "[" + str(aa_ai2 + 1) + "] = (long long)(" + self.gen_expr(aa_call_args.get(aa_ai2)) + "); "
                            aa_ai2 = aa_ai2 + 1
                        aa_code = aa_code + "_tr_tg_push(_tr_thread_start(_tr_spawn_wrap_" + aa_fn + ", _aab" + str(aa_i) + ")); } "
                else:
                    aa_code = aa_code + self.gen_expr(args.get(aa_i)) + "; "
                aa_i = aa_i + 1
            aa_code = aa_code + "_tr_taskgroup_wait(); 0LL; })"
            return aa_code

        # iter / enumerate / sorted / reversed - identity for now
        if base_callee == "iter" or base_callee == "enumerate" or base_callee == "sorted" or base_callee == "reversed":
            if args.len > 0: return self.gen_expr(args.get(0))
            return "NULL"

        # sum - sum all elements of a list
        if base_callee == "sum":
            if args.len > 0:
                mut sum_tmp = self.next_temp()
                mut sum_l = self.next_temp()
                return "({ long long " + sum_tmp + " = 0; __auto_type " + sum_l + " = " + self.gen_expr(args.get(0)) + "; for (long long _si = 0; _si < " + sum_l + "->len; _si++) " + sum_tmp + " += (long long)" + sum_l + "->data[_si]; " + sum_tmp + "; })"
            return "0LL"

        # any / all - short-circuit list scan
        if base_callee == "any":
            if args.len > 0:
                mut any_l = self.next_temp()
                return "({ _Bool _any_r = 0; __auto_type " + any_l + " = " + self.gen_expr(args.get(0)) + "; for (long long _ai = 0; _ai < " + any_l + "->len; _ai++) if (" + any_l + "->data[_ai]) { _any_r = 1; break; } _any_r; })"
            return "0"
        if base_callee == "all":
            if args.len > 0:
                mut all_l = self.next_temp()
                return "({ _Bool _all_r = 1; __auto_type " + all_l + " = " + self.gen_expr(args.get(0)) + "; for (long long _ai = 0; _ai < " + all_l + "->len; _ai++) if (!" + all_l + "->data[_ai]) { _all_r = 0; break; } _all_r; })"
            return "1"

        # Option / Result constructors
        if base_callee == "Some":
            if args.len > 0: return "_tr_option_some((void*)(" + self.gen_expr(args.get(0)) + "))"
            return "_tr_option_none()"
        if base_callee == "Ok":
            if args.len > 0: return "_tr_result_ok((void*)(" + self.gen_expr(args.get(0)) + "))"
            return "_tr_result_ok(NULL)"
        if base_callee == "Err":
            if args.len > 0: return "_tr_result_err((void*)(" + self.gen_expr(args.get(0)) + "))"
            return "_tr_result_err(NULL)"

        # Intercept alloc
        if base_callee == "alloc" or base_callee == "core_alloc_alloc":
            mut count_s = "1LL"
            if args.len > 0: count_s = self.gen_expr(args.get(0))
            mut alloc_ty = "void"
            if has_generic and generic_ty.name != "void":
                alloc_ty = self.type_to_c(generic_ty)
            elif call_ty.name == "Pointer" and call_ty.args.len > 0:
                alloc_ty = self.type_to_c(call_ty.args.get(0).read())
            else:
                match callee.read():
                    case HirExpr.EIdent(_, ident_ty, _):
                        if ident_ty.args.len > 0:
                            alloc_ty = self.type_to_c(ident_ty.args.get(0).read())
                    case _: pass
            if alloc_ty == "void" or alloc_ty == "void*":
                return "malloc((size_t)(" + count_s + "))"
            return "((" + alloc_ty + "*)_tr_c_calloc((size_t)(" + count_s + "), sizeof(" + alloc_ty + ")))"

        # Intercept dealloc
        if base_callee == "dealloc":
            if args.len > 0:
                return "_tr_free((void*)(" + self.gen_expr(args.get(0)) + "))"
            return ""

        # Intercept resize[T](ptr, n) -> _tr_c_realloc
        if base_callee == "resize" or base_callee == "core_alloc_resize":
            if args.len >= 2:
                mut rptr_s = self.gen_expr(args.get(0))
                mut rcnt_s = self.gen_expr(args.get(1))
                mut resize_ty = "void"
                if has_generic and generic_ty.name != "void":
                    resize_ty = self.type_to_c(generic_ty)
                if resize_ty == "void" or resize_ty == "void*":
                    return "(void*)_tr_c_realloc((void*)(" + rptr_s + "), (size_t)(" + rcnt_s + "))"
                return "((" + resize_ty + "*)_tr_c_realloc((void*)(" + rptr_s + "), (size_t)(" + rcnt_s + ") * sizeof(" + resize_ty + ")))"
            return "NULL"

        # Intercept copy[T](dst, src, n) -> _tr_c_memcpy
        if base_callee == "copy" or base_callee == "core_alloc_copy":
            if args.len >= 3:
                mut cdst_s = self.gen_expr(args.get(0))
                mut csrc_s = self.gen_expr(args.get(1))
                mut ccnt_s = self.gen_expr(args.get(2))
                mut copy_ty = "void"
                if has_generic and generic_ty.name != "void":
                    copy_ty = self.type_to_c(generic_ty)
                if copy_ty == "void" or copy_ty == "void*":
                    return "_tr_c_memcpy((void*)(" + cdst_s + "), (void*)(" + csrc_s + "), (size_t)(" + ccnt_s + "))"
                return "_tr_c_memcpy((void*)(" + cdst_s + "), (void*)(" + csrc_s + "), (size_t)(" + ccnt_s + ") * sizeof(" + copy_ty + "))"
            return ""

        # input() - read a line from stdin
        if base_callee == "input":
            if args.len > 0: return "_tr_input(" + self.gen_expr(args.get(0)) + ")"
            return "_tr_input(NULL)"

        # Pointer[T](addr) -> (T*)addr  (null pointer construction)
        if base_callee == "Pointer":
            if args.len > 0:
                mut ptr_arg = self.gen_expr(args.get(0))
                if has_generic and generic_ty.name != "void":
                    mut ct = self.type_to_c(generic_ty)
                    return "(" + ct + "*)(" + ptr_arg + ")"
                match callee.read():
                    case HirExpr.EIdent(_, ident_ty, _):
                        if ident_ty.args.len > 0:
                            mut elem = ident_ty.args.get(0).read()
                            mut ct = self.type_to_c(elem)
                            return "(" + ct + "*)(" + ptr_arg + ")"
                    case _: pass
                return "(void*)(" + ptr_arg + ")"
            return "NULL"

        # Class constructor call: ClassName() or GenericClass[T]()
        match callee.read():
            case HirExpr.EIdent(n, ident_ty, _):
                if self.classes.contains(n) and n != "Vec" and n != "Map" and n != "Dict" and n != "List":
                    mut ucls = self.classes.get(n)
                    if ucls.generics.len > 0 and ident_ty.args.len > 0:
                        mut sfx = self.type_args_suffix(ident_ty.args)
                        self.ensure_mono(ucls, ident_ty.args)
                        mut mn = n + "_" + sfx
                        return "((" + mn + "*)_tr_checked_alloc(sizeof(" + mn + ")))"
                    # Synthesize mono name from active type_subst when args absent in HIR
                    if ucls.generics.len > 0:
                        mut sfx2 = self.synth_class_suffix(ucls)
                        if sfx2 != "":
                            mut mn2 = n + "_" + sfx2
                            return "((" + mn2 + "*)_tr_checked_alloc(sizeof(" + mn2 + ")))"
                    return "((" + n + "*)_tr_checked_alloc(sizeof(" + n + ")))"
                if self.enums.contains(n):
                    return "(" + n + "){.tag=" + n + "_" + n + "}"
            case HirExpr.EPropAccess(obj_inner, variant, _):
                # Intercept Chan/Mutex/RwLock/ThreadPool static constructors
                mut oi_ctor_name = ""
                match obj_inner.read():
                    case HirExpr.EIdent(oin, _, _): oi_ctor_name = oin
                    case _: pass
                if oi_ctor_name == "Chan":
                    if variant == "init":
                        mut ch_cap = "1LL"
                        if args.len > 0: ch_cap = self.gen_expr(args.get(0))
                        return "_tr_chan_new(" + ch_cap + ")"
                if oi_ctor_name == "Mutex":
                    if variant == "init":
                        mut mx_val = "0LL"
                        if args.len > 0: mx_val = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                        return "_tr_mutexbox_new(" + mx_val + ")"
                if oi_ctor_name == "RwLock":
                    if variant == "init":
                        mut rw_val = "0LL"
                        if args.len > 0: rw_val = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                        return "_tr_rwlbox_new(" + rw_val + ")"
                if oi_ctor_name == "ThreadPool":
                    if variant == "new":
                        mut tp_n = "4LL"
                        if args.len > 0: tp_n = self.gen_expr(args.get(0))
                        return "_tr_threadpool_new(" + tp_n + ")"
                    if variant == "auto":
                        return "_tr_threadpool_auto()"
                if oi_ctor_name == "Thread":
                    if variant == "spawn" or variant == "new":
                        if args.len >= 2:
                            mut th2_fn_nm = ""
                            match args.get(0).read():
                                case HirExpr.EIdent(thn3, _, _): th2_fn_nm = thn3
                                case _: pass
                            mut th2_arg_s = "(void*)(" + self.gen_expr(args.get(1)) + ")"
                            mut th2_aty = hir_expr_type(args.get(1)).name
                            if _is_int_type(th2_aty) or th2_aty == "bool" or th2_aty == "char":
                                th2_arg_s = "(void*)(uintptr_t)(" + self.gen_expr(args.get(1)) + ")"
                            if th2_fn_nm != "":
                                return "_tr_threadobj_spawn(_tr_spawn_wrap_" + th2_fn_nm + ", " + th2_arg_s + ")"
                            return "_tr_threadobj_spawn((void*(*)(void*))(" + self.gen_expr(args.get(0)) + "), " + th2_arg_s + ")"
                        elif args.len == 1:
                            mut th2_fn_nm2 = ""
                            match args.get(0).read():
                                case HirExpr.EIdent(thn4, _, _): th2_fn_nm2 = thn4
                                case _: pass
                            if th2_fn_nm2 != "":
                                return "_tr_threadobj_spawn(_tr_spawn_wrap_" + th2_fn_nm2 + ", NULL)"
                            return "_tr_threadobj_spawn((void*(*)(void*))(" + self.gen_expr(args.get(0)) + "), NULL)"
                    if variant == "sleep" or variant == "sleep_ms":
                        mut th2_ms = "0LL"
                        if args.len > 0: th2_ms = self.gen_expr(args.get(0))
                        return "_tr_thread_sleep_ms((long long)(" + th2_ms + "))"
                    if variant == "id" or variant == "current_id":
                        return "_tr_thread_current_id()"
                if oi_ctor_name == "Atomic":
                    if variant == "new" or variant == "init":
                        mut at2_v = "0LL"
                        if args.len > 0: at2_v = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                        return "_tr_atomic_new(" + at2_v + ")"
                if oi_ctor_name == "ThreadLocal":
                    if variant == "new" or variant == "init":
                        mut tl2_v = "0LL"
                        if args.len > 0: tl2_v = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                        return "_tr_tls_new(" + tl2_v + ")"
                mut oi_type_n = hir_expr_type(obj_inner).name
                if oi_type_n == "Result":
                    if variant == "ok":
                        mut ok_val = "NULL"
                        if args.len > 0:
                            ok_val = "(void*)(" + self.gen_expr(args.get(0)) + ")"
                        return "((Result){.tag=Result_Ok, .data.Ok.val=" + ok_val + "})"
                    elif variant == "err":
                        mut err_val = "NULL"
                        if args.len > 0:
                            err_val = "(void*)(" + self.gen_expr(args.get(0)) + ")"
                        return "((Result){.tag=Result_Err, .data.Err.err=" + err_val + "})"
                elif oi_type_n == "Option":
                    if variant == "some" or variant == "Some":
                        mut sv = "NULL"
                        if args.len > 0:
                            sv = "(void*)(" + self.gen_expr(args.get(0)) + ")"
                        return "((Option){.tag=Option_Some, .data.Some.val=" + sv + "})"
                    elif variant == "none" or variant == "None":
                        return "((Option){.tag=Option_None})"
                if self.enums.contains(oi_type_n):
                    if args.len > 0:
                        return oi_type_n + "_ctor_" + variant + "(" + self.gen_args(args) + ")"
                    else:
                        return oi_type_n + "_make_" + variant + "()"
            case _: pass

        # If callee is a known function, auto-wrap class args that target interface params
        if self.functions.contains(callee_s):
            mut fn_def = self.functions.get(callee_s)
            mut self_skip = 0
            if fn_def.params as usize != 0 as usize and fn_def.params.len > 0 and fn_def.params.get(0).name == "self":
                self_skip = 1
            mut any_wrapped = false
            mut ai = 0
            while ai < args.len:
                mut pi = ai + self_skip
                if fn_def.params as usize != 0 as usize and pi < fn_def.params.len:
                    if self.interfaces.contains(fn_def.params.get(pi).ty.name):
                        mut actual_ty_n = hir_expr_type(args.get(ai)).name
                        if self.classes.contains(actual_ty_n):
                            any_wrapped = true
                ai = ai + 1
            if any_wrapped:
                mut wrapped_args = ""
                ai = 0
                while ai < args.len:
                    if ai > 0: wrapped_args = wrapped_args + ", "
                    mut pi = ai + self_skip
                    mut arg_s = self.gen_expr(args.get(ai))
                    if fn_def.params as usize != 0 as usize and pi < fn_def.params.len:
                        mut _p_iface_ty = fn_def.params.get(pi).ty
                        mut expected_iface = _p_iface_ty.name
                        if self.interfaces.contains(expected_iface):
                            mut _ep_iface = self.interfaces.get(expected_iface)
                            if _ep_iface.generics.len > 0 and _p_iface_ty.args.len > 0:
                                expected_iface = expected_iface + "_" + self.type_args_suffix(_p_iface_ty.args)
                            mut actual_ty_e = hir_expr_type(args.get(ai))
                            mut actual_ty_n = actual_ty_e.name
                            if self.classes.contains(actual_ty_n):
                                mut _acls = self.classes.get(actual_ty_n)
                                if _acls.generics.len > 0 and actual_ty_e.args.len > 0:
                                    actual_ty_n = actual_ty_n + "_" + self.type_args_suffix(actual_ty_e.args)
                                arg_s = actual_ty_n + "_as_" + expected_iface + "(" + arg_s + ")"
                    wrapped_args = wrapped_args + arg_s
                    ai = ai + 1
                return callee_s + "(" + wrapped_args + ")"

        # Lambda / void* function pointer: cast to typed function pointer before calling
        mut callee_ty_n: str = hir_expr_type(callee).name
        # Indirect call through a function-pointer VALUE (a variable/element of
        # type def(...)->R, or a lambda). A direct call to a named top-level
        # function is excluded - it emits a plain call below.
        mut _callee_direct_fn = false
        match callee.read():
            case HirExpr.EIdent(_lc_n, _, _):
                if self.functions.contains(_lc_n): _callee_direct_fn = true
            case _: pass
        if (callee_ty_n == "lambda" or callee_ty_n == "void*" or callee_ty_n == "def") and not _callee_direct_fn:
            mut ret_cty = self.type_to_c(call_ty)
            if ret_cty == "void" or ret_cty == "void*": ret_cty = "long long"
            mut arg_types = ""
            mut ai2 = 0
            while ai2 < args.len:
                if ai2 > 0: arg_types = arg_types + ", "
                arg_types = arg_types + self.type_to_c(hir_expr_type(args.get(ai2)))
                ai2 = ai2 + 1
            if arg_types == "": arg_types = "void"
            return "((" + ret_cty + "(*)(" + arg_types + "))(" + callee_s + "))(" + self.gen_args(args) + ")"

        # __call__ dispatch: callee is a variable holding a callable object
        mut callee_cls_ty: str = hir_expr_type(callee).name
        if self.classes.contains(callee_cls_ty) and self.has_method(callee_cls_ty, "__call__"):
            mut is_fn_or_cls = false
            match callee.read():
                case HirExpr.EIdent(cname, _, _):
                    if self.functions.contains(cname): is_fn_or_cls = true
                    if self.classes.contains(cname): is_fn_or_cls = true
                case _: pass
            if not is_fn_or_cls:
                return self.cls_method_c_call(callee_cls_ty, "__call__", callee_s, self.gen_args(args))
        return callee_s + "(" + self.gen_args(args) + ")"

    pub def gen_print_call(self, args: Vec[Pointer[HirExpr]]) -> str:
        if args.len == 0: return "printf(\"\\n\")"
        mut arg0 = args.get(0)
        mut ty0_n: str = hir_expr_type(arg0).name
        mut s0 = self.gen_expr(arg0)
        if _is_int_type(ty0_n): return "printf(\"%lld\\n\", (long long)(" + s0 + "))"
        if _is_float_type(ty0_n): return "printf(\"%g\\n\", (double)(" + s0 + "))"
        if ty0_n == "bool": return "printf(\"%s\\n\", (" + s0 + ") ? \"true\" : \"false\")"
        if ty0_n == "char": return "printf(\"%c\\n\", " + s0 + ")"
        if self.has_method(ty0_n, "__str__"):
            return "printf(\"%s\\n\", " + self.cls_method_c_call(ty0_n, "__str__", s0, "") + ")"
        if self.has_method(ty0_n, "__repr__"):
            return "printf(\"%s\\n\", " + self.cls_method_c_call(ty0_n, "__repr__", s0, "") + ")"
        if ty0_n == "void" or ty0_n == "" or ty0_n == "lambda":
            return "printf(\"%s\\n\", _TR_AUTO_STR(" + s0 + "))"
        return "printf(\"%s\\n\", (char*)(" + s0 + "))"

    pub def gen_args(self, args: Vec[Pointer[HirExpr]]) -> str:
        mut s = ""
        mut i = 0
        while i < args.len:
            if i > 0: s = s + ", "
            s = s + self.gen_expr(args.get(i))
            i = i + 1
        return s

    pub def gen_method_call(self, obj: Pointer[HirExpr], method: str, args: Vec[Pointer[HirExpr]], call_ty: AstType) -> str:
        mut obj_s = self.gen_expr(obj)
        mut t_n: str = hir_expr_type(obj).name

        # Fallback: when HIR stores void for an EPropAccess type (cross-module field lookup),
        # recover the actual type from the parent class field declaration
        if t_n == "void" or t_n == "":
            match obj.read():
                case HirExpr.EPropAccess(inner_obj_fb, field_name_fb, _):
                    mut inner_t_n_fb: str = hir_expr_type(inner_obj_fb).name
                    if inner_t_n_fb == "void" or inner_t_n_fb == "":
                        inner_t_n_fb = self.cur_class
                    if self.classes.contains(inner_t_n_fb):
                        mut parent_cls_fb = self.classes.get(inner_t_n_fb)
                        mut fi_fb = 0
                        while fi_fb < parent_cls_fb.fields.len:
                            mut fld_fb = parent_cls_fb.fields.get(fi_fb)
                            if fld_fb.name == field_name_fb and fld_fb.ty.name != "" and fld_fb.ty.name != "void":
                                t_n = fld_fb.ty.name
                            fi_fb = fi_fb + 1
                case _: pass

        # Shared var: unwrap _TrSharedBox* -> (TypeName*)obj->data for method dispatch
        if self.shared_vars.contains(obj_s):
            mut sh_ty = self.shared_vars.get(obj_s)
            # Shared-specific built-in methods - operate on the box, NOT the inner object
            if method == "clone": return "_tr_shared_clone(" + obj_s + ")"
            if method == "drop": return "_tr_shared_drop(" + obj_s + ")"
            if method == "is_null": return "(" + obj_s + " == NULL || " + obj_s + "->data == NULL)"
            if method == "downgrade": return "_tr_weak_new(" + obj_s + ")"
            # All other methods: unwrap and dispatch as user-defined class method
            mut sh_unwrapped = "((" + sh_ty + "*)(" + obj_s + "->data))"
            mut sh_sig = sh_ty + "_" + method + "(" + sh_unwrapped
            if args.len > 0:
                sh_sig = sh_sig + ", " + self.gen_args(args)
            return sh_sig + ")"

        # Interface vtable dispatch: obj.vtable->method(obj.data, extra_args...)
        if self.interfaces.contains(t_n):
            mut s = obj_s + ".vtable->" + method + "(" + obj_s + ".data"
            if args.len > 0:
                s = s + ", " + self.gen_args(args)
            return s + ")"

        # Result[T,E] method dispatch
        if t_n == "Result":
            if obj_s == "Result":
                # Static constructor: Result[T,E].ok(val) or Result[T,E].err(val)
                if method == "ok":
                    mut ok_cv = "NULL"
                    if args.len > 0:
                        ok_cv = "(void*)(" + self.gen_expr(args.get(0)) + ")"
                    return "((Result){.tag=Result_Ok, .data.Ok.val=" + ok_cv + "})"
                elif method == "err":
                    mut err_cv = "NULL"
                    if args.len > 0:
                        err_cv = "(void*)(" + self.gen_expr(args.get(0)) + ")"
                    return "((Result){.tag=Result_Err, .data.Err.err=" + err_cv + "})"
            # Instance methods on a Result value
            if method == "is_err": return "(" + obj_s + ".tag == Result_Err)"
            if method == "is_ok": return "(" + obj_s + ".tag == Result_Ok)"
            if method == "unwrap": return "Result_unwrap(" + obj_s + ")"
            if method == "unwrap_err": return "Result_unwrap_err(" + obj_s + ")"
            mut res_extra = ""
            if args.len > 0:
                res_extra = ", " + self.gen_args(args)
            return "Result_" + method + "(" + obj_s + res_extra + ")"

        # Option[T] method dispatch
        if t_n == "Option":
            if obj_s == "Option":
                # Static constructor
                if method == "some" or method == "Some":
                    mut sv2 = "NULL"
                    if args.len > 0:
                        sv2 = "(void*)(" + self.gen_expr(args.get(0)) + ")"
                    return "((Option){.tag=Option_Some, .data.Some.val=" + sv2 + "})"
                elif method == "none" or method == "None":
                    return "((Option){.tag=Option_None})"
            # Instance methods
            if method == "is_some": return "(" + obj_s + ".tag == Option_Some)"
            if method == "is_none": return "(" + obj_s + ".tag == Option_None)"
            if method == "unwrap": return "Option_unwrap(" + obj_s + ")"
            mut opt_extra = ""
            if args.len > 0:
                opt_extra = ", " + self.gen_args(args)
            return "Option_" + method + "(" + obj_s + opt_extra + ")"

        # Str.join static call: Str.join(parts, sep) -> _tr_str_join((List_str*)parts, sep)
        if obj_s == "Str" and method == "join":
            if args.len >= 2: return "_tr_str_join((List_str*)" + self.gen_expr(args.get(0)) + ", " + self.gen_expr(args.get(1)) + ")"
            if args.len == 1: return "_tr_str_join((List_str*)" + self.gen_expr(args.get(0)) + ", \"\")"

        # str primitive method dispatch - "hello".trim() -> _tr_str_strip("hello")
        if t_n == "str":
            mut str_arg0 = ""
            if args.len > 0: str_arg0 = self.gen_expr(args.get(0))
            mut str_arg1 = ""
            if args.len > 1: str_arg1 = self.gen_expr(args.get(1))
            if method == "split":         return "_tr_str_split(" + obj_s + ", " + str_arg0 + ")"
            if method == "split_to_vec":  return "_tr_str_split(" + obj_s + ", " + str_arg0 + ")"
            if method == "trim" or method == "strip": return "_tr_str_strip(" + obj_s + ")"
            if method == "trim_left":     return "_tr_str_trim_left(" + obj_s + ")"
            if method == "trim_right":    return "_tr_str_trim_right(" + obj_s + ")"
            if method == "to_upper":      return "_tr_str_upper(" + obj_s + ")"
            if method == "to_lower":      return "_tr_str_lower(" + obj_s + ")"
            if method == "capitalize":    return "_tr_str_capitalize(" + obj_s + ")"
            if method == "title":         return "_tr_str_title(" + obj_s + ")"
            if method == "reverse":       return "_tr_str_reverse(" + obj_s + ")"
            if method == "repeat":        return "_tr_str_repeat(" + obj_s + ", " + str_arg0 + ")"
            if method == "replace":       return "_tr_str_replace(" + obj_s + ", " + str_arg0 + ", " + str_arg1 + ")"
            if method == "replace_first": return "_tr_str_replace_first(" + obj_s + ", " + str_arg0 + ", " + str_arg1 + ")"
            if method == "slice":         return "_tr_str_slice(" + obj_s + ", " + str_arg0 + ", " + str_arg1 + ")"
            if method == "strip_prefix":  return "_tr_str_strip_prefix(" + obj_s + ", " + str_arg0 + ")"
            if method == "strip_suffix":  return "_tr_str_strip_suffix(" + obj_s + ", " + str_arg0 + ")"
            if method == "remove_char":   return "_tr_str_remove_char(" + obj_s + ", " + str_arg0 + ")"
            if method == "join":          return "_tr_str_join((List_str*)(void*)" + obj_s + ", " + str_arg0 + ")"
            if method == "len":           return "_tr_strlen((char*)" + obj_s + ")"
            if method == "index_of":      return "_tr_str_index_of(" + obj_s + ", " + str_arg0 + ")"
            if method == "last_index_of": return "_tr_str_last_index_of(" + obj_s + ", " + str_arg0 + ")"
            if method == "count":         return "_tr_str_count_occ(" + obj_s + ", " + str_arg0 + ")"
            if method == "char_at":       return "_tr_str_char_at_code(" + obj_s + ", " + str_arg0 + ")"
            if method == "starts_with":   return "_tr_str_starts_with(" + obj_s + ", " + str_arg0 + ")"
            if method == "ends_with":     return "_tr_str_ends_with(" + obj_s + ", " + str_arg0 + ")"
            if method == "contains":      return "_tr_str_contains(" + obj_s + ", " + str_arg0 + ")"
            if method == "contains_char": return "_tr_str_contains_char(" + obj_s + ", " + str_arg0 + ")"
            if method == "eq":            return "_tr_str_eq(" + obj_s + ", " + str_arg0 + ")"
            if method == "is_digit":      return "_tr_str_is_digit(" + obj_s + ")"
            if method == "is_alpha":      return "_tr_str_is_alpha(" + obj_s + ")"
            if method == "is_alnum":      return "_tr_str_is_alnum(" + obj_s + ")"
            if method == "is_space":      return "_tr_str_is_space(" + obj_s + ")"
            if method == "is_upper":      return "_tr_str_is_upper(" + obj_s + ")"
            if method == "is_lower":      return "_tr_str_is_lower(" + obj_s + ")"
            if method == "parse_int":     return "_tr_str_to_int(" + obj_s + ")"
            if method == "parse_float":   return "_tr_str_to_float(" + obj_s + ")"
            if method == "parse_bool":    return "_tr_str_parse_bool(" + obj_s + ")"
            if method == "lines":         return "_tr_str_lines(" + obj_s + ")"
            if method == "words":         return "_tr_str_words(" + obj_s + ")"
            if method == "lpad":          return "_tr_str_lpad(" + obj_s + ", " + str_arg0 + ", " + str_arg1 + ")"
            if method == "rpad":          return "_tr_str_rpad(" + obj_s + ", " + str_arg0 + ", " + str_arg1 + ")"
            if method == "center":        return "_tr_str_center(" + obj_s + ", " + str_arg0 + ")"

        # Pointer method calls - intercept when:
        #   (a) receiver is explicitly Pointer[T], or
        #   (b) method is "offset" (only valid on pointers), or
        #   (c) method is read/write/as_ptr AND receiver is NOT a known user-defined class
        #       (handles chained results of .offset() whose HIR type is void/unknown).
        mut _ptr_intercept = t_n == "Pointer" or method == "offset"
        if not _ptr_intercept and (method == "read" or method == "write" or method == "as_ptr"):
            # Don't intercept for concurrency types that have their own read/write semantics
            if t_n != "Chan" and t_n != "Mutex" and t_n != "RwLock" and t_n != "ThreadPool" and t_n != "Thread" and t_n != "Atomic" and t_n != "ThreadLocal" and obj_s != "Chan" and obj_s != "Mutex" and obj_s != "RwLock" and obj_s != "ThreadPool" and obj_s != "Thread" and obj_s != "Atomic" and obj_s != "ThreadLocal":
                if not self.classes.contains(t_n):
                    _ptr_intercept = true
        if _ptr_intercept:
            if method == "offset": return "(" + obj_s + " + " + self.gen_expr(args.get(0)) + ")"
            if method == "read": return "(*" + obj_s + ")"
            if method == "write": return "(*" + obj_s + " = " + self.gen_expr(args.get(0)) + ")"
            if method == "as_ptr": return obj_s

        # Chan[T] method dispatch - also handles Chan.init() static constructor
        if t_n == "Chan" or obj_s == "Chan":
            if method == "init":
                mut ch_cap_s = "1LL"
                if args.len > 0: ch_cap_s = self.gen_expr(args.get(0))
                return "_tr_chan_new(" + ch_cap_s + ")"
            if method == "send":
                mut ch_v = "0LL"
                if args.len > 0: ch_v = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                return "_tr_chan_send(" + obj_s + ", " + ch_v + ")"
            if method == "recv": return "_tr_chan_recv(" + obj_s + ")"
            if method == "try_send":
                mut ch_tv = "0LL"
                if args.len > 0: ch_tv = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                return "_tr_chan_try_send(" + obj_s + ", " + ch_tv + ")"
            if method == "try_recv": return "_tr_chan_try_recv_val(" + obj_s + ")"
            if method == "close": return "_tr_chan_close(" + obj_s + ")"
            if method == "is_closed": return "_tr_chan_is_closed(" + obj_s + ")"
            if method == "len": return "_tr_chan_len(" + obj_s + ")"
            if method == "cap": return "_tr_chan_cap(" + obj_s + ")"
            if method == "free": return "_tr_chan_free(" + obj_s + ")"
            if method == "send_timeout" and args.len >= 2:
                return "_tr_chan_send_timeout(" + obj_s + ", (long long)(" + self.gen_expr(args.get(0)) + "), " + self.gen_expr(args.get(1)) + ")"
            if method == "recv_timeout" and args.len >= 1:
                return "_tr_chan_recv_timeout_val(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"

        # Mutex[T] method dispatch - also handles Mutex.init() static constructor
        if t_n == "Mutex" or obj_s == "Mutex":
            if method == "init":
                mut mx_init_v = "0LL"
                if args.len > 0: mx_init_v = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                return "_tr_mutexbox_new(" + mx_init_v + ")"
            if method == "lock" or method == "get":
                return "_tr_mutexbox_lock_get(" + obj_s + ")"
            if method == "set":
                mut mx_sv = "0LL"
                if args.len > 0: mx_sv = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                return "_tr_mutexbox_set_unlock(" + obj_s + ", " + mx_sv + ")"
            if method == "unlock": return "_tr_mutexbox_unlock(" + obj_s + ")"
            if method == "free": return "_tr_mutexbox_free(" + obj_s + ")"

        # RwLock[T] method dispatch - also handles RwLock.init() static constructor
        if t_n == "RwLock" or obj_s == "RwLock":
            if method == "init":
                mut rw_init_v = "0LL"
                if args.len > 0: rw_init_v = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                return "_tr_rwlbox_new(" + rw_init_v + ")"
            if method == "read" or method == "read_lock":
                return "_tr_rwlbox_read_get(" + obj_s + ")"
            if method == "read_unlock":
                return "_tr_rwlbox_read_unlock(" + obj_s + ")"
            if method == "write" or method == "write_lock":
                return "_tr_rwlbox_write_get(" + obj_s + ")"
            if method == "write_set" or method == "set":
                mut rw_sv = "0LL"
                if args.len > 0: rw_sv = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                return "_tr_rwlbox_write_set_unlock(" + obj_s + ", " + rw_sv + ")"
            if method == "free": return "_tr_rwlbox_free(" + obj_s + ")"

        # ThreadPool method dispatch - also handles ThreadPool.new() / ThreadPool.auto() static constructors
        if t_n == "ThreadPool" or obj_s == "ThreadPool":
            if method == "new":
                mut tp_nw = "4LL"
                if args.len > 0: tp_nw = self.gen_expr(args.get(0))
                return "_tr_threadpool_new(" + tp_nw + ")"
            if method == "auto":
                return "_tr_threadpool_auto()"
            if method == "spawn":
                # ThreadPool.spawn(fn, arg) - dispatch work item to the pool
                if args.len >= 2:
                    mut tp_fn_s = self.gen_expr(args.get(0))
                    mut tp_fn_nm = ""
                    match args.get(0).read():
                        case HirExpr.EIdent(tpn, _, _): tp_fn_nm = tpn
                        case _: pass
                    mut tp_arg_s = "(void*)(" + self.gen_expr(args.get(1)) + ")"
                    mut tp_aty = hir_expr_type(args.get(1)).name
                    if _is_int_type(tp_aty) or tp_aty == "bool" or tp_aty == "char":
                        tp_arg_s = "(void*)(uintptr_t)(" + self.gen_expr(args.get(1)) + ")"
                    if tp_fn_nm != "":
                        return "_tr_threadpool_spawn(" + obj_s + ", _tr_spawn_wrap_" + tp_fn_nm + ", " + tp_arg_s + ")"
                    return "_tr_threadpool_spawn(" + obj_s + ", (void*(*)(void*))(" + tp_fn_s + "), " + tp_arg_s + ")"
                elif args.len == 1:
                    mut tp_fn2_s = self.gen_expr(args.get(0))
                    mut tp_fn2_nm = ""
                    match args.get(0).read():
                        case HirExpr.EIdent(tpn2, _, _): tp_fn2_nm = tpn2
                        case _: pass
                    if tp_fn2_nm != "":
                        return "_tr_threadpool_spawn(" + obj_s + ", _tr_spawn_wrap_" + tp_fn2_nm + ", NULL)"
                    return "_tr_threadpool_spawn(" + obj_s + ", (void*(*)(void*))(" + tp_fn2_s + "), NULL)"
            if method == "wait": return "_tr_threadpool_wait(" + obj_s + ")"
            if method == "free": return "_tr_threadpool_free(" + obj_s + ")"

        # Thread method dispatch - Thread.spawn(fn, arg), t.join(), t.detach(), Thread.sleep(ms), Thread.id()
        if t_n == "Thread" or obj_s == "Thread":
            if method == "spawn":
                if args.len >= 3:
                    # multi-arg: heap-pack args[1..] into long long[N]
                    mut th_ma_fn = ""
                    match args.get(0).read():
                        case HirExpr.EIdent(thn_ma, _, _): th_ma_fn = thn_ma
                        case _: pass
                    mut th_ma_n = args.len - 1
                    mut th_ma_tmp = self.next_temp()
                    mut th_ma_s = "({ long long* _thab" + th_ma_tmp + " = (long long*)_tr_checked_alloc(" + str(th_ma_n) + " * sizeof(long long)); "
                    mut th_ma_ai = 1
                    mut th_ma_di = 0
                    while th_ma_ai < args.len:
                        mut th_ma_aty = hir_expr_type(args.get(th_ma_ai)).name
                        if _is_int_type(th_ma_aty) or th_ma_aty == "bool" or th_ma_aty == "char":
                            th_ma_s = th_ma_s + "_thab" + th_ma_tmp + "[" + str(th_ma_di) + "] = (long long)(" + self.gen_expr(args.get(th_ma_ai)) + "); "
                        else:
                            th_ma_s = th_ma_s + "_thab" + th_ma_tmp + "[" + str(th_ma_di) + "] = (long long)(uintptr_t)(" + self.gen_expr(args.get(th_ma_ai)) + "); "
                        th_ma_ai = th_ma_ai + 1
                        th_ma_di = th_ma_di + 1
                    if th_ma_fn != "":
                        th_ma_s = th_ma_s + "_tr_threadobj_spawn(_tr_spawn_wrap_" + th_ma_fn + ", _thab" + th_ma_tmp + "); })"
                    else:
                        th_ma_s = th_ma_s + "_tr_threadobj_spawn((void*(*)(void*))(" + self.gen_expr(args.get(0)) + "), _thab" + th_ma_tmp + "); })"
                    return th_ma_s
                elif args.len == 2:
                    mut th_fn_nm = ""
                    match args.get(0).read():
                        case HirExpr.EIdent(thn, _, _): th_fn_nm = thn
                        case _: pass
                    mut th_arg_s = "(void*)(" + self.gen_expr(args.get(1)) + ")"
                    mut th_aty = hir_expr_type(args.get(1)).name
                    if _is_int_type(th_aty) or th_aty == "bool" or th_aty == "char":
                        th_arg_s = "(void*)(uintptr_t)(" + self.gen_expr(args.get(1)) + ")"
                    if th_fn_nm != "":
                        return "_tr_threadobj_spawn(_tr_spawn_wrap_" + th_fn_nm + ", " + th_arg_s + ")"
                    return "_tr_threadobj_spawn((void*(*)(void*))(" + self.gen_expr(args.get(0)) + "), " + th_arg_s + ")"
                elif args.len == 1:
                    mut th_fn_nm2 = ""
                    match args.get(0).read():
                        case HirExpr.EIdent(thn2, _, _): th_fn_nm2 = thn2
                        case _: pass
                    if th_fn_nm2 != "":
                        return "_tr_threadobj_spawn(_tr_spawn_wrap_" + th_fn_nm2 + ", NULL)"
                    return "_tr_threadobj_spawn((void*(*)(void*))(" + self.gen_expr(args.get(0)) + "), NULL)"
            if method == "join": return "_tr_threadobj_join(" + obj_s + ")"
            if method == "detach": return "_tr_threadobj_detach(" + obj_s + ")"
            if method == "free": return "_tr_threadobj_free(" + obj_s + ")"
            if method == "id" or method == "current_id": return "_tr_thread_current_id()"
            if method == "sleep" or method == "sleep_ms":
                mut th_ms = "0LL"
                if args.len > 0: th_ms = self.gen_expr(args.get(0))
                return "_tr_thread_sleep_ms((long long)(" + th_ms + "))"

        # Atomic[T] method dispatch - Atomic.new(v), a.load(), a.store(v), a.add(v), a.sub(v), a.swap(v), a.cas(e,d)
        if t_n == "Atomic" or obj_s == "Atomic":
            if method == "new" or method == "init":
                mut at_v = "0LL"
                if args.len > 0: at_v = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                return "_tr_atomic_new(" + at_v + ")"
            if method == "load" or method == "get": return "_tr_atomic_load(" + obj_s + ")"
            if method == "store" or method == "set":
                mut at_sv = "0LL"
                if args.len > 0: at_sv = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                return "_tr_atomic_store(" + obj_s + ", " + at_sv + ")"
            if method == "add" or method == "fetch_add":
                mut at_av = "0LL"
                if args.len > 0: at_av = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                return "_tr_atomic_add(" + obj_s + ", " + at_av + ")"
            if method == "sub" or method == "fetch_sub":
                mut at_bv = "0LL"
                if args.len > 0: at_bv = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                return "_tr_atomic_sub(" + obj_s + ", " + at_bv + ")"
            if method == "swap" or method == "exchange":
                mut at_xv = "0LL"
                if args.len > 0: at_xv = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                return "_tr_atomic_swap(" + obj_s + ", " + at_xv + ")"
            if method == "cas" or method == "compare_exchange":
                mut at_exp = "0LL"
                mut at_des = "0LL"
                if args.len >= 1: at_exp = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                if args.len >= 2: at_des = "(long long)(" + self.gen_expr(args.get(1)) + ")"
                return "_tr_atomic_cas(" + obj_s + ", " + at_exp + ", " + at_des + ")"
            if method == "increment": return "_tr_atomic_add(" + obj_s + ", 1LL)"
            if method == "decrement": return "_tr_atomic_sub(" + obj_s + ", 1LL)"
            if method == "free": return "_tr_atomic_free(" + obj_s + ")"
            # Memory-ordered variants
            if method == "load_relaxed": return "_tr_atomic_load_relaxed(" + obj_s + ")"
            if method == "load_acquire": return "_tr_atomic_load_acquire(" + obj_s + ")"
            if method == "load_seqcst":  return "_tr_atomic_load_seqcst(" + obj_s + ")"
            if method == "store_relaxed":
                mut at_or_v = "0LL"
                if args.len > 0: at_or_v = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                return "_tr_atomic_store_relaxed(" + obj_s + ", " + at_or_v + ")"
            if method == "store_release":
                mut at_or_v2 = "0LL"
                if args.len > 0: at_or_v2 = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                return "_tr_atomic_store_release(" + obj_s + ", " + at_or_v2 + ")"
            if method == "store_seqcst":
                mut at_or_v3 = "0LL"
                if args.len > 0: at_or_v3 = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                return "_tr_atomic_store_seqcst(" + obj_s + ", " + at_or_v3 + ")"
            if method == "add_relaxed" or method == "fetch_add_relaxed":
                mut at_or_av = "0LL"
                if args.len > 0: at_or_av = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                return "_tr_atomic_add_relaxed(" + obj_s + ", " + at_or_av + ")"
            if method == "add_release" or method == "fetch_add_release":
                mut at_or_av2 = "0LL"
                if args.len > 0: at_or_av2 = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                return "_tr_atomic_add_release(" + obj_s + ", " + at_or_av2 + ")"
            if method == "add_acqrel" or method == "fetch_add_acqrel":
                mut at_or_av3 = "0LL"
                if args.len > 0: at_or_av3 = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                return "_tr_atomic_add_acqrel(" + obj_s + ", " + at_or_av3 + ")"
            if method == "sub_relaxed" or method == "fetch_sub_relaxed":
                mut at_or_sv = "0LL"
                if args.len > 0: at_or_sv = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                return "_tr_atomic_sub_relaxed(" + obj_s + ", " + at_or_sv + ")"
            if method == "sub_release" or method == "fetch_sub_release":
                mut at_or_sv2 = "0LL"
                if args.len > 0: at_or_sv2 = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                return "_tr_atomic_sub_release(" + obj_s + ", " + at_or_sv2 + ")"
            if method == "cas_weak":
                mut at_or_exp = "0LL"
                mut at_or_des = "0LL"
                if args.len >= 1: at_or_exp = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                if args.len >= 2: at_or_des = "(long long)(" + self.gen_expr(args.get(1)) + ")"
                return "_tr_atomic_cas_weak(" + obj_s + ", " + at_or_exp + ", " + at_or_des + ")"
            if method == "cas_acqrel":
                mut at_or_exp2 = "0LL"
                mut at_or_des2 = "0LL"
                if args.len >= 1: at_or_exp2 = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                if args.len >= 2: at_or_des2 = "(long long)(" + self.gen_expr(args.get(1)) + ")"
                return "_tr_atomic_cas_acqrel(" + obj_s + ", " + at_or_exp2 + ", " + at_or_des2 + ")"

        # ThreadLocal[T] method dispatch - ThreadLocal.new(v), tl.get(), tl.set(v)
        if t_n == "ThreadLocal" or obj_s == "ThreadLocal":
            if method == "new" or method == "init":
                mut tl_v = "0LL"
                if args.len > 0: tl_v = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                return "_tr_tls_new(" + tl_v + ")"
            if method == "get": return "_tr_tls_get(" + obj_s + ")"
            if method == "set":
                mut tl_sv = "0LL"
                if args.len > 0: tl_sv = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                return "_tr_tls_set(" + obj_s + ", " + tl_sv + ")"
            if method == "free": return "_tr_tls_free(" + obj_s + ")"

        # Primitive conversion methods
        if method == "to_str" or method == "to_string":
            if _is_int_type(t_n): return "_tr_int_to_str((long long)(" + obj_s + "))"
            if _is_float_type(t_n): return "_tr_float_to_str((double)(" + obj_s + "))"
            if t_n == "bool": return "((" + obj_s + ") ? \"true\" : \"false\")"
            if t_n == "char": return "_tr_char_to_str_alloc(" + obj_s + ")"
            # Fall through for class types (StringBuilder, user classes) so they hit their own branch
            if not (self.classes.contains(t_n) and t_n != "Vec" and t_n != "Map" and t_n != "Dict" and t_n != "List") and t_n != "StringBuilder":
                return obj_s
        # String receivers parse; numeric receivers cast.
        if method == "to_float":
            if _is_str_type(t_n): return "_tr_str_to_float(" + obj_s + ")"
            return "(double)(" + obj_s + ")"
        if method == "to_int":
            if _is_str_type(t_n): return "_tr_str_to_int(" + obj_s + ")"
            return "(long long)(" + obj_s + ")"

        # Float math methods - expose libc math as methods on float/f64 values.
        if _is_float_type(t_n):
            if method == "floor":  return "((double)floor((double)(" + obj_s + ")))"
            if method == "ceil":   return "((double)ceil((double)(" + obj_s + ")))"
            if method == "round":  return "((double)round((double)(" + obj_s + ")))"
            if method == "sqrt":   return "((double)sqrt((double)(" + obj_s + ")))"
            if method == "abs" or method == "fabs": return "((double)fabs((double)(" + obj_s + ")))"
            if method == "log":    return "((double)log((double)(" + obj_s + ")))"
            if method == "log2":   return "((double)log2((double)(" + obj_s + ")))"
            if method == "log10":  return "((double)log10((double)(" + obj_s + ")))"
            if method == "exp":    return "((double)exp((double)(" + obj_s + ")))"
            if method == "sin":    return "((double)sin((double)(" + obj_s + ")))"
            if method == "cos":    return "((double)cos((double)(" + obj_s + ")))"
            if method == "tan":    return "((double)tan((double)(" + obj_s + ")))"
            if method == "asin":   return "((double)asin((double)(" + obj_s + ")))"
            if method == "acos":   return "((double)acos((double)(" + obj_s + ")))"
            if method == "atan":   return "((double)atan((double)(" + obj_s + ")))"
            if method == "atan2" and args.len > 0:
                return "((double)atan2((double)(" + obj_s + "), (double)(" + self.gen_expr(args.get(0)) + ")))"
            if method == "pow" and args.len > 0:
                return "((double)pow((double)(" + obj_s + "), (double)(" + self.gen_expr(args.get(0)) + ")))"
            if method == "sign":
                return "((double)(((" + obj_s + ") > 0.0) - ((" + obj_s + ") < 0.0)))"
            if method == "clamp" and args.len == 2:
                mut _ca = self.gen_expr(args.get(0))
                mut _cb = self.gen_expr(args.get(1))
                return "({ double _v = (double)(" + obj_s + "); double _lo = (double)(" + _ca + "); double _hi = (double)(" + _cb + "); _v < _lo ? _lo : (_v > _hi ? _hi : _v); })"
            if method == "is_nan":  return "_tr_float_is_nan((double)(" + obj_s + "))"
            if method == "is_inf":  return "_tr_float_is_inf((double)(" + obj_s + "))"

        # Int utility methods - format and math on integer types.
        if _is_int_type(t_n):
            if method == "to_hex":
                return "({ char* _hb = (char*)_tr_checked_alloc(32); snprintf(_hb, 32, \"%llx\", (long long)(" + obj_s + ")); _hb; })"
            if method == "to_HEX" or method == "to_hex_upper":
                return "({ char* _hb = (char*)_tr_checked_alloc(32); snprintf(_hb, 32, \"%llX\", (long long)(" + obj_s + ")); _hb; })"
            if method == "to_octal" or method == "to_oct":
                return "({ char* _ob = (char*)_tr_checked_alloc(32); snprintf(_ob, 32, \"%llo\", (long long)(" + obj_s + ")); _ob; })"
            if method == "to_binary" or method == "to_bin":
                return "_tr_int_to_binary((long long)(" + obj_s + "))"
            if method == "sign":
                return "((long long)(((" + obj_s + ") > 0LL) - ((" + obj_s + ") < 0LL)))"
            if method == "clamp" and args.len == 2:
                mut _ia = self.gen_expr(args.get(0))
                mut _ib = self.gen_expr(args.get(1))
                return "({ long long _v = (long long)(" + obj_s + "); long long _lo = (long long)(" + _ia + "); long long _hi = (long long)(" + _ib + "); _v < _lo ? _lo : (_v > _hi ? _hi : _v); })"
            if method == "gcd" and args.len > 0:
                return "_tr_int_gcd((long long)(" + obj_s + "), (long long)(" + self.gen_expr(args.get(0)) + "))"
            if method == "lcm" and args.len > 0:
                return "_tr_int_lcm((long long)(" + obj_s + "), (long long)(" + self.gen_expr(args.get(0)) + "))"

        # Checked arithmetic - returns Option[int]: Some(result) or None on overflow.
        if _is_int_type(t_n) or _is_int_type(t_n):
            if method == "checked_add" and args.len > 0:
                mut _ca = obj_s
                mut _cb = self.gen_expr(args.get(0))
                mut _cr = self.next_temp()
                return "({ long long " + _cr + "; __builtin_add_overflow((long long)(" + _ca + "),(long long)(" + _cb + "),&" + _cr + ") ? ((Option){.tag=Option_None}) : ((Option){.tag=Option_Some,.data.Some.val=(void*)(uintptr_t)" + _cr + "}); })"
            if method == "checked_sub" and args.len > 0:
                mut _sa = obj_s
                mut _sb = self.gen_expr(args.get(0))
                mut _sr = self.next_temp()
                return "({ long long " + _sr + "; __builtin_sub_overflow((long long)(" + _sa + "),(long long)(" + _sb + "),&" + _sr + ") ? ((Option){.tag=Option_None}) : ((Option){.tag=Option_Some,.data.Some.val=(void*)(uintptr_t)" + _sr + "}); })"
            if method == "checked_mul" and args.len > 0:
                mut _ma = obj_s
                mut _mb = self.gen_expr(args.get(0))
                mut _mr = self.next_temp()
                return "({ long long " + _mr + "; __builtin_mul_overflow((long long)(" + _ma + "),(long long)(" + _mb + "),&" + _mr + ") ? ((Option){.tag=Option_None}) : ((Option){.tag=Option_Some,.data.Some.val=(void*)(uintptr_t)" + _mr + "}); })"
            if method == "abs": return "llabs((long long)(" + obj_s + "))"
            if method == "min" and args.len > 0:
                mut _mn = self.next_temp()
                return "({ long long " + _mn + " = (long long)(" + obj_s + "); long long _b = (long long)(" + self.gen_expr(args.get(0)) + "); " + _mn + " < _b ? " + _mn + " : _b; })"
            if method == "max" and args.len > 0:
                mut _mx = self.next_temp()
                return "({ long long " + _mx + " = (long long)(" + obj_s + "); long long _b = (long long)(" + self.gen_expr(args.get(0)) + "); " + _mx + " > _b ? " + _mx + " : _b; })"
            if method == "pow" and args.len > 0:
                return "((long long)pow((double)(" + obj_s + "),(double)(" + self.gen_expr(args.get(0)) + ")))"
        if method == "as_str":
            if t_n == "StringObj": return "StringObj_as_str(" + obj_s + ")"
            return "(char*)(" + obj_s + ")"
        if method == "starts_with" and args.len > 0 and _is_str_type(t_n):
            return "_tr_str_starts_with(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
        if method == "ends_with" and args.len > 0 and _is_str_type(t_n):
            return "_tr_str_ends_with(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
        if method == "contains" and args.len > 0 and _is_str_type(t_n):
            return "_tr_str_contains(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"

        # String method dispatch - must be before the generic TrStr_ fallback
        if _is_str_type(t_n):
            if method == "upper" or method == "to_upper": return "_tr_str_upper(" + obj_s + ")"
            if method == "lower" or method == "to_lower": return "_tr_str_lower(" + obj_s + ")"
            if method == "strip" or method == "trim": return "_tr_str_strip(" + obj_s + ")"
            if method == "trim_left": return "_tr_str_trim_left(" + obj_s + ")"
            if method == "trim_right": return "_tr_str_trim_right(" + obj_s + ")"
            if method == "replace" and args.len == 2:
                return "_tr_str_replace(" + obj_s + ", " + self.gen_expr(args.get(0)) + ", " + self.gen_expr(args.get(1)) + ")"
            if method == "split" and args.len > 0:
                return "_tr_str_split(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "find" and args.len > 0:
                mut tmp_find: str = self.next_temp()
                return "({ char* " + tmp_find + " = strstr(" + obj_s + ", " + self.gen_expr(args.get(0)) + "); " + tmp_find + " ? (long long)(" + tmp_find + " - (" + obj_s + ")) : -1LL; })"
            if method == "slice" and args.len == 2:
                return "_tr_str_slice(" + obj_s + ", " + self.gen_expr(args.get(0)) + ", " + self.gen_expr(args.get(1)) + ")"
            if method == "index_of" and args.len > 0:
                return "_tr_str_index_of(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "last_index_of" and args.len > 0:
                return "_tr_str_last_index_of(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "len" or method == "length":
                return "_tr_strlen(" + obj_s + ")"
            if method == "starts_with" and args.len > 0:
                return "_tr_str_starts_with(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "ends_with" and args.len > 0:
                return "_tr_str_ends_with(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "contains" and args.len > 0:
                return "_tr_str_contains(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "strip_prefix" and args.len > 0:
                return "_tr_str_strip_prefix(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "strip_suffix" and args.len > 0:
                return "_tr_str_strip_suffix(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "repeat" and args.len > 0:
                return "_tr_str_repeat(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "reverse": return "_tr_str_reverse(" + obj_s + ")"
            if method == "parse_int": return "_tr_str_to_int(" + obj_s + ")"
            if method == "parse_float": return "_tr_str_to_float(" + obj_s + ")"
            if method == "parse_bool": return "_tr_str_parse_bool(" + obj_s + ")"
            if method == "char_at" and args.len > 0:
                return "_tr_str_char_at_code(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            # str.split_once(sep) -> (left, right) at first occurrence; right="" if not found
            if method == "split_once" and args.len > 0:
                mut _so_sep = self.gen_expr(args.get(0))
                mut _so_t = self.next_temp()
                mut _so_p = self.next_temp()
                return "({ char* " + _so_p + " = strstr(" + obj_s + ", " + _so_sep + "); " + _so_p + " ? _tr_str_tuple2(_tr_str_slice(" + obj_s + ", 0LL, (long long)(" + _so_p + " - (" + obj_s + "))), _tr_str_slice(" + _so_p + ", _tr_strlen(" + _so_sep + "), _tr_strlen(" + _so_p + "))) : _tr_str_tuple2(" + obj_s + ", \"\"); })"

        # When sema returns void/empty type, still dispatch known string methods on the object.
        # This handles chained calls like Process.shell_output(cmd).trim() where the intermediate
        # return type is unknown to sema.
        if t_n == "void" or t_n == "":
            if method == "strip" or method == "trim": return "_tr_str_strip(" + obj_s + ")"
            if method == "upper" or method == "to_upper": return "_tr_str_upper(" + obj_s + ")"
            if method == "lower" or method == "to_lower": return "_tr_str_lower(" + obj_s + ")"
            if method == "trim_left": return "_tr_str_trim_left(" + obj_s + ")"
            if method == "trim_right": return "_tr_str_trim_right(" + obj_s + ")"
            if method == "slice" and args.len == 2:
                return "_tr_str_slice(" + obj_s + ", " + self.gen_expr(args.get(0)) + ", " + self.gen_expr(args.get(1)) + ")"
            if method == "index_of" and args.len > 0:
                return "_tr_str_index_of(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "starts_with" and args.len > 0:
                return "_tr_str_starts_with(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "ends_with" and args.len > 0:
                return "_tr_str_ends_with(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "contains" and args.len > 0:
                return "_tr_str_contains(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "split" and args.len > 0:
                return "_tr_str_split(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "replace" and args.len == 2:
                return "_tr_str_replace(" + obj_s + ", " + self.gen_expr(args.get(0)) + ", " + self.gen_expr(args.get(1)) + ")"
            if method == "len" or method == "length": return "_tr_strlen(" + obj_s + ")"
            if method == "char_at" and args.len > 0:
                return "_tr_str_char_at_code(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"

        mut class_name: str = t_n
        if _is_str_type(class_name): class_name = "TrStr"

        # Resolve user type aliases so `type NodeList = List[str]` is transparent.
        if class_name != "" and class_name != "void" and self.type_alias_map.contains(class_name):
            mut resolved_c = self.type_alias_map.get(class_name)
            # Map C type strings back to Tauraro-level names for dispatch
            if resolved_c.starts_with("List_"):
                class_name = "List"
            elif resolved_c.starts_with("Map_") or resolved_c == "TrMap*":
                class_name = "Map"

        # Built-in module static dispatch: OS, Process, Env, Hash, File
        if obj_s == "OS" or class_name == "OS":
            if method == "cwd":        return "_tr_cwd()"
            if method == "is_windows": return "_tr_is_windows()"
            if method == "is_linux":   return "(!_tr_is_windows())"
            if method == "platform":   return "(_tr_is_windows() ? \"windows\" : \"linux\")"
        if obj_s == "Process" or class_name == "Process":
            if method == "system" and args.len > 0:
                return "_tr_system(" + self.gen_expr(args.get(0)) + ")"
            if method == "shell_output" and args.len > 0:
                return "_tr_popen_read(" + self.gen_expr(args.get(0)) + ")"
            if method == "exit" and args.len > 0:
                return "_tr_exit(" + self.gen_expr(args.get(0)) + ")"
        if obj_s == "Env" or class_name == "Env":
            if method == "get_var" and args.len > 0:
                return "_tr_getenv(" + self.gen_expr(args.get(0)) + ")"
            if method == "set_var" and args.len > 1:
                return "_tr_setenv(" + self.gen_expr(args.get(0)) + ", " + self.gen_expr(args.get(1)) + ")"
        if obj_s == "Hash" or class_name == "Hash":
            if method == "sha256" and args.len > 0:
                return "_tr_sha256_hex(" + self.gen_expr(args.get(0)) + ")"
            if method == "md5" and args.len > 0:
                return "_tr_md5_hex(" + self.gen_expr(args.get(0)) + ")"
        if obj_s == "File" or class_name == "File":
            if method == "dir_exists" and args.len > 0:
                return "_tr_dir_exists(" + self.gen_expr(args.get(0)) + ")"

        # Static call: Task.init(...) - obj is a type-name ident, hir_expr_type returns void/empty.
        # Recover class_name from obj_s when it matches a known user class.
        if (class_name == "void" or class_name == "") and self.classes.contains(obj_s):
            class_name = obj_s
        # Also recover for built-in collection types used in static calls (Vec.init, List.init, etc.)
        if (class_name == "void" or class_name == "") and (obj_s == "Vec" or obj_s == "List" or obj_s == "Map" or obj_s == "Dict"):
            class_name = obj_s

        # StringBuilder special handling (must be before len/length shortcut)
        if class_name == "StringBuilder":
            if method == "init": return "StringBuilder_init(" + self.gen_args(args) + ")"
            if method == "append": return "StringBuilder_append(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "append_char": return "StringBuilder_append_char(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "to_string": return "StringBuilder_to_string(" + obj_s + ")"
            if method == "len" or method == "length": return obj_s + "->buf->len"
            if method == "free": return "StringBuilder_free(" + obj_s + ")"

        # len/length - only shortcut for non-user-class types
        if (method == "len" or method == "__len__" or method == "length") and not (self.classes.contains(t_n) and t_n != "Vec" and t_n != "Map" and t_n != "Dict" and t_n != "List") and not self.enums.contains(t_n):
            if _is_str_type(t_n): return "_tr_strlen(" + obj_s + ")"
            return "((long long)" + obj_s + "->len)"

        # __getitem__ dunder: sema lowers bag[i] -> EMethodCall(bag, "get_index", [i], void)
        if method == "get_index" and self.has_method(class_name, "__getitem__") and args.len > 0:
            return self.cls_method_c_call(class_name, "__getitem__", obj_s, self.gen_args(args))

        # User-defined generic class: dispatch through monomorphized name
        if self.classes.contains(class_name) and class_name != "Vec" and class_name != "Map" and class_name != "Dict" and class_name != "List":
            mut ucls = self.classes.get(class_name)
            if ucls.generics.len > 0:
                if hir_expr_type(obj).args.len > 0:
                    mut sfx = self.type_args_suffix(hir_expr_type(obj).args)
                    mut mono_name = class_name + "_" + sfx
                    self.ensure_mono(ucls, hir_expr_type(obj).args)
                    mut gmethod_c: str = method
                    if _is_c_keyword(gmethod_c): gmethod_c = "_tr_fn_" + gmethod_c
                    if method == "init" or method == "new":
                        return mono_name + "_" + gmethod_c + "(" + self.gen_args(args) + ")"
                    if obj_s == class_name:
                        return mono_name + "_" + gmethod_c + "(" + self.gen_args(args) + ")"
                    mut ms = mono_name + "_" + gmethod_c + "(" + obj_s
                    if args.len > 0: ms = ms + ", " + self.gen_args(args)
                    return ms + ")"
                # Recover type args from the parent class field declaration when HIR type args
                # are absent (bootstrap stores AstType* that can point to freed stack memory).
                match obj.read():
                    case HirExpr.EPropAccess(inner_obj2, fld_name2, _):
                        mut parent_ty_n2 = hir_expr_type(inner_obj2).name
                        if self.classes.contains(parent_ty_n2):
                            mut parent_cls2 = self.classes.get(parent_ty_n2)
                            mut fld_i2 = 0
                            while fld_i2 < parent_cls2.fields.len:
                                mut fld2 = parent_cls2.fields.get(fld_i2)
                                if fld2.name == fld_name2 and fld2.ty.name == class_name and fld2.ty.args.len > 0:
                                    mut sfx3 = self.type_args_suffix(fld2.ty.args)
                                    mut mn3 = class_name + "_" + sfx3
                                    self.ensure_mono(ucls, fld2.ty.args)
                                    mut method_c3 = method
                                    if _is_c_keyword(method_c3): method_c3 = "_tr_fn_" + method_c3
                                    if method == "init" or method == "new":
                                        return mn3 + "_" + method_c3 + "(" + self.gen_args(args) + ")"
                                    if obj_s == class_name:
                                        return mn3 + "_" + method_c3 + "(" + self.gen_args(args) + ")"
                                    mut ms3 = mn3 + "_" + method_c3 + "(" + obj_s
                                    if args.len > 0: ms3 = ms3 + ", " + self.gen_args(args)
                                    return ms3 + ")"
                                fld_i2 = fld_i2 + 1
                    case _: pass
                # self param has no type args in HIR (sema stores class_name without generics).
                # When inside a monomorphized body, use cur_class as the dispatch prefix.
                if self.cur_class != "":
                    mut method_c_g: str = method
                    if _is_c_keyword(method_c_g):
                        method_c_g = "_tr_fn_" + method_c_g
                    if method == "init" or method == "new":
                        return self.cur_class + "_" + method_c_g + "(" + self.gen_args(args) + ")"
                    if obj_s == class_name:
                        return self.cur_class + "_" + method_c_g + "(" + self.gen_args(args) + ")"
                    mut ms_g = self.cur_class + "_" + method_c_g + "(" + obj_s
                    if args.len > 0:
                        ms_g = ms_g + ", " + self.gen_args(args)
                    return ms_g + ")"

        # Non-generic user class dispatch
        if self.classes.contains(class_name) and class_name != "Vec" and class_name != "Map" and class_name != "Dict" and class_name != "List":
            mut method_c: str = method
            if _is_c_keyword(method_c): method_c = "_tr_fn_" + method_c
            if method == "init" or method == "new":
                return class_name + "_" + method_c + "(" + self.gen_args(args) + ")"
            if obj_s == class_name:
                return class_name + "_" + method_c + "(" + self.gen_args(args) + ")"
            # Check if method exists in own class; if not, fall back to base class dispatch
            mut ucls_inh: HirClass = self.classes.get(class_name)
            mut has_own_method: bool = false
            mut mci: int = 0
            while mci < ucls_inh.methods.len:
                mut mdef: HirFunction = ucls_inh.methods.get(mci)
                if mdef.name == method:
                    has_own_method = true
                mci = mci + 1
            if not has_own_method and ucls_inh.base_classes.len > 0:
                mut base_cls_n: str = ucls_inh.base_classes.get(0)
                if self.classes.contains(base_cls_n):
                    mut s_base: str = base_cls_n + "_" + method_c + "((" + base_cls_n + "*)" + obj_s
                    if args.len > 0:
                        s_base = s_base + ", " + self.gen_args(args)
                    return s_base + ")"
            # Check for method overloading: if multiple overloads exist, mangle by arg count.
            mut dispatch_name = class_name + "_" + method_c
            if self.overloaded_sigs.contains(dispatch_name):
                dispatch_name = dispatch_name + "_" + args.len.to_str() + "arg"
            mut s = dispatch_name + "(" + obj_s
            if args.len > 0: s = s + ", " + self.gen_args(args)
            return s + ")"

        if self.enums.contains(class_name):
            mut _evdef = self.enums.get(class_name)
            mut _is_var = false
            mut _vi2 = 0
            while _vi2 < _evdef.variants.len:
                if _evdef.variants.get(_vi2).name == method: _is_var = true
                _vi2 = _vi2 + 1
            if _is_var:
                if args.len > 0:
                    return class_name + "_ctor_" + method + "(" + self.gen_args(args) + ")"
                else:
                    return class_name + "_make_" + method + "()"
            mut enum_dispatch_name = class_name + "_" + method
            if self.overloaded_sigs.contains(enum_dispatch_name):
                enum_dispatch_name = enum_dispatch_name + "_" + args.len.to_str() + "arg"
            mut s = enum_dispatch_name + "(" + obj_s
            if args.len > 0: s = s + ", " + self.gen_args(args)
            return s + ")"

        # Extract List/Vec element suffix from the obj expression's type args
        mut elem_sfx: str = "ptr"
        match obj.read():
            case HirExpr.EIdent(_, ity, _):
                if ity.args.len > 0:
                    elem_sfx = self.list_elem_suffix(ity.args.get(0).read().name)
                elif self.type_alias_map.contains(ity.name):
                    # Type alias e.g. NodeList -> "List_str*" - extract elem suffix from C name.
                    mut _alias_raw = self.type_alias_map.get(ity.name)
                    mut _alias_c = _alias_raw.trim()
                    if _alias_c.ends_with("*"):
                        mut _alias_sl = _alias_c.slice(0, _alias_c.len() - 1)
                        _alias_c = _alias_sl.trim()
                    if _alias_c.starts_with("List_"): elem_sfx = _alias_c.slice(5, _alias_c.len())
            case HirExpr.EMethodCall(_, _, _, mty):
                if mty.args.len > 0: elem_sfx = self.list_elem_suffix(mty.args.get(0).read().name)
            case HirExpr.ECall(_, _, cty):
                if cty.args.len > 0: elem_sfx = self.list_elem_suffix(cty.args.get(0).read().name)
            case HirExpr.EPropAccess(_, _, pty):
                if pty.args.len > 0: elem_sfx = self.list_elem_suffix(pty.args.get(0).read().name)
            case _: pass

        # List[T] / Vec[T] method dispatch (Vec maps to List in the C runtime)
        mut is_list_vec: bool = class_name == "List" or class_name == "Vec" or (class_name == "int" and (method == "append" or method == "push" or method == "pop" or method == "set" or method == "get" or method == "free" or method == "contains"))
        if not is_list_vec and class_name as usize != 0 as usize:
            mut cp2 = class_name as Pointer[char]
            if cp2.offset(0).read() as int == 86 and cp2.offset(1).read() as int == 101 and cp2.offset(2).read() as int == 99 and cp2.offset(3).read() as int == 95:
                is_list_vec = true
            elif cp2.offset(0).read() as int == 76 and cp2.offset(1).read() as int == 105 and cp2.offset(2).read() as int == 115 and cp2.offset(3).read() as int == 116 and cp2.offset(4).read() as int == 95:
                is_list_vec = true
 
        if is_list_vec:
            if method == "append" or method == "push":
                # If elem_sfx is still "ptr" but the argument is a known primitive, infer the right suffix
                if elem_sfx == "ptr" and args.len > 0:
                    mut push_arg_ty = hir_expr_type(args.get(0)).name
                    if _is_int_type(push_arg_ty) or push_arg_ty == "bool": elem_sfx = "i64"
                    elif _is_float_type(push_arg_ty): elem_sfx = "f64"
                    elif push_arg_ty == "str" or push_arg_ty == "char*": elem_sfx = "str"
                return "List_" + elem_sfx + "_append(" + obj_s + ", " + self.gen_args(args) + ")"
            if method == "free": return "List_" + elem_sfx + "_free(" + obj_s + ")"
            if method == "pop":
                mut pop_r = "List_" + elem_sfx + "_pop(" + obj_s + ")"
                if elem_sfx == "ptr" and call_ty.name != "" and call_ty.name != "void" and call_ty.name != "Pointer":
                    if _tr_strlen(call_ty.name) > 1:
                        return "((" + call_ty.name + "*)" + pop_r + ")"
                return pop_r
            if method == "set":
                return "List_" + elem_sfx + "_set(" + obj_s + ", " + self.gen_args(args) + ")"
            if method == "contains":
                return "List_" + elem_sfx + "_contains(" + obj_s + ", " + self.gen_args(args) + ")"
            if method == "get":
                mut get_r = "List_" + elem_sfx + "_get(" + obj_s + ", " + self.gen_args(args) + ")"
                if elem_sfx == "ptr" and call_ty.name == "Pointer" and call_ty.args.len > 0:
                    mut inner_ct = self.type_to_c(call_ty.args.get(0).read())
                    return "((" + inner_ct + "*)" + get_r + ")"
                if elem_sfx == "ptr" and call_ty.name != "" and call_ty.name != "void" and call_ty.name != "Pointer" and call_ty.name != "List" and call_ty.name != "Vec" and call_ty.name != "Map" and call_ty.name != "Dict" and call_ty.name != "str":
                    if _tr_strlen(call_ty.name) > 1:
                        return "((" + call_ty.name + "*)" + get_r + ")"
                return get_r
            if method == "len" or method == "length": return "((long long)" + obj_s + "->len)"
            if method == "new" or method == "init":
                return "(void*)List_" + elem_sfx + "_new()"
            if method == "remove":
                return "List_" + elem_sfx + "_remove(" + obj_s + ", " + self.gen_args(args) + ")"
            if method == "swap":
                return "List_" + elem_sfx + "_swap(" + obj_s + ", " + self.gen_args(args) + ")"
            if method == "clear":
                return "List_" + elem_sfx + "_clear(" + obj_s + ")"
            if method == "is_empty":
                return "List_" + elem_sfx + "_is_empty(" + obj_s + ")"
            if method == "extend":
                return "List_" + elem_sfx + "_extend(" + obj_s + ", " + self.gen_args(args) + ")"
            if method == "index_of":
                return "List_" + elem_sfx + "_index_of(" + obj_s + ", " + self.gen_args(args) + ")"
            # sort() / sort_by(cmp_fn) - in-place sort
            if method == "sort" or method == "sort_asc":
                return "_tr_list_sort_" + elem_sfx + "(" + obj_s + ", 1)"
            if method == "sort_desc":
                return "_tr_list_sort_" + elem_sfx + "(" + obj_s + ", -1)"
            if method == "sort_by" and args.len > 0:
                return "_tr_list_sort_by_" + elem_sfx + "(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            # first / last - aliases for get(0) / get(len-1)
            if method == "first": return "List_" + elem_sfx + "_get(" + obj_s + ", 0LL)"
            if method == "last": return "List_" + elem_sfx + "_get(" + obj_s + ", (long long)(" + obj_s + "->len - 1LL))"
            # any(pred) / all(pred) - boolean short-circuit over list
            if method == "any" and args.len > 0:
                return "_tr_list_any_" + elem_sfx + "(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "all" and args.len > 0:
                return "_tr_list_all_" + elem_sfx + "(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            # sum / min_val / max_val - numeric aggregates
            if method == "sum":
                return "_tr_list_sum_" + elem_sfx + "(" + obj_s + ")"
            if method == "min_val" or method == "min":
                return "_tr_list_min_" + elem_sfx + "(" + obj_s + ")"
            if method == "max_val" or method == "max":
                return "_tr_list_max_" + elem_sfx + "(" + obj_s + ")"
            # join(sep) - concatenate string elements with separator
            if method == "join":
                mut sep_s = "\"\""
                if args.len > 0: sep_s = self.gen_expr(args.get(0))
                return "_tr_str_join((List_str*)" + obj_s + ", " + sep_s + ")"
            # reversed_copy() - return a new reversed list
            if method == "reversed" or method == "reversed_copy":
                return "_tr_list_reversed_" + elem_sfx + "(" + obj_s + ")"
            # reverse in place
            if method == "reverse":
                return "_tr_list_reverse_" + elem_sfx + "(" + obj_s + ")"
            # clone: shallow copy with a fresh backing buffer
            if method == "clone" or method == "copy":
                return "_tr_list_clone_" + elem_sfx + "(" + obj_s + ")"

        # Set[T] method dispatch - backed by _TrSet (hash set via TrMap with bool values)
        if class_name == "Set":
            mut set_elem = elem_sfx
            if set_elem == "ptr": set_elem = "str"  # default element type
            # Choose runtime prefix: int-keyed sets use _tr_iset_*, others _tr_set_*
            mut sfn = "_tr_set_"
            if set_elem == "i64": sfn = "_tr_iset_"
            if method == "init" or method == "new":
                if args.len == 0: return sfn + "new(16)"
                return sfn + "new(" + self.gen_args(args) + ")"
            if method == "add" and args.len > 0:
                return sfn + "add(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "contains" or method == "has":
                return sfn + "contains(" + obj_s + ", " + self.gen_args(args) + ")"
            if method == "remove" and args.len > 0:
                return sfn + "remove(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "len" or method == "length":
                return sfn + "len(" + obj_s + ")"
            if method == "is_empty":
                return "(" + sfn + "len(" + obj_s + ") == 0LL)"
            if method == "clear":
                return sfn + "clear(" + obj_s + ")"
            if method == "to_list":
                return sfn + "to_list(" + obj_s + ")"
            if method == "union" and args.len > 0:
                return sfn + "union(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "intersection" and args.len > 0:
                return sfn + "intersection(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "difference" and args.len > 0:
                return sfn + "difference(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "is_subset" and args.len > 0:
                return sfn + "is_subset(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"

        # Map/Dict method dispatch
        mut is_map_dict: bool = class_name == "Map" or class_name == "Dict" or class_name == "TrMap"
        if not is_map_dict and class_name as usize != 0 as usize:
            mut cp = class_name as Pointer[char]
            if cp.offset(0).read() as int == 77 and cp.offset(1).read() as int == 97 and cp.offset(2).read() as int == 112 and cp.offset(3).read() as int == 95:
                is_map_dict = true
            elif cp.offset(0).read() as int == 68 and cp.offset(1).read() as int == 105 and cp.offset(2).read() as int == 99 and cp.offset(3).read() as int == 116 and cp.offset(4).read() as int == 95:
                is_map_dict = true

        if is_map_dict:
            # Detect int-keyed dict from type args
            mut obj_full_ty = hir_expr_type(obj)
            # Map[K,V] / Dict[K,V]: first type arg is the key type.
            mut dict_key_ty = "str"
            if obj_full_ty.args.len > 0:
                mut ka = obj_full_ty.args.get(0).read()
                if _is_int_type(ka.name) or ka.name == "int" or ka.name == "i64" or ka.name == "i32" or ka.name == "usize":
                    dict_key_ty = "int"
            mut is_idict = dict_key_ty == "int"
            if method == "init" or method == "new":
                if is_idict: return "_tr_idict_new(" + self.gen_args(args) + ")"
                return "_tr_dict_new(" + self.gen_args(args) + ")"
            if method == "get":
                mut c_ty_c = self.type_to_c(call_ty)
                if is_idict:
                    mut iget_r = "_tr_idict_get(" + obj_s + ", " + self.gen_args(args) + ")"
                    if c_ty_c != "void" and c_ty_c != "":
                        return "((" + c_ty_c + ")(uintptr_t)" + iget_r + ")"
                    return iget_r
                mut mget_r = "_tr_dict_get(" + obj_s + ", " + self.gen_args(args) + ")"
                if c_ty_c != "void" and c_ty_c != "":
                    return "((" + c_ty_c + ")(uintptr_t)" + mget_r + ")"
                return mget_r
            if method == "set" or method == "insert":
                if is_idict: return "_tr_idict_set(" + obj_s + ", " + self.gen_args(args) + ")"
                return "_tr_dict_set(" + obj_s + ", " + self.gen_args(args) + ")"
            if method == "contains" or method == "has":
                if is_idict: return "_tr_idict_contains(" + obj_s + ", " + self.gen_args(args) + ")"
                return "_tr_dict_contains(" + obj_s + ", " + self.gen_args(args) + ")"
            if method == "remove":
                if is_idict: return "_tr_idict_remove(" + obj_s + ", " + self.gen_args(args) + ")"
                return "_tr_dict_remove(" + obj_s + ", " + self.gen_args(args) + ")"
            if method == "len" or method == "length":
                if is_idict: return "_tr_idict_len(" + obj_s + ")"
                return "_tr_dict_len(" + obj_s + ")"
            if method == "keys":
                if is_idict: return "_tr_idict_keys(" + obj_s + ")"
                return "_tr_dict_keys(" + obj_s + ")"
            if method == "values":
                if is_idict: return "_tr_idict_values(" + obj_s + ")"
                return "_tr_dict_values(" + obj_s + ")"
            if method == "items":
                if is_idict: return "_tr_idict_items(" + obj_s + ")"
                return "_tr_dict_items(" + obj_s + ")"
            # update(other) - merge all entries from other map into self
            if method == "update" and args.len > 0:
                if is_idict: return "_tr_idict_update(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
                return "_tr_dict_update(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            # clear() - remove all entries
            if method == "clear":
                if is_idict: return "_tr_idict_clear(" + obj_s + ")"
                return "_tr_dict_clear(" + obj_s + ")"
            # is_empty() - true if len == 0
            if method == "is_empty":
                if is_idict: return "(_tr_idict_len(" + obj_s + ") == 0LL)"
                return "(_tr_dict_len(" + obj_s + ") == 0LL)"
            # get_or(key, default) - get with fallback
            if method == "get_or" and args.len >= 2:
                mut _k = self.gen_expr(args.get(0))
                mut _d = self.gen_expr(args.get(1))
                if is_idict:
                    return "(_tr_idict_contains(" + obj_s + ", " + _k + ") ? _tr_idict_get(" + obj_s + ", " + _k + ") : (void*)(uintptr_t)(" + _d + "))"
                return "(_tr_dict_contains(" + obj_s + ", " + _k + ") ? _tr_dict_get(" + obj_s + ", " + _k + ") : (void*)(uintptr_t)(" + _d + "))"

        mut extra_args = ""
        if args.len > 0:
            extra_args = ", " + self.gen_args(args)
        # Fallback: when class_name is known but the method wasn't handled above,
        # emit ClassNme_method(obj, ...) - prevents bare calls that collide with C stdlib.
        # Only skip the prefix for truly primitive/unresolvable types.
        mut safe_method = method
        if _is_c_keyword(safe_method): safe_method = "_tr_fn_" + safe_method
        if class_name != "" and class_name != "void" and class_name != "int" and class_name != "float" and class_name != "bool" and class_name != "char" and class_name != "str":
            if not _is_primitive(class_name) and not _is_str_type(class_name):
                return class_name + "_" + safe_method + "(" + obj_s + extra_args + ")"
        return safe_method + "(" + obj_s + extra_args + ")"

    pub def gen_fstring(self, parts: Vec[HirFStringPart]) -> str:
        if parts.len == 0: return "\"\""
        mut fmt = ""
        mut fargs = ""
        mut i = 0
        while i < parts.len:
            mut part = parts.get(i)
            if not part.is_expr:
                fmt = fmt + _escape_str_for_c(part.text)
            else:
                mut s = self.gen_expr(part.expr)
                mut ty_n: str = hir_expr_type(part.expr).name
                mut spec = part.fmt_spec  # e.g. ".2f", ">10", "05d"

                if spec.len() > 0:
                    # User supplied a format spec - map to printf format.
                    # Detect the conversion type character at the end of spec.
                    mut spec_n = spec.len()
                    mut last_c = spec.char_at(spec_n - 1)
                    # Float specs: f, e, E, g, G
                    if last_c == 102 or last_c == 101 or last_c == 69 or last_c == 103 or last_c == 71:
                        fmt = fmt + "%" + spec
                        fargs = fargs + ", (double)(" + s + ")"
                    # Integer specs: d, i, u, o, x, X
                    elif last_c == 100 or last_c == 105 or last_c == 117 or last_c == 111 or last_c == 120 or last_c == 88:
                        fmt = fmt + "%" + spec
                        fargs = fargs + ", (long long)(" + s + ")"
                    # String specs: s (width/alignment)
                    elif last_c == 115:
                        fmt = fmt + "%" + spec
                        if _is_int_type(ty_n):
                            fargs = fargs + ", _tr_int_to_str(" + s + ")"
                        elif _is_float_type(ty_n):
                            fargs = fargs + ", _tr_float_to_str(" + s + ")"
                        else:
                            fargs = fargs + ", (char*)(" + s + ")"
                    # Alignment / width only: ">10", "<10", "^10", "10"
                    # Map Python alignment chars to printf width specifiers.
                    else:
                        mut _align_spec = spec
                        mut _left_align = false
                        if _align_spec.starts_with(">"):
                            _align_spec = _align_spec.slice(1, _align_spec.len())  # right = default %Ws
                        elif _align_spec.starts_with("<"):
                            _align_spec = _align_spec.slice(1, _align_spec.len())
                            _left_align = true
                        elif _align_spec.starts_with("^"):
                            _align_spec = _align_spec.slice(1, _align_spec.len())  # center ~= right
                        if _is_int_type(ty_n):
                            if _left_align: fmt = fmt + "%-" + _align_spec + "lld"
                            else:           fmt = fmt + "%" + _align_spec + "lld"
                            fargs = fargs + ", (long long)(" + s + ")"
                        elif _is_float_type(ty_n):
                            if _left_align: fmt = fmt + "%-" + _align_spec + "g"
                            else:           fmt = fmt + "%" + _align_spec + "g"
                            fargs = fargs + ", (double)(" + s + ")"
                        else:
                            if _left_align: fmt = fmt + "%-" + _align_spec + "s"
                            else:           fmt = fmt + "%" + _align_spec + "s"
                            fargs = fargs + ", (char*)(" + s + ")"
                elif _is_int_type(ty_n):
                    fmt = fmt + "%lld"
                    fargs = fargs + ", (long long)(" + s + ")"
                elif _is_float_type(ty_n):
                    fmt = fmt + "%g"
                    fargs = fargs + ", (double)(" + s + ")"
                elif ty_n == "bool":
                    fmt = fmt + "%s"
                    fargs = fargs + ", ((" + s + ") ? \"true\" : \"false\")"
                elif ty_n == "char":
                    fmt = fmt + "%c"
                    fargs = fargs + ", (char)(" + s + ")"
                elif ty_n == "void" or ty_n == "":
                    fmt = fmt + "%s"
                    fargs = fargs + ", _TR_AUTO_STR(" + s + ")"
                else:
                    fmt = fmt + "%s"
                    if self.has_method(ty_n, "__str__"):
                        fargs = fargs + ", " + self.cls_method_c_call(ty_n, "__str__", s, "")
                    elif self.has_method(ty_n, "__repr__"):
                        fargs = fargs + ", " + self.cls_method_c_call(ty_n, "__repr__", s, "")
                    else:
                        fargs = fargs + ", (char*)(" + s + ")"
            i = i + 1
        return "({ int _fz = snprintf(NULL,0,\"" + fmt + "\"" + fargs + "); char* _fr=(char*)_tr_checked_alloc(_fz+1); snprintf(_fr,_fz+1,\"" + fmt + "\"" + fargs + "); _fr; })"

    pub def gen_tuple(self, items: Vec[Pointer[HirExpr]]) -> str:
        if items.len == 0: return "((TrTuple){.data={0}})"
        mut s = "((TrTuple){.data={"
        mut i = 0
        while i < items.len:
            if i > 0: s = s + ", "
            s = s + "(long long)(uintptr_t)(" + self.gen_expr(items.get(i)) + ")"
            i = i + 1
        return s + "}})"

    # -- Real async/await -----------------------------------------------------

    pub def emit_async_wrapper_for_call(self, fn_name: str, args: Vec[Pointer[HirExpr]], ret_name: str):
        if self.async_wrappers.contains(fn_name): return
        self.async_wrappers.insert(fn_name, true)
        mut nargs = args.len
        # Emit: static void* _tr_async_wrap_FNAME(void* _vp) { ... }
        self.w("static void* _tr_async_wrap_" + fn_name + "(void* _vp) {\n")
        self.w("    long long* _a = (long long*)_vp;\n")
        self.w("    _TrTaskState* _ts = (_TrTaskState*)(uintptr_t)_a[0];\n")
        # Cast each arg back
        mut ci = 0
        while ci < nargs:
            mut arg_ty_name = hir_expr_type(args.get(ci)).name
            mut c_arg_ty = self.type_to_c(hir_expr_type(args.get(ci)))
            if c_arg_ty == "void" or c_arg_ty == "": c_arg_ty = "long long"
            mut is_int = _is_int_type(arg_ty_name) or arg_ty_name == "bool" or arg_ty_name == "char"
            if is_int:
                self.w("    " + c_arg_ty + " _arg" + ci.to_str() + " = (" + c_arg_ty + ")_a[" + (ci + 1).to_str() + "];\n")
            else:
                self.w("    " + c_arg_ty + " _arg" + ci.to_str() + " = (" + c_arg_ty + ")(uintptr_t)_a[" + (ci + 1).to_str() + "];\n")
            ci = ci + 1
        # Build the call
        mut call_s = fn_name + "("
        mut ai = 0
        while ai < nargs:
            if ai > 0: call_s = call_s + ", "
            call_s = call_s + "_arg" + ai.to_str()
            ai = ai + 1
        call_s = call_s + ")"
        if ret_name == "void" or ret_name == "":
            self.w("    " + call_s + ";\n")
            self.w("    _tr_task_complete(_ts, 0LL);\n")
        else:
            self.w("    long long _r = (long long)(uintptr_t)(" + call_s + ");\n")
            self.w("    _tr_task_complete(_ts, _r);\n")
        self.w("    free(_a);\n")
        self.w("    return NULL;\n")
        self.w("}\n")

    pub def gen_await_call(self, expr: Pointer[HirExpr]) -> str:
        if _is_invalid_ptr(expr as usize): return "0LL"
        match expr.read():
            case HirExpr.ECall(callee, args, call_ty):
                mut fn_name = ""
                match callee.read():
                    case HirExpr.EIdent(n, _, _): fn_name = n
                    case _: pass
                if fn_name == "":
                    # Fallback: can't wrap, call directly
                    return self.gen_expr(expr)
                mut ret_name = call_ty.name
                if ret_name == "": ret_name = "void"
                self.emit_async_wrapper_for_call(fn_name, args, ret_name)
                mut nargs = args.len
                mut tmp = self.next_temp()
                mut buf_size = (nargs + 1).to_str()
                mut s = "({ long long* _ab" + tmp + " = (long long*)_tr_checked_alloc(" + buf_size + " * sizeof(long long)); "
                s = s + "_TrTaskState* _ts" + tmp + " = _tr_task_new(); "
                s = s + "_ab" + tmp + "[0] = (long long)(uintptr_t)_ts" + tmp + "; "
                mut ai = 0
                while ai < nargs:
                    mut arg_ty_name = hir_expr_type(args.get(ai)).name
                    mut is_int = _is_int_type(arg_ty_name) or arg_ty_name == "bool" or arg_ty_name == "char"
                    if is_int:
                        s = s + "_ab" + tmp + "[" + (ai + 1).to_str() + "] = (long long)(" + self.gen_expr(args.get(ai)) + "); "
                    else:
                        s = s + "_ab" + tmp + "[" + (ai + 1).to_str() + "] = (long long)(uintptr_t)(" + self.gen_expr(args.get(ai)) + "); "
                    ai = ai + 1
                s = s + "_tr_async_pool_submit(_tr_global_async_pool, _tr_async_wrap_" + fn_name + ", _ab" + tmp + "); "
                s = s + "long long _r" + tmp + " = _tr_task_await(_ts" + tmp + "); "
                s = s + "_tr_task_free(_ts" + tmp + "); "
                if ret_name == "void":
                    s = s + "0LL; })"
                elif _is_int_type(ret_name) or ret_name == "bool" or ret_name == "char":
                    mut c_ret = self.type_to_c(call_ty)
                    s = s + "(" + c_ret + ")_r" + tmp + "; })"
                else:
                    mut c_ret2 = self.type_to_c(call_ty)
                    if c_ret2 == "void" or c_ret2 == "": c_ret2 = "void*"
                    s = s + "(" + c_ret2 + ")(uintptr_t)_r" + tmp + "; })"
                return s
            case _:
                # Not a call - just evaluate synchronously
                return self.gen_expr(expr)

    # -- await_timeout(expr, ms): like gen_await_call but with timeout ----------

    pub def gen_await_timeout_call(self, expr: Pointer[HirExpr], ms_expr: Pointer[HirExpr]) -> str:
        if _is_invalid_ptr(expr as usize): return "0LL"
        match expr.read():
            case HirExpr.ECall(callee, args, call_ty):
                mut fn_name = ""
                match callee.read():
                    case HirExpr.EIdent(n, _, _): fn_name = n
                    case _: pass
                if fn_name == "":
                    return self.gen_expr(expr)
                mut ret_name = call_ty.name
                if ret_name == "": ret_name = "void"
                self.emit_async_wrapper_for_call(fn_name, args, ret_name)
                mut nargs = args.len
                mut tmp = self.next_temp()
                mut buf_size = (nargs + 1).to_str()
                mut ms_s = self.gen_expr(ms_expr)
                mut s = "({ long long* _ab" + tmp + " = (long long*)_tr_checked_alloc(" + buf_size + " * sizeof(long long)); "
                s = s + "_TrTaskState* _ts" + tmp + " = _tr_task_new(); "
                s = s + "_ab" + tmp + "[0] = (long long)(uintptr_t)_ts" + tmp + "; "
                mut ai = 0
                while ai < nargs:
                    mut arg_ty_name = hir_expr_type(args.get(ai)).name
                    mut is_int = _is_int_type(arg_ty_name) or arg_ty_name == "bool" or arg_ty_name == "char"
                    if is_int:
                        s = s + "_ab" + tmp + "[" + (ai + 1).to_str() + "] = (long long)(" + self.gen_expr(args.get(ai)) + "); "
                    else:
                        s = s + "_ab" + tmp + "[" + (ai + 1).to_str() + "] = (long long)(uintptr_t)(" + self.gen_expr(args.get(ai)) + "); "
                    ai = ai + 1
                s = s + "_tr_async_pool_submit(_tr_global_async_pool, _tr_async_wrap_" + fn_name + ", _ab" + tmp + "); "
                s = s + "long long _rto" + tmp + " = 0LL; "
                s = s + "_tr_task_await_timeout(_ts" + tmp + ", (long long)(" + ms_s + "), &_rto" + tmp + "); "
                s = s + "_tr_task_free(_ts" + tmp + "); "
                if ret_name == "void":
                    s = s + "0LL; })"
                elif _is_int_type(ret_name) or ret_name == "bool" or ret_name == "char":
                    mut c_ret = self.type_to_c(call_ty)
                    s = s + "(" + c_ret + ")_rto" + tmp + "; })"
                else:
                    mut c_ret2 = self.type_to_c(call_ty)
                    if c_ret2 == "void" or c_ret2 == "": c_ret2 = "void*"
                    s = s + "(" + c_ret2 + ")(uintptr_t)_rto" + tmp + "; })"
                return s
            case _:
                return self.gen_expr(expr)

    # -- SMultiLet (tuple unpacking) -----------------------------------------

    pub def gen_multi_let(self, names: Vec[str], is_mut: bool, val: Pointer[HirExpr], indent: int):
        pad = _indent_str(indent)
        mut tmp = "_tup" + self.next_temp()
        self.w(pad + "TrTuple " + tmp + " = " + self.gen_expr(val) + ";\n")
        mut i = 0
        while i < names.len:
            mut vname = _safe_c_varname(names.get(i))
            self.w(pad + "long long " + vname + " = " + tmp + ".data[" + i.to_str() + "];\n")
            self.decl_vars.insert(names.get(i), true)
            i = i + 1

    pub def gen_list_literal(self, items: Vec[Pointer[HirExpr]], ty: AstType) -> str:
        mut sfx = "ptr"
        if ty.args.len > 0: sfx = self.list_elem_suffix(ty.args.get(0).read().name)
        elif items.len > 0:
            sfx = self.list_elem_suffix(hir_expr_type(items.get(0)).name)
        mut l = "_l_" + self.next_temp()
        mut s = "({ List_" + sfx + "* " + l + " = List_" + sfx + "_new(); "
        mut i = 0
        while i < items.len:
            s = s + "List_" + sfx + "_append(" + l + ", " + self.gen_expr(items.get(i)) + "); "
            i = i + 1
        return s + l + "; })"

    pub def gen_dict_literal(self, keys: Vec[Pointer[HirExpr]], vals: Vec[Pointer[HirExpr]], hint_ty: AstType) -> str:
        # Detect int-keyed from type args (works for empty dicts too)
        mut is_int_key = false
        if hint_ty.args.len > 0:
            mut ka_h = hint_ty.args.get(0).read()
            if _is_int_type(ka_h.name) or ka_h.name == "int" or ka_h.name == "i64" or ka_h.name == "i32" or ka_h.name == "usize":
                is_int_key = true
        if keys.len == 0:
            if is_int_key: return "_tr_idict_new(0LL)"
            return "_tr_dict_new(0LL)"
        # Detect int-keyed literal from key type (fallback when no hint)
        if not is_int_key and keys.len > 0:
            mut k0_ty = hir_expr_type(keys.get(0)).name
            if _is_int_type(k0_ty) or k0_ty == "int" or k0_ty == "i64":
                is_int_key = true
        mut tmp = self.next_temp()
        if is_int_key:
            mut s = "({ TrIDict* " + tmp + " = _tr_idict_new(" + str(keys.len) + "LL); "
            mut i = 0
            while i < keys.len:
                s = s + "_tr_idict_set(" + tmp + ", " + self.gen_expr(keys.get(i)) + ", " + self.gen_expr(vals.get(i)) + "); "
                i = i + 1
            s = s + tmp + "; })"
            return s
        mut s = "({ TrMap* " + tmp + " = _tr_dict_new(" + str(keys.len) + "LL); "
        mut i = 0
        while i < keys.len:
            s = s + "_tr_dict_set(" + tmp + ", " + self.gen_expr(keys.get(i)) + ", " + self.gen_expr(vals.get(i)) + "); "
            i = i + 1
        s = s + tmp + "; })"
        return s

    pub def gen_list_comp(self, element: Pointer[HirExpr], generators: Vec[Pointer[HirComprehension]]) -> str:
        mut tmp = self.next_temp()
        mut elem_ty_n: str = hir_expr_type(element).name
        mut sfx = self.list_elem_suffix(elem_ty_n)
        mut s = "({ List_" + sfx + "* " + tmp + " = List_" + sfx + "_new(); "
        mut i = 0
        while i < generators.len:
            mut gen = generators.get(i).read()
            mut iter_s = self.gen_expr(gen.iter)
            s = s + "{ __auto_type _gc" + i.to_str() + " = " + iter_s + "; long long _gi" + i.to_str() + " = 0;"
            s = s + " while (_gi" + i.to_str() + " < _gc" + i.to_str() + "->len) {"
            s = s + " __auto_type " + gen.target + " = _gc" + i.to_str() + "->data[_gi" + i.to_str() + "]; "
            mut fi = 0
            while fi < gen.ifs.len:
                s = s + "if (" + self.gen_expr(gen.ifs.get(fi)) + ") { "
                fi = fi + 1
            i = i + 1
        s = s + "List_" + sfx + "_append(" + tmp + ", " + self.gen_expr(element) + "); "
        i = 0
        while i < generators.len:
            mut gen2 = generators.get(i).read()
            mut fi = 0
            while fi < gen2.ifs.len:
                s = s + "} "
                fi = fi + 1
            s = s + "_gi" + i.to_str() + "++; } } "
            i = i + 1
        return s + tmp + "; })"

    pub def gen_closure(self, params: Vec[HirParam], ret_ty: AstType, body: HirBlock, captures: Vec[HirParam]) -> str:
        self.closure_count = self.closure_count + 1
        mut cname = "_closure_" + self.closure_count.to_str()
        mut ret_c = self.type_to_c(ret_ty)
        if ret_c == "void": ret_c = "long long"

        # Seed closure params into decl_vars so SAssign generates plain assignment, not __auto_type
        mut pi = 0
        while pi < params.len:
            self.decl_vars.insert(params.get(pi).name, true)
            pi = pi + 1
        # Seed captured vars into decl_vars so assignments to them don't create new locals
        mut ci = 0
        while ci < captures.len:
            self.decl_vars.insert(captures.get(ci).name, true)
            ci = ci + 1

        # GCC nested function: has access to all outer scope variables via trampoline
        self.w("    " + ret_c + " " + cname + "(")
        mut first: bool = true
        mut i: int = 0
        while i < params.len:
            mut p: HirParam = params.get(i)
            if not first: self.w(", ")
            self.w(self.type_to_c(p.ty) + " " + _safe_c_varname(p.name))
            first = false
            i = i + 1
        self.w(") {\n")
        self.gen_block(body, 2)
        self.w("    }\n")
        return "(void*)(&" + cname + ")"

    # -- Spawn wrapper pre-scan ------------------------------------------------

    pub def emit_spawn_wrapper_for_expr(self, e: Pointer[HirExpr]):
        if _is_invalid_ptr(e as usize): return
        match e.read():
            case HirExpr.ECall(callee, args, ew_ret_ty):
                mut fn_name = ""
                match callee.read():
                    case HirExpr.EIdent(n, _, _): fn_name = n
                    case _: return
                if fn_name == "": return
                if self.spawn_wrappers.contains(fn_name): return
                self.spawn_wrappers.insert(fn_name, true)
                if args.len == 0:
                    self.w("static void* _tr_spawn_wrap_" + fn_name + "(void* _vp) { (void)_vp; " + fn_name + "(); return NULL; }\n")
                elif args.len == 1:
                    mut arg_ty_n = hir_expr_type(args.get(0)).name
                    mut cast_back = "(long long)(uintptr_t)_vp"
                    if not _is_int_type(arg_ty_n) and arg_ty_n != "bool" and arg_ty_n != "char":
                        mut c_arg_ty = self.type_to_c(hir_expr_type(args.get(0)))
                        cast_back = "(" + c_arg_ty + ")_vp"
                    self.w("static void* _tr_spawn_wrap_" + fn_name + "(void* _vp) { " + fn_name + "(" + cast_back + "); return NULL; }\n")
                else:
                    # multi-arg: wrapper receives heap long long[N+1] where [0]=return slot, [1..N]=args
                    mut ma_nargs = args.len
                    mut ew_is_void = ew_ret_ty.name == "void" or ew_ret_ty.name == ""
                    self.w("static void* _tr_spawn_wrap_" + fn_name + "(void* _vp) {\n")
                    self.w("    long long* _ab = (long long*)_vp;\n")
                    mut ma_call_s = ""
                    mut ma_ai = 0
                    while ma_ai < ma_nargs:
                        if ma_ai > 0: ma_call_s = ma_call_s + ", "
                        mut ma_atn = hir_expr_type(args.get(ma_ai)).name
                        if not _is_int_type(ma_atn) and ma_atn != "bool" and ma_atn != "char":
                            mut ma_cty = self.type_to_c(hir_expr_type(args.get(ma_ai)))
                            ma_call_s = ma_call_s + "(" + ma_cty + ")_ab[" + str(ma_ai + 1) + "]"
                        else:
                            ma_call_s = ma_call_s + "_ab[" + str(ma_ai + 1) + "]"
                        ma_ai = ma_ai + 1
                    if ew_is_void:
                        self.w("    " + fn_name + "(" + ma_call_s + ");\n")
                    else:
                        self.w("    _ab[0] = (long long)" + fn_name + "(" + ma_call_s + ");\n")
                    self.w("    free(_ab); return NULL;\n")
                    self.w("}\n")
            case _: pass

    pub def prescan_block_spawns(self, block: HirBlock):
        if _is_invalid_ptr(block as usize): return
        if _is_invalid_ptr(block.stmts as usize): return
        if _is_invalid_ptr(block.stmts.data as usize): return
        mut blen = block.stmts.len
        mut i = 0
        while i < blen:
            mut sp = block.stmts.get(i)
            self.prescan_stmt_spawns(sp)
            i = i + 1

    pub def prescan_stmt_spawns(self, s: Pointer[HirStmt]):
        if _is_invalid_ptr(s as usize): return
        match s.read():
            case HirStmt.SSpawn(e):
                self.emit_spawn_wrapper_for_expr(e)
            case HirStmt.STaskGroup(body):
                self.prescan_block_spawns(body)
            case HirStmt.SIf(_, t, e):
                self.prescan_block_spawns(t)
                if not _is_invalid_ptr(e as usize):
                    self.prescan_block_spawns(e)
            case HirStmt.SWhile(_, body):
                self.prescan_block_spawns(body)
            case HirStmt.SFor(_, _, body):
                self.prescan_block_spawns(body)
            case HirStmt.SForUnpack(_, _, body):
                self.prescan_block_spawns(body)
            case HirStmt.STry(tb, catches, fin):
                self.prescan_block_spawns(tb)
                if not _is_invalid_ptr(fin as usize):
                    self.prescan_block_spawns(fin)
                mut ci = 0
                while ci < catches.len:
                    mut cc = catches.get(ci).read()
                    self.prescan_block_spawns(cc.body)
                    ci = ci + 1
            case HirStmt.SExpr(se):
                self.prescan_await_all_in_expr(se)
            case HirStmt.SLet(_, _, _, _, _, _, se_v):
                self.prescan_await_all_in_expr(se_v)
            case HirStmt.SReturn(se_r):
                if not _is_invalid_ptr(se_r as usize):
                    self.prescan_await_all_in_expr(se_r)
            case _:
                pass

    pub def prescan_await_all_in_expr(self, e: Pointer[HirExpr]):
        if _is_invalid_ptr(e as usize): return
        match e.read():
            case HirExpr.ECall(aa_callee, aa_args, _):
                mut aa_fn_n = ""
                match aa_callee.read():
                    case HirExpr.EIdent(nn, _, _): aa_fn_n = nn
                    case HirExpr.EPropAccess(th_obj2, th_var2, _):
                        # Thread.spawn(fn, arg) static call - emit spawn wrapper
                        mut th_ctor2 = ""
                        match th_obj2.read():
                            case HirExpr.EIdent(thn2, _, _): th_ctor2 = thn2
                            case _: pass
                        if th_ctor2 == "Thread" and (th_var2 == "spawn" or th_var2 == "new"):
                            if aa_args.len >= 1:
                                mut th2_fn_nm = ""
                                match aa_args.get(0).read():
                                    case HirExpr.EIdent(tspn2, _, _): th2_fn_nm = tspn2
                                    case _: pass
                                if th2_fn_nm != "" and not self.spawn_wrappers.contains(th2_fn_nm):
                                    self.spawn_wrappers.insert(th2_fn_nm, true)
                                    if aa_args.len == 1:
                                        self.w("static void* _tr_spawn_wrap_" + th2_fn_nm + "(void* _vp) { (void)_vp; " + th2_fn_nm + "(); return NULL; }\n")
                                    else:
                                        mut th2_sp_aty = hir_expr_type(aa_args.get(1)).name
                                        mut th2_sp_cast = "(long long)(uintptr_t)_vp"
                                        if not _is_int_type(th2_sp_aty) and th2_sp_aty != "bool" and th2_sp_aty != "char":
                                            mut th2_sp_cty = self.type_to_c(hir_expr_type(aa_args.get(1)))
                                            th2_sp_cast = "(" + th2_sp_cty + ")_vp"
                                        self.w("static void* _tr_spawn_wrap_" + th2_fn_nm + "(void* _vp) { " + th2_fn_nm + "(" + th2_sp_cast + "); return NULL; }\n")
                    case _: pass
                if aa_fn_n == "await_all":
                    mut aa_pi = 0
                    while aa_pi < aa_args.len:
                        self.emit_spawn_wrapper_for_expr(aa_args.get(aa_pi))
                        aa_pi = aa_pi + 1
            case HirExpr.EMethodCall(pool_obj, pool_meth, pool_args, _):
                # Thread.spawn(fn, arg) - emit spawn wrapper
                if pool_meth == "spawn":
                    mut th_ps_nm = ""
                    match pool_obj.read():
                        case HirExpr.EIdent(tpn2, _, _): th_ps_nm = tpn2
                        case _: pass
                    if th_ps_nm == "Thread" and pool_args.len >= 1:
                        mut th_ps_fn = ""
                        match pool_args.get(0).read():
                            case HirExpr.EIdent(tpfn, _, _): th_ps_fn = tpfn
                            case _: pass
                        if th_ps_fn != "" and not self.spawn_wrappers.contains(th_ps_fn):
                            self.spawn_wrappers.insert(th_ps_fn, true)
                            if pool_args.len == 1:
                                self.w("static void* _tr_spawn_wrap_" + th_ps_fn + "(void* _vp) { (void)_vp; " + th_ps_fn + "(); return NULL; }\n")
                            elif pool_args.len == 2:
                                mut th_ps_aty = hir_expr_type(pool_args.get(1)).name
                                mut th_ps_cast = "(long long)(uintptr_t)_vp"
                                if not _is_int_type(th_ps_aty) and th_ps_aty != "bool" and th_ps_aty != "char":
                                    mut th_ps_cty = self.type_to_c(hir_expr_type(pool_args.get(1)))
                                    th_ps_cast = "(" + th_ps_cty + ")_vp"
                                self.w("static void* _tr_spawn_wrap_" + th_ps_fn + "(void* _vp) { " + th_ps_fn + "(" + th_ps_cast + "); return NULL; }\n")
                            else:
                                # multi-arg: wrapper receives heap long long[N] where [0..N-1] = fn args
                                mut th_ps_nfnargs = pool_args.len - 1
                                self.w("static void* _tr_spawn_wrap_" + th_ps_fn + "(void* _vp) {\n")
                                self.w("    long long* _ab = (long long*)_vp;\n")
                                mut th_ps_cs = ""
                                mut th_ps_ii = 0
                                while th_ps_ii < th_ps_nfnargs:
                                    if th_ps_ii > 0: th_ps_cs = th_ps_cs + ", "
                                    mut th_ps_atn = hir_expr_type(pool_args.get(th_ps_ii + 1)).name
                                    if not _is_int_type(th_ps_atn) and th_ps_atn != "bool" and th_ps_atn != "char":
                                        mut th_ps_cty2 = self.type_to_c(hir_expr_type(pool_args.get(th_ps_ii + 1)))
                                        th_ps_cs = th_ps_cs + "(" + th_ps_cty2 + ")_ab[" + str(th_ps_ii) + "]"
                                    else:
                                        th_ps_cs = th_ps_cs + "_ab[" + str(th_ps_ii) + "]"
                                    th_ps_ii = th_ps_ii + 1
                                self.w("    " + th_ps_fn + "(" + th_ps_cs + ");\n")
                                self.w("    free(_ab); return NULL;\n")
                                self.w("}\n")
                # Emit spawn wrappers for pool.spawn(fn, args...) calls
                if pool_meth == "spawn" and hir_expr_type(pool_obj).name == "ThreadPool":
                    if pool_args.len >= 1:
                        # Build a synthetic ECall with fn as callee and remaining args as args
                        mut sp_fn_nm = ""
                        match pool_args.get(0).read():
                            case HirExpr.EIdent(spn, _, _): sp_fn_nm = spn
                            case _: pass
                        if sp_fn_nm != "":
                            if not self.spawn_wrappers.contains(sp_fn_nm):
                                self.spawn_wrappers.insert(sp_fn_nm, true)
                                if pool_args.len == 1:
                                    self.w("static void* _tr_spawn_wrap_" + sp_fn_nm + "(void* _vp) { (void)_vp; " + sp_fn_nm + "(); return NULL; }\n")
                                elif pool_args.len == 2:
                                    mut sp_aty = hir_expr_type(pool_args.get(1)).name
                                    mut sp_cast = "(long long)(uintptr_t)_vp"
                                    if not _is_int_type(sp_aty) and sp_aty != "bool" and sp_aty != "char":
                                        mut sp_cty = self.type_to_c(hir_expr_type(pool_args.get(1)))
                                        sp_cast = "(" + sp_cty + ")_vp"
                                    self.w("static void* _tr_spawn_wrap_" + sp_fn_nm + "(void* _vp) { " + sp_fn_nm + "(" + sp_cast + "); return NULL; }\n")
                                else:
                                    mut sp_na = pool_args.len - 1
                                    mut sp_is_void = true
                                    if self.functions.contains(sp_fn_nm):
                                        mut sp_hf = self.functions.get(sp_fn_nm)
                                        sp_is_void = sp_hf.ret_ty.name == "void" or sp_hf.ret_ty.name == ""
                                    self.w("static void* _tr_spawn_wrap_" + sp_fn_nm + "(void* _vp) {\n")
                                    self.w("    long long* _ab = (long long*)_vp;\n")
                                    mut sp_cs = ""
                                    mut sp_ii = 0
                                    while sp_ii < sp_na:
                                        if sp_ii > 0: sp_cs = sp_cs + ", "
                                        mut sp_atn2 = hir_expr_type(pool_args.get(sp_ii + 1)).name
                                        if not _is_int_type(sp_atn2) and sp_atn2 != "bool" and sp_atn2 != "char":
                                            mut sp_ct2 = self.type_to_c(hir_expr_type(pool_args.get(sp_ii + 1)))
                                            sp_cs = sp_cs + "(" + sp_ct2 + ")_ab[" + str(sp_ii + 1) + "]"
                                        else:
                                            sp_cs = sp_cs + "_ab[" + str(sp_ii + 1) + "]"
                                        sp_ii = sp_ii + 1
                                    if sp_is_void:
                                        self.w("    " + sp_fn_nm + "(" + sp_cs + ");\n")
                                    else:
                                        self.w("    _ab[0] = (long long)" + sp_fn_nm + "(" + sp_cs + ");\n")
                                    self.w("    free(_ab); return NULL;\n")
                                    self.w("}\n")
            case _: pass

    pub def prescan_spawns(self, prog: HirProgram):
        if _is_invalid_ptr(prog as usize): return
        if _is_invalid_ptr(prog.functions as usize): return
        if _is_invalid_ptr(prog.classes as usize): return
        mut i = 0
        while i < prog.functions.len:
            mut f = prog.functions.get(i)
            if not _is_invalid_ptr(f as usize):
                if not self.prescanned_fns.contains(f.name):
                    self.prescanned_fns.insert(f.name, true)
                    mut fb = f.body
                    if not _is_invalid_ptr(fb as usize):
                        self.prescan_block_spawns(fb)
            i = i + 1
        i = 0
        while i < prog.classes.len:
            mut c = prog.classes.get(i)
            if not _is_invalid_ptr(c as usize):
                if not _is_invalid_ptr(c.methods as usize):
                    mut mi = 0
                    while mi < c.methods.len:
                        mut m = c.methods.get(mi)
                        if not _is_invalid_ptr(m as usize):
                            mut mk = c.name + "::" + m.name
                            if not self.prescanned_fns.contains(mk):
                                self.prescanned_fns.insert(mk, true)
                                if not _is_invalid_ptr(m.body as usize):
                                    self.prescan_block_spawns(m.body)
                        mi = mi + 1
            i = i + 1

    # -- Async wrapper prescan -------------------------------------------------

    pub def prescan_expr_awaits(self, e: Pointer[HirExpr]):
        if _is_invalid_ptr(e as usize): return
        match e.read():
            case HirExpr.EAwait(inner, _):
                if not _is_invalid_ptr(inner as usize):
                    match inner.read():
                        case HirExpr.ECall(callee, args, call_ty):
                            mut fn_name = ""
                            match callee.read():
                                case HirExpr.EIdent(n, _, _): fn_name = n
                                case _: pass
                            if fn_name != "":
                                self.emit_async_wrapper_for_call(fn_name, args, call_ty.name)
                        case _: pass
                self.prescan_expr_awaits(inner)
            case HirExpr.EAwaitTimeout(ato_inner, ato_ms, _):
                if not _is_invalid_ptr(ato_inner as usize):
                    match ato_inner.read():
                        case HirExpr.ECall(ato_callee, ato_args, ato_call_ty):
                            mut ato_fn_nm = ""
                            match ato_callee.read():
                                case HirExpr.EIdent(nn, _, _): ato_fn_nm = nn
                                case _: pass
                            if ato_fn_nm != "":
                                self.emit_async_wrapper_for_call(ato_fn_nm, ato_args, ato_call_ty.name)
                        case _: pass
                self.prescan_expr_awaits(ato_ms)
            case HirExpr.ECall(callee, args, _):
                self.prescan_expr_awaits(callee)
                mut ai = 0
                while ai < args.len:
                    self.prescan_expr_awaits(args.get(ai))
                    ai = ai + 1
            case HirExpr.EBinOp(_, l, r, _):
                self.prescan_expr_awaits(l)
                self.prescan_expr_awaits(r)
            case HirExpr.EMethodCall(obj, _, margs, _):
                self.prescan_expr_awaits(obj)
                mut mi = 0
                while mi < margs.len:
                    self.prescan_expr_awaits(margs.get(mi))
                    mi = mi + 1
            case _: pass

    pub def prescan_block_awaits(self, block: HirBlock):
        if _is_invalid_ptr(block as usize): return
        mut i = 0
        while i < block.stmts.len:
            self.prescan_stmt_awaits(block.stmts.get(i))
            i = i + 1

    pub def prescan_stmt_awaits(self, s: Pointer[HirStmt]):
        if _is_invalid_ptr(s as usize): return
        match s.read():
            case HirStmt.SExpr(e): self.prescan_expr_awaits(e)
            case HirStmt.SLet(_, _, _, _, _, _, v): self.prescan_expr_awaits(v)
            case HirStmt.SReturn(v): self.prescan_expr_awaits(v)
            case HirStmt.SIf(cond, t, e):
                self.prescan_expr_awaits(cond)
                self.prescan_block_awaits(t)
                self.prescan_block_awaits(e)
            case HirStmt.SWhile(cond, body):
                self.prescan_expr_awaits(cond)
                self.prescan_block_awaits(body)
            case HirStmt.SFor(_, iter, body):
                self.prescan_expr_awaits(iter)
                self.prescan_block_awaits(body)
            case HirStmt.SForUnpack(_, iter, body):
                self.prescan_expr_awaits(iter)
                self.prescan_block_awaits(body)
            case HirStmt.STry(tb, catches, fin):
                self.prescan_block_awaits(tb)
                self.prescan_block_awaits(fin)
                mut ci = 0
                while ci < catches.len:
                    mut cc = catches.get(ci).read()
                    self.prescan_block_awaits(cc.body)
                    ci = ci + 1
            case HirStmt.STaskGroup(body): self.prescan_block_awaits(body)
            case HirStmt.SMultiLet(_, _, v): self.prescan_expr_awaits(v)
            case HirStmt.SAssign(tgt, v):
                self.prescan_expr_awaits(tgt)
                self.prescan_expr_awaits(v)
            case _: pass

    pub def prescan_awaits(self, prog: HirProgram):
        if _is_invalid_ptr(prog as usize): return
        mut i = 0
        while i < prog.functions.len:
            mut f = prog.functions.get(i)
            if not _is_invalid_ptr(f as usize):
                if not _is_invalid_ptr(f.body as usize):
                    self.prescan_block_awaits(f.body)
            i = i + 1
        i = 0
        while i < prog.classes.len:
            mut c = prog.classes.get(i)
            if not _is_invalid_ptr(c as usize):
                if not _is_invalid_ptr(c.methods as usize):
                    mut mi = 0
                    while mi < c.methods.len:
                        mut m = c.methods.get(mi)
                        if not _is_invalid_ptr(m as usize):
                            if not _is_invalid_ptr(m.body as usize):
                                self.prescan_block_awaits(m.body)
                        mi = mi + 1
            i = i + 1

    # -- Statement generation --------------------------------------------------

    pub def gen_stmt(self, s_ptr: Pointer[HirStmt], indent: int):
        if _is_invalid_ptr(s_ptr as usize): return
        pad = _indent_str(indent)
        match s_ptr.read():
            case HirStmt.SExpr(e):
                # ? propagation at expression-statement level
                if e as usize != 0 as usize:
                    match e.read():
                        case HirExpr.ETryExpr(inner_try, _):
                            mut tmp_qr = "_qr" + self.next_temp()
                            self.w(pad + "Result " + tmp_qr + " = (" + self.gen_expr(inner_try) + ");\n")
                            self.w(pad + "if (" + tmp_qr + ".tag == Result_Err) return " + tmp_qr + ";\n")
                            return
                        case _: pass
                self.w(pad + self.gen_expr(e) + ";\n")
            case HirStmt.SDefer(inner_defer):
                # defer: save the C code now, emit it before each return.
                mut saved_buf = self.buf
                self.buf = StringBuilder.init(256)
                self.gen_stmt(inner_defer, indent)
                mut deferred_c = self.buf.to_string().as_str()
                self.buf = saved_buf
                self.defer_stack.push(deferred_c)
            case HirStmt.SReturn(e):
                # Flush deferred statements in LIFO order before returning.
                if self.defer_stack.len > 0:
                    mut di2 = self.defer_stack.len - 1
                    while di2 >= 0:
                        self.w(self.defer_stack.get(di2))
                        if di2 == 0: break
                        di2 = di2 - 1
                if e as usize == 0 as usize:
                    if self.cur_throws_ty != "":
                        self.w(pad + "return ((Result){.tag=Result_Ok});\n")
                    elif self.cur_func == "main":
                        self.w(pad + "return 0;\n")
                    else:
                        self.w(pad + "return;\n")
                else:
                    # ? propagation in return position
                    match e.read():
                        case HirExpr.ETryExpr(inner_try2, ok_ty2):
                            mut tmp_qr2 = "_qr" + self.next_temp()
                            self.w(pad + "Result " + tmp_qr2 + " = (" + self.gen_expr(inner_try2) + ");\n")
                            self.w(pad + "if (" + tmp_qr2 + ".tag == Result_Err) return " + tmp_qr2 + ";\n")
                            if self.cur_throws_ty != "":
                                mut ok_c2 = self.type_to_c(ok_ty2)
                                if _is_int_type(ok_ty2.name) or ok_ty2.name == "bool":
                                    self.w(pad + "return ((Result){.tag=Result_Ok, .data.Ok.val=(void*)(uintptr_t)((" + ok_c2 + ")(uintptr_t)" + tmp_qr2 + ".data.Ok.val)});\n")
                                else:
                                    self.w(pad + "return ((Result){.tag=Result_Ok, .data.Ok.val=" + tmp_qr2 + ".data.Ok.val});\n")
                            else:
                                mut ok_c2b = self.type_to_c(ok_ty2)
                                if _is_int_type(ok_ty2.name) or ok_ty2.name == "bool":
                                    self.w(pad + "return (" + ok_c2b + ")(uintptr_t)" + tmp_qr2 + ".data.Ok.val;\n")
                                else:
                                    self.w(pad + "return (" + ok_c2b + "*)" + tmp_qr2 + ".data.Ok.val;\n")
                            return
                        case _: pass
                    if self.cur_throws_ty != "":
                        # throws function: wrap return value in Result_Ok
                        mut ret_s = self.gen_expr(e)
                        mut ret_ty_n = hir_expr_type(e).name
                        if _is_int_type(ret_ty_n) or ret_ty_n == "bool" or ret_ty_n == "char":
                            self.w(pad + "return ((Result){.tag=Result_Ok, .data.Ok.val=(void*)(uintptr_t)(" + ret_s + ")});\n")
                        else:
                            self.w(pad + "return ((Result){.tag=Result_Ok, .data.Ok.val=(void*)(" + ret_s + ")});\n")
                    else:
                        self.w(pad + "return " + self.gen_expr(e) + ";\n")
            case HirStmt.SLet(n, _, _, is_const, is_shared, ty, v):
                mut c_ty = self.type_to_c(ty)
                # If SLet.ty is Vec/List without generic args, recover c_ty from the init expression
                if c_ty == "List_ptr*" and v as usize != 0 as usize:
                    mut _init_sfx = "ptr"
                    match v.read():
                        case HirExpr.ECall(_, _, call_ty):
                            if (call_ty.name == "Vec" or call_ty.name == "List") and call_ty.args.len > 0:
                                _init_sfx = self.list_elem_suffix(call_ty.args.get(0).read().name)
                        case HirExpr.EMethodCall(hobj_mc, _m, iargs, call_ty):
                            if (call_ty.name == "Vec" or call_ty.name == "List") and call_ty.args.len > 0:
                                _init_sfx = self.list_elem_suffix(call_ty.args.get(0).read().name)
                            # gen_call already handles Vec[T].init(): reuse the expr's inferred elem sfx
                            elif hobj_mc as usize != 0 as usize and (_m == "init" or _m == "new"):
                                mut hobj_ty_mc = hir_expr_type(hobj_mc)
                                if (hobj_ty_mc.name == "Vec" or hobj_ty_mc.name == "List") and hobj_ty_mc.args.len > 0:
                                    _init_sfx = self.list_elem_suffix(hobj_ty_mc.args.get(0).read().name)
                                elif iargs.len > 0:
                                    # Fallback: infer from first arg to init (capacity hint, same type as elems)
                                    pass
                        case _: pass
                    if _init_sfx != "ptr":
                        c_ty = "List_" + _init_sfx + "*"
                if c_ty == "void" and v as usize != 0 as usize: c_ty = "__auto_type"
                # ? propagation in let binding
                if v as usize != 0 as usize:
                    match v.read():
                        case HirExpr.ETryExpr(inner_try3, ok_ty3):
                            mut tmp_qr3 = "_qr" + self.next_temp()
                            self.w(pad + "Result " + tmp_qr3 + " = (" + self.gen_expr(inner_try3) + ");\n")
                            self.w(pad + "if (" + tmp_qr3 + ".tag == Result_Err) return " + tmp_qr3 + ";\n")
                            mut ok_c3 = self.type_to_c(ok_ty3)
                            if ok_c3 == "void" or ok_c3 == "__auto_type": ok_c3 = "long long"
                            mut ok_val3 = ""
                            if _is_int_type(ok_ty3.name) or ok_ty3.name == "bool" or ok_ty3.name == "char":
                                ok_val3 = "(" + ok_c3 + ")(uintptr_t)" + tmp_qr3 + ".data.Ok.val"
                            else:
                                ok_val3 = "(" + ok_c3 + "*)" + tmp_qr3 + ".data.Ok.val"
                            if is_const:
                                self.w(pad + "const " + ok_c3 + " " + _safe_c_varname(n) + " = " + ok_val3 + ";\n")
                            else:
                                self.w(pad + ok_c3 + " " + _safe_c_varname(n) + " = " + ok_val3 + ";\n")
                            self.decl_vars.insert(n, true)
                            return
                        case _: pass
                # Special-case: EClosure in SLet - write nested function FIRST, then the variable,
                # to prevent gen_closure's self.w() calls from merging into the "c_ty n" prefix line.
                if v as usize != 0 as usize:
                    match v.read():
                        case HirExpr.EClosure(cl_params, cl_ret_ty, cl_body, _, cl_caps):
                            self.closure_count = self.closure_count + 1
                            mut cl_cname = "_closure_" + self.closure_count.to_str()
                            mut cl_ret_c = self.type_to_c(cl_ret_ty)
                            if cl_ret_c == "void": cl_ret_c = "long long"
                            mut cl_pi = 0
                            while cl_pi < cl_params.len:
                                self.decl_vars.insert(cl_params.get(cl_pi).name, true)
                                cl_pi = cl_pi + 1
                            mut cl_ci = 0
                            while cl_ci < cl_caps.len:
                                self.decl_vars.insert(cl_caps.get(cl_ci).name, true)
                                cl_ci = cl_ci + 1
                            self.w(pad + cl_ret_c + " " + cl_cname + "(")
                            mut cl_first = true
                            mut cl_ii = 0
                            while cl_ii < cl_params.len:
                                mut cl_p = cl_params.get(cl_ii)
                                if not cl_first: self.w(", ")
                                self.w(self.type_to_c(cl_p.ty) + " " + _safe_c_varname(cl_p.name))
                                cl_first = false
                                cl_ii = cl_ii + 1
                            self.w(") {\n")
                            self.gen_block(cl_body, indent + 1)
                            self.w(pad + "}\n")
                            self.w(pad + "void* " + _safe_c_varname(n) + " = (void*)(&" + cl_cname + ");\n")
                            self.decl_vars.insert(n, true)
                            return
                        case _: pass
                mut _sn = _safe_c_varname(n)
                if is_const:
                    self.w(pad + "const " + c_ty + " " + _sn)
                elif is_shared:
                    self.w(pad + "_TrSharedBox* " + _sn)
                else:
                    # Auto-unlock RAII guard: emit __attribute__((cleanup)) guard before Mutex.get() / RwLock.read() / write()
                    if v as usize != 0 as usize:
                        match v.read():
                            case HirExpr.EMethodCall(au_obj, au_method, _, _):
                                if not _is_invalid_ptr(au_obj as usize):
                                    mut au_oty = hir_expr_type(au_obj)
                                    if au_oty.name == "Mutex" and (au_method == "get" or au_method == "lock"):
                                        self.w(pad + "__attribute__((cleanup(_tr_mutexbox_cleanup))) _TrMutexBox* __g_" + _sn + " = " + self.gen_expr(au_obj) + ";\n")
                                    elif au_oty.name == "RwLock" and (au_method == "read" or au_method == "read_lock"):
                                        self.w(pad + "__attribute__((cleanup(_tr_rwlbox_cleanup_r))) _TrRWLBox* __g_" + _sn + " = " + self.gen_expr(au_obj) + ";\n")
                                    elif au_oty.name == "RwLock" and (au_method == "write" or au_method == "write_lock"):
                                        self.w(pad + "__attribute__((cleanup(_tr_rwlbox_cleanup_w))) _TrRWLBox* __g_" + _sn + " = " + self.gen_expr(au_obj) + ";\n")
                            case _: pass
                    self.w(pad + c_ty + " " + _sn)
                if v as usize != 0 as usize:
                    if is_shared:
                        # Detect clone vs new-wrap: if value is an already-shared var, clone it
                        mut is_clone = false
                        match v.read():
                            case HirExpr.EIdent(vn, _, _):
                                if self.shared_vars.contains(vn):
                                    self.w(" = _tr_shared_clone(" + vn + ");\n")
                                    is_clone = true
                            case _: pass
                        if not is_clone:
                            self.w(" = _tr_shared_new(" + self.gen_expr(v) + ");\n")
                        # Register var in shared_vars with the raw Tauraro type name
                        mut sh_type_name = ty.name
                        if sh_type_name == "void" or sh_type_name == "None":
                            sh_type_name = hir_expr_type(v).name
                        self.shared_vars.insert(n, sh_type_name)
                    else:
                        # For empty list literals, propagate annotation type so suffix is correct
                        mut init_s = ""
                        # Auto-wrap class instance into interface object
                        if self.interfaces.contains(ty.name):
                            mut _slet_iface = self.interfaces.get(ty.name)
                            mut _slet_iface_name = ty.name
                            if _slet_iface.generics.len > 0 and ty.args.len > 0:
                                _slet_iface_name = ty.name + "_" + self.type_args_suffix(ty.args)
                            mut _slet_val_ty = hir_expr_type(v)
                            mut val_ty_n = _slet_val_ty.name
                            if self.classes.contains(val_ty_n):
                                mut _slet_cls = self.classes.get(val_ty_n)
                                if _slet_cls.generics.len > 0 and _slet_val_ty.args.len > 0:
                                    val_ty_n = val_ty_n + "_" + self.type_args_suffix(_slet_val_ty.args)
                                init_s = val_ty_n + "_as_" + _slet_iface_name + "(" + self.gen_expr(v) + ")"
                        if init_s == "":
                            match v.read():
                                case HirExpr.EList(items, list_ty):
                                    # Avoid variable reassignment - ownership model would free list_ty early
                                    if list_ty.args.len == 0 and ty.name == "List" and ty.args.len > 0:
                                        init_s = self.gen_list_literal(items, ty)
                                    else:
                                        init_s = self.gen_list_literal(items, list_ty)
                                case HirExpr.EDict(d_keys, d_vals, d_ty):
                                    # Propagate annotation type for empty dicts (sema stores plain "Dict" with no args)
                                    if (d_ty.args.len == 0 or d_ty.name == "Dict") and (ty.name == "Dict" or ty.name == "Map") and ty.args.len > 0:
                                        init_s = self.gen_dict_literal(d_keys, d_vals, ty)
                                    else:
                                        init_s = self.gen_dict_literal(d_keys, d_vals, d_ty)
                                case _:
                                    init_s = self.gen_expr(v)
                        self.w(" = " + init_s + ";\n")
                else:
                    if is_shared:
                        self.w(" = NULL;\n")
                        self.shared_vars.insert(n, ty.name)
                    elif c_ty == "Result" or c_ty == "Option":
                        self.w(" = (" + c_ty + "){0};\n")
                    else:
                        self.w(" = 0;\n")
                self.decl_vars.insert(n, true)
            case HirStmt.SAssign(t, v):
                match t.read():
                    case HirExpr.EIdent(n, _, _):
                        if not self.decl_vars.contains(n):
                            self.w(pad + "__auto_type " + _safe_c_varname(n) + " = " + self.gen_expr(v) + ";\n")
                            self.decl_vars.insert(n, true)
                            return
                    case HirExpr.EIndex(idx_obj, idx_key, _):
                        mut idx_ty_n: str = hir_expr_type(idx_obj).name
                        if self.has_method(idx_ty_n, "__setitem__"):
                            mut _si_obj = self.gen_expr(idx_obj)
                            mut _si_key = self.gen_expr(idx_key)
                            mut _si_val = self.gen_expr(v)
                            self.w(pad + self.cls_method_c_call(idx_ty_n, "__setitem__", _si_obj, _si_key + ", " + _si_val) + ";\n")
                            return
                    case HirExpr.EMethodCall(mc_obj, mc_meth, mc_args, _):
                        # sema lowers bag[i] = v -> SAssign(EMethodCall(bag, "get_index", [i]), v)
                        if mc_meth == "get_index" and mc_args.len > 0:
                            mut mc_ty_n: str = hir_expr_type(mc_obj).name
                            if self.has_method(mc_ty_n, "__setitem__"):
                                mut _si2_obj = self.gen_expr(mc_obj)
                                mut _si2_key = self.gen_args(mc_args)
                                mut _si2_val = self.gen_expr(v)
                                self.w(pad + self.cls_method_c_call(mc_ty_n, "__setitem__", _si2_obj, _si2_key + ", " + _si2_val) + ";\n")
                                return
                    case _: pass
                mut _assign_rhs = ""
                match v.read():
                    case HirExpr.EList(litems, list_ty):
                        if list_ty.args.len == 0:
                            mut tgt_ty = hir_expr_type(t)
                            if (tgt_ty.name == "List" or tgt_ty.name == "Vec") and tgt_ty.args.len > 0:
                                _assign_rhs = self.gen_list_literal(litems, tgt_ty)
                    case _: pass
                if _assign_rhs == "": _assign_rhs = self.gen_expr(v)
                self.w(pad + self.gen_expr(t) + " = " + _assign_rhs + ";\n")
            case HirStmt.SIf(c, t, e):
                self.w(pad + "if (" + self.gen_cond_expr(c) + ") {\n")
                self.gen_block(t, indent + 1)
                mut cur = e
                mut going = not _is_invalid_ptr(cur as usize)
                while going:
                    if _is_invalid_ptr(cur.stmts as usize):
                        going = false
                    elif cur.stmts.len == 1:
                        match cur.stmts.get(0).read():
                            case HirStmt.SIf(ic, it, ie):
                                self.w(pad + "} else if (" + self.gen_cond_expr(ic) + ") {\n")
                                self.gen_block(it, indent + 1)
                                cur = ie
                                going = not _is_invalid_ptr(cur as usize)
                            case _:
                                self.w(pad + "} else {\n")
                                self.gen_block(cur, indent + 1)
                                going = false
                    elif cur.stmts.len > 0:
                        self.w(pad + "} else {\n")
                        self.gen_block(cur, indent + 1)
                        going = false
                    else:
                        going = false
                self.w(pad + "}\n")
            case HirStmt.SWhile(c, b):
                self.w(pad + "while (" + self.gen_cond_expr(c) + ") {\n")
                self.gen_block(b, indent + 1)
                self.w(pad + "}\n")
            case HirStmt.SFor(var, iter, body):
                if self.in_gpu_block > 0:
                    self.w(pad + "#pragma omp for\n")
                self.gen_for_loop(var, iter, body, indent)
            case HirStmt.SForUnpack(vars, iter, body):
                self.gen_for_unpack(vars, iter, body, indent)
            case HirStmt.SMatch(e, arms):
                self.gen_match(e, arms, indent)
            case HirStmt.STry(try_body, catches, finally_b):
                self.gen_try(try_body, catches, finally_b, indent)
            case HirStmt.SRaise(e):
                if self.cur_throws_ty != "":
                    # throws function: raise becomes return Result_Err
                    self.w(pad + "return ((Result){.tag=Result_Err, .data.Err.err=(void*)(" + self.gen_expr(e) + ")});\n")
                else:
                    self.w(pad + "_tr_exc_raise((char*)(" + self.gen_expr(e) + "));\n")
            case HirStmt.SAssert(cond, msg):
                if msg as usize == 0 as usize:
                    self.w(pad + "_TR_ASSERT(" + self.gen_expr(cond) + ");\n")
                else:
                    self.w(pad + "_TR_ASSERT_MSG(" + self.gen_expr(cond) + ", " + self.gen_expr(msg) + ");\n")
            case HirStmt.SUnsafe(b):
                self.w(pad + "/* unsafe block */\n")
                self.gen_block(b, indent)
            case HirStmt.SWith(items, aliases, body):
                mut with_base = self.next_temp()
                mut wi = 0
                while wi < items.len:
                    mut with_item = items.get(wi)
                    # Parser emits `with expr as alias:` as ECast(expr, alias_type) when the
                    # `as` is treated as a type cast rather than a binding alias. Unwrap it.
                    mut actual_wi: Pointer[HirExpr] = with_item
                    mut cast_alias: str = ""
                    match with_item.read():
                        case HirExpr.ECast(wi_inner, wi_cast_ty):
                            actual_wi = wi_inner
                            cast_alias = wi_cast_ty.name
                        case _: pass
                    mut item_s = self.gen_expr(actual_wi)
                    mut item_ty_n: str = hir_expr_type(actual_wi).name
                    # Resolve alias: prefer the SWith alias list, fall back to cast_alias
                    mut alias_n: str = ""
                    if wi < aliases.len and aliases.get(wi) != "":
                        alias_n = aliases.get(wi)
                    elif cast_alias != "":
                        alias_n = cast_alias
                    mut ctx_name = with_base + "_ctx" + wi.to_str()
                    if self.has_method(item_ty_n, "__enter__"):
                        self.w(pad + "__auto_type " + ctx_name + " = " + item_s + ";\n")
                        mut enter_val = self.cls_method_c_call(item_ty_n, "__enter__", ctx_name, "")
                        if alias_n != "":
                            self.w(pad + "__auto_type " + alias_n + " = " + enter_val + ";\n")
                        else:
                            self.w(pad + enter_val + ";\n")
                    else:
                        if alias_n != "":
                            self.w(pad + "__auto_type " + alias_n + " = " + item_s + ";\n")
                        else:
                            self.w(pad + item_s + ";\n")
                    wi = wi + 1
                self.gen_block(body, indent)
                mut rei = items.len - 1
                while rei >= 0:
                    mut with_item_exit = items.get(rei)
                    # Unwrap ECast alias pattern for exit type detection
                    mut exit_actual: Pointer[HirExpr] = with_item_exit
                    match with_item_exit.read():
                        case HirExpr.ECast(we_inner, _):
                            exit_actual = we_inner
                        case _: pass
                    mut exit_ty_n: str = hir_expr_type(exit_actual).name
                    if self.has_method(exit_ty_n, "__exit__"):
                        mut ctx_exit = with_base + "_ctx" + rei.to_str()
                        self.w(pad + self.cls_method_c_call(exit_ty_n, "__exit__", ctx_exit, "NULL, NULL, NULL") + ";\n")
                    rei = rei - 1
            case HirStmt.SAsm(code, outputs, inputs, clobbers):
                mut asm_s = pad + "__asm__ volatile(\"" + _escape_str_for_c(code) + "\""
                if outputs != "" or inputs != "" or clobbers != "":
                    asm_s = asm_s + " : " + outputs
                    if inputs != "" or clobbers != "":
                        asm_s = asm_s + " : " + inputs
                        if clobbers != "":
                            asm_s = asm_s + " : \"" + clobbers + "\""
                self.w(asm_s + ");\n")
            case HirStmt.SSpawn(e):
                match e.read():
                    case HirExpr.ECall(callee, args, _):
                        mut sp_fn = ""
                        match callee.read():
                            case HirExpr.EIdent(n, _, _): sp_fn = n
                            case _: pass
                        if sp_fn == "":
                            self.w(pad + self.gen_expr(e) + "; /* spawn: inline */\n")
                        elif args.len == 0:
                            if self.in_task_group > 0:
                                self.w(pad + "_tr_tg_push(_tr_thread_start(_tr_spawn_wrap_" + sp_fn + ", NULL));\n")
                            else:
                                self.w(pad + "_tr_thread_detach(_tr_thread_start(_tr_spawn_wrap_" + sp_fn + ", NULL));\n")
                        elif args.len == 1:
                            mut arg_ty_n = hir_expr_type(args.get(0)).name
                            mut void_cast = "(void*)(uintptr_t)(" + self.gen_expr(args.get(0)) + ")"
                            if not _is_int_type(arg_ty_n) and arg_ty_n != "bool" and arg_ty_n != "char":
                                void_cast = "(void*)(" + self.gen_expr(args.get(0)) + ")"
                            if self.in_task_group > 0:
                                self.w(pad + "_tr_tg_push(_tr_thread_start(_tr_spawn_wrap_" + sp_fn + ", " + void_cast + "));\n")
                            else:
                                self.w(pad + "_tr_thread_detach(_tr_thread_start(_tr_spawn_wrap_" + sp_fn + ", " + void_cast + "));\n")
                        else:
                            # multi-arg spawn: heap-pack args into long long[N+1] ([0]=result, [1..N]=args)
                            mut sp_nargs = args.len
                            self.w(pad + "{ long long* _sa = (long long*)malloc(" + str(sp_nargs + 1) + " * sizeof(long long));\n")
                            mut sp_ai = 0
                            while sp_ai < sp_nargs:
                                mut sp_atn = hir_expr_type(args.get(sp_ai)).name
                                if not _is_int_type(sp_atn) and sp_atn != "bool" and sp_atn != "char":
                                    self.w(pad + "  _sa[" + str(sp_ai + 1) + "] = (long long)" + self.gen_expr(args.get(sp_ai)) + ";\n")
                                else:
                                    self.w(pad + "  _sa[" + str(sp_ai + 1) + "] = (long long)(" + self.gen_expr(args.get(sp_ai)) + ");\n")
                                sp_ai = sp_ai + 1
                            if self.in_task_group > 0:
                                self.w(pad + "  _tr_tg_push(_tr_thread_start(_tr_spawn_wrap_" + sp_fn + ", _sa)); }\n")
                            else:
                                self.w(pad + "  _tr_thread_detach(_tr_thread_start(_tr_spawn_wrap_" + sp_fn + ", _sa)); }\n")
                    case _:
                        self.w(pad + self.gen_expr(e) + "; /* spawn: non-call sync */\n")
            case HirStmt.STaskGroup(body):
                self.w(pad + "_tr_tg_begin();\n")
                self.w(pad + "{\n")
                self.in_task_group = self.in_task_group + 1
                self.gen_block(body, indent + 1)
                self.in_task_group = self.in_task_group - 1
                self.w(pad + "}\n")
                self.w(pad + "_tr_taskgroup_wait();\n")
            case HirStmt.SGpuBlock(body):
                # gpu: keyword is deprecated in core. Use std.gpu instead.
                # Emits the block body sequentially with no OpenMP wrappers.
                self.w(pad + "/* deprecated gpu: block - use std.gpu for GPU dispatch */\n")
                self.w(pad + "{\n")
                self.in_gpu_block = self.in_gpu_block + 1
                self.gen_block(body, indent + 1)
                self.in_gpu_block = self.in_gpu_block - 1
                self.w(pad + "}\n")
            case HirStmt.SBreak: self.w(pad + "break;\n")
            case HirStmt.SContinue: self.w(pad + "continue;\n")
            case HirStmt.SPass: self.w(pad + "/* pass */\n")
            case HirStmt.SFree(name): self.w(pad + "if (" + name + ") { free(" + name + "); " + name + " = NULL; }\n")
            case HirStmt.SMultiLet(names, is_mut, val):
                self.gen_multi_let(names, is_mut, val, indent)
            case HirStmt.SChanSelect(cs_arms):
                self.gen_chan_select(cs_arms, indent)
            case _: pass

    pub def gen_for_loop(self, var: str, iter: Pointer[HirExpr], body: HirBlock, indent: int):
        pad = _indent_str(indent)
        mut iter_s = self.gen_expr(iter)

        # Check if it's a range call
        match iter.read():
            case HirExpr.ECall(callee, args, _):
                match callee.read():
                    case HirExpr.EIdent(n, _, _):
                        if n == "range":
                            mut start_s = "0LL"
                            mut end_s = "0LL"
                            mut step_s = "1LL"
                            if args.len == 1:
                                end_s = self.gen_expr(args.get(0))
                            elif args.len == 2:
                                start_s = self.gen_expr(args.get(0))
                                end_s = self.gen_expr(args.get(1))
                            elif args.len >= 3:
                                start_s = self.gen_expr(args.get(0))
                                end_s = self.gen_expr(args.get(1))
                                step_s = self.gen_expr(args.get(2))
                            mut cmp = "<"
                            mut step_p = step_s as Pointer[char]
                            if step_p.offset(0).read() as int == 45: cmp = ">"
                            self.w(pad + "for (long long " + var + " = " + start_s + "; " + var + " " + cmp + " " + end_s + "; " + var + " += " + step_s + ") {\n")
                            self.gen_block(body, indent + 1)
                            self.w(pad + "}\n")
                            return
                    case _: pass
            case _: pass

        # Generic iteration over a collection
        mut tmp = self.next_temp()
        mut iter_ty = hir_expr_type(iter)
        mut iter_ty_n: str = iter_ty.name

        # __iter__ + __next__ protocol (iterator objects)
        if self.has_method(iter_ty_n, "__iter__"):
            mut iter_ret = self.cls_method_ret_ty(iter_ty_n, "__iter__")
            mut it_cls = iter_ret.name
            if it_cls == "" or it_cls == "void": it_cls = iter_ty_n
            if self.has_method(it_cls, "__next__"):
                mut next_ret = self.cls_method_ret_ty(it_cls, "__next__")
                mut elem_ct = "void*"
                if next_ret.name == "Option" and next_ret.args.len > 0:
                    elem_ct = self.type_to_c(next_ret.args.get(0).read())
                self.w(pad + "{ __auto_type " + tmp + "_it = " + self.cls_method_c_call(iter_ty_n, "__iter__", iter_s, "") + ";\n")
                self.w(pad + "  while (1) {\n")
                self.w(pad + "    __auto_type " + tmp + "_nx = " + self.cls_method_c_call(it_cls, "__next__", tmp + "_it", "") + ";\n")
                self.w(pad + "    if (" + tmp + "_nx.tag == Option_None) break;\n")
                self.w(pad + "    " + elem_ct + " " + var + " = (" + elem_ct + ")" + tmp + "_nx.data.Some.val;\n")
                self.gen_block(body, indent + 2)
                self.w(pad + "  }\n")
                self.w(pad + "}\n")
                return

        # __len__ + __getitem__ sequence protocol
        if self.has_method(iter_ty_n, "__len__") and self.has_method(iter_ty_n, "__getitem__"):
            mut col_tmp = self.next_temp()
            self.w(pad + "{ __auto_type " + col_tmp + " = " + iter_s + ";\n")
            self.w(pad + "  long long " + tmp + "_len = (long long)" + self.cls_method_c_call(iter_ty_n, "__len__", col_tmp, "") + ";\n")
            self.w(pad + "  for (long long " + tmp + "_i = 0; " + tmp + "_i < " + tmp + "_len; " + tmp + "_i++) {\n")
            self.w(pad + "    __auto_type " + var + " = " + self.cls_method_c_call(iter_ty_n, "__getitem__", col_tmp, tmp + "_i") + ";\n")
            self.gen_block(body, indent + 2)
            self.w(pad + "  }\n")
            self.w(pad + "}\n")
            return

        # Chan[T] iteration: receive until channel closed
        if iter_ty_n == "Chan":
            mut ch_elem_c = "long long"
            if iter_ty.args.len > 0:
                ch_elem_c = self.type_to_c(iter_ty.args.get(0).read())
            mut ch_ok_v = self.next_temp()
            self.w(pad + "{ int " + ch_ok_v + " = 1;\n")
            self.w(pad + "  while (" + ch_ok_v + ") {\n")
            self.w(pad + "    " + ch_elem_c + " " + var + " = (" + ch_elem_c + ")_tr_chan_recv_ok(" + iter_s + ", &" + ch_ok_v + ");\n")
            self.w(pad + "    if (!" + ch_ok_v + ") break;\n")
            self.gen_block(body, indent + 2)
            self.w(pad + "  }\n")
            self.w(pad + "}\n")
            return

        mut elem_c = "__auto_type"
        if iter_ty.name == "List" or iter_ty.name == "Vec":
            if iter_ty.args.len > 0:
                elem_c = self.type_to_c(iter_ty.args.get(0).read())
        self.w(pad + "{ long long " + tmp + "_i = 0;\n")
        self.w(pad + "  __auto_type " + tmp + "_col = " + iter_s + ";\n")
        self.w(pad + "  while (" + tmp + "_i < " + tmp + "_col->len) {\n")
        if elem_c == "__auto_type":
            self.w(pad + "    __auto_type " + var + " = " + tmp + "_col->data[" + tmp + "_i];\n")
        else:
            self.w(pad + "    " + elem_c + " " + var + " = (" + elem_c + ")" + tmp + "_col->data[" + tmp + "_i];\n")
        self.gen_block(body, indent + 2)
        self.w(pad + "    " + tmp + "_i++;\n")
        self.w(pad + "  }\n")
        self.w(pad + "}\n")

    pub def gen_for_unpack(self, vars: Vec[str], iter: Pointer[HirExpr], body: HirBlock, indent: int):
        pad = _indent_str(indent)
        mut tmp = self.next_temp()

        # -- Case 1: enumerate(collection) ------------------------------------
        match iter.read():
            case HirExpr.ECall(eu_callee, eu_args, _):
                match eu_callee.read():
                    case HirExpr.EIdent(eu_n, _, _):
                        if eu_n == "enumerate" and eu_args.len == 1 and vars.len >= 2:
                            mut eu_col = eu_args.get(0)
                            mut eu_col_s = self.gen_expr(eu_col)
                            mut eu_ty = hir_expr_type(eu_col)
                            mut eu_elem_c = "__auto_type"
                            if (eu_ty.name == "List" or eu_ty.name == "Vec") and eu_ty.args.len > 0:
                                eu_elem_c = self.type_to_c(eu_ty.args.get(0).read())
                            mut eu_v0 = _safe_c_varname(vars.get(0))
                            mut eu_v1 = _safe_c_varname(vars.get(1))
                            self.decl_vars.insert(vars.get(0), true)
                            self.decl_vars.insert(vars.get(1), true)
                            self.w(pad + "{ __auto_type " + tmp + "_c = " + eu_col_s + ";\n")
                            self.w(pad + "  for (long long " + tmp + "_i = 0; " + tmp + "_i < (long long)" + tmp + "_c->len; " + tmp + "_i++) {\n")
                            self.w(pad + "    long long " + eu_v0 + " = " + tmp + "_i;\n")
                            if eu_elem_c == "__auto_type":
                                self.w(pad + "    __auto_type " + eu_v1 + " = " + tmp + "_c->data[" + tmp + "_i];\n")
                            else:
                                self.w(pad + "    " + eu_elem_c + " " + eu_v1 + " = (" + eu_elem_c + ")" + tmp + "_c->data[" + tmp + "_i];\n")
                            self.gen_block(body, indent + 2)
                            self.w(pad + "  }\n")
                            self.w(pad + "}\n")
                            return
                        if eu_n == "zip" and eu_args.len == 2 and vars.len >= 2:
                            mut za_col = eu_args.get(0)
                            mut zb_col = eu_args.get(1)
                            mut za_s = self.gen_expr(za_col)
                            mut zb_s = self.gen_expr(zb_col)
                            mut za_ty = hir_expr_type(za_col)
                            mut zb_ty = hir_expr_type(zb_col)
                            mut za_c = "__auto_type"
                            mut zb_c = "__auto_type"
                            if (za_ty.name == "List" or za_ty.name == "Vec") and za_ty.args.len > 0:
                                za_c = self.type_to_c(za_ty.args.get(0).read())
                            if (zb_ty.name == "List" or zb_ty.name == "Vec") and zb_ty.args.len > 0:
                                zb_c = self.type_to_c(zb_ty.args.get(0).read())
                            mut zv0 = _safe_c_varname(vars.get(0))
                            mut zv1 = _safe_c_varname(vars.get(1))
                            self.decl_vars.insert(vars.get(0), true)
                            self.decl_vars.insert(vars.get(1), true)
                            self.w(pad + "{ __auto_type " + tmp + "_a = " + za_s + "; __auto_type " + tmp + "_b = " + zb_s + ";\n")
                            self.w(pad + "  long long " + tmp + "_n = (long long)(" + tmp + "_a->len < " + tmp + "_b->len ? " + tmp + "_a->len : " + tmp + "_b->len);\n")
                            self.w(pad + "  for (long long " + tmp + "_i = 0; " + tmp + "_i < " + tmp + "_n; " + tmp + "_i++) {\n")
                            if za_c == "__auto_type":
                                self.w(pad + "    __auto_type " + zv0 + " = " + tmp + "_a->data[" + tmp + "_i];\n")
                            else:
                                self.w(pad + "    " + za_c + " " + zv0 + " = (" + za_c + ")" + tmp + "_a->data[" + tmp + "_i];\n")
                            if zb_c == "__auto_type":
                                self.w(pad + "    __auto_type " + zv1 + " = " + tmp + "_b->data[" + tmp + "_i];\n")
                            else:
                                self.w(pad + "    " + zb_c + " " + zv1 + " = (" + zb_c + ")" + tmp + "_b->data[" + tmp + "_i];\n")
                            self.gen_block(body, indent + 2)
                            self.w(pad + "  }\n")
                            self.w(pad + "}\n")
                            return
                    case _: pass
            case _: pass

        # -- Case 2: obj.items() - inline dict bucket walk ---------------------
        match iter.read():
            case HirExpr.EMethodCall(di_obj, di_meth, _, _):
                if di_meth == "items":
                    mut di_s = self.gen_expr(di_obj)
                    mut di_ty = hir_expr_type(di_obj)
                    mut di_idict = false
                    if di_ty.args.len > 0:
                        mut di_ka = di_ty.args.get(0).read()
                        if _is_int_type(di_ka.name) or di_ka.name == "int" or di_ka.name == "i64" or di_ka.name == "i32" or di_ka.name == "usize":
                            di_idict = true
                    mut di_v0 = _safe_c_varname(vars.get(0))
                    mut di_v1 = "_di_ign"
                    if vars.len > 1: di_v1 = _safe_c_varname(vars.get(1))
                    self.decl_vars.insert(vars.get(0), true)
                    if vars.len > 1: self.decl_vars.insert(vars.get(1), true)
                    if di_idict:
                        mut di_val_c = "void*"
                        if di_ty.args.len > 1: di_val_c = self.type_to_c(di_ty.args.get(1).read())
                        self.w(pad + "{ TrIDict* " + tmp + "_d = " + di_s + ";\n")
                        self.w(pad + "  for (size_t " + tmp + "_bi = 0; " + tmp + "_bi < " + tmp + "_d->cap; " + tmp + "_bi++) {\n")
                        self.w(pad + "    _TrIDictNode* " + tmp + "_nd = " + tmp + "_d->buckets[" + tmp + "_bi];\n")
                        self.w(pad + "    while (" + tmp + "_nd) {\n")
                        self.w(pad + "      long long " + di_v0 + " = " + tmp + "_nd->key;\n")
                        if di_val_c == "void*" or di_val_c == "void":
                            self.w(pad + "      void* " + di_v1 + " = " + tmp + "_nd->value;\n")
                        else:
                            self.w(pad + "      " + di_val_c + " " + di_v1 + " = (" + di_val_c + ")(uintptr_t)" + tmp + "_nd->value;\n")
                        self.gen_block(body, indent + 3)
                        self.w(pad + "      " + tmp + "_nd = " + tmp + "_nd->next;\n")
                        self.w(pad + "    }\n")
                        self.w(pad + "  }\n")
                        self.w(pad + "}\n")
                    else:
                        mut di_val_c = "void*"
                        if di_ty.args.len > 1: di_val_c = self.type_to_c(di_ty.args.get(1).read())
                        self.w(pad + "{ TrMap* " + tmp + "_d = " + di_s + ";\n")
                        self.w(pad + "  for (size_t " + tmp + "_bi = 0; " + tmp + "_bi < " + tmp + "_d->cap; " + tmp + "_bi++) {\n")
                        self.w(pad + "    _DictNode* " + tmp + "_nd = " + tmp + "_d->buckets[" + tmp + "_bi];\n")
                        self.w(pad + "    while (" + tmp + "_nd) {\n")
                        self.w(pad + "      char* " + di_v0 + " = " + tmp + "_nd->key;\n")
                        if di_val_c == "void*" or di_val_c == "void":
                            self.w(pad + "      void* " + di_v1 + " = " + tmp + "_nd->value;\n")
                        else:
                            self.w(pad + "      " + di_val_c + " " + di_v1 + " = (" + di_val_c + ")(uintptr_t)" + tmp + "_nd->value;\n")
                        self.gen_block(body, indent + 3)
                        self.w(pad + "      " + tmp + "_nd = " + tmp + "_nd->next;\n")
                        self.w(pad + "    }\n")
                        self.w(pad + "  }\n")
                        self.w(pad + "}\n")
                    return
            case _: pass

        # -- Generic fallback: List_ptr* of TrTuple* --------------------------
        mut fu_iter_s = self.gen_expr(iter)
        self.w(pad + "{ __auto_type " + tmp + "_col = " + fu_iter_s + ";\n")
        self.w(pad + "  for (long long " + tmp + "_i = 0; " + tmp + "_i < (long long)" + tmp + "_col->len; " + tmp + "_i++) {\n")
        self.w(pad + "    TrTuple* " + tmp + "_pair = (TrTuple*)" + tmp + "_col->data[" + tmp + "_i];\n")
        mut fu_pi = 0
        while fu_pi < vars.len:
            mut fu_vn = _safe_c_varname(vars.get(fu_pi))
            self.decl_vars.insert(vars.get(fu_pi), true)
            self.w(pad + "    long long " + fu_vn + " = " + tmp + "_pair->data[" + fu_pi.to_str() + "];\n")
            fu_pi = fu_pi + 1
        self.gen_block(body, indent + 2)
        self.w(pad + "  }\n")
        self.w(pad + "}\n")

    pub def gen_try(self, try_body: HirBlock, catches: Vec[Pointer[HirCatchClause]], finally_b: HirBlock, indent: int):
        pad = _indent_str(indent)
        mut jb = self.next_temp()
        mut em = self.next_temp()
        self.w(pad + "{\n")
        self.w(pad + "    jmp_buf " + jb + "; char* " + em + " = NULL;\n")
        self.w(pad + "    _tr_exc_push(&" + jb + ", &" + em + ");\n")
        self.w(pad + "    if (setjmp(" + jb + ") == 0) {\n")
        self.gen_block(try_body, indent + 2)
        self.w(pad + "        _tr_exc_pop();\n")
        if catches.len > 0:
            self.w(pad + "    } else {\n")
            # Note: _tr_exc_raise already decremented sp before longjmp.
            # Do NOT call _tr_exc_pop() here - that would remove the outer handler frame.
            mut i = 0
            while i < catches.len:
                mut cc = catches.get(i).read()
                if cc.err_name != "":
                    self.w(pad + "        char* " + cc.err_name + " = " + em + ";\n")
                    self.w(pad + "        (void)" + cc.err_name + ";\n")
                self.gen_block(cc.body, indent + 2)
                i = i + 1
        else:
            self.w(pad + "    } else {\n")
            self.w(pad + "        /* exception not caught */\n")
        self.w(pad + "    }\n")
        if finally_b as usize != 0 as usize and finally_b.stmts.len > 0:
            self.w(pad + "    /* finally */\n")
            self.gen_block(finally_b, indent + 1)
        self.w(pad + "}\n")

    pub def gen_chan_select(self, arms: Vec[Pointer[HirChanSelectArm]], indent: int):
        # chan_select generates a polling loop.
        # Active cases (recv/send) are tried in random order each pass.
        # default fires only if NO active case succeeded in a pass (non-blocking).
        # timeout fires only if NO active case succeeded AND deadline passed (soft deadline).
        pad = _indent_str(indent)
        mut tmp = self.next_temp()
        mut n = arms.len
        mut has_default = false
        mut has_timeout = false
        mut timeout_ms_s = "5000LL"
        mut default_idx = -1
        mut timeout_idx = -1
        mut active_n = 0
        mut ai = 0
        while ai < n:
            if not _is_invalid_ptr(arms.get(ai) as usize):
                mut ak = arms.get(ai).read()
                if ak.kind == 3:
                    has_default = true
                    default_idx = ai
                elif ak.kind == 2:
                    has_timeout = true
                    timeout_idx = ai
                    if not _is_invalid_ptr(ak.timeout_ms as usize):
                        timeout_ms_s = self.gen_expr(ak.timeout_ms)
                else:
                    active_n = active_n + 1
            ai = ai + 1
        if active_n == 0: active_n = 1
        self.w(pad + "{ /* chan_select */\n")
        if has_timeout:
            self.w(pad + "  long long _cst_dl_" + tmp + " = _tr_monotonic_ms() + (long long)(" + timeout_ms_s + ");\n")
        self.w(pad + "  int _cst_start_" + tmp + " = (int)(rand() % " + str(active_n) + ");\n")
        self.w(pad + "  int _cst_done_" + tmp + " = 0;\n")
        self.w(pad + "  while (!_cst_done_" + tmp + ") {\n")
        # Build list of active-only indices for random rotation
        self.w(pad + "    int _cst_active_" + tmp + "[" + str(n) + "]; int _cst_na_" + tmp + " = 0;\n")
        mut idx2 = 0
        while idx2 < n:
            if not _is_invalid_ptr(arms.get(idx2) as usize):
                mut ak2 = arms.get(idx2).read()
                if ak2.kind != 2 and ak2.kind != 3:
                    self.w(pad + "    _cst_active_" + tmp + "[_cst_na_" + tmp + "++] = " + str(idx2) + ";\n")
            idx2 = idx2 + 1
        # Try active cases in random order
        self.w(pad + "    for (int _csi_" + tmp + " = 0; _csi_" + tmp + " < _cst_na_" + tmp + " && !_cst_done_" + tmp + "; _csi_" + tmp + "++) {\n")
        self.w(pad + "      int _csc_" + tmp + " = _cst_active_" + tmp + "[(_csi_" + tmp + " + _cst_start_" + tmp + ") % (_cst_na_" + tmp + " > 0 ? _cst_na_" + tmp + " : 1)];\n")
        self.w(pad + "      switch (_csc_" + tmp + ") {\n")
        mut bi = 0
        while bi < n:
            if not _is_invalid_ptr(arms.get(bi) as usize):
                mut arm = arms.get(bi).read()
                if arm.kind != 2 and arm.kind != 3:
                    self.w(pad + "        case " + str(bi) + ": {\n")
                    if arm.kind == 0:
                        # recv arm - extract channel from ch.recv() if needed
                        mut chan_s = ""
                        if not _is_invalid_ptr(arm.chan_expr as usize):
                            match arm.chan_expr.read():
                                case HirExpr.EMethodCall(rc_obj, rc_meth, _, _):
                                    if rc_meth == "recv" or rc_meth == "receive":
                                        chan_s = self.gen_expr(rc_obj)
                                    else:
                                        chan_s = self.gen_expr(arm.chan_expr)
                                case _:
                                    chan_s = self.gen_expr(arm.chan_expr)
                        self.w(pad + "          long long _crv_" + tmp + "_" + str(bi) + " = _tr_chan_try_recv_val(" + chan_s + ");\n")
                        self.w(pad + "          if (_crv_" + tmp + "_" + str(bi) + " != LLONG_MIN) {\n")
                        if arm.var_name != "":
                            self.w(pad + "            long long " + _safe_c_varname(arm.var_name) + " = _crv_" + tmp + "_" + str(bi) + ";\n")
                        self.gen_block(arm.body, indent + 3)
                        self.w(pad + "            _cst_done_" + tmp + " = 1;\n")
                        self.w(pad + "          }\n")
                    elif arm.kind == 1:
                        # send arm - extract chan/val from ch.send(val) if needed
                        mut send_chan_s = ""
                        mut send_val_s = "0LL"
                        if not _is_invalid_ptr(arm.chan_expr as usize):
                            match arm.chan_expr.read():
                                case HirExpr.EMethodCall(sc_obj, sc_meth, sc_args, _):
                                    send_chan_s = self.gen_expr(sc_obj)
                                    if sc_args.len > 0: send_val_s = self.gen_expr(sc_args.get(0))
                                case _:
                                    send_chan_s = self.gen_expr(arm.chan_expr)
                        if not _is_invalid_ptr(arm.val_expr as usize): send_val_s = self.gen_expr(arm.val_expr)
                        if send_chan_s != "":
                            self.w(pad + "          if (_tr_chan_try_send(" + send_chan_s + ", " + send_val_s + ")) {\n")
                            self.gen_block(arm.body, indent + 3)
                            self.w(pad + "            _cst_done_" + tmp + " = 1;\n")
                            self.w(pad + "          }\n")
                    self.w(pad + "          break;\n")
                    self.w(pad + "        }\n")
            bi = bi + 1
        self.w(pad + "        default: break;\n")
        self.w(pad + "      }\n")  # switch
        self.w(pad + "    }\n")    # for active
        # After trying all active cases - check fallback cases
        self.w(pad + "    if (!_cst_done_" + tmp + ") {\n")
        if has_timeout:
            mut to_arm = arms.get(timeout_idx).read()
            self.w(pad + "      if (_tr_monotonic_ms() >= _cst_dl_" + tmp + ") {\n")
            self.gen_block(to_arm.body, indent + 3)
            self.w(pad + "        _cst_done_" + tmp + " = 1;\n")
            self.w(pad + "      } else ")
        else:
            self.w(pad + "      ")
        if has_default:
            mut def_arm = arms.get(default_idx).read()
            if has_timeout:
                self.w("{\n")
            else:
                self.w("{\n")
            self.gen_block(def_arm.body, indent + 3)
            self.w(pad + "        _cst_done_" + tmp + " = 1;\n")
            self.w(pad + "      }\n")
        elif not has_timeout:
            self.w("{ _tr_thread_sleep_ms(0); }\n")
        else:
            self.w("{ _tr_thread_sleep_ms(0); }\n")
        self.w(pad + "    }\n")
        self.w(pad + "  }\n")  # while
        self.w(pad + "} /* end chan_select */\n")

    pub def gen_block(self, b: HirBlock, indent: int):
        if _is_invalid_ptr(b as usize): return
        if _is_invalid_ptr(b.stmts as usize): return
        mut i = 0
        while i < b.stmts.len:
            self.gen_stmt(b.stmts.get(i), indent)
            i = i + 1

    pub def gen_match(self, expr: Pointer[HirExpr], arms: Vec[HirMatchArm], indent: int):
        pad = _indent_str(indent)
        mut subj = self.next_temp()
        self.w(pad + "__auto_type " + subj + " = " + self.gen_expr(expr) + ";\n")

        # If any arm has a guard, use sequential do{...}while(0) with break so
        # that a failing guard falls through to the next arm instead of exiting
        # the whole if/else-if chain.
        mut has_any_guard = false
        mut gk = 0
        while gk < arms.len:
            if arms.get(gk).guard as usize != 0 as usize: has_any_guard = true
            gk = gk + 1

        if has_any_guard:
            # Sequential do{...}while(0): each arm is an independent if block.
            # When a guard fails we fall through to the next arm naturally.
            self.w(pad + "do {\n")
            mut gi = 0
            while gi < arms.len:
                mut garm = arms.get(gi)
                # Compute cond + bindings for this arm (same logic as below).
                mut gcond = "1 /* wildcard */"
                mut gbindings = ""
                match garm.pat:
                    case Pattern.PLitInt(v):   gcond = subj + " == " + v.to_str() + "LL"
                    case Pattern.PLitBool(v):
                        if v:
                            gcond = subj
                        else:
                            gcond = "!" + subj
                    case Pattern.PLitStr(v):   gcond = "_tr_str_eq(" + subj + ", \"" + _escape_str_for_c(v) + "\")"
                    case Pattern.PVariant(tn, vn):
                        mut gpv = vn
                        if tn == "Option" and (vn == "" or vn == "none"): gpv = "None"
                        gcond = subj + ".tag == " + tn + "_" + gpv
                    case Pattern.PVariantBind(tn, vn, field):
                        gcond = subj + ".tag == " + tn + "_" + vn
                        mut gaf = field
                        if tn == "Option" and vn == "Some": gaf = "val"
                        if tn == "Result" and vn == "Ok": gaf = "val"
                        if tn == "Result" and vn == "Err": gaf = "err"
                        if self.enums.contains(tn):
                            mut _gev = self.enums.get(tn)
                            mut _gvi = 0
                            while _gvi < _gev.variants.len:
                                mut _gv = _gev.variants.get(_gvi)
                                if _gv.name == vn and _gv.fields.len > 0: gaf = _gv.fields.get(0).name
                                _gvi = _gvi + 1
                        self.decl_vars.insert(field, true)
                        gbindings = "__auto_type " + _safe_c_varname(field) + " = " + subj + ".data." + vn + "." + gaf + ";\n"
                    case Pattern.PVariantBindMany(tn, vn, fields):
                        gcond = subj + ".tag == " + tn + "_" + vn
                        mut _gbi = 0
                        while _gbi < fields.len:
                            mut _gbf = fields.get(_gbi)
                            if _gbf != "_":
                                mut _gact = _gbf
                                if self.enums.contains(tn):
                                    mut _gev2 = self.enums.get(tn)
                                    mut _gvi2 = 0
                                    while _gvi2 < _gev2.variants.len:
                                        mut _gv2 = _gev2.variants.get(_gvi2)
                                        if _gv2.name == vn and _gbi < _gv2.fields.len: _gact = _gv2.fields.get(_gbi).name
                                        _gvi2 = _gvi2 + 1
                                self.decl_vars.insert(_gbf, true)
                                gbindings = gbindings + "__auto_type " + _safe_c_varname(_gbf) + " = " + subj + ".data." + vn + "." + _gact + ";\n"
                            _gbi = _gbi + 1
                    case Pattern.PBind(gn):
                        gcond = "1"
                        self.decl_vars.insert(gn, true)
                        gbindings = "__auto_type " + _safe_c_varname(gn) + " = " + subj + ";\n"
                    case Pattern.PWild: gcond = "1"
                    case _: gcond = "1"
                self.w(pad + "  if (" + gcond + ") {\n")
                if gbindings != "": self.w(pad + "    " + gbindings)
                if garm.guard as usize != 0 as usize:
                    self.w(pad + "    if (" + self.gen_expr(garm.guard) + ") {\n")
                    self.gen_block(garm.body, indent + 3)
                    self.w(pad + "      break;\n")
                    self.w(pad + "    }\n")
                else:
                    self.gen_block(garm.body, indent + 2)
                    self.w(pad + "    break;\n")
                self.w(pad + "  }\n")
                gi = gi + 1
            self.w(pad + "} while(0);\n")
            return

        mut i = 0
        while i < arms.len:
            mut arm = arms.get(i)
            mut cond = "1 /* wildcard */"
            mut bindings = ""

            match arm.pat:
                case Pattern.PLitInt(v): cond = subj + " == " + v.to_str() + "LL"
                case Pattern.PLitBool(v):
                    if v: cond = subj
                    else: cond = "!" + subj
                case Pattern.PLitStr(v): cond = "_tr_str_eq(" + subj + ", \"" + _escape_str_for_c(v) + "\")"
                case Pattern.PVariant(tn, vn):
                    mut pv_vn = vn
                    if tn == "Option" and (vn == "" or vn == "none"): pv_vn = "None"
                    cond = subj + ".tag == " + tn + "_" + pv_vn
                case Pattern.PVariantBind(tn, vn, field):
                    cond = subj + ".tag == " + tn + "_" + vn
                    mut actual_fld = field
                    # Built-in Option/Result: use known field names
                    if tn == "Option" and vn == "Some": actual_fld = "val"
                    if tn == "Result" and vn == "Ok": actual_fld = "val"
                    if tn == "Result" and vn == "Err": actual_fld = "err"
                    if self.enums.contains(tn):
                        mut _ev_def = self.enums.get(tn)
                        mut _vi = 0
                        while _vi < _ev_def.variants.len:
                            mut _ev = _ev_def.variants.get(_vi)
                            if _ev.name == vn and _ev.fields.len > 0:
                                actual_fld = _ev.fields.get(0).name
                            _vi = _vi + 1
                    self.decl_vars.insert(field, true)
                    bindings = "__auto_type " + _safe_c_varname(field) + " = " + subj + ".data." + vn + "." + actual_fld + ";\n"
                case Pattern.PVariantBindMany(tn, vn, fields):
                    cond = subj + ".tag == " + tn + "_" + vn
                    mut _bi = 0
                    while _bi < fields.len:
                        mut _bf = fields.get(_bi)
                        if _bf != "_":
                            mut _actual = _bf
                            if self.enums.contains(tn):
                                mut _ev_def2 = self.enums.get(tn)
                                mut _vi2 = 0
                                while _vi2 < _ev_def2.variants.len:
                                    mut _ev2 = _ev_def2.variants.get(_vi2)
                                    if _ev2.name == vn and _bi < _ev2.fields.len:
                                        _actual = _ev2.fields.get(_bi).name
                                    _vi2 = _vi2 + 1
                            self.decl_vars.insert(_bf, true)
                            bindings = bindings + "__auto_type " + _safe_c_varname(_bf) + " = " + subj + ".data." + vn + "." + _actual + ";\n"
                        _bi = _bi + 1
                case Pattern.PBind(n):
                    cond = "1"
                    self.decl_vars.insert(n, true)
                    bindings = "__auto_type " + _safe_c_varname(n) + " = " + subj + ";\n"
                case Pattern.PWild: cond = "1"
                case Pattern.POr(pats):
                    mut or_conds = ""
                    mut oi = 0
                    while oi < pats.len:
                        mut pp = pats.get(oi)
                        mut pc = "1"
                        match pp:
                            case Pattern.PVariant(tn, vn):
                                mut or_vn = vn
                                if tn == "Option" and (vn == "" or vn == "none"): or_vn = "None"
                                pc = subj + ".tag == " + tn + "_" + or_vn
                            case Pattern.PLitInt(vi): pc = subj + " == " + vi.to_str() + "LL"
                            case Pattern.PLitStr(vs): pc = "_tr_str_eq(" + subj + ", \"" + _escape_str_for_c(vs) + "\")"
                            case Pattern.PLitBool(bv):
                                if bv: pc = subj
                                else: pc = "!" + subj
                            case Pattern.PBind(bn):
                                pc = "1"
                                self.decl_vars.insert(bn, true)
                                bindings = bindings + "__auto_type " + _safe_c_varname(bn) + " = " + subj + ";\n"
                            case _: pc = "1"
                        if oi == 0: or_conds = pc
                        else: or_conds = or_conds + " || " + pc
                        oi = oi + 1
                    cond = "(" + or_conds + ")"
                case _: cond = "1"

            # No-guard path: standard if/else-if chain (guards handled above via do-while)
            if i == 0: self.w(pad + "if (" + cond + ") {\n")
            else: self.w(pad + "} else if (" + cond + ") {\n")
            if bindings != "":
                self.w(pad + "    " + bindings)
            self.gen_block(arm.body, indent + 1)
            i = i + 1

        if arms.len > 0: self.w(pad + "}\n")

    # -- Program generation ----------------------------------------------------

    pub def register_program(self, prog: HirProgram):
        # Register type aliases so type_to_c can resolve them.
        if not _is_invalid_ptr(prog.type_alias_names as usize):
            mut tai = 0
            while tai < prog.type_alias_names.len:
                mut ta_name = prog.type_alias_names.get(tai)
                mut ta_ty_p = prog.type_alias_types.get(tai)
                if ta_ty_p as usize != 0 as usize:
                    self.type_alias_map.insert(ta_name, self.type_to_c(ta_ty_p.read()))
                tai = tai + 1
        mut i = 0
        while i < prog.classes.len:
            self.classes.insert(prog.classes.get(i).name, prog.classes.get(i))
            if not prog.classes.get(i).is_class:
                self.value_types.insert(prog.classes.get(i).name, true)
            i = i + 1
        i = 0
        while i < prog.enums.len:
            self.enums.insert(prog.enums.get(i).name, prog.enums.get(i))
            i = i + 1
        i = 0
        while i < prog.interfaces.len:
            self.interfaces.insert(prog.interfaces.get(i).name, prog.interfaces.get(i))
            i = i + 1
        i = 0
        while i < prog.functions.len:
            mut pf = prog.functions.get(i)
            # The bare-name function map is for free functions. A class/enum
            # method (class_name != "") must not clobber a free function of the
            # same name (e.g. Vec.copy vs the generic free copy[T]) -- that would
            # strip the free function's .generics and leak bare T into the C.
            # Free functions always win; a method only registers when the name
            # is otherwise free.
            if pf.class_name == "" or not self.functions.contains(pf.name):
                self.functions.insert(pf.name, pf)
            i = i + 1
        i = 0
        while i < prog.decorator_defs.len:
            mut _dd = prog.decorator_defs.get(i)
            self.decorator_defs.insert(_dd.name, _dd)
            i = i + 1

        # -- Detect overloaded methods (same name, different param count) -----
        # Scan each class/enum for duplicate method names; mark them in overloaded_sigs
        # so gen_func_sig and gen_method_call can emit mangled C names.
        i = 0
        while i < prog.classes.len:
            mut ov_cls = prog.classes.get(i)
            if ov_cls.generics.len == 0:
                mut mi = 0
                while mi < ov_cls.methods.len:
                    mut m1 = ov_cls.methods.get(mi)
                    mut mj = mi + 1
                    while mj < ov_cls.methods.len:
                        if ov_cls.methods.get(mj).name == m1.name:
                            self.overloaded_sigs.insert(ov_cls.name + "_" + m1.name, true)
                            break
                        mj = mj + 1
                    mi = mi + 1
            i = i + 1
        i = 0
        while i < prog.enums.len:
            mut ov_enm = prog.enums.get(i)
            mut mi = 0
            while mi < ov_enm.methods.len:
                mut m1 = ov_enm.methods.get(mi)
                mut mj = mi + 1
                while mj < ov_enm.methods.len:
                    if ov_enm.methods.get(mj).name == m1.name:
                        self.overloaded_sigs.insert(ov_enm.name + "_" + m1.name, true)
                        break
                    mj = mj + 1
                mi = mi + 1
            i = i + 1

    # -- Generic type pre-scan (collect all instantiations before codegen) ----

    pub def scan_mono_ty(self, ty: AstType):
        if ty as usize == 0 as usize: return
        if ty.name == "": return
        mut i = 0
        while i < ty.args.len:
            self.scan_mono_ty(ty.args.get(i).read())
            i = i + 1
        if ty.args.len > 0 and self.classes.contains(ty.name) and ty.name != "Vec" and ty.name != "Map" and ty.name != "Dict" and ty.name != "List":
            mut ucls = self.classes.get(ty.name)
            if ucls.generics.len > 0:
                self.ensure_mono(ucls, ty.args)

    pub def scan_mono_block(self, block: HirBlock):
        if _is_invalid_ptr(block as usize): return
        if _is_invalid_ptr(block.stmts as usize): return
        mut i = 0
        while i < block.stmts.len:
            self.scan_mono_stmt(block.stmts.get(i))
            i = i + 1

    # Scan expression tree for __MONO_-mangled generic function calls.
    pub def scan_mono_expr(self, e: Pointer[HirExpr]):
        if e as usize == 0 as usize: return
        if _is_invalid_ptr(e as usize): return
        match e.read():
            case HirExpr.ECall(callee, args, _):
                self.scan_mono_expr(callee)
                mut ei = 0
                while ei < args.len:
                    self.scan_mono_expr(args.get(ei))
                    ei = ei + 1
                match callee.read():
                    case HirExpr.EIdent(mn, _, _):
                        if mn.contains("__MONO_"):
                            mut nlen = _tr_strlen(mn)
                            mut si2 = 0
                            mut found_s = false
                            mut sep_p = 0
                            while si2 <= nlen - 7 and not found_s:
                                if _tr_str_slice(mn, si2, si2 + 7) == "__MONO_":
                                    found_s = true
                                    sep_p = si2
                                si2 = si2 + 1
                            if found_s:
                                mut gfunc_n = _tr_str_slice(mn, 0, sep_p)
                                mut gfunc_t = _tr_str_slice(mn, sep_p + 7, nlen)
                                if self.functions.contains(gfunc_n):
                                    self.ensure_mono_func(gfunc_n, gfunc_t)
                    case _: pass
            case HirExpr.EMethodCall(obj, _, margs, _):
                self.scan_mono_expr(obj)
                mut ei2 = 0
                while ei2 < margs.len:
                    self.scan_mono_expr(margs.get(ei2))
                    ei2 = ei2 + 1
            case HirExpr.EBinOp(_, bl, br, _):
                self.scan_mono_expr(bl)
                self.scan_mono_expr(br)
            case HirExpr.EUnaryOp(_, ue, _):
                self.scan_mono_expr(ue)
            case _: pass

    pub def scan_mono_stmt(self, s_ptr: Pointer[HirStmt]):
        if _is_invalid_ptr(s_ptr as usize): return
        match s_ptr.read():
            case HirStmt.SLet(_, _, _, _, _, ty, val):
                self.scan_mono_ty(ty)
                if val as usize != 0 as usize: self.scan_mono_expr(val)
            case HirStmt.SExpr(expr):
                if expr as usize != 0 as usize: self.scan_mono_expr(expr)
            case HirStmt.SReturn(val):
                if val as usize != 0 as usize: self.scan_mono_expr(val)
            case HirStmt.SIf(cond_s, then_b, else_b):
                if cond_s as usize != 0 as usize: self.scan_mono_expr(cond_s)
                self.scan_mono_block(then_b)
                if else_b as usize != 0 as usize:
                    self.scan_mono_block(else_b)
            case HirStmt.SWhile(cond_s2, body):
                if cond_s2 as usize != 0 as usize: self.scan_mono_expr(cond_s2)
                self.scan_mono_block(body)
            case HirStmt.SFor(_, _, body):
                self.scan_mono_block(body)
            case HirStmt.SForUnpack(_, _, body):
                self.scan_mono_block(body)
            case HirStmt.SMatch(subj_s, arms):
                if subj_s as usize != 0 as usize: self.scan_mono_expr(subj_s)
                mut ai = 0
                while ai < arms.len:
                    self.scan_mono_block(arms.get(ai).body)
                    ai = ai + 1
            case HirStmt.STry(try_body, catches, finally_b):
                self.scan_mono_block(try_body)
                if finally_b as usize != 0 as usize:
                    self.scan_mono_block(finally_b)
            case HirStmt.SUnsafe(body):
                self.scan_mono_block(body)
            case HirStmt.STaskGroup(body):
                self.scan_mono_block(body)
            case _: pass

    pub def scan_mono_func(self, f: HirFunction):
        self.scan_mono_ty(f.ret_ty)
        mut i = 0
        while i < f.params.len:
            self.scan_mono_ty(f.params.get(i).ty)
            i = i + 1
        self.scan_mono_block(f.body)

    pub def scan_mono_prog(self, prog: HirProgram):
        # Scan field and method types in concrete (non-generic) classes only.
        # Generic classes use unresolved type params (T, V, ...) in their signatures;
        # scanning them here would call ensure_mono with non-concrete args.
        mut i = 0
        while i < prog.classes.len:
            mut cls = prog.classes.get(i)
            if cls.generics.len == 0:
                mut fi = 0
                while fi < cls.fields.len:
                    self.scan_mono_ty(cls.fields.get(fi).ty)
                    fi = fi + 1
                mut mi = 0
                while mi < cls.methods.len:
                    self.scan_mono_func(cls.methods.get(mi))
                    mi = mi + 1
            i = i + 1
        # Scan free-standing functions (skip methods of generic classes -
        # their signatures contain unresolved type params like T/V).
        i = 0
        while i < prog.functions.len:
            mut fn = prog.functions.get(i)
            mut skip = false
            if fn.class_name != "":
                if self.classes.contains(fn.class_name):
                    mut owner = self.classes.get(fn.class_name)
                    if owner.generics.len > 0: skip = true
            if fn.generics.len > 0: skip = true
            if not skip: self.scan_mono_func(fn)
            i = i + 1
        # Scan top-level stmts
        i = 0
        while i < prog.top_level_stmts.len:
            self.scan_mono_stmt(prog.top_level_stmts.get(i))
            i = i + 1

    pub def generate(self, prog: HirProgram) -> str:
        self.register_program(prog)

        # -- Phase 1: Runtime header include + file-wide optimization pragmas ----
        self.w("#define _TR_MAIN\n")
        self.w("#include \"tauraro_rt.h\"\n")

        # -- Phase 2: Forward declarations (opaque struct pointers) ------------
        # Skip generic classes - their mono versions are handled in Phase 2.75
        mut i = 0
        while i < prog.classes.len:
            mut cls2 = prog.classes.get(i)
            if cls2.generics.len == 0:
                self.w("typedef struct " + cls2.name + " " + cls2.name + ";\n")
            i = i + 1
        i = 0
        while i < prog.enums.len:
            self.w("typedef struct " + prog.enums.get(i).name + " " + prog.enums.get(i).name + ";\n")
            i = i + 1
        i = 0
        while i < prog.interfaces.len:
            mut iface_fwd = prog.interfaces.get(i)
            if iface_fwd.generics.len == 0:
                self.w("typedef struct _" + iface_fwd.name + "_vtable " + iface_fwd.name + "_vtable;\n")
            i = i + 1
        # Emit forward declarations for value-type List_T structs used in fields
        self.emit_list_fwd_decls(prog)
        self.w("\n")

        # -- Phase 2.5: Extern C function declarations -------------------------
        i = 0
        while i < prog.extern_funcs.len:
            mut ef = prog.extern_funcs.get(i)
            mut ef_ret = self.type_to_c(ef.ret_ty)
            mut ef_name = ef.name
            if not _starts_with_tr(ef_name):
                self.w("extern " + ef_ret + " " + ef_name + "(")
                mut ef_first = true
                mut epi = 0
                while epi < ef.params.len:
                    mut ep = ef.params.get(epi)
                    if ep.name != "self":
                        if not ef_first: self.w(", ")
                        self.w(self.type_to_c(ep.ty) + " " + ep.name)
                        ef_first = false
                    epi = epi + 1
                if ef.is_variadic:
                    if not ef_first: self.w(", ")
                    self.w("...")
                self.w(");\n")
            i = i + 1
        if prog.extern_funcs.len > 0: self.w("\n")

        # -- Phase 2.75: Generic monomorphization ------------------------------
        # Pre-scan all HIR types to collect and generate monomorphized classes.
        # mono_buf accumulates: fwd decl + struct body + prototypes + impls.
        self.scan_mono_prog(prog)
        mut mono_out = self.mono_buf.to_string().as_str()
        if mono_out != "":
            self.w(mono_out)
            self.w("\n")

        # -- Phase 3: Struct definitions ---------------------------------------
        i = 0
        while i < prog.enums.len:
            self.gen_enum_struct(prog.enums.get(i))
            i = i + 1
        i = 0
        while i < prog.classes.len:
            mut cls3 = prog.classes.get(i)
            if cls3.generics.len == 0:
                self.gen_class_struct(cls3)
            i = i + 1
        i = 0
        while i < prog.interfaces.len:
            self.gen_interface_vtable(prog.interfaces.get(i))
            i = i + 1

        # Flush struct buffer into main output
        self.w(self.struct_buf.to_string().as_str())
        self.struct_buf = StringBuilder.init(16)

        # -- Phase 3.5: Value-type list definitions (after all enums/structs defined) --
        mut lt_out = self.list_types_buf.to_string().as_str()
        if lt_out != "": self.w(lt_out)

        # -- Phase 4: Function prototypes --------------------------------------
        i = 0
        while i < prog.classes.len:
            mut c = prog.classes.get(i)
            if c.generics.len == 0:
                mut mi = 0
                while mi < c.methods.len:
                    mut m = c.methods.get(mi)
                    self.w(self.get_inline_attrs(m) + self.gen_func_sig(m, c.name) + ";\n")
                    mi = mi + 1
            i = i + 1
        i = 0
        while i < prog.enums.len:
            mut e = prog.enums.get(i)
            mut mi = 0
            while mi < e.methods.len:
                mut m = e.methods.get(mi)
                self.w(self.get_inline_attrs(m) + self.gen_func_sig(m, e.name) + ";\n")
                mi = mi + 1
            i = i + 1
        i = 0
        while i < prog.functions.len:
            mut f = prog.functions.get(i)
            if f.name != "main" and not f.is_extern:
                mut skip4 = false
                if f.class_name != "":
                    skip4 = true   # class/enum methods handled in per-class loops or mono_buf
                if not skip4:
                    if not self.emitted_fns.contains("p_" + f.name):
                        self.emitted_fns.insert("p_" + f.name, true)
                        self.w(self.get_inline_attrs(f) + self.gen_func_sig(f, f.class_name) + ";\n")
            i = i + 1
        self.w("\n")

        # -- Phase 4.5: Spawn + async wrappers (static thread-entry functions) --
        self.prescan_spawns(prog)
        self.prescan_awaits(prog)
        self.w("\n")

        # -- Phase 5: Method implementations -----------------------------------
        i = 0
        while i < prog.classes.len:
            mut c = prog.classes.get(i)
            if c.generics.len == 0:
                mut mi = 0
                while mi < c.methods.len:
                    mut m = c.methods.get(mi)
                    self.cur_class = c.name
                    self.cur_func  = m.name
                    self.cur_throws_ty = m.throws_ty.name
                    self.decl_vars = Map[str, bool].init(64)
                    self.shared_vars = Map[str, str].init(8)
                    self.seed_params(m)
                    self.w(self.get_inline_attrs(m) + self.gen_func_sig(m, c.name) + " {\n")
                    self.gen_func_body(m.body, 1)
                    self.w("}\n\n")
                    self.cur_class = ""
                    self.cur_func  = ""
                    self.cur_throws_ty = ""
                    mi = mi + 1
            i = i + 1

        i = 0
        while i < prog.enums.len:
            mut e = prog.enums.get(i)
            mut mi = 0
            while mi < e.methods.len:
                mut m = e.methods.get(mi)
                self.cur_class = e.name
                self.cur_func  = m.name
                self.cur_throws_ty = m.throws_ty.name
                self.decl_vars = Map[str, bool].init(64)
                self.shared_vars = Map[str, str].init(8)
                self.seed_params(m)
                self.w(self.get_inline_attrs(m) + self.gen_func_sig(m, e.name) + " {\n")
                self.gen_func_body(m.body, 1)
                self.w("}\n\n")
                self.cur_class = ""
                self.cur_func  = ""
                self.cur_throws_ty = ""
                mi = mi + 1
            i = i + 1

        # -- Phase 6: Free-standing function implementations -------------------
        i = 0
        while i < prog.functions.len:
            mut f = prog.functions.get(i)
            if f.name != "main" and not f.is_extern:
                mut skip6 = false
                if f.class_name != "":
                    skip6 = true   # class/enum methods handled in per-class loops or mono_buf
                # Skip duplicate free-standing functions (same name from multiple modules)
                if not skip6:
                    if self.emitted_fns.contains("i_" + f.name):
                        skip6 = true
                    else:
                        self.emitted_fns.insert("i_" + f.name, true)
                if not skip6:
                    self.cur_func  = f.name
                    self.cur_class = f.class_name
                    self.cur_throws_ty = f.throws_ty.name
                    self.decl_vars = Map[str, bool].init(64)
                    self.shared_vars = Map[str, str].init(8)
                    self.seed_params(f)
                    self.w(self.get_inline_attrs(f) + self.gen_func_sig(f, f.class_name) + " {\n")
                    self.gen_func_body(f.body, 1)
                    self.w("}\n\n")
                    self.cur_func  = ""
                    self.cur_class = ""
                    self.cur_throws_ty = ""
            i = i + 1

        # -- Phase 7: C main entry point ---------------------------------------
        self.w("__attribute__((hot)) int main(int argc, char** argv) {\n")
        self.w("    _tr_argc = argc; _tr_argv = argv;\n")
        self.w("    _tr_init_console();\n")
        self.w("#ifndef TAURARO_BARE\n")
        self.w("    _tr_global_async_pool = _tr_threadpool_auto();\n")
        self.w("#endif\n")
        # Set up args list only when main() takes a parameter
        mut main_has_args = false
        mut main_args_name = "args"
        mut mi2 = 0
        while mi2 < prog.functions.len:
            mut mf = prog.functions.get(mi2)
            if mf.name == "main" and mf.params.len > 0:
                main_has_args = true
                main_args_name = mf.params.get(0).name
            mi2 = mi2 + 1
        if main_has_args:
            # Rename to avoid shadowing C's char** argv parameter
            if main_args_name == "argv": main_args_name = "_tr_main_argv"
            self.w("    List_str* " + main_args_name + " = List_str_new();\n")
            self.w("    for (int _ai = 0; _ai < argc; _ai++) { List_str_append(" + main_args_name + ", argv[_ai]); }\n")

        # Call top-level statements
        i = 0
        while i < prog.top_level_stmts.len:
            self.gen_stmt(prog.top_level_stmts.get(i), 1)
            i = i + 1

        # Call user's main function if it exists
        i = 0
        while i < prog.functions.len:
            mut f = prog.functions.get(i)
            if f.name == "main":
                self.cur_func  = "main"
                self.decl_vars = Map[str, bool].init(64)
                self.gen_func_body(f.body, 1)
                self.cur_func  = ""
            i = i + 1

        self.w("#ifndef TAURARO_BARE\n")
        self.w("    if (_tr_global_async_pool) { _tr_threadpool_free(_tr_global_async_pool); _tr_global_async_pool = NULL; }\n")
        self.w("#endif\n")
        self.w("    return 0;\n}\n")

        return self.buf.to_string().as_str()

    # -- Modular output helpers ----------------------------------------------------

    # Full types header: forward decls + struct/enum/interface bodies + ALL function
    # prototypes from every module.  Each module .c file does #include "tauraro_types.h"
    # so every cross-module call is visible to the C compiler without extra header files.
    pub def generate_types_header(self, prog: HirProgram) -> str:
        if _is_invalid_ptr(prog as usize): return ""
        if _is_invalid_ptr(prog.classes as usize): return ""
        if _is_invalid_ptr(prog.enums as usize): return ""
        if _is_invalid_ptr(prog.interfaces as usize): return ""
        if _is_invalid_ptr(prog.functions as usize): return ""

        if self.classes.len == 0:
            self.register_program(prog)
            self.scan_mono_prog(prog)

        # Temporarily redirect self.buf / struct_buf / list_types_buf so that the
        # helpers (emit_list_fwd_decls, gen_class_struct, etc.) write into our buffers.
        mut old_buf      = self.buf
        mut old_struct   = self.struct_buf
        mut old_list     = self.list_types_buf
        self.buf           = StringBuilder.init(4096)
        self.struct_buf    = StringBuilder.init(16384)
        self.list_types_buf = StringBuilder.init(2048)

        mut out = StringBuilder.init(65536)
        out.append("#pragma once\n")
        # Suppress rt.h helper fallbacks (StringBuilder, file I/O) when the std library
        # provides its own canonical implementations.  Detect by checking if "StringBuilder"
        # class or "read_file" / "write_file" functions appear in the compiled program.
        mut has_std_lib = false
        mut sbi = 0
        while sbi < prog.classes.len:
            mut sbc = prog.classes.get(sbi)
            if not _is_invalid_ptr(sbc as usize):
                if sbc.name == "StringBuilder":
                    has_std_lib = true
                    break
            sbi = sbi + 1
        if not has_std_lib:
            mut fi2 = 0
            while fi2 < prog.functions.len:
                mut fc = prog.functions.get(fi2)
                if not _is_invalid_ptr(fc as usize):
                    if fc.name == "read_file" or fc.name == "write_file":
                        has_std_lib = true
                        break
                fi2 = fi2 + 1
        if has_std_lib:
            out.append("#define TAURARO_STD_LIB\n")
            out.append("#define TAURARO_RT_NO_STRINGBUILDER\n")
        out.append("#include \"tauraro_rt.h\"\n\n")

        # -- Forward declarations ----------------------------------------------
        mut i = 0
        while i < prog.classes.len:
            mut c2 = prog.classes.get(i)
            if not _is_invalid_ptr(c2 as usize):
                if c2.generics.len == 0:
                    mut fwd_key = "fwd_" + c2.name
                    if not self.emitted_fns.contains(fwd_key):
                        self.emitted_fns.insert(fwd_key, true)
                        out.append("typedef struct " + c2.name + " " + c2.name + ";\n")
            i = i + 1
        i = 0
        while i < prog.enums.len:
            mut e2 = prog.enums.get(i)
            if not _is_invalid_ptr(e2 as usize):
                mut fwd_key2 = "fwd_" + e2.name
                if not self.emitted_fns.contains(fwd_key2):
                    self.emitted_fns.insert(fwd_key2, true)
                    out.append("typedef struct " + e2.name + " " + e2.name + ";\n")
            i = i + 1
        i = 0
        while i < prog.interfaces.len:
            mut iface2 = prog.interfaces.get(i)
            if not _is_invalid_ptr(iface2 as usize):
                if iface2.generics.len == 0:
                    out.append("typedef struct _" + iface2.name + "_vtable " + iface2.name + "_vtable;\n")
                    out.append("typedef struct { " + iface2.name + "_vtable* vtable; void* data; } " + iface2.name + "_obj;\n")
                    self.emitted_fns.insert("iface_obj_" + iface2.name, true)
            i = i + 1
        self.emit_list_fwd_decls(prog)          # writes to self.buf
        out.append(self.buf.to_string().as_str())
        self.buf = StringBuilder.init(256)
        out.append("\n")

        # -- Monomorphized generic types (must precede prototypes that use them) -
        mut mono_early = self.mono_buf.to_string().as_str()
        if mono_early != "": out.append(mono_early + "\n")

        # -- Extern C declarations ---------------------------------------------
        if not _is_invalid_ptr(prog.extern_funcs as usize):
            i = 0
            while i < prog.extern_funcs.len:
                mut ef = prog.extern_funcs.get(i)
                if not _is_invalid_ptr(ef as usize):
                    if not _starts_with_tr(ef.name):
                        mut ef_s = "extern " + self.type_to_c(ef.ret_ty) + " " + ef.name + "("
                        mut ef_first = true
                        mut epi = 0
                        while epi < ef.params.len:
                            mut ep = ef.params.get(epi)
                            if ep.name != "self":
                                if not ef_first: ef_s = ef_s + ", "
                                ef_s = ef_s + self.type_to_c(ep.ty) + " " + ep.name
                                ef_first = false
                            epi = epi + 1
                        if ef.is_variadic:
                            if not ef_first: ef_s = ef_s + ", "
                            ef_s = ef_s + "..."
                        out.append(ef_s + ");\n")
                i = i + 1
            if prog.extern_funcs.len > 0: out.append("\n")

        # -- User type aliases: `type Name = Target` -> `typedef Target Name;` -----
        if not _is_invalid_ptr(prog.type_alias_names as usize):
            mut tai = 0
            while tai < prog.type_alias_names.len:
                mut ta_name = prog.type_alias_names.get(tai)
                mut ta_ty_p = prog.type_alias_types.get(tai)
                if ta_ty_p as usize != 0 as usize:
                    mut ta_c = self.type_to_c(ta_ty_p.read())
                    out.append("typedef " + ta_c + " " + ta_name + ";\n")
                tai = tai + 1
            if prog.type_alias_names.len > 0: out.append("\n")

        # -- Struct / enum / interface definitions (BEFORE prototypes) ------------
        # Must come before function prototypes so that Vec[UserType] list structs
        # (e.g. List_JsonVal) are defined before any prototype uses them.
        i = 0
        while i < prog.enums.len:
            mut e3 = prog.enums.get(i)
            if not _is_invalid_ptr(e3 as usize):
                self.gen_enum_struct(e3)
            i = i + 1
        i = 0
        while i < prog.classes.len:
            mut c3 = prog.classes.get(i)
            if not _is_invalid_ptr(c3 as usize):
                if c3.generics.len == 0:
                    self.gen_class_struct(c3)
            i = i + 1
        i = 0
        while i < prog.interfaces.len:
            mut iface3 = prog.interfaces.get(i)
            if not _is_invalid_ptr(iface3 as usize):
                self.gen_interface_vtable(iface3)
            i = i + 1
        out.append(self.struct_buf.to_string().as_str())
        out.append(self.list_types_buf.to_string().as_str())
        out.append("\n")

        # -- Freestanding Function Prototypes (so generic monomorphization can call them) --
        i = 0
        while i < prog.functions.len:
            mut f4 = prog.functions.get(i)
            if not _is_invalid_ptr(f4 as usize):
                if f4.name != "main" and not f4.is_extern:
                    if f4.class_name != "":
                        # Extend-block methods: emit prototype with class prefix.
                        # Skip generic classes (Vec, Map, etc.) - monomorphized variants handle their own prototypes.
                        mut skip4_generic = false
                        if self.classes.contains(f4.class_name):
                            mut cls4g = self.classes.get(f4.class_name)
                            if cls4g.generics.len > 0:
                                skip4_generic = true
                        if not skip4_generic:
                            mut ep_key = "p_" + f4.class_name + "_" + f4.name
                            if not self.emitted_fns.contains(ep_key):
                                self.emitted_fns.insert(ep_key, true)
                                out.append(self.get_proto_attrs(f4) + self.gen_func_sig(f4, f4.class_name) + ";\n")
                    else:
                        if not self.emitted_fns.contains("p_" + f4.name):
                            self.emitted_fns.insert("p_" + f4.name, true)
                            out.append(self.get_proto_attrs(f4) + self.gen_func_sig(f4, f4.class_name) + ";\n")
            i = i + 1
        out.append("\n")

        # -- ALL function prototypes (cross-module visibility) -----------------
        i = 0
        while i < prog.classes.len:
            mut c4 = prog.classes.get(i)
            if not _is_invalid_ptr(c4 as usize):
                if c4.generics.len == 0:
                    mut mi = 0
                    if not _is_invalid_ptr(c4.methods as usize):
                        while mi < c4.methods.len:
                            mut m = c4.methods.get(mi)
                            if not _is_invalid_ptr(m as usize):
                                mut ep_key3 = "p_" + c4.name + "_" + m.name
                                if not self.emitted_fns.contains(ep_key3):
                                    self.emitted_fns.insert(ep_key3, true)
                                    out.append(self.get_proto_attrs(m) + self.gen_func_sig(m, c4.name) + ";\n")
                            mi = mi + 1
            i = i + 1
        i = 0
        while i < prog.enums.len:
            mut e4 = prog.enums.get(i)
            if not _is_invalid_ptr(e4 as usize):
                mut mi = 0
                if not _is_invalid_ptr(e4.methods as usize):
                    while mi < e4.methods.len:
                        mut m = e4.methods.get(mi)
                        if not _is_invalid_ptr(m as usize):
                            out.append(self.get_proto_attrs(m) + self.gen_func_sig(m, e4.name) + ";\n")
                        mi = mi + 1
            i = i + 1
        i = 0
        while i < prog.functions.len:
            mut f4 = prog.functions.get(i)
            if not _is_invalid_ptr(f4 as usize):
                if f4.name != "main" and not f4.is_extern:
                    if f4.class_name != "":
                        # Extend-block methods: emit prototype with class prefix.
                        # Skip generic classes (Vec, Map, etc.) - monomorphized variants handle their own prototypes.
                        mut skip4b_generic = false
                        if self.classes.contains(f4.class_name):
                            mut cls4bg = self.classes.get(f4.class_name)
                            if cls4bg.generics.len > 0:
                                skip4b_generic = true
                        if not skip4b_generic:
                            mut ep_key2 = "p_" + f4.class_name + "_" + f4.name
                            if not self.emitted_fns.contains(ep_key2):
                                self.emitted_fns.insert(ep_key2, true)
                                out.append(self.get_proto_attrs(f4) + self.gen_func_sig(f4, f4.class_name) + ";\n")
                    else:
                        if not self.emitted_fns.contains("p_" + f4.name):
                            self.emitted_fns.insert("p_" + f4.name, true)
                            out.append(self.get_proto_attrs(f4) + self.gen_func_sig(f4, f4.class_name) + ";\n")
            i = i + 1
        out.append("\n")

        # -- Spawn + async wrappers (after prototypes so wrappers can call declared fns) -
        self.buf = StringBuilder.init(1024)
        self.prescan_spawns(prog)
        self.prescan_awaits(prog)
        mut sw_out = self.buf.to_string().as_str()
        self.buf = StringBuilder.init(256)
        if sw_out != "":
            out.append(sw_out)
            out.append("\n")

        # -- Interface vtable wrap functions (static inline, after prototypes) -
        mut wi = 0
        while wi < prog.classes.len:
            mut wcls = prog.classes.get(wi)
            if not _is_invalid_ptr(wcls as usize):
                if wcls.generics.len == 0 and wcls.iface_names as usize != 0 as usize and not _is_invalid_ptr(wcls.iface_names as usize):
                    mut wii = 0
                    while wii < wcls.iface_names.len:
                        mut wiface_name = wcls.iface_names.get(wii)
                        if self.interfaces.contains(wiface_name):
                            mut wiface = self.interfaces.get(wiface_name)
                            if not _is_invalid_ptr(wiface as usize):
                                out.append(self.gen_one_iface_wrap(wcls.name, wiface))
                                out.append("\n")
                        wii = wii + 1
            wi = wi + 1

        # Restore all temporary buffers
        self.buf           = old_buf
        self.struct_buf    = old_struct
        self.list_types_buf = old_list

        return out.to_string().as_str()

    # Appended to tauraro_types.h: module-prefixed typedef aliases + Vec/Map struct defs +
    # core_alloc declarations, so include/core/*.c can use module-qualified names against
    # the self-hosted-generated header without modification.
    pub def generate_module_compat(self, all_decl_modules: Vec[str], all_decls: Vec[Pointer[Decl]]) -> str:
        mut out = "\n/* === Module-prefixed typedef aliases (auto-generated) === */\n"
        out = out + "/* Maps module-qualified C names to short-name types in tauraro_types.h */\n\n"

        out = out + "#ifndef TAURARO_RT_NO_STRINGBUILDER\n"
        out = out + "typedef struct core_string_StringObj core_string_StringObj;\n"
        out = out + "typedef core_string_StringObj StringObj;\n"
        out = out + "typedef struct core_string_StringBuilder core_string_StringBuilder;\n"
        out = out + "typedef core_string_StringBuilder StringBuilder;\n"
        out = out + "#endif\n\n"

        mut seen = Map[str, bool].init(128)
        mut i = 0
        while i < all_decl_modules.len:
            mut mod_dp = all_decl_modules.get(i)
            if mod_dp != "":
                mut sm = _c_dot_to_safe(mod_dp)
                match all_decls.get(i).read():
                    case Decl.DClass(c):
                        if c.generics.len == 0:
                            mut key = sm + "_" + c.name
                            if not seen.contains(key):
                                seen.insert(key, true)
                                out = out + "typedef " + c.name + " " + key + ";\n"
                                out = out + "struct core_vec_Vec_" + key + " { " + key + "** data; long long len; long long capacity; };\n"
                                out = out + "typedef struct core_vec_Vec_" + key + " core_vec_Vec_" + key + ";\n"
                                out = out + "struct core_vec_Vec_" + key + "_ptr { " + key + "*** data; long long len; long long capacity; };\n"
                                out = out + "typedef struct core_vec_Vec_" + key + "_ptr core_vec_Vec_" + key + "_ptr;\n"
                                out = out + "struct core_map_MapNode_str_" + key + " { char* key; " + key + "* value; struct core_map_MapNode_str_" + key + "* next; };\n"
                                out = out + "typedef struct core_map_MapNode_str_" + key + " core_map_MapNode_str_" + key + ";\n"
                                out = out + "struct core_map_Map_str_" + key + " { core_map_MapNode_str_" + key + "** buckets; long long capacity; long long len; };\n"
                                out = out + "typedef struct core_map_Map_str_" + key + " core_map_Map_str_" + key + ";\n"
                                out = out + "__attribute__((hot)) " + key + "** core_alloc_alloc_" + key + "(long long count);\n"
                                out = out + "__attribute__((hot)) " + key + "** core_alloc_resize_" + key + "(" + key + "** ptr, long long new_count);\n"
                                out = out + "__attribute__((hot)) void core_alloc_dealloc_" + key + "(" + key + "** ptr);\n"
                                out = out + "__attribute__((hot)) " + key + "*** core_alloc_alloc_" + key + "_ptr(long long count);\n"
                                out = out + "__attribute__((hot)) " + key + "*** core_alloc_resize_" + key + "_ptr(" + key + "*** ptr, long long new_count);\n"
                                out = out + "__attribute__((hot)) void core_alloc_dealloc_" + key + "_ptr(" + key + "*** ptr);\n"
                                out = out + "__attribute__((hot)) core_map_MapNode_str_" + key + "** core_alloc_alloc_core_map_MapNode_str_" + key + "(long long count);\n"
                                out = out + "__attribute__((hot)) void core_alloc_dealloc_core_map_MapNode_str_" + key + "(core_map_MapNode_str_" + key + "** ptr);\n"
                                out = out + "\n"
                    case Decl.DEnum(e):
                        if e.generics.len == 0:
                            mut key = sm + "_" + e.name
                            if not seen.contains(key):
                                seen.insert(key, true)
                                out = out + "typedef " + e.name + " " + key + ";\n"
                                out = out + "struct core_vec_Vec_" + key + " { " + key + "* data; long long len; long long capacity; };\n"
                                out = out + "typedef struct core_vec_Vec_" + key + " core_vec_Vec_" + key + ";\n"
                                out = out + "struct core_vec_Vec_" + key + "_ptr { " + key + "** data; long long len; long long capacity; };\n"
                                out = out + "typedef struct core_vec_Vec_" + key + "_ptr core_vec_Vec_" + key + "_ptr;\n"
                                out = out + "__attribute__((hot)) " + key + "* core_alloc_alloc_" + key + "(long long count);\n"
                                out = out + "__attribute__((hot)) " + key + "* core_alloc_resize_" + key + "(" + key + "* ptr, long long new_count);\n"
                                out = out + "__attribute__((hot)) void core_alloc_dealloc_" + key + "(" + key + "* ptr);\n"
                                out = out + "__attribute__((hot)) " + key + "** core_alloc_alloc_" + key + "_ptr(long long count);\n"
                                out = out + "__attribute__((hot)) " + key + "** core_alloc_resize_" + key + "_ptr(" + key + "** ptr, long long new_count);\n"
                                out = out + "__attribute__((hot)) void core_alloc_dealloc_" + key + "_ptr(" + key + "** ptr);\n"
                                out = out + "\n"
                    case Decl.DInterface(iface):
                        if iface.generics.len == 0:
                            mut key = sm + "_" + iface.name
                            if not seen.contains(key):
                                seen.insert(key, true)
                                out = out + "typedef " + iface.name + "_obj " + key + ";\n\n"
                    case _: pass
            i = i + 1

        out = out + "/* Primitive vec/map types for core modules */\n"
        out = out + "struct core_vec_Vec_str { char** data; long long len; long long capacity; };\n"
        out = out + "typedef struct core_vec_Vec_str core_vec_Vec_str;\n"
        out = out + "__attribute__((hot)) char** core_alloc_alloc_str(long long count);\n"
        out = out + "__attribute__((hot)) char** core_alloc_resize_str(char** ptr, long long new_count);\n"
        out = out + "__attribute__((hot)) void core_alloc_dealloc_str(char** ptr);\n"
        out = out + "struct core_vec_Vec_i64 { long long* data; long long len; long long capacity; };\n"
        out = out + "typedef struct core_vec_Vec_i64 core_vec_Vec_i64;\n"
        out = out + "__attribute__((hot)) long long* core_alloc_alloc_i64(long long count);\n"
        out = out + "__attribute__((hot)) long long* core_alloc_resize_i64(long long* ptr, long long new_count);\n"
        out = out + "__attribute__((hot)) void core_alloc_dealloc_i64(long long* ptr);\n"
        out = out + "struct core_map_MapNode_str_bool { char* key; bool value; struct core_map_MapNode_str_bool* next; };\n"
        out = out + "typedef struct core_map_MapNode_str_bool core_map_MapNode_str_bool;\n"
        out = out + "struct core_map_Map_str_bool { core_map_MapNode_str_bool** buckets; long long capacity; long long len; };\n"
        out = out + "typedef struct core_map_Map_str_bool core_map_Map_str_bool;\n"
        out = out + "__attribute__((hot)) core_map_MapNode_str_bool** core_alloc_alloc_core_map_MapNode_str_bool(long long count);\n"
        out = out + "__attribute__((hot)) void core_alloc_dealloc_core_map_MapNode_str_bool(core_map_MapNode_str_bool** ptr);\n"
        out = out + "struct core_map_MapNode_str_str { char* key; char* value; struct core_map_MapNode_str_str* next; };\n"
        out = out + "typedef struct core_map_MapNode_str_str core_map_MapNode_str_str;\n"
        out = out + "struct core_map_Map_str_str { core_map_MapNode_str_str** buckets; long long capacity; long long len; };\n"
        out = out + "typedef struct core_map_Map_str_str core_map_Map_str_str;\n"
        out = out + "__attribute__((hot)) core_map_MapNode_str_str** core_alloc_alloc_core_map_MapNode_str_str(long long count);\n"
        out = out + "__attribute__((hot)) void core_alloc_dealloc_core_map_MapNode_str_str(core_map_MapNode_str_str** ptr);\n"
        out = out + "struct core_map_MapNode_str_i64 { char* key; long long value; struct core_map_MapNode_str_i64* next; };\n"
        out = out + "typedef struct core_map_MapNode_str_i64 core_map_MapNode_str_i64;\n"
        out = out + "struct core_map_Map_str_i64 { core_map_MapNode_str_i64** buckets; long long capacity; long long len; };\n"
        out = out + "typedef struct core_map_Map_str_i64 core_map_Map_str_i64;\n"
        out = out + "__attribute__((hot)) core_map_MapNode_str_i64** core_alloc_alloc_core_map_MapNode_str_i64(long long count);\n"
        out = out + "__attribute__((hot)) void core_alloc_dealloc_core_map_MapNode_str_i64(core_map_MapNode_str_i64** ptr);\n"
        out = out + "__attribute__((hot)) char* core_alloc_alloc_char(long long count);\n"
        out = out + "__attribute__((hot)) void core_alloc_copy_char(char* dst, char* src, long long count);\n"
        out = out + "__attribute__((hot)) char* core_alloc_resize_char(char* ptr, long long new_count);\n"
        out = out + "__attribute__((hot)) void core_alloc_dealloc_char(char* ptr);\n"
        return out

    # Generate C implementations for one module (no struct defs - those are in tauraro_types.h).
    # class_set: class/enum names declared in this module.
    # fn_set:    standalone function names declared in this module.
    # depth:     how many directories deep the output file is (for relative include path).
    pub def generate_module_c(self, prog: HirProgram, class_set: Map[str, bool], fn_set: Map[str, bool], depth: int) -> str:
        self.buf = StringBuilder.init(65536)

        mut inc_prefix = ""
        mut d = 0
        while d < depth:
            inc_prefix = inc_prefix + "../"
            d = d + 1

        self.w("#include \"" + inc_prefix + "tauraro_types.h\"\n\n")

        # -- Forward declarations for private (non-pub) functions in this module -
        # Public functions are already declared in tauraro_types.h.
        # Private helpers defined after their call sites need a prototype here
        # so GCC doesn't fail with "implicit declaration of function".
        mut fwd_i = 0
        while fwd_i < prog.functions.len:
            mut fwd_f = prog.functions.get(fwd_i)
            if fwd_f.name != "main" and not fwd_f.is_extern and not fwd_f.is_public:
                mut in_this_mod = false
                if fwd_f.class_name == "" and fn_set.contains(fwd_f.name):
                    in_this_mod = true
                elif fwd_f.class_name != "" and class_set.contains(fwd_f.class_name):
                    if self.classes.contains(fwd_f.class_name):
                        if self.classes.get(fwd_f.class_name).generics.len == 0:
                            in_this_mod = true
                if in_this_mod:
                    self.w(self.gen_func_sig(fwd_f, fwd_f.class_name) + ";\n")
            fwd_i = fwd_i + 1
        self.w("\n")

        # -- Class / enum method implementations ------------------------------
        mut i = 0
        while i < prog.classes.len:
            mut c = prog.classes.get(i)
            if c.generics.len == 0 and class_set.contains(c.name):
                if not self.emitted_fns.contains("cls_" + c.name):
                    self.emitted_fns.insert("cls_" + c.name, true)
                    mut mi = 0
                    while mi < c.methods.len:
                        mut m = c.methods.get(mi)
                        # Mark with the per-method key so loop-2 (prog.functions) won't re-emit.
                        self.emitted_fns.insert("i_" + c.name + "_" + m.name, true)
                        self.cur_class = c.name
                        self.cur_func  = m.name
                        self.decl_vars = Map[str, bool].init(64)
                        self.seed_params(m)
                        self.w(self.get_proto_attrs(m) + self.gen_func_sig(m, c.name) + " {\n")
                        self.gen_func_body(m.body, 1)
                        self.w("}\n\n")
                        self.cur_class = ""
                        self.cur_func  = ""
                        mi = mi + 1
            i = i + 1
        i = 0
        while i < prog.enums.len:
            mut e = prog.enums.get(i)
            if class_set.contains(e.name):
                if not self.emitted_fns.contains("cls_" + e.name):
                    self.emitted_fns.insert("cls_" + e.name, true)
                    mut mi = 0
                    while mi < e.methods.len:
                        mut m = e.methods.get(mi)
                        self.cur_class = e.name
                        self.cur_func  = m.name
                        self.decl_vars = Map[str, bool].init(64)
                        self.seed_params(m)
                        self.w(self.get_proto_attrs(m) + self.gen_func_sig(m, e.name) + " {\n")
                        self.gen_func_body(m.body, 1)
                        self.w("}\n\n")
                        self.cur_class = ""
                        self.cur_func  = ""
                        mi = mi + 1
            i = i + 1

        # -- Free-standing function implementations ----------------------------
        i = 0
        while i < prog.functions.len:
            mut f = prog.functions.get(i)
            if f.name != "main" and not f.is_extern:
                mut in_mod = false
                if f.class_name == "" and fn_set.contains(f.name):
                    in_mod = true
                elif f.class_name != "" and class_set.contains(f.class_name):
                    # Skip generic class extend methods - only monomorphized instances are emitted.
                    mut is_generic_cls = false
                    if self.classes.contains(f.class_name):
                        if self.classes.get(f.class_name).generics.len > 0:
                            is_generic_cls = true
                    if not is_generic_cls:
                        in_mod = true  # extend method belonging to this module
                if in_mod:
                    mut em_key = "i_" + f.class_name + "_" + f.name
                    if not self.emitted_fns.contains(em_key):
                        self.emitted_fns.insert(em_key, true)
                        self.cur_func  = f.name
                        self.cur_class = f.class_name
                        self.decl_vars = Map[str, bool].init(64)
                        self.seed_params(f)
                        self.w(self.get_proto_attrs(f) + self.gen_func_sig(f, f.class_name) + " {\n")
                        self.gen_func_body(f.body, 1)
                        self.w("}\n\n")
                        self.cur_func  = ""
                        self.cur_class = ""
            i = i + 1

        return self.buf.to_string().as_str()

    # Generate main.c: main-module implementations + C entry point.
    pub def generate_main_c(self, prog: HirProgram, class_set: Map[str, bool], fn_set: Map[str, bool]) -> str:
        self.buf = StringBuilder.init(65536)

        self.w("#define _TR_MAIN\n")
        self.w("#include \"tauraro_types.h\"\n\n")

        # Emit spawn + async wrappers (static thread-entry functions) before any function body
        self.prescan_spawns(prog)
        self.prescan_awaits(prog)
        self.w("\n")

        # Main-module class / enum method implementations
        mut i = 0
        if not _is_invalid_ptr(prog as usize) and not _is_invalid_ptr(prog.classes as usize):
            while i < prog.classes.len:
                mut c = prog.classes.get(i)
                if not _is_invalid_ptr(c as usize):
                    if c.generics.len == 0 and class_set.contains(c.name):
                        if not self.emitted_fns.contains("cls_" + c.name):
                            self.emitted_fns.insert("cls_" + c.name, true)
                            mut mi = 0
                            if not _is_invalid_ptr(c.methods as usize):
                                while mi < c.methods.len:
                                    mut m = c.methods.get(mi)
                                    if not _is_invalid_ptr(m as usize):
                                        # Mark with per-method key so loop-2 won't re-emit.
                                        self.emitted_fns.insert("i_" + c.name + "_" + m.name, true)
                                        self.cur_class = c.name
                                        self.cur_func  = m.name
                                        self.cur_throws_ty = m.throws_ty.name
                                        self.decl_vars = Map[str, bool].init(64)
                                        self.shared_vars = Map[str, str].init(8)
                                        self.seed_params(m)
                                        self.w(self.get_proto_attrs(m) + self.gen_func_sig(m, c.name) + " {\n")
                                        self.gen_func_body(m.body, 1)
                                        self.w("}\n\n")
                                        self.cur_class = ""
                                        self.cur_func  = ""
                                        self.cur_throws_ty = ""
                                    mi = mi + 1
                i = i + 1
        i = 0
        if not _is_invalid_ptr(prog as usize) and not _is_invalid_ptr(prog.enums as usize):
            while i < prog.enums.len:
                mut e = prog.enums.get(i)
                if not _is_invalid_ptr(e as usize):
                    if class_set.contains(e.name):
                        if not self.emitted_fns.contains("cls_" + e.name):
                            self.emitted_fns.insert("cls_" + e.name, true)
                            mut mi = 0
                            if not _is_invalid_ptr(e.methods as usize):
                                while mi < e.methods.len:
                                    mut m = e.methods.get(mi)
                                    if not _is_invalid_ptr(m as usize):
                                        self.cur_class = e.name
                                        self.cur_func  = m.name
                                        self.cur_throws_ty = m.throws_ty.name
                                        self.decl_vars = Map[str, bool].init(64)
                                        self.shared_vars = Map[str, str].init(8)
                                        self.seed_params(m)
                                        self.w(self.get_proto_attrs(m) + self.gen_func_sig(m, e.name) + " {\n")
                                        self.gen_func_body(m.body, 1)
                                        self.w("}\n\n")
                                        self.cur_class = ""
                                        self.cur_func  = ""
                                        self.cur_throws_ty = ""
                                    mi = mi + 1
                i = i + 1

        # Main-module free-standing function implementations
        i = 0
        if not _is_invalid_ptr(prog as usize) and not _is_invalid_ptr(prog.functions as usize):
            while i < prog.functions.len:
                mut f = prog.functions.get(i)
                if not _is_invalid_ptr(f as usize):
                    if f.name != "main" and not f.is_extern:
                        mut in_mod = false
                        if f.class_name == "" and fn_set.contains(f.name):
                            in_mod = true
                        elif f.class_name != "" and class_set.contains(f.class_name):
                            # Skip generic class extend methods - only monomorphized instances are emitted.
                            mut is_generic_cls2 = false
                            if self.classes.contains(f.class_name):
                                if self.classes.get(f.class_name).generics.len > 0:
                                    is_generic_cls2 = true
                            if not is_generic_cls2:
                                in_mod = true  # extend method belonging to this module
                        if in_mod:
                            mut em_key2 = "i_" + f.class_name + "_" + f.name
                            if not self.emitted_fns.contains(em_key2):
                                self.emitted_fns.insert(em_key2, true)
                                self.cur_func  = f.name
                                self.cur_class = f.class_name
                                self.cur_throws_ty = f.throws_ty.name
                                self.decl_vars = Map[str, bool].init(64)
                                self.shared_vars = Map[str, str].init(8)
                                self.seed_params(f)
                                self.w(self.get_proto_attrs(f) + self.gen_func_sig(f, f.class_name) + " {\n")
                                self.gen_func_body(f.body, 1)
                                self.w("}\n\n")
                                self.cur_func  = ""
                                self.cur_class = ""
                                self.cur_throws_ty = ""
                i = i + 1

        # C main() entry point
        self.w("__attribute__((hot)) int main(int argc, char** argv) {\n")
        self.w("    _tr_argc = argc; _tr_argv = argv;\n")
        self.w("    _tr_init_console();\n")
        self.w("#ifndef TAURARO_BARE\n")
        self.w("    _tr_global_async_pool = _tr_threadpool_auto();\n")
        self.w("#endif\n")
        mut main_has_args = false
        mut main_args_name = "args"
        mut mi2 = 0
        if not _is_invalid_ptr(prog as usize) and not _is_invalid_ptr(prog.functions as usize):
            while mi2 < prog.functions.len:
                mut mf = prog.functions.get(mi2)
                if not _is_invalid_ptr(mf as usize):
                    if mf.name == "main" and mf.params.len > 0:
                        main_has_args = true
                        main_args_name = mf.params.get(0).name
                mi2 = mi2 + 1
        if main_has_args:
            # Rename to avoid shadowing C's char** argv parameter
            if main_args_name == "argv": main_args_name = "_tr_main_argv"
            self.w("    List_str* " + main_args_name + " = List_str_new();\n")
            self.w("    for (int _ai = 0; _ai < argc; _ai++) { List_str_append(" + main_args_name + ", argv[_ai]); }\n")

        i = 0
        if not _is_invalid_ptr(prog as usize) and not _is_invalid_ptr(prog.top_level_stmts as usize):
            while i < prog.top_level_stmts.len:
                self.gen_stmt(prog.top_level_stmts.get(i), 1)
                i = i + 1

        i = 0
        if not _is_invalid_ptr(prog as usize) and not _is_invalid_ptr(prog.functions as usize):
            while i < prog.functions.len:
                mut f = prog.functions.get(i)
                if not _is_invalid_ptr(f as usize):
                    if f.name == "main":
                        self.cur_func  = "main"
                        self.decl_vars = Map[str, bool].init(64)
                        self.gen_func_body(f.body, 1)
                        self.cur_func  = ""
                i = i + 1

        self.w("#ifndef TAURARO_BARE\n")
        self.w("    if (_tr_global_async_pool) { _tr_threadpool_free(_tr_global_async_pool); _tr_global_async_pool = NULL; }\n")
        self.w("#endif\n")
        self.w("    return 0;\n}\n")
        return self.buf.to_string().as_str()
