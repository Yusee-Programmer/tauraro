# @trusted: compiler systems module — audited raw-pointer core (like Rust std internals)
# compiler/src/codegen/c.tr - C code generator for the Tauraro self-hosted compiler.
# Generates brutally optimized C from HIR with zero-cost abstractions.

from core.vec import Vec
from core.map import Map
from core.string import StringBuilder
from core.alloc import alloc
from core.io import write_file
from hir import HirProgram, HirFunction, HirClass, HirEnum, HirInterface, HirStmt, HirExpr, HirBlock, HirParam, HirField, HirVariant, HirFStringPart, HirComprehension, HirCatchClause, HirMatchArm, HirChanSelectArm, _tr_str_len, hir_expr_type
from ast import AstType, Decorator, Pattern, Ownership, Decl

extern "C":
    def _tr_float_to_c_lit(n: float) -> str

# --- Helpers ------------------------------------------------------------------

pub def _c_dot_to_safe(s: str) -> str:
    mut n = 0
    mut p = s as Pointer[char]
    while p.offset(n).read() as int != 0: n = n + 1
    mut buf = s.slice(0, n)
    mut bp = buf as Pointer[char]
    mut j = 0
    while j < n:
        if bp.offset(j).read() as int == 46:
            unsafe: bp.offset(j).write(95 as char)
        j = j + 1
    return buf

pub def _indent_str(n: int) -> str:
    mut s = ""
    mut i = 0
    while i < n:
        s = s + "    "
        i = i + 1
    return s

pub def _is_invalid_ptr(addr: usize) -> bool:
    if addr < 0x10000 as usize: return true
    if addr > 0x0000ffffffffffff as usize: return true
    if addr == 0xabababab as usize or addr == 0xfeeefeee as usize: return true
    if addr == 0xbaadf00d as usize or addr == 0xcccccccc as usize: return true
    if addr == 0xcdcdcdcd as usize or addr == 0xdddddddd as usize: return true
    if addr == 0xfeeefeeefeeefeee as usize or addr == 0xabababababababab as usize: return true
    if addr == 0xbaadf00dbaadf00d as usize or addr == 0xcccccccccccccccc as usize: return true
    if addr % 8 as usize != 0 as usize: return true
    return false


pub def _is_str_type(n: str) -> bool:
    return n == "str" or n == "String"

pub def _is_int_type(n: str) -> bool:
    if n == "int" or n == "i64" or n == "i32" or n == "i16" or n == "i8": return true
    if n == "u64" or n == "u32" or n == "u16" or n == "u8": return true
    if n == "usize" or n == "isize" or n == "long long": return true
    return false

pub def _is_float_type(n: str) -> bool:
    return n == "float" or n == "f64" or n == "f32" or n == "double"

pub def _safe_c_varname(n: str) -> str:
    if _is_c_keyword(n): return "_tr_v_" + n
    return n

pub def _is_c_keyword(n: str) -> bool:
    # C language keywords
    if n == "double" or n == "float" or n == "int" or n == "char": return true
    if n == "long" or n == "short" or n == "void" or n == "unsigned": return true
    if n == "signed" or n == "register" or n == "inline" or n == "auto": return true
    if n == "struct" or n == "union" or n == "enum" or n == "extern": return true
    if n == "static" or n == "volatile" or n == "const" or n == "restrict": return true
    if n == "typedef" or n == "sizeof" or n == "alignof" or n == "typeof": return true
    if n == "goto" or n == "switch" or n == "case" or n == "default": return true
    if n == "do" or n == "for" or n == "while" or n == "if" or n == "else": return true
    if n == "break" or n == "continue" or n == "return": return true
    # C stdlib / POSIX names that conflict with common method names
    if n == "exit" or n == "abort" or n == "remove" or n == "rename": return true
    if n == "read" or n == "write" or n == "open" or n == "close": return true
    if n == "send" or n == "recv" or n == "bind" or n == "connect": return true
    if n == "accept" or n == "listen" or n == "socket": return true
    if n == "time" or n == "sleep" or n == "signal" or n == "raise": return true
    if n == "stat" or n == "mkdir" or n == "rmdir" or n == "unlink": return true
    if n == "malloc" or n == "free" or n == "calloc" or n == "realloc": return true
    if n == "printf" or n == "scanf" or n == "puts" or n == "gets": return true
    if n == "strlen" or n == "strcpy" or n == "strcat" or n == "strcmp": return true
    if n == "system" or n == "getenv" or n == "setenv" or n == "putenv": return true
    if n == "fopen" or n == "fclose" or n == "fread" or n == "fwrite": return true
    if n == "fseek" or n == "ftell" or n == "rewind" or n == "feof": return true
    if n == "index" or n == "count" or n == "new" or n == "delete": return true
    return false

pub def _starts_with_tr(s: str) -> bool:
    mut p = s as Pointer[char]
    if p as int == 0: return false
    if p.offset(0).read() as int == 0: return false
    if p.offset(0).read() as int == 95: # '_'
        if p.offset(1).read() as int == 0: return false
        if p.offset(1).read() as int == 116: # 't'
            if p.offset(2).read() as int == 0: return false
            if p.offset(2).read() as int == 114: # 'r'
                if p.offset(3).read() as int == 0: return false
                if p.offset(3).read() as int == 95: # '_'
                    return true
    return false

pub def _is_primitive(n: str) -> bool:
    if _is_int_type(n) or _is_float_type(n): return true
    if n == "bool" or n == "char" or n == "void" or n == "None": return true
    return false

pub def _escape_str_for_c(s: str) -> str:
    mut sb = StringBuilder.init(64)
    mut p = s as Pointer[char]
    mut i = 0
    while True:
        mut c = p.offset(i).read() as int
        if c == 0: break
        if c == 34: sb.append("\\\"")
        elif c == 92: sb.append("\\\\")
        elif c == 10: sb.append("\\n")
        elif c == 13: sb.append("\\r")
        elif c == 9: sb.append("\\t")
        else: sb.append_char(c)
        i = i + 1
    return sb.to_string().as_str()

# --- CGenerator class ---------------------------------------------------------

pub class CGenerator:
    pub buf:            StringBuilder
    pub fwd_buf:        StringBuilder   # forward declarations
    pub struct_buf:     StringBuilder   # struct definitions
    pub list_types_buf: StringBuilder   # value-type List_T definitions (emitted after structs)
    pub proto_buf:      StringBuilder   # function prototypes
    pub mono_buf:       StringBuilder   # monomorphized generic class code
    pub fn_mono_body:   StringBuilder   # monomorphized generic FREE-function bodies (flushed after all prototypes)
    pub temp_count:     int
    pub classes:        Map[str, HirClass]
    pub enums:          Map[str, HirEnum]
    pub interfaces:     Map[str, HirInterface]
    pub functions:      Map[str, HirFunction]
    pub method_owners:  Map[str, bool]  # "ClassOrEnumName#method" -> true (extend methods, incl. enums)
    pub decl_vars:      Map[str, bool]
    pub str_local_names: Map[str, bool]  # TrStr-typed locals declared via SLet in current function (retain/release tracked)
    pub class_local_names: Map[str, bool]  # heap-class-typed locals in current function that OWN a refcount (released at scope exit; reset in seed_params)
    pub fn_owned: Map[str, bool]  # return-ownership inference (from sema HirFunction.returns_owned): fn key ("name" or "Class.method") -> returns an OWNED heap-class ref; drives _obj_expr_owns_ref
    pub raw_aliased: Map[str, bool]  # class names reachable as Pointer[T] anywhere in the program — their instances are aliased by RAW pointers that bypass refcounting, so they must NEVER be auto-dropped (is_heap_class_tn excludes them). e.g. AstType via AstType.args: Vec[Pointer[AstType]]
    pub coll_field_owned: Map[str, bool]  # "Class.field" collection field with a FRESH-collection assignment (candidate to free in _trdrop_T)
    pub coll_field_disq: Map[str, bool]   # bare collection field NAME ever assigned a non-fresh (aliased) collection anywhere — disqualifies freeing that field (collections aren't refcounted, so an alias would double-free)
    pub cur_proven_borrows: Map[str, bool]  # outlives engine: ref-borrow locals whose source provably outlives them — refcount ELIDED (no retain at bind, no release at scope)
    pub cur_ret_is_borrow: bool  # current function's return type is `ref` — returns a BORROW (no retain on return; the caller does not free it)
    pub eliding_get_retain: bool # set while generating a PROVEN collection-element borrow's RHS (`ref T = coll.get(k)`) — the str-valued get returns the unboxed alias WITHOUT retaining (zero-copy borrow); the SLet also skips the release
    pub no_elide: bool           # --no-elide: force pure ARC (drop ALL proven-borrow elision) — the differential-soundness oracle baseline
    pub tier_define: str         # --freestanding => "TAURARO_KERNEL" (no libc), --no-std => "TAURARO_NO_OS" (no OS); emitted as a #define before the runtime include so the tier build "just works" without a hand-passed -D
    pub bare_arch:   str         # bare-metal boot architecture for @entry glue + linker script: "cortex-m" (default) or "riscv" (selected by --target embedded-riscv*)
    pub cur_self_is_ptr: bool     # inside a MUTATING @value_type method, `self` is a POINTER (`ClassName* self`) so writes persist — gen_prop_access uses `self->field`, not `self.field`
    pub coll_local_sfx: Map[str, str]    # List/Vec local name -> list_sfx (e.g. "i64"/"TrStr") for SAutoDrop's List_<sfx>_free; Dict/Map/Set don't need a suffix (Dict_free)
    pub coll_local_idict: Map[str, bool] # Dict/Map/Set local name -> true if int-keyed (TrIDict*/_TrISet*, freed via _tr_idict_free instead of Dict_free)
    pub coll_local_strval: Map[str, bool] # Dict/Map local name -> true if value type is str (_tr_str_box'd; freed via Dict_free_strval/_tr_idict_free_strval, #54)
    pub coll_local_vtcoll: Map[str, str] # Dict/Map/Set local name -> typed-collection struct (e.g. "Dict_str_Point"/"Set_Point") for SAutoDrop's <name>_free
    pub type_subst:     Map[str, str]   # T -> "long long" during mono gen
    pub mono_done:      Map[str, bool]  # "Vec_i64" -> true (prevents duplicate gen)
    pub emit_fn_name:   str             # override the emitted C name of a free fn (mono: id -> id_i64)
    pub list_type_done: Map[str, bool]  # "Token" -> true (prevents duplicate list gen)
    pub list_fwd_done:  Map[str, bool]  # "Token" -> true (prevents duplicate fwd decl)
    pub elem_fmt_done:  Map[str, bool]  # "_tr_fmt_obj_X" -> true (prevents duplicate to_str formatter gen)
    pub cur_class:      str
    pub cur_func:       str
    pub closure_count:  int
    pub emitted_fns:    Map[str, bool]   # tracks emitted free-standing fn names to prevent duplicates
    pub spawn_wrappers:  Map[str, bool]   # fn_name -> true once wrapper emitted
    pub async_wrappers:  Map[str, bool]   # fn_name -> true once async wrapper emitted
    pub prescanned_fns:  Map[str, bool]   # fn key -> true once body prescanned (prevents re-scan after heap churn)
    pub shared_vars:     Map[str, str]    # var_name -> type_name (for _TrSharedBox unwrap)
    pub cur_throws_ty:   str              # non-empty = current function has throws annotation
    pub in_task_group:   int              # depth counter for task_group nesting
    pub in_gpu_block:    int              # depth counter for gpu: block nesting
    pub value_types:     Map[str, bool]  # classes with is_class=false - no * in C type
    pub value_list_elems: Vec[str]       # monomorphized value-type element names (Box_i64) needing a List_<name> type; emitted by emit_list_fwd_decls (post buffer-redirect) since the mono scan runs before it
    pub value_dict_elems: Vec[str]       # "kc|vname" pairs: Dict/Map with a value-type VALUE stored inline (typed Dict_<kc>_<vname>); recorded by scan, emitted by emit_list_fwd_decls
    pub value_set_elems:  Vec[str]       # value-type names for Set elements stored inline (typed Set_<vname>); recorded by scan, emitted by emit_list_fwd_decls
    pub global_vars:     Map[str, bool]  # top-level var names hoisted to C file scope (visible in all functions)
    pub closure_cap_set: Map[str, bool]  # captured var names for the current closure being generated
    pub closure_env_var: str             # env var name inside a closure body (empty = not in closure body)
    pub closure_buf:    StringBuilder    # outlined top-level closure typedefs + static functions, flushed before each function
    pub last_clo_cname:   str            # last gen_closure: outlined fn name (for the SLet stack-env path)
    pub last_clo_estruct: str            # last gen_closure: inline env struct type
    pub last_clo_ptypes:  str            # last gen_closure: param type list (after env)
    pub last_clo_ret:     str            # last gen_closure: C return type
    pub last_clo_init:    str            # last gen_closure: positional env initializer
    pub decorator_defs:   Map[str, HirFunction]  # user-defined decorator registry
    pub overloaded_sigs:  Map[str, bool]          # "ClassName_method" keys where multiple overloads exist
    pub type_alias_map:   Map[str, str]           # alias_name -> resolved C type string
    pub defer_stack:      Vec[str]                # deferred C statements for current function (LIFO)
    pub wrap_temp_decls:  Vec[str]                # pending "TrStr _wtN = (_tr_str_wrap(...))" decls for the current top-level expr
    pub wrap_temp_names:  Vec[str]                # names of the above, to _tr_str_release after the expr is consumed
    pub wrap_obj_names:   Vec[str]                # fresh-owned heap-class arg temps (decls in wrap_temp_decls) to _tr_obj_release after the expr
    pub wrap_obj_drops:   Vec[str]                # parallel: the _trdrop_T fn for each wrap_obj_names temp
    pub loop_res_stack:   Vec[str]               # `loop:`/`while:` EXPRESSION result-temp per enclosing loop ("" = a plain statement loop: a valued break has no target)
    pub loop_done_stack:  Vec[str]               # `while:` EXPRESSION normal-exit flag per enclosing loop ("" = none)
    pub emit_line_info:   bool                    # --debug: emit `#line N "src.tr"` directives for SLineMarker
    pub cur_src_file:     str                     # source file of the module currently being generated (for #line)

    pub def init() -> CGenerator:
        mut g = CGenerator()
        g.buf           = StringBuilder.init(65536)
        g.fwd_buf       = StringBuilder.init(4096)
        g.struct_buf    = StringBuilder.init(16384)
        g.list_types_buf = StringBuilder.init(2048)
        g.proto_buf     = StringBuilder.init(8192)
        g.mono_buf      = StringBuilder.init(8192)
        g.fn_mono_body  = StringBuilder.init(4096)
        g.temp_count    = 0
        g.classes       = Map[str, HirClass].init(128)
        g.enums         = Map[str, HirEnum].init(64)
        g.interfaces    = Map[str, HirInterface].init(32)
        g.functions     = Map[str, HirFunction].init(256)
        g.method_owners = Map[str, bool].init(64)
        g.decl_vars     = Map[str, bool].init(64)
        g.str_local_names = Map[str, bool].init(16)
        g.class_local_names = Map[str, bool].init(16)
        g.fn_owned = Map[str, bool].init(64)
        g.raw_aliased = Map[str, bool].init(32)
        g.coll_field_owned = Map[str, bool].init(32)
        g.coll_field_disq = Map[str, bool].init(32)
        g.cur_proven_borrows = Map[str, bool].init(8)
        g.cur_ret_is_borrow = false
        g.eliding_get_retain = false
        g.no_elide = false
        g.tier_define = ""
        g.bare_arch   = "cortex-m"
        g.cur_self_is_ptr = false
        g.coll_local_sfx = Map[str, str].init(16)
        g.coll_local_idict = Map[str, bool].init(16)
        g.coll_local_strval = Map[str, bool].init(16)
        g.coll_local_vtcoll = Map[str, str].init(16)
        g.type_subst    = Map[str, str].init(8)
        g.mono_done     = Map[str, bool].init(32)
        g.emit_fn_name  = ""
        g.list_type_done = Map[str, bool].init(16)
        g.list_fwd_done  = Map[str, bool].init(16)
        g.elem_fmt_done  = Map[str, bool].init(16)
        g.cur_class     = ""
        g.cur_func      = ""
        g.closure_count = 0
        g.emitted_fns   = Map[str, bool].init(256)
        g.spawn_wrappers = Map[str, bool].init(16)
        g.async_wrappers = Map[str, bool].init(16)
        g.prescanned_fns = Map[str, bool].init(256)
        g.shared_vars    = Map[str, str].init(16)
        g.cur_throws_ty  = ""
        g.in_task_group  = 0
        g.in_gpu_block   = 0
        g.value_types    = Map[str, bool].init(32)
        g.value_list_elems = Vec[str].init(8)
        g.value_dict_elems = Vec[str].init(8)
        g.value_set_elems  = Vec[str].init(8)
        g.global_vars    = Map[str, bool].init(32)
        g.closure_cap_set = Map[str, bool].init(0)
        g.closure_env_var = ""
        g.closure_buf = StringBuilder.init(2048)
        g.last_clo_cname = ""
        g.last_clo_estruct = ""
        g.last_clo_ptypes = ""
        g.last_clo_ret = ""
        g.last_clo_init = ""
        g.decorator_defs  = Map[str, HirFunction].init(16)
        g.overloaded_sigs = Map[str, bool].init(32)
        g.type_alias_map  = Map[str, str].init(16)
        g.defer_stack     = Vec[str].init(0)
        g.wrap_temp_decls = Vec[str].init(0)
        g.wrap_temp_names = Vec[str].init(0)
        g.wrap_obj_names = Vec[str].init(0)
        g.wrap_obj_drops = Vec[str].init(0)
        g.loop_res_stack = Vec[str].init(4)
        g.loop_done_stack = Vec[str].init(4)
        g.emit_line_info  = false
        g.cur_src_file    = ""
        return g

    pub def next_temp(self) -> str:
        self.temp_count = self.temp_count + 1
        return "_t" + self.temp_count.to_str()

    # Call before generating a function body to reset the defer stack.
    pub def reset_defer_stack(self):
        self.defer_stack = Vec[str].init(0)

    # Emit a function body, then flush any defers that the body did not already
    # flush via an explicit trailing 'return'. defer statements run on function
    # exit; a void function that falls off the end must still run its defers.
    pub def gen_func_body(self, body: HirBlock, indent: int):
        self.reset_defer_stack()
        self.gen_block(body, indent)
        if self.defer_stack.len > 0:
            mut ends_in_return = false
            if body.stmts.len > 0:
                match body.stmts.get(body.stmts.len - 1).read():
                    case HirStmt.SReturn(_): ends_in_return = true
                    case _: pass
            if not ends_in_return:
                mut fdi = self.defer_stack.len - 1
                while fdi >= 0:
                    self.w(self.defer_stack.get(fdi))
                    if fdi == 0: break
                    fdi = fdi - 1

    # Append the outlined closure functions (accumulated during body codegen) to
    # the current translation unit, at file scope after everything else. Each
    # closure's creation site carries a block-scope prototype, so emitting the
    # definitions last is safe (and lets them use any user type/function above).
    pub def flush_closures(self):
        mut cd = self.closure_buf.to_string().as_str()
        if cd != "":
            self.w("\n/* ---- outlined closures ---- */\n")
            self.w(cd)
            self.closure_buf = StringBuilder.init(2048)

    pub def seed_params(self, f: HirFunction):
        # Load the outlives-proven borrow set for THIS function (every function-entry
        # path calls seed_params), so the SLet codegen can elide their refcounts.
        self.set_proven_borrows(f.proven_borrows)
        # Reset per-function heap-class ownership tracking here (seed_params is the
        # single common entry for every function/method emit — avoids resetting at
        # each of the ~13 emit sites).
        self.class_local_names = Map[str, bool].init(16)
        # A `-> ref` function returns a BORROW: it does NOT retain on return, and its
        # callers must NOT free the result (see _is_fresh_str_expr / _expr_is_borrow_call).
        self.cur_ret_is_borrow = f.ret_ty.is_borrow
        mut pi = 0
        while pi < f.params.len:
            self.decl_vars.insert(f.params.get(pi).name, true)
            pi = pi + 1

    pub def w(self, s: str): self.buf.append(s)
    pub def wf(self, s: str): self.fwd_buf.append(s)
    pub def ws(self, s: str): self.struct_buf.append(s)
    pub def wp(self, s: str): self.proto_buf.append(s)
    pub def wlt(self, s: str): self.list_types_buf.append(s)

    pub def ensure_list_type(self, n: str):
        if self.list_type_done.contains(n): return
        self.list_type_done.insert(n, true)
        self.wlt("typedef struct List_" + n + " { " + n + "* data; size_t len; size_t capacity; } List_" + n + ";\n")
        self.wlt("static inline List_" + n + "* List_" + n + "_new(void) { List_" + n + "* l=(List_" + n + "*)malloc(sizeof(List_" + n + ")); l->data=(" + n + "*)malloc(sizeof(" + n + ")*8); l->len=0; l->capacity=8; return l; }\n")
        self.wlt("static inline void List_" + n + "_append(List_" + n + "* l, " + n + " val) { if(l->len==l->capacity){ l->capacity*=2; l->data=(" + n + "*)realloc(l->data,sizeof(" + n + ")*l->capacity); } l->data[l->len++]=val; }\n")
        self.wlt("static inline " + n + " List_" + n + "_get(List_" + n + "* l, long long i) { _tr_bounds_check(i, l->len); return l->data[i]; }\n")
        self.wlt("static inline " + n + " List_" + n + "_pop(List_" + n + "* l) { if(!l||l->len==0) return (" + n + "){0}; l->len--; return l->data[l->len]; }\n")
        self.wlt("static inline void List_" + n + "_free(List_" + n + "* l) { if(l){ free(l->data); free(l); } }\n")

    # Typed inline dict: Dict_<kc>_<vname> stores the value-type struct BY VALUE in
    # the node (no void* boxing, no per-entry heap copy) - like Rust's HashMap<K,V>.
    # kc is "str" (char* keys) or "i64" (long long keys). Mirrors the runtime Dict.
    pub def ensure_dict_type(self, kc: str, vname: str):
        mut dn = "Dict_" + kc + "_" + vname
        if self.list_type_done.contains(dn): return
        self.list_type_done.insert(dn, true)
        self.ensure_list_type(vname)            # for .values() -> List_<vname>
        mut is_str = kc == "str"
        mut ktype = "long long"
        if is_str: ktype = "char*"
        mut node = "_DN_" + kc + "_" + vname
        mut hashexpr = "((size_t)key) % d->cap"
        mut keyeq = "n->key==key"
        mut keystore = "key"
        mut keyfree = ""
        if is_str:
            hashexpr = "_dict_hash(key, d->cap)"
            keyeq = "strcmp(n->key,key)==0"
            keystore = "strdup(key)"
            keyfree = "if(n->key) _tr_free(n->key); "
        self.wlt("typedef struct " + node + " { " + ktype + " key; " + vname + " value; struct " + node + "* next; } " + node + ";\n")
        self.wlt("typedef struct { " + node + "** buckets; size_t cap; size_t len; } " + dn + ";\n")
        self.wlt("static inline " + dn + "* " + dn + "_new(long long c){ (void)c; " + dn + "* d=(" + dn + "*)malloc(sizeof(" + dn + ")); d->cap=0; d->len=0; d->buckets=NULL; return d; }\n")
        self.wlt("static inline void " + dn + "_set(" + dn + "* d, " + ktype + " key, " + vname + " val){ if(!d) return; if(d->cap==0){ d->cap=16; d->buckets=(" + node + "**)calloc(16,sizeof(" + node + "*)); } size_t i=" + hashexpr + "; " + node + "* n=d->buckets[i]; while(n){ if(" + keyeq + "){ n->value=val; return; } n=n->next; } " + node + "* nd=(" + node + "*)malloc(sizeof(" + node + ")); nd->key=" + keystore + "; nd->value=val; nd->next=d->buckets[i]; d->buckets[i]=nd; d->len++; }\n")
        self.wlt("static inline " + vname + " " + dn + "_get(" + dn + "* d, " + ktype + " key){ if(!d||d->cap==0) return (" + vname + "){0}; size_t i=" + hashexpr + "; " + node + "* n=d->buckets[i]; while(n){ if(" + keyeq + ") return n->value; n=n->next; } return (" + vname + "){0}; }\n")
        self.wlt("static inline bool " + dn + "_has(" + dn + "* d, " + ktype + " key){ if(!d||d->cap==0) return false; size_t i=" + hashexpr + "; " + node + "* n=d->buckets[i]; while(n){ if(" + keyeq + ") return true; n=n->next; } return false; }\n")
        self.wlt("static inline long long " + dn + "_len(" + dn + "* d){ return d?(long long)d->len:0LL; }\n")
        self.wlt("static inline void " + dn + "_remove(" + dn + "* d, " + ktype + " key){ if(!d||d->cap==0) return; size_t i=" + hashexpr + "; " + node + "* n=d->buckets[i]; " + node + "* p=NULL; while(n){ if(" + keyeq + "){ if(p) p->next=n->next; else d->buckets[i]=n->next; " + keyfree + "_tr_free(n); if(d->len>0)d->len--; return; } p=n; n=n->next; } }\n")
        self.wlt("static inline void " + dn + "_free(" + dn + "* d){ if(!d) return; for(size_t i=0;i<d->cap;i++){ " + node + "* n=d->buckets[i]; while(n){ " + node + "* nx=n->next; " + keyfree + "_tr_free(n); n=nx; } } _tr_free(d->buckets); _tr_free(d); }\n")
        self.wlt("static inline void " + dn + "_clear(" + dn + "* d){ if(!d) return; for(size_t i=0;i<d->cap;i++){ " + node + "* n=d->buckets[i]; while(n){ " + node + "* nx=n->next; " + keyfree + "_tr_free(n); n=nx; } if(d->buckets) d->buckets[i]=NULL; } d->len=0; }\n")
        self.wlt("static inline List_" + vname + "* " + dn + "_values(" + dn + "* d){ List_" + vname + "* l=List_" + vname + "_new(); if(d){ for(size_t i=0;i<d->cap;i++){ " + node + "* n=d->buckets[i]; while(n){ List_" + vname + "_append(l,n->value); n=n->next; } } } return l; }\n")
        if is_str:
            self.wlt("static inline List_TrStr* " + dn + "_keys(" + dn + "* d){ List_TrStr* l=List_TrStr_new(); if(d){ for(size_t i=0;i<d->cap;i++){ " + node + "* n=d->buckets[i]; while(n){ List_TrStr_append(l,_tr_str_lit(n->key)); n=n->next; } } } return l; }\n")
        else:
            self.wlt("static inline List_i64* " + dn + "_keys(" + dn + "* d){ List_i64* l=List_i64_new(); if(d){ for(size_t i=0;i<d->cap;i++){ " + node + "* n=d->buckets[i]; while(n){ List_i64_append(l,n->key); n=n->next; } } } return l; }\n")

    # Typed inline set: Set_<vname> stores the value-type struct BY VALUE; hashed by
    # its raw bytes (FNV) and compared with memcmp (POD value types only).
    pub def ensure_set_type(self, vname: str):
        mut sn = "Set_" + vname
        if self.list_type_done.contains(sn): return
        self.list_type_done.insert(sn, true)
        self.ensure_list_type(vname)            # for .to_list() -> List_<vname>
        mut node = "_SN_" + vname
        self.wlt("typedef struct " + node + " { " + vname + " elem; struct " + node + "* next; } " + node + ";\n")
        self.wlt("typedef struct { " + node + "** buckets; size_t cap; size_t len; } " + sn + ";\n")
        self.wlt("static inline size_t " + sn + "_hash(" + vname + " e, size_t cap){ unsigned char* p=(unsigned char*)&e; size_t h=5381; for(size_t i=0;i<sizeof(" + vname + ");i++) h=h*33+p[i]; return h%cap; }\n")
        self.wlt("static inline " + sn + "* " + sn + "_new(long long c){ (void)c; " + sn + "* s=(" + sn + "*)malloc(sizeof(" + sn + ")); s->cap=0; s->len=0; s->buckets=NULL; return s; }\n")
        self.wlt("static inline void " + sn + "_add(" + sn + "* s, " + vname + " e){ if(!s) return; if(s->cap==0){ s->cap=16; s->buckets=(" + node + "**)calloc(16,sizeof(" + node + "*)); } size_t i=" + sn + "_hash(e,s->cap); " + node + "* n=s->buckets[i]; while(n){ if(memcmp(&n->elem,&e,sizeof(" + vname + "))==0) return; n=n->next; } " + node + "* nd=(" + node + "*)malloc(sizeof(" + node + ")); nd->elem=e; nd->next=s->buckets[i]; s->buckets[i]=nd; s->len++; }\n")
        self.wlt("static inline bool " + sn + "_contains(" + sn + "* s, " + vname + " e){ if(!s||s->cap==0) return false; size_t i=" + sn + "_hash(e,s->cap); " + node + "* n=s->buckets[i]; while(n){ if(memcmp(&n->elem,&e,sizeof(" + vname + "))==0) return true; n=n->next; } return false; }\n")
        self.wlt("static inline void " + sn + "_remove(" + sn + "* s, " + vname + " e){ if(!s||s->cap==0) return; size_t i=" + sn + "_hash(e,s->cap); " + node + "* n=s->buckets[i]; " + node + "* p=NULL; while(n){ if(memcmp(&n->elem,&e,sizeof(" + vname + "))==0){ if(p)p->next=n->next; else s->buckets[i]=n->next; _tr_free(n); if(s->len>0)s->len--; return; } p=n; n=n->next; } }\n")
        self.wlt("static inline long long " + sn + "_len(" + sn + "* s){ return s?(long long)s->len:0LL; }\n")
        self.wlt("static inline void " + sn + "_free(" + sn + "* s){ if(!s) return; for(size_t i=0;i<s->cap;i++){ " + node + "* n=s->buckets[i]; while(n){ " + node + "* nx=n->next; _tr_free(n); n=nx; } } _tr_free(s->buckets); _tr_free(s); }\n")
        self.wlt("static inline void " + sn + "_clear(" + sn + "* s){ if(!s) return; for(size_t i=0;i<s->cap;i++){ " + node + "* n=s->buckets[i]; while(n){ " + node + "* nx=n->next; _tr_free(n); n=nx; } if(s->buckets)s->buckets[i]=NULL; } s->len=0; }\n")
        self.wlt("static inline List_" + vname + "* " + sn + "_to_list(" + sn + "* s){ List_" + vname + "* l=List_" + vname + "_new(); if(s){ for(size_t i=0;i<s->cap;i++){ " + node + "* n=s->buckets[i]; while(n){ List_" + vname + "_append(l,n->elem); n=n->next; } } } return l; }\n")

    pub def check_and_emit_list_fwd(self, ty: AstType):
        if ty as usize == 0 as usize: return
        if ty.name == "List" or ty.name == "Vec":
            if ty.args.len > 0:
                mut elem = ty.args.get(0).read()
                if self.enums.contains(elem.name):
                    if not self.list_fwd_done.contains(elem.name):
                        self.list_fwd_done.insert(elem.name, true)
                        self.w("typedef struct List_" + elem.name + " List_" + elem.name + ";\n")

    pub def emit_list_fwd_decls(self, prog: HirProgram):
        # Monomorphized value-type list types (List_Box_i64) recorded by the mono
        # scan — emit them here, after generate_types_header has swapped in the
        # real list_types_buf, so they actually land in the header.
        mut vli = 0
        while vli < self.value_list_elems.len:
            self.ensure_list_type(self.value_list_elems.get(vli))
            vli = vli + 1
        # Typed inline value-type dicts (Dict_str_Point) and sets (Set_Date),
        # recorded by scan_mono_ty. Emit here, post buffer-redirect, like lists.
        mut vdi = 0
        while vdi < self.value_dict_elems.len:
            mut spec = self.value_dict_elems.get(vdi)
            mut bar = spec.index_of("|")
            if bar > 0:
                self.ensure_dict_type(spec.slice(0, bar), spec.slice(bar + 1, spec.length()))
            vdi = vdi + 1
        mut vsi = 0
        while vsi < self.value_set_elems.len:
            self.ensure_set_type(self.value_set_elems.get(vsi))
            vsi = vsi + 1
        mut ci = 0
        while ci < prog.classes.len:
            mut cls = prog.classes.get(ci)
            # Non-generic @value_type classes are stored inline in List_<Name>;
            # ensure that list type eagerly. GENERIC value types (`Box[T]`) are
            # NOT ensured here — `T` is unresolved (would emit `struct Box { T v }`);
            # their list types are ensured per-monomorphization in scan_mono_ty.
            if not cls.is_class and cls.generics.len == 0:
                self.ensure_list_type(cls.name)
            mut fi = 0
            while fi < cls.fields.len:
                self.check_and_emit_list_fwd(cls.fields.get(fi).ty)
                fi = fi + 1
            ci = ci + 1
        mut ei = 0
        while ei < prog.enums.len:
            mut enm = prog.enums.get(ei)
            mut vi = 0
            while vi < enm.variants.len:
                mut v = enm.variants.get(vi)
                mut vfi = 0
                while vfi < v.fields.len:
                    self.check_and_emit_list_fwd(v.fields.get(vfi).ty)
                    vfi = vfi + 1
                vi = vi + 1
            ei = ei + 1

    # -- Type mapping ----------------------------------------------------------

    pub def type_to_c(self, ty: AstType) -> str:
        if ty as usize == 0 as usize: return "void"
        mut n: str = ty.name
        if n == "" or n == "void" or n == "None": return "void"

        # Gap 4: 'ref T' and 'mut ref T' are transparent wrappers - map to inner type
        if (n == "ref" or n == "mut_ref") and ty.args.len > 0:
            return self.type_to_c(ty.args.get(0).read())

        # Fixed-size array [T; N]: a zero-cost VALUE-type struct wrapping a C array
        # (stack-allocated, no ARC). Emitted once as _TrArr_<Tsfx>_<N>.
        if n == "Array" and ty.array_size > 0 and ty.args.len > 0:
            return self.ensure_array_type(ty)

        # Function-pointer type (def(...)->R): stored as a void* function pointer.
        # Zero-cost: the call site casts back to the exact signature before calling.
        if n == "def": return "void*"

        # Check active type substitution first (used during monomorphization)
        if self.type_subst.contains(n): return self.type_subst.get(n)

        # Resolve user type aliases: `type Name = Target` -> resolve to Target C type
        if self.type_alias_map.contains(n): return self.type_alias_map.get(n)

        if n == "int" or n == "i64" or n == "isize": return "long long"
        if n == "i32": return "int"
        if n == "i16": return "short"
        if n == "i8": return "signed char"
        if n == "u64" or n == "usize": return "unsigned long long"
        if n == "u32": return "unsigned int"
        if n == "u16": return "unsigned short"
        if n == "u8": return "unsigned char"
        if n == "f64" or n == "float": return "double"
        if n == "f32": return "float"
        if n == "bool": return "bool"
        if n == "char": return "char"
        if _is_str_type(n): return "TrStr"

        # FFI / C interop types
        if n == "c_int": return "int"
        if n == "c_long": return "long"
        if n == "c_longlong": return "long long"
        if n == "c_uint": return "unsigned int"
        if n == "c_ulong": return "unsigned long"
        if n == "c_ulonglong": return "unsigned long long"
        if n == "c_short": return "short"
        if n == "c_ushort": return "unsigned short"
        if n == "c_char": return "char"
        if n == "c_uchar": return "unsigned char"
        if n == "c_schar": return "signed char"
        if n == "c_float": return "float"
        if n == "c_double": return "double"
        if n == "c_ldouble": return "long double"
        if n == "c_void_ptr" or n == "RawPtr": return "void*"
        if n == "c_size_t": return "size_t"
        if n == "c_ssize_t": return "ssize_t"
        if n == "c_ptrdiff_t": return "ptrdiff_t"
        if n == "c_intptr_t": return "intptr_t"
        if n == "c_uintptr_t": return "uintptr_t"
        if n == "c_int8_t": return "int8_t"
        if n == "c_int16_t": return "int16_t"
        if n == "c_int32_t": return "int32_t"
        if n == "c_int64_t": return "int64_t"
        if n == "c_uint8_t": return "uint8_t"
        if n == "c_uint16_t": return "uint16_t"
        if n == "c_uint32_t": return "uint32_t"
        if n == "c_uint64_t": return "uint64_t"
        if n == "CFile" or n == "c_FILE": return "FILE*"
        if n == "CString": return "char*"

        # Check if it's a generic type parameter in current function
        if self.cur_func != "":
            if self.functions.contains(self.cur_func):
                mut f = self.functions.get(self.cur_func)
                mut gi = 0
                while gi < f.generics.len:
                    if f.generics.get(gi) == n: return "void*"
                    gi = gi + 1

        # Check if it's a generic type parameter in the current class
        if self.cur_class != "":
            mut base_cls_n = self.cur_class
            mut u_idx = 0
            mut cp = self.cur_class as Pointer[char]
            while cp.offset(u_idx).read() as int != 0:
                if cp.offset(u_idx).read() as int == 95: # '_'
                    base_cls_n = self.cur_class.slice(0, u_idx)
                    break
                u_idx = u_idx + 1
            if self.classes.contains(base_cls_n):
                mut cls_def = self.classes.get(base_cls_n)
                mut gi = 0
                while gi < cls_def.generics.len:
                    if cls_def.generics.get(gi) == n: return "void*"
                    gi = gi + 1

        if n == "Pointer":
            if ty.args.len > 0:
                mut inner = ty.args.get(0).read()
                mut it = self.type_to_c(inner)
                if it == "void": return "void*"
                return it + "*"
            return "void*"

        # User-defined generic class takes precedence over built-in Vec/Map/List
        # Exclude built-in concurrency types - they always map to their runtime _Tr* handles
        if self.classes.contains(n) and n != "Vec" and n != "Map" and n != "Dict" and n != "List" and not self.is_rt_concurrency_type(n):
            mut ucls = self.classes.get(n)
            mut is_val = self.value_types.contains(n)
            if ucls.generics.len > 0 and ty.args.len > 0:
                mut sfx = self.type_args_suffix(ty.args)
                self.ensure_mono(ucls, ty.args)
                if is_val: return n + "_" + sfx
                return n + "_" + sfx + "*"
            # Inside a monomorphized body, synthesize suffix from active type_subst
            if ucls.generics.len > 0:
                mut sfx2 = self.synth_class_suffix(ucls)
                if sfx2 != "":
                    if is_val: return n + "_" + sfx2
                    return n + "_" + sfx2 + "*"
            if is_val: return n
            return n + "*"

        if n == "List":
            if ty.args.len > 0:
                mut elem = ty.args.get(0).read()
                # Generic value-type element (`List[Box[int]]`): inline-store the
                # MONOMORPHIZED struct (`List_Box_i64`), not the base name.
                if self.value_types.contains(elem.name) and elem.args.len > 0 and self.classes.contains(elem.name):
                    self.ensure_mono(self.classes.get(elem.name), elem.args)
                    return "List_" + elem.name + "_" + self.type_args_suffix(elem.args) + "*"
                mut sfx = self.list_elem_suffix(elem.name)
                if sfx == "ptr": return "List_ptr*"
                return "List_" + self.list_sfx(sfx) + "*"
            return "List_ptr*"

        if n == "Vec":
            if ty.args.len > 0:
                mut elem = ty.args.get(0).read()
                if self.value_types.contains(elem.name) and elem.args.len > 0 and self.classes.contains(elem.name):
                    self.ensure_mono(self.classes.get(elem.name), elem.args)
                    return "List_" + elem.name + "_" + self.type_args_suffix(elem.args) + "*"
                mut sfx = self.list_elem_suffix(elem.name)
                if sfx == "ptr": return "List_ptr*"
                return "List_" + self.list_sfx(sfx) + "*"
            return "List_ptr*"

        if n == "Map" or n == "Dict":
            # Map[K, V] / Dict[K, V]: first type arg is the key type.
            # int key -> TrIDict*, anything else (str, ...) -> TrMap*.
            if ty.args.len > 0:
                mut ka = ty.args.get(0).read()
                mut kc = "str"
                if _is_int_type(ka.name) or ka.name == "int" or ka.name == "i64" or ka.name == "usize": kc = "i64"
                # Value-type VALUE -> typed inline dict (Dict_<kc>_<Vname>), stores
                # the struct by value (no void* boxing). Non-generic value types only.
                if ty.args.len > 1:
                    mut va = ty.args.get(1).read()
                    if self.value_types.contains(va.name) and va.args.len == 0:
                        return "Dict_" + kc + "_" + va.name + "*"
                if kc == "i64": return "TrIDict*"
            return "TrMap*"

        if n == "Set":
            # Set[int] -> int-keyed set; everything else -> string-keyed set
            if ty.args.len > 0:
                mut se = ty.args.get(0).read()
                # Value-type element -> typed inline set (Set_<Vname>).
                if self.value_types.contains(se.name) and se.args.len == 0:
                    return "Set_" + se.name + "*"
                if _is_int_type(se.name) or se.name == "int" or se.name == "i64" or se.name == "usize":
                    return "_TrISet*"
                # Heap-class element -> pointer-identity set (owns + releases elements).
                if self.is_heap_class_tn(se.name):
                    return "_TrPtrSet*"
            return "_TrSet*"

        if n == "Chan": return "_TrChan*"
        if n == "Mutex": return "_TrMutexBox*"
        if n == "RwLock": return "_TrRWLBox*"
        if n == "ThreadPool": return "_TrThreadPool*"
        if n == "Thread": return "_TrThreadObj*"
        if n == "Atomic": return "_TrAtomic*"
        if n == "ThreadLocal": return "_TrTLS*"
        if n == "Shared": return "_TrSharedBox*"
        if n == "Weak": return "_TrWeakBox*"

        if n == "Tuple" or n == "tuple": return "TrTuple"

        if n == "Result": return "Result"
        if n == "Option": return "Option"
        if n == "lambda": return "void*"
        if self.enums.contains(n): return n
        if self.interfaces.contains(n):
            mut gi_iface = self.interfaces.get(n)
            if gi_iface.generics.len > 0 and ty.args.len > 0:
                return n + "_" + self.type_args_suffix(ty.args) + "_obj"
            return n + "_obj"
        return n + "*"

    pub def type_suffix(self, n: str) -> str:
        if n == "int" or n == "i64": return "i64"
        if n == "i32": return "i32"
        if n == "i16": return "i16"
        if n == "i8": return "i8"
        if n == "u64" or n == "usize": return "u64"
        if n == "u32": return "u32"
        if n == "u16": return "u16"
        if n == "u8": return "u8"
        if n == "f64" or n == "float": return "f64"
        if n == "f32": return "f32"
        if n == "bool": return "bool"
        if n == "char": return "char"
        if _is_str_type(n): return "str"
        mut np = n as Pointer[char]
        mut nlen = 0
        while np.offset(nlen).read() as int != 0: nlen = nlen + 1
        if nlen > 0:
            if np.offset(nlen - 1).read() as int == 42: # '*'
                return n.slice(0, nlen - 1) + "_ptr"
        return n

    pub def list_elem_suffix(self, n: str) -> str:
        mut actual_n = n
        if self.type_subst.contains(n):
            mut cv = self.type_subst.get(n)
            if cv == "long long": actual_n = "int"
            elif cv == "double": actual_n = "float"
            elif cv == "char*": actual_n = "str"
            elif cv == "TrStr": actual_n = "str"
            elif cv == "bool": actual_n = "bool"
            elif cv == "char": actual_n = "char"
            elif cv == "unsigned long long": actual_n = "u64"
            elif cv == "unsigned int": actual_n = "u32"
            elif cv == "int": actual_n = "i32"
            elif cv == "short": actual_n = "i16"
            elif cv == "signed char": actual_n = "i8"
            elif cv == "float": actual_n = "f32"
        # Builtin tuple as a list element: stored by value as TrTuple.
        # List_TrTuple is predefined in the runtime header, so no ensure here.
        if actual_n == "Tuple" or actual_n == "tuple":
            return "TrTuple"
        mut sfx = self.type_suffix(actual_n)
        if sfx == "i64" or sfx == "f64" or sfx == "str" or sfx == "bool" or sfx == "i8" or sfx == "i32" or sfx == "char" or sfx == "u8" or sfx == "u32":
            return sfx
        if self.enums.contains(actual_n) or self.value_types.contains(actual_n):
            # Enums and @value_type classes are stored BY VALUE inline in the list
            # (List_<Name>), exactly like a primitive — no per-element heap box.
            self.ensure_list_type(actual_n)
            return actual_n
        return "ptr"

    # List[T]/Vec[T] use a refcounted-string element representation
    # (List_TrStr) for str elements, distinct from the char*-based
    # "str" suffix used by Set/Dict codegen (set_elem/dict_key_arg/
    # gen_args_strify). Map "str" -> "TrStr" for List/Vec-only codegen
    # paths; all other suffixes pass through unchanged.
    pub def list_sfx(self, elem_sfx: str) -> str:
        if elem_sfx == "str": return "TrStr"
        return elem_sfx



    pub def type_args_suffix(self, args: Vec[Pointer[AstType]]) -> str:
        mut sfx = ""
        mut i = 0
        while i < args.len:
            if i > 0: sfx = sfx + "_"
            mut arg_ty = args.get(i).read()
            mut arg_name = arg_ty.name
            # Nested user generic class arg (e.g. Box[Box[int]]): recurse so the
            # inner type args aren't lost (otherwise Box[int] and Box[str] would
            # both collapse to suffix "Box" and collide). Also ensure the inner
            # monomorphization is emitted.
            if (not self.type_subst.contains(arg_name)) and arg_ty.args.len > 0 and self.classes.contains(arg_name) and arg_name != "Vec" and arg_name != "Map" and arg_name != "Dict" and arg_name != "List" and not self.is_rt_concurrency_type(arg_name):
                self.ensure_mono(self.classes.get(arg_name), arg_ty.args)
                sfx = sfx + arg_name + "_" + self.type_args_suffix(arg_ty.args)
                i = i + 1
                continue
            # Apply active type substitution (e.g., T -> long long during mono gen)
            if self.type_subst.contains(arg_name):
                mut concrete = self.type_subst.get(arg_name)
                # Map C type back to a type_suffix-friendly name
                if concrete == "long long": arg_name = "int"
                elif concrete == "double": arg_name = "float"
                elif concrete == "char*": arg_name = "str"
                elif concrete == "TrStr": arg_name = "str"
                elif concrete == "bool": arg_name = "bool"
                elif concrete == "char": arg_name = "char"
                elif concrete == "unsigned long long": arg_name = "u64"
                elif concrete == "unsigned int": arg_name = "u32"
                elif concrete == "int": arg_name = "i32"
                elif concrete == "short": arg_name = "i16"
                elif concrete == "signed char": arg_name = "i8"
                elif concrete == "float": arg_name = "f32"
                else:
                    # A generic param bound to a user-class/struct pointer, e.g. the T of
                    # Box[Box[int]] is "Box_i64*". Its mono suffix is the POINTEE struct
                    # name (Box_i64) — matching how the outer type's struct is named via
                    # the nested-type recursion above — not "Box_i64_ptr" (which
                    # type_suffix would yield for a trailing '*').
                    if concrete.ends_with("*"):
                        arg_name = concrete.slice(0, concrete.len() - 1)
                    else:
                        arg_name = concrete
            sfx = sfx + self.type_suffix(arg_name)
            i = i + 1
        return sfx

    # Synthesize a monomorphized suffix for a generic class using active type_subst.
    # Returns "" when not all generics are covered by type_subst (non-mono context).
    pub def synth_class_suffix(self, ucls: HirClass) -> str:
        mut sfx = ""
        mut gi = 0
        while gi < ucls.generics.len:
            mut gp = ucls.generics.get(gi)
            if not self.type_subst.contains(gp): return ""
            if gi > 0: sfx = sfx + "_"
            mut cv = self.type_subst.get(gp)
            mut tn = cv
            if cv == "long long": tn = "int"
            elif cv == "double": tn = "float"
            elif cv == "char*": tn = "str"
            elif cv == "TrStr": tn = "str"
            elif cv == "bool": tn = "bool"
            elif cv == "char": tn = "char"
            elif cv == "unsigned long long": tn = "u64"
            elif cv == "unsigned int": tn = "u32"
            elif cv == "int": tn = "i32"
            elif cv == "short": tn = "i16"
            elif cv == "signed char": tn = "i8"
            elif cv == "float": tn = "f32"
            sfx = sfx + self.type_suffix(tn)
            gi = gi + 1
        return sfx

    # Ensure a monomorphized version of cls is generated into mono_buf.
    # Safe to call multiple times - guarded by mono_done map.
    # Emit (once) the value-type struct for a fixed-size array [T; N] and return its
    # C name (_TrArr_<Tsfx>_<N>). A plain C array can't be a uniform type prefix, so we
    # wrap it in a struct — giving value semantics (copyable, passable) and a clean
    # `.data[i]` index. No __rc: it's a stack value, never refcounted.
    pub def ensure_array_type(self, ty: AstType) -> str:
        mut elem = ty.args.get(0).read()
        mut elem_c = self.type_to_c(elem)
        mut sfx = self.type_args_suffix(ty.args)
        mut nm = "_TrArr_" + sfx + "_" + ty.array_size.to_str()
        if not self.mono_done.contains(nm):
            self.mono_done.insert(nm, true)
            self.value_types.insert(nm, true)
            mut old_buf  = self.buf
            mut old_sbuf = self.struct_buf
            mut old_pbuf = self.proto_buf
            self.buf        = self.mono_buf
            self.struct_buf = self.mono_buf
            self.proto_buf  = self.mono_buf
            self.w("typedef struct " + nm + " { " + elem_c + " data[" + ty.array_size.to_str() + "]; } " + nm + ";\n")
            self.buf        = old_buf
            self.struct_buf = old_sbuf
            self.proto_buf  = old_pbuf
        return nm

    pub def ensure_mono(self, cls: HirClass, type_args: Vec[Pointer[AstType]]):
        mut sfx = self.type_args_suffix(type_args)
        mut mono_key = cls.name + "_" + sfx
        if self.mono_done.contains(mono_key): return
        self.mono_done.insert(mono_key, true)

        mut mono_name = cls.name + "_" + sfx
        # Generic VALUE type: the monomorphized instance (`Box_i64`) is also a
        # value type — register it so every value-type codegen site (construction,
        # field access via `.`, by-value self, no-drop, inline list storage)
        # recognizes the mono name, not just the base generic name (`Box`).
        if self.value_types.contains(cls.name):
            self.value_types.insert(mono_name, true)

        # Pre-resolve type arguments using active parent substitutions
        mut resolved_args = Vec[str].init(type_args.len)
        mut i = 0
        while i < type_args.len:
            resolved_args.push(self.type_to_c(type_args.get(i).read()))
            i = i + 1

        # Set up type substitution: generic param -> concrete C type
        mut old_subst = self.type_subst
        self.type_subst = Map[str, str].init(8)
        i = 0
        while i < cls.generics.len and i < resolved_args.len:
            mut param = cls.generics.get(i)
            mut concrete = resolved_args.get(i)
            self.type_subst.insert(param, concrete)
            i = i + 1

        # Redirect writes to mono_buf so output is collected for flushing later
        mut old_buf      = self.buf
        mut old_sbuf     = self.struct_buf
        mut old_pbuf     = self.proto_buf
        self.buf         = self.mono_buf
        self.struct_buf  = self.mono_buf
        self.proto_buf   = self.mono_buf

        # Forward declaration
        self.w("typedef struct " + mono_name + " " + mono_name + ";\n")

        # Struct body — heap monos carry the ARC refcount at offset 0 (must match
        # gen_class_struct, since _tr_obj_alloc writes __rc there). Value-type
        # monos are stack `(mn){0}` and get none.
        self.w("typedef struct " + mono_name + " {\n")
        mut _mono_vt = self.value_types.contains(cls.name)
        if not _mono_vt:
            self.w("    size_t __rc;\n")
        mut fi = 0
        while fi < cls.fields.len:
            mut f = cls.fields.get(fi)
            self.w("    " + self.type_to_c(f.ty) + " " + f.name + ";\n")
            fi = fi + 1
        if cls.fields.len == 0 and _mono_vt:
            self.w("    char _pad;\n")
        self.w("} " + mono_name + ";\n\n")

        # Method prototypes then bodies
        mut mi = 0
        while mi < cls.methods.len:
            mut m = cls.methods.get(mi)
            mut old_class = self.cur_class
            mut old_func  = self.cur_func
            self.cur_class = mono_name
            self.cur_func  = m.name
            mut sig = self.get_inline_attrs(m) + self.gen_func_sig(m, mono_name)
            self.w(sig + ";\n")
            mi = mi + 1
        # Method bodies -> fn_mono_body (flushed after ALL prototypes) so a mono method
        # that calls a regular function/method declared later (e.g. self.field.show() on
        # a T-typed field where T=Cat -> Cat_show) resolves. `static` keeps it multi-TU
        # safe. Prototypes above stay in mono_buf (early).
        mi = 0
        mut _cmb_obuf  = self.buf
        mut _cmb_osbuf = self.struct_buf
        mut _cmb_opbuf = self.proto_buf
        self.buf        = self.fn_mono_body
        self.struct_buf = self.fn_mono_body
        self.proto_buf  = self.fn_mono_body
        while mi < cls.methods.len:
            mut m = cls.methods.get(mi)
            mut old_class = self.cur_class
            mut old_func  = self.cur_func
            self.cur_class = mono_name
            self.cur_func  = m.name
            self.decl_vars = Map[str, bool].init(64)
            self.str_local_names = Map[str, bool].init(16)
            self.coll_local_sfx = Map[str, str].init(16)
            self.coll_local_idict = Map[str, bool].init(16)
            self.coll_local_strval = Map[str, bool].init(16)
            self.coll_local_vtcoll = Map[str, str].init(16)
            self.seed_params(m)
            self.cur_self_is_ptr = self.value_types.contains(mono_name) and self.vt_method_mutates_self(m)
            mut sig = self.get_inline_attrs(m) + self.gen_func_sig(m, mono_name)
            self.w(sig + " {\n")
            self.gen_func_body(m.body, 1)
            self.cur_self_is_ptr = false
            self.w("}\n\n")
            self.cur_class = old_class
            self.cur_func  = old_func
            mi = mi + 1
        self.fn_mono_body = self.buf
        self.buf        = _cmb_obuf
        self.struct_buf = _cmb_osbuf
        self.proto_buf  = _cmb_opbuf

        # Generate monomorphized interface vtable + wrapper for each implemented interface.
        # type_subst is still active here so type_to_c substitutes T->concrete correctly.
        if cls.iface_names as usize != 0 as usize and not _is_invalid_ptr(cls.iface_names as usize):
            mut ifw_i = 0
            while ifw_i < cls.iface_names.len:
                mut iface_base = cls.iface_names.get(ifw_i)
                if self.interfaces.contains(iface_base):
                    mut m_iface = self.interfaces.get(iface_base)
                    if not _is_invalid_ptr(m_iface as usize):
                        mut mono_iface_name = iface_base
                        if m_iface.generics.len > 0:
                            mono_iface_name = iface_base + "_" + sfx
                        # Emit vtable struct + obj typedef once per monomorphized interface name
                        mut vtbl_done_key = "iface_obj_" + mono_iface_name
                        if not self.emitted_fns.contains(vtbl_done_key):
                            self.emitted_fns.insert(vtbl_done_key, true)
                            self.w("typedef struct _" + mono_iface_name + "_vtable {\n")
                            mut vmi = 0
                            while vmi < m_iface.methods.len:
                                mut vm2 = m_iface.methods.get(vmi)
                                mut vret2 = self.type_to_c(vm2.ret_ty)
                                self.w("    " + vret2 + " (*" + vm2.name + ")(void* self")
                                mut vpi = 0
                                while vpi < vm2.params.len:
                                    mut vp2 = vm2.params.get(vpi)
                                    if vp2.name != "self":
                                        self.w(", " + self.type_to_c(vp2.ty) + " " + vp2.name)
                                    vpi = vpi + 1
                                self.w(");\n")
                                vmi = vmi + 1
                            self.w("} " + mono_iface_name + "_vtable;\n\n")
                            self.w("typedef struct { " + mono_iface_name + "_vtable* vtable; void* data; } " + mono_iface_name + "_obj;\n\n")
                        # Emit wrapper function once per class+interface pair
                        mut wrap_done_key = "iface_wrap_" + mono_name + "_" + mono_iface_name
                        if not self.emitted_fns.contains(wrap_done_key):
                            self.emitted_fns.insert(wrap_done_key, true)
                            self.w("static inline " + mono_iface_name + "_obj " + mono_name + "_as_" + mono_iface_name + "(" + mono_name + "* self) {\n")
                            self.w("    static const " + mono_iface_name + "_vtable _vtbl_" + mono_name + "_" + mono_iface_name + " = {\n")
                            mut wm_i = 0
                            while wm_i < m_iface.methods.len:
                                mut wm2 = m_iface.methods.get(wm_i)
                                mut wret_c2 = self.type_to_c(wm2.ret_ty)
                                mut wcast2 = wret_c2 + "(*)(void*"
                                mut wp_i = 0
                                while wp_i < wm2.params.len:
                                    mut wp2 = wm2.params.get(wp_i)
                                    if wp2.name != "self":
                                        wcast2 = wcast2 + ", " + self.type_to_c(wp2.ty)
                                    wp_i = wp_i + 1
                                wcast2 = wcast2 + ")"
                                self.w("        ." + wm2.name + " = (" + wcast2 + ")(" + mono_name + "_" + wm2.name + "),\n")
                                wm_i = wm_i + 1
                            self.w("    };\n")
                            self.w("    return (" + mono_iface_name + "_obj){ .vtable = (" + mono_iface_name + "_vtable*)&_vtbl_" + mono_name + "_" + mono_iface_name + ", .data = (void*)self };\n")
                            self.w("}\n\n")
                ifw_i = ifw_i + 1

        # Save back the (possibly realloc-grown) mono buffer before restoring.
        # self.buf IS the mono buffer; without this, mono_buf.ptr becomes stale
        # after any realloc during generation and causes an access violation at flush time.
        self.mono_buf   = self.buf
        self.buf        = old_buf
        self.struct_buf = old_sbuf
        self.proto_buf  = old_pbuf
        self.type_subst = old_subst

    # Infer the single type argument of a generic free function from its call args,
    # by matching a parameter declared directly as the type param (x: T) against the
    # actual arg type. Returns the concrete type NAME (Cat / int / str) or "" when it
    # can't be inferred / isn't an eligible single-generic free function. Under an
    # active substitution (a call inside another mono body) the arg type resolves
    # through it, so _map_hash(key,..) inside Map_str picks up "str".
    pub def infer_generic_targ(self, fname: str, args: Vec[Pointer[HirExpr]]) -> str:
        if not self.functions.contains(fname): return ""
        mut fd = self.functions.get(fname)
        if fd.class_name != "" or fd.generics.len != 1: return ""
        if fd.params as usize == 0 as usize: return ""
        mut sk = 0
        if fd.params.len > 0 and fd.params.get(0).name == "self": sk = 1
        mut gp = fd.generics.get(0)
        mut targ = ""
        mut pi = 0
        while pi < fd.params.len:
            mut pp = fd.params.get(pi)
            if pp.name != "self" and pp.ty.name == gp:
                mut aidx = pi - sk
                if aidx >= 0 and aidx < args.len:
                    targ = self.resolve_generic_tyname(hir_expr_type(args.get(aidx)).name)
            pi = pi + 1
        if targ == "void" or targ == gp or targ == "": return ""
        return targ

    # Ensure a monomorphized copy of a generic free function is generated. The
    # PROTOTYPE goes into mono_buf (flushed early, only forward-declared types
    # needed); the BODY goes into fn_mono_body (flushed after all prototypes, so
    # calls to other functions resolve). Both are `static` so the copy can live in
    # the shared header without a multi-TU duplicate-symbol clash — exactly like the
    # generic-class method monos.
    pub def ensure_mono_func(self, fname: str, targ: str):
        mut mono_key = "func_" + fname + "__MONO_" + targ
        if self.mono_done.contains(mono_key): return
        self.mono_done.insert(mono_key, true)
        if not self.functions.contains(fname): return
        mut f = self.functions.get(fname)
        if f.generics.len == 0: return
        mut type_param = f.generics.get(0)
        mut concrete_c = self.type_to_c(AstType.init(targ))
        mut old_subst = self.type_subst
        self.type_subst = Map[str, str].init(4)
        self.type_subst.insert(type_param, concrete_c)
        mut old_buf = self.buf
        mut old_sbuf = self.struct_buf
        mut old_pbuf = self.proto_buf
        mut mono_fname = fname + "__MONO_" + targ
        mut ret_s = self.type_to_c(f.ret_ty)
        mut sig = "static __attribute__((hot)) " + ret_s + " " + mono_fname + "("
        mut first = true
        mut pi = 0
        while pi < f.params.len:
            mut p = f.params.get(pi)
            if p.name != "self":
                if not first: sig = sig + ", "
                sig = sig + self.type_to_c(p.ty) + " " + _safe_c_varname(p.name)
                first = false
            pi = pi + 1
        sig = sig + ")"
        # Prototype -> mono_buf (early).
        self.buf        = self.mono_buf
        self.struct_buf = self.mono_buf
        self.proto_buf  = self.mono_buf
        self.w(sig + ";\n")
        self.mono_buf = self.buf
        # Body -> fn_mono_body (after prototypes).
        self.buf        = self.fn_mono_body
        self.struct_buf = self.fn_mono_body
        self.proto_buf  = self.fn_mono_body
        mut old_class = self.cur_class
        mut old_func = self.cur_func
        self.cur_class = ""
        self.cur_func = mono_fname
        self.decl_vars = Map[str, bool].init(64)
        self.str_local_names = Map[str, bool].init(16)
        self.coll_local_sfx = Map[str, str].init(16)
        self.coll_local_idict = Map[str, bool].init(16)
        self.coll_local_strval = Map[str, bool].init(16)
        self.coll_local_vtcoll = Map[str, str].init(16)
        self.seed_params(f)
        # extend-block methods are free functions carrying class_name; a mutating
        # @value_type method here takes a pointer self -> `self->field` in the body.
        self.cur_self_is_ptr = f.class_name != "" and self.value_types.contains(f.class_name) and self.vt_method_mutates_self(f)
        self.w(sig + " {\n")
        self.gen_func_body(f.body, 1)
        self.cur_self_is_ptr = false
        self.w("}\n\n")
        self.cur_class = old_class
        self.cur_func = old_func
        self.fn_mono_body = self.buf
        self.buf = old_buf
        self.struct_buf = old_sbuf
        self.proto_buf = old_pbuf
        self.type_subst = old_subst

    # -- Attributes & signatures -----------------------------------------------

    pub def get_user_decorator_attr(self, name: str) -> str:
        if not self.decorator_defs.contains(name): return ""
        mut df = self.decorator_defs.get(name)
        # A decorator body with a single return of a string literal -> use as C attribute suffix
        if df.body.stmts.len == 1:
            match df.body.stmts.get(0).read():
                case HirStmt.SReturn(rv):
                    if rv as usize != 0 as usize:
                        match rv.read():
                            case HirExpr.ELitStr(attr_s, _):
                                return "__attribute__((" + attr_s + ")) "
                            case _: pass
                case _: pass
        return ""

    # First string argument of a decorator (e.g. @section("x") -> "x"), or "".
    pub def deco_first_str(self, d: Decorator) -> str:
        if d.args.len == 0: return ""
        match d.args.get(0).read():
            case Expr.ELitStr(v): return v
            case _: return ""

    # Bare-metal / low-level codegen attributes from decorators: @naked, @interrupt,
    # @used, and @section("name") -> a combined GCC __attribute__((...)) prefix, or ""
    # if the function carries none. Emitted WITHOUT `static` so a reset entry / ISR /
    # sectioned symbol stays linkable (referenced from a vector table or the linker).
    pub def hw_attrs(self, f: HirFunction) -> str:
        mut parts = Vec[str].init(0)
        mut i = 0
        while i < f.decorators.len:
            mut d = f.decorators.get(i)
            if d.name == "naked": parts.push("naked")
            elif d.name == "interrupt": parts.push("interrupt")
            elif d.name == "used": parts.push("used")
            elif d.name == "section":
                mut s = self.deco_first_str(d)
                if s != "": parts.push("section(\"" + s + "\")")
            i = i + 1
        if parts.len == 0: return ""
        mut body = parts.get(0)
        mut j = 1
        while j < parts.len:
            body = body + "," + parts.get(j)
            j = j + 1
        return "__attribute__((" + body + ")) "

    # The #define wiring a runtime pluggable macro to a user function `f`, if `f`
    # carries a hook decorator (@allocator/@free/@realloc/@calloc/@output); else "".
    # Lets a bare-metal program supply its allocator + output sink in pure Tauraro —
    # no C hooks header. Hook fns must use basic C types (usize, Pointer[u8],
    # Pointer[char]) so the forward-decl is valid before the runtime include.
    pub def hook_macro_for(self, f: HirFunction) -> str:
        mut i = 0
        mut nm = f.name
        while i < f.decorators.len:
            mut d = f.decorators.get(i).name
            if d == "allocator": return "#define TAURARO_ALLOC(sz) " + nm + "(sz)\n"
            if d == "free":      return "#define TAURARO_FREE(p) " + nm + "(p)\n"
            if d == "realloc":   return "#define TAURARO_REALLOC(p,sz) " + nm + "(p,sz)\n"
            if d == "calloc":    return "#define TAURARO_CALLOC(n,sz) " + nm + "(n,sz)\n"
            if d == "output":    return "#define _TR_WRITE(s) " + nm + "(s)\n"
            i = i + 1
        return ""

    # Prologue text (forward-decls + #defines) wiring every hook function in `prog`
    # to the runtime macros. Emitted before the runtime include.
    pub def emit_tier_hooks(self, prog: HirProgram) -> str:
        mut fwd = ""
        mut defs = ""
        mut i = 0
        while i < prog.functions.len:
            mut f = prog.functions.get(i)
            if not _is_invalid_ptr(f as usize):
                mut hm = self.hook_macro_for(f)
                if hm != "":
                    fwd = fwd + self.gen_func_sig(f, "") + ";\n"
                    defs = defs + hm
            i = i + 1
        return fwd + defs

    # Emit the top-level global-initializer statements (assignments to hoisted globals
    # + any module-scope code) — the SAME logic main() runs inline. Shared so the
    # @entry reset trampoline initializes globals too: @entry boots past main(), so
    # without this a non-zero global initializer (mut x: usize = 0x...) stays at its
    # .bss zero (a silent HardFault). Writes via self.w.
    pub def emit_global_inits(self, prog: HirProgram):
        if _is_invalid_ptr(prog as usize): return
        if _is_invalid_ptr(prog.top_level_stmts as usize): return
        mut i = 0
        while i < prog.top_level_stmts.len:
            mut _tlg = false
            match prog.top_level_stmts.get(i).read():
                case HirStmt.SLet(gn, _, _, _, _, _, gv):
                    if self.global_vars.contains(gn):
                        # File-scope globals are already declared (and zero-initialized
                        # by C static storage). With a value, run the initializer here in
                        # the boot path; without one, the static zero suffices. Either way
                        # never fall through to gen_stmt, which would re-declare (shadow)
                        # the global as a main-local (breaks cross-function globals, e.g.
                        # a `[u8; N]` arena shared with an @allocator).
                        if gv as usize != 0 as usize:
                            self.w("    " + gn + " = " + self.gen_expr(gv) + ";\n")
                        _tlg = true
                case _: pass
            if not _tlg:
                self.gen_stmt(prog.top_level_stmts.get(i), 1)
            i = i + 1

    # --freestanding @entry: emit a reset trampoline + Cortex-M .isr_vector table so
    # the user's @entry function is the boot entry — no hand-written startup.c. The
    # trampoline copies .data, zeroes .bss, runs the global initializers, then calls
    # the entry; the .bss/.data/_stack_top symbols come from the generated linker
    # script (--emit-ld). Writes nothing if the program has no @entry. Emitted after
    # all function defs (the entry fn is already in scope, so no forward decl needed).
    pub def emit_entry_glue(self, prog: HirProgram):
        mut entry = ""
        mut i = 0
        while i < prog.functions.len:
            mut f = prog.functions.get(i)
            if not _is_invalid_ptr(f as usize):
                mut j = 0
                while j < f.decorators.len:
                    if f.decorators.get(j).name == "entry": entry = f.name
                    j = j + 1
            i = i + 1
        if entry == "": return
        if self.bare_arch == "riscv":
            # RISC-V (qemu 'virt', loaded to RAM at 0x80000000): the ELF entry is
            # _start. It parks harts != 0, sets sp, then boots. .data is already in RAM
            # (loaded from the ELF), so only .bss needs clearing. No vector table.
            self.w("\n/* --freestanding @entry: RISC-V boot (qemu virt) */\n")
            self.w("extern unsigned _stack_top, __bss_start__, __bss_end__;\n")
            self.w("__attribute__((used)) void _tr_boot(void){\n")
            self.w("    unsigned *d;\n")
            self.w("    for(d=&__bss_start__; d<&__bss_end__;) *d++ = 0;\n")
            self.emit_global_inits(prog)
            self.w("    " + entry + "();\n")
            self.w("    for(;;){}\n}\n")
            self.w("__attribute__((naked, used, section(\".text.init\"))) void _start(void){\n")
            self.w("    __asm__ volatile(\n")
            self.w("        \"csrr t0, mhartid\\n\"\n")
            self.w("        \"bnez t0, 1f\\n\"\n")
            self.w("        \"la sp, _stack_top\\n\"\n")
            self.w("        \"call _tr_boot\\n\"\n")
            self.w("        \"1: wfi\\n\"\n")
            self.w("        \"j 1b\\n\"\n")
            self.w("    );\n")
            self.w("}\n")
            return
        self.w("\n/* --freestanding @entry: reset trampoline + Cortex-M vector table */\n")
        self.w("extern unsigned _stack_top, __bss_start__, __bss_end__, _sidata, _sdata, _edata;\n")
        self.w("__attribute__((used)) void _tr_reset(void){\n")
        self.w("    unsigned *d, *sp;\n")
        self.w("    for(d=&_sdata, sp=&_sidata; d<&_edata;) *d++ = *sp++;\n")
        self.w("    for(d=&__bss_start__; d<&__bss_end__;) *d++ = 0;\n")
        self.emit_global_inits(prog)
        self.w("    " + entry + "();\n")
        self.w("    for(;;){}\n}\n")
        self.w("__attribute__((used, section(\".isr_vector\")))\n")
        self.w("void* const _tr_isr_vector[] = { (void*)&_stack_top, (void*)_tr_reset };\n")

    pub def get_inline_attrs(self, f: HirFunction) -> str:
        mut hw = self.hw_attrs(f)
        if hw != "": return hw
        mut i = 0
        while i < f.decorators.len:
            if f.decorators.get(i).name == "inline": return "static inline __attribute__((always_inline,hot)) "
            if f.decorators.get(i).name == "hot": return "static __attribute__((hot)) "
            if f.decorators.get(i).name == "noinline": return "static __attribute__((noinline)) "
            mut user_attr = self.get_user_decorator_attr(f.decorators.get(i).name)
            if user_attr != "": return "static " + user_attr
            i = i + 1
        if f.name == "main" or f.name == "_tr_main":
            return "__attribute__((hot)) "
        if f.name == "init":
            # A value-type `init` returns the struct BY VALUE — `malloc` /
            # `returns_nonnull` are pointer-only attributes and are invalid here.
            if self.value_types.contains(f.class_name):
                return "static __attribute__((hot)) "
            return "static __attribute__((malloc,returns_nonnull,hot)) "
        return "static __attribute__((hot)) "

    pub def is_rt_concurrency_type(self, name: str) -> bool:
        if name == "Atomic": return true
        if name == "Thread": return true
        if name == "Mutex": return true
        if name == "RwLock": return true
        if name == "Chan": return true
        if name == "ThreadPool": return true
        if name == "ThreadLocal": return true
        return false

    # Like get_inline_attrs but without `static` - for cross-module prototypes in tauraro_types.h.
    pub def get_proto_attrs(self, f: HirFunction) -> str:
        mut hwp = self.hw_attrs(f)
        if hwp != "": return hwp
        mut i = 0
        while i < f.decorators.len:
            if f.decorators.get(i).name == "inline": return "inline __attribute__((always_inline,hot)) "
            if f.decorators.get(i).name == "hot": return "__attribute__((hot)) "
            if f.decorators.get(i).name == "noinline": return "__attribute__((noinline)) "
            mut user_attr_p = self.get_user_decorator_attr(f.decorators.get(i).name)
            if user_attr_p != "": return user_attr_p
            i = i + 1
        if f.name == "main" or f.name == "_tr_main":
            return "__attribute__((hot)) "
        if f.name == "init":
            if self.value_types.contains(f.class_name):
                return "__attribute__((hot)) "
            return "__attribute__((malloc,returns_nonnull,hot)) "
        return "__attribute__((hot)) "

    # True if this method writes `self.<field> = ...` anywhere in its body. A
    # @value_type method that mutates self must take `self` BY POINTER (else the
    # write hits a by-value copy and is lost).
    pub def vt_method_mutates_self(self, f: HirFunction) -> bool:
        return self.hir_block_mutates_self(f.body)

    # True when a call `recv.method(...)` targets a MUTATING @value_type method,
    # so the receiver must be passed by address (`&recv`).
    pub def vt_call_needs_ptr_self(self, class_name: str, method: str) -> bool:
        if not self.value_types.contains(class_name): return false
        if not self.classes.contains(class_name): return false
        mut cls = self.classes.get(class_name)
        mut i = 0
        while i < cls.methods.len:
            if cls.methods.get(i).name == method:
                return self.vt_method_mutates_self(cls.methods.get(i))
            i = i + 1
        return false

    pub def hir_block_mutates_self(self, block: HirBlock) -> bool:
        if _is_invalid_ptr(block as usize): return false
        if _is_invalid_ptr(block.stmts as usize): return false
        mut i = 0
        while i < block.stmts.len:
            if self.hir_stmt_mutates_self(block.stmts.get(i)): return true
            i = i + 1
        return false

    pub def hir_stmt_mutates_self(self, s: Pointer[HirStmt]) -> bool:
        if _is_invalid_ptr(s as usize): return false
        match s.read():
            case HirStmt.SAssign(tgt, _):
                match tgt.read():
                    case HirExpr.EPropAccess(o, _, _):
                        match o.read():
                            case HirExpr.EIdent(on, _, _):
                                if on == "self": return true
                            case _: pass
                    case _: pass
                return false
            case HirStmt.SIf(_, t, e):
                if self.hir_block_mutates_self(t): return true
                if not _is_invalid_ptr(e as usize): return self.hir_block_mutates_self(e)
                return false
            case HirStmt.SWhile(_, body): return self.hir_block_mutates_self(body)
            case HirStmt.SFor(_, _, body): return self.hir_block_mutates_self(body)
            case HirStmt.SForUnpack(_, _, body): return self.hir_block_mutates_self(body)
            case HirStmt.SUnsafe(body): return self.hir_block_mutates_self(body)
            case HirStmt.SWith(_, _, body): return self.hir_block_mutates_self(body)
            case HirStmt.SMatch(_, arms):
                mut ai = 0
                while ai < arms.len:
                    if self.hir_block_mutates_self(arms.get(ai).body): return true
                    ai = ai + 1
                return false
            case HirStmt.STry(tb, catches, fin):
                if self.hir_block_mutates_self(tb): return true
                if not _is_invalid_ptr(fin as usize):
                    if self.hir_block_mutates_self(fin): return true
                mut ci = 0
                while ci < catches.len:
                    if self.hir_block_mutates_self(catches.get(ci).read().body): return true
                    ci = ci + 1
                return false
            case _: return false

    pub def gen_func_sig(self, f: HirFunction, class_name: str) -> str:
        mut old_f = self.cur_func
        self.cur_func = f.name
        mut ret_ty_str = self.type_to_c(f.ret_ty)
        if f.throws_ty.name != "":
            ret_ty_str = "Result"
        mut fname = f.name
        if fname == "main": fname = "_tr_main"
        # Escape C reserved keywords used as function names
        if _is_c_keyword(fname): fname = "_tr_fn_" + fname
        if class_name != "":
            mut base_sig_key = class_name + "_" + fname
            if self.overloaded_sigs.contains(base_sig_key):
                # Mangle overloaded method: append _Narg suffix by non-self param count.
                mut param_count = 0
                mut opi = 0
                while opi < f.params.len:
                    if f.params.get(opi).name != "self": param_count = param_count + 1
                    opi = opi + 1
                fname = base_sig_key + "_" + param_count.to_str() + "arg"
            else:
                fname = base_sig_key
        # Monomorphized free function: emit under the specialized name (id -> id_i64).
        elif self.emit_fn_name != "":
            fname = self.emit_fn_name
        mut sig = ret_ty_str + " " + fname + "("
        # Exported (FFI) functions get a dllexport/visibility attribute so they
        # land in a shared library's exported symbol table. Only free functions
        # (no class) are exportable with a stable C name.
        if f.is_export and class_name == "":
            sig = "TR_EXPORT " + sig
        mut first = true

        if class_name != "" and not f.is_static:
            # A @value_type method that MUTATES self takes a pointer (writes must
            # persist). Otherwise enums and @value_type classes take `self` BY
            # VALUE; reference (heap) classes take a pointer.
            if self.value_types.contains(class_name) and self.vt_method_mutates_self(f):
                sig = sig + class_name + "* self"
            elif self.enums.contains(class_name) or self.value_types.contains(class_name):
                sig = sig + class_name + " self"
            else:
                sig = sig + class_name + "* self"
            first = false

        mut i = 0
        while i < f.params.len:
            mut p = f.params.get(i)
            if p.name != "self":
                if not first: sig = sig + ", "
                sig = sig + self.type_to_c(p.ty) + " " + _safe_c_varname(p.name)
                first = false
            i = i + 1

        if f.is_variadic:
            if not first: sig = sig + ", "
            sig = sig + "..."

        sig = sig + ")"
        self.cur_func = old_f
        return sig

    # -- Struct generation -----------------------------------------------------

    pub def emit_base_fields(self, base_name: str):
        if self.classes.contains(base_name):
            mut base_cls: HirClass = self.classes.get(base_name)
            mut bfi: int = 0
            while bfi < base_cls.fields.len:
                mut bf: HirField = base_cls.fields.get(bfi)
                self.ws("    " + self.type_to_c(bf.ty) + " " + bf.name + ";\n")
                bfi = bfi + 1

    # Forward-declare every per-class `_trdrop_T` before any is defined, so a
    # class whose _trdrop releases a class-typed field (calling another class's
    # _trdrop) compiles regardless of declaration order.
    pub def emit_drop_fwd_decls(self, prog: HirProgram):
        mut i = 0
        while i < prog.classes.len:
            mut c = prog.classes.get(i)
            if not _is_invalid_ptr(c as usize):
                if c.generics.len == 0 and not self.value_types.contains(c.name) and not self.has_method(c.name, "free"):
                    self.ws("static void " + self.obj_drop_fn(c.name) + "(void* vp);\n")
            i = i + 1
        self.ws("\n")

    pub def gen_class_struct(self, c: HirClass):
        self.ws("#ifndef " + c.name + "_STRUCT_DEFINED\n")
        self.ws("#define " + c.name + "_STRUCT_DEFINED\n")
        self.ws("typedef struct " + c.name + " {\n")
        # ARC refcount, first member (offset 0) for heap classes. Value types live
        # on the stack by value and need no refcount. Inherited via the base copy
        # is NOT duplicated: emit_base_fields copies only the base's HirFields.
        mut _is_vt = self.value_types.contains(c.name)
        if not _is_vt:
            self.ws("    size_t __rc;\n")
        # Emit inherited fields first (single-level inheritance via field copying)
        mut bi: int = 0
        while bi < c.base_classes.len:
            mut base_name: str = c.base_classes.get(bi)
            self.emit_base_fields(base_name)
            bi = bi + 1
        mut i: int = 0
        while i < c.fields.len:
            mut f: HirField = c.fields.get(i)
            self.ws("    " + self.type_to_c(f.ty) + " " + f.name + ";\n")
            i = i + 1
        if c.fields.len == 0 and c.base_classes.len == 0 and _is_vt:
            self.ws("    char _pad;\n")
        self.ws("} " + c.name + ";\n")
        # Field-drop for a refcounted plain class: releases owned str fields when
        # _tr_obj_release drives the count to zero. Value types (stack) and
        # user-free() classes are excluded (the latter self-manage). Emitted right
        # after the struct so it is defined before any function references it.
        if not _is_vt:
            mut _cs_has_free = false
            mut _csm = 0
            while _csm < c.methods.len:
                if c.methods.get(_csm).name == "free": _cs_has_free = true
                _csm = _csm + 1
            if not _cs_has_free:
                self.ws("static void " + self.obj_drop_fn(c.name) + "(void* vp) {\n")
                self.ws("    " + c.name + "* self = (" + c.name + "*)vp; (void)self;\n")
                mut _csf = 0
                while _csf < c.fields.len:
                    mut _csfld = c.fields.get(_csf)
                    if _csfld.ty.is_borrow:
                        # `ref T` field is a borrow — the object does not own it.
                        _csf = _csf + 1
                    elif _is_str_type(self.resolve_generic_prim(_csfld.ty.name)):
                        self.ws("    _tr_str_release(self->" + _safe_c_varname(_csfld.name) + ");\n")
                        _csf = _csf + 1
                    elif self.is_heap_class_tn(_csfld.ty.name):
                        # Owned heap-class field: recursively release it (its own
                        # _trdrop releases ITS str/class fields). Field stores co-own
                        # (retain), so this release is balanced. Pointer-aliased types
                        # (raw_aliased) are excluded by is_heap_class_tn.
                        self.ws("    _tr_obj_release(self->" + _safe_c_varname(_csfld.name) + ", " + self.obj_drop_fn(_csfld.ty.name) + ");\n")
                        _csf = _csf + 1
                    elif self._is_coll_type_name(_csfld.ty.name) and self.coll_field_owned.contains(c.name + "." + _csfld.name) and not self.coll_field_disq.contains(_csfld.name):
                        # Uniquely-owned collection field (only ever assigned a fresh
                        # collection, name never aliased): free it, releasing any owned
                        # heap-class elements/values. Aliased collection fields are left
                        # alone (collections aren't refcounted → freeing would double-free).
                        mut _cfree = self._coll_field_free_call("self->" + _safe_c_varname(_csfld.name), _csfld.ty)
                        if _cfree != "": self.ws("    " + _cfree + ";\n")
                        _csf = _csf + 1
                    else:
                        _csf = _csf + 1
                self.ws("}\n")
        self.ws("#endif\n\n")

    pub def gen_enum_struct(self, e: HirEnum):
        # Emit tag constants
        self.ws("typedef enum {\n")
        mut i = 0
        while i < e.variants.len:
            mut v = e.variants.get(i)
            self.ws("    " + e.name + "_" + v.name)
            if i < e.variants.len - 1: self.ws(",")
            self.ws("\n")
            i = i + 1
        if e.variants.len == 0:
            self.ws("    " + e.name + "_EMPTY\n")
        self.ws("} " + e.name + "_tag;\n\n")

        # Emit the tagged union struct
        self.ws("typedef struct " + e.name + " {\n")
        self.ws("    " + e.name + "_tag tag;\n")
        mut has_data = false
        i = 0
        while i < e.variants.len:
            if e.variants.get(i).fields.len > 0:
                has_data = true
            i = i + 1
        if has_data:
            self.ws("    union {\n")
            i = 0
            while i < e.variants.len:
                mut v = e.variants.get(i)
                if v.fields.len > 0:
                    self.ws("        struct {\n")
                    mut j = 0
                    while j < v.fields.len:
                        mut fld = v.fields.get(j)
                        self.ws("            " + self.type_to_c(fld.ty) + " " + _safe_c_varname(fld.name) + ";\n")
                        j = j + 1
                    self.ws("        } " + v.name + ";\n")
                i = i + 1
            self.ws("    } data;\n")
        self.ws("} " + e.name + ";\n\n")

        # Emit constructor macros for each variant
        i = 0
        while i < e.variants.len:
            mut v = e.variants.get(i)
            if v.fields.len == 0:
                self.ws("#define " + e.name + "_make_" + v.name + "() ((" + e.name + "){.tag=" + e.name + "_" + v.name + "})\n")
            else:
                self.ws("static inline __attribute__((always_inline)) " + e.name + " " + e.name + "_ctor_" + v.name + "(")
                mut j = 0
                while j < v.fields.len:
                    if j > 0: self.ws(", ")
                    self.ws(self.type_to_c(v.fields.get(j).ty) + " " + _safe_c_varname(v.fields.get(j).name))
                    j = j + 1
                self.ws(") { " + e.name + " _r = {.tag=" + e.name + "_" + v.name + "}; ")
                j = 0
                while j < v.fields.len:
                    mut _ef = v.fields.get(j)
                    mut _efn = _safe_c_varname(_ef.name)
                    # Retain str payload fields: the enum value may outlive the
                    # caller's argument local, which can auto-drop at scope exit.
                    if _is_str_type(self.resolve_generic_prim(_ef.ty.name)):
                        self.ws("_r.data." + v.name + "." + _efn + " = _tr_str_retain(" + _efn + "); ")
                    elif self.is_heap_class_tn(_ef.ty.name):
                        # Heap-class payload (e.g. HirStmt.SIf holding a HirBlock): the
                        # enum stores the instance BY REFERENCE and becomes a co-owner.
                        # Retain so the caller's providing local can auto-drop at scope
                        # exit without dangling the reference the tree keeps (symmetric
                        # with str payloads and collection-element stores).
                        self.ws("_r.data." + v.name + "." + _efn + " = _tr_obj_retain(" + _efn + "); ")
                    else:
                        self.ws("_r.data." + v.name + "." + _efn + " = " + _efn + "; ")
                    j = j + 1
                self.ws("return _r; }\n")
            i = i + 1
        self.ws("\n")
        # Pre-generate List_EnumName so Vec[EnumType] works in prototypes
        # that appear after this struct definition. Without this, the prototype
        # uses List_EnumName before it is defined.
        if not self.list_type_done.contains(e.name):
            self.ensure_list_type(e.name)

    pub def gen_interface_vtable(self, iface: HirInterface):
        if iface.generics.len > 0: return  # monomorphized versions generated in ensure_mono
        self.ws("typedef struct _" + iface.name + "_vtable {\n")
        mut i = 0
        while i < iface.methods.len:
            mut m = iface.methods.get(i)
            mut ret = self.type_to_c(m.ret_ty)
            self.ws("    " + ret + " (*" + m.name + ")(void* self")
            mut j = 0
            while j < m.params.len:
                mut p = m.params.get(j)
                if p.name != "self":
                    self.ws(", " + self.type_to_c(p.ty) + " " + p.name)
                j = j + 1
            self.ws(");\n")
            i = i + 1
        self.ws("} " + iface.name + "_vtable;\n\n")
        if not self.emitted_fns.contains("iface_obj_" + iface.name):
            self.emitted_fns.insert("iface_obj_" + iface.name, true)
            self.ws("typedef struct { " + iface.name + "_vtable* vtable; void* data; } " + iface.name + "_obj;\n\n")

    # Build the static-inline _as_ wrap function string for one class+interface pair.
    # Called from generate_types_header (appended after all prototypes).
    pub def gen_one_iface_wrap(self, cls_name: str, iface: HirInterface) -> str:
        mut s = "static inline " + iface.name + "_obj " + cls_name + "_as_" + iface.name + "(" + cls_name + "* self) {\n"
        s = s + "    static const " + iface.name + "_vtable _vtbl_" + cls_name + "_" + iface.name + " = {\n"
        mut mi = 0
        while mi < iface.methods.len:
            mut m = iface.methods.get(mi)
            mut ret_c = self.type_to_c(m.ret_ty)
            mut cast_sig = ret_c + "(*)(void*"
            mut pi = 0
            while pi < m.params.len:
                mut p = m.params.get(pi)
                if p.name != "self":
                    cast_sig = cast_sig + ", " + self.type_to_c(p.ty)
                pi = pi + 1
            cast_sig = cast_sig + ")"
            s = s + "        ." + m.name + " = (" + cast_sig + ")(" + cls_name + "_" + m.name + "),\n"
            mi = mi + 1
        s = s + "    };\n"
        s = s + "    return (" + iface.name + "_obj){ .vtable = (" + iface.name + "_vtable*)&_vtbl_" + cls_name + "_" + iface.name + ", .data = (void*)self };\n"
        s = s + "}\n"
        return s

    # -- Expression generation -------------------------------------------------

    pub def gen_expr(self, e_ptr: Pointer[HirExpr]) -> str:
        if e_ptr as usize == 0 as usize: return "NULL"
        e = e_ptr.read()
        match e:
            case HirExpr.ELitInt(v, _): return v.to_str() + "LL"
            case HirExpr.ELitFloat(v, _): return _tr_float_to_c_lit(v)
            case HirExpr.ELitStr(v, _): return "_tr_str_lit(\"" + _escape_str_for_c(v) + "\")"
            case HirExpr.ERawStr(v, _): return "_tr_str_lit(\"" + _escape_str_for_c(v) + "\")"
            case HirExpr.ELitBytes(v, _): return "\"" + _escape_str_for_c(v) + "\""
            case HirExpr.ELitChar(v, _):
                if v == 0: return "'\\0'"
                if v == 10: return "'\\n'"
                if v == 9: return "'\\t'"
                if v == 13: return "'\\r'"
                if v == 92: return "'\\\\'"
                if v == 39: return "'\\''"
                return "((char)" + v.to_str() + ")"
            case HirExpr.ELitBool(v, _):
                if v: return "true"
                else: return "false"
            case HirExpr.ELitNone(_): return "NULL"
            case HirExpr.EIdent(n, _, _):
                # Inside an outlined closure body, a captured variable is reached
                # by-reference through the env pointer (preserves live read/write).
                if self.closure_env_var != "" and self.closure_cap_set.contains(n):
                    return "(*(__env->p_" + _safe_c_varname(n) + "))"
                if _is_c_keyword(n) and self.decl_vars.contains(n): return "_tr_v_" + n
                if n == "argv" and self.cur_func == "main": return "_tr_main_argv"
                # A top-level function used as a value (not a call target) is a
                # zero-cost function pointer: emit its address as void*.
                if self.functions.contains(n) and not self.decl_vars.contains(n): return "(void*)" + n
                return n
            case HirExpr.EBinOp(op, l, r, _): return self.gen_binop(op, l, r)
            case HirExpr.EUnaryOp(op, expr, _): return self.gen_unary(op, expr)
            case HirExpr.ECall(callee, args, call_ty): return self.gen_call(callee, args, call_ty)
            case HirExpr.EMethodCall(o, m, a, ty): return self.gen_method_call(o, m, a, ty)
            case HirExpr.EPropAccess(o, p, _): return self.gen_prop_access(o, p)
            case HirExpr.EIndex(o, idx, _): return self.gen_index(o, idx)
            case HirExpr.ESizeOf(target_ty, _):
                mut sizeof_cty = self.type_to_c(target_ty)
                mut sizeof_len = sizeof_cty.len
                if sizeof_len > 0:
                    if (sizeof_cty as Pointer[char]).offset(sizeof_len - 1).read() as int == 42:
                        sizeof_cty = sizeof_cty.slice(0, sizeof_len - 1)
                return "((long long)sizeof(" + sizeof_cty + "))"
            case HirExpr.ECast(expr, target_ty):
                # List/Vec -> Pointer[T]: decay to the underlying data array (C interop)
                if target_ty.name == "Pointer":
                    mut cast_src_ty: str = hir_expr_type(expr).name
                    if cast_src_ty == "List" or cast_src_ty == "Vec":
                        return "((" + self.type_to_c(target_ty) + ")(" + self.gen_expr(expr) + "->data))"
                # `as str`: TrStr is a struct, can't C-cast to it. If the source
                # expr is already str-typed it's a no-op; otherwise it's a
                # generic/void* result (e.g. Dict.get(k) as str) - unbox it.
                if _is_str_type(target_ty.name):
                    mut cast_src_full_n: str = hir_expr_type(expr).name
                    if _is_str_type(cast_src_full_n): return self.gen_expr(expr)
                    # Raw pointer (e.g. `buffer as str` where buffer: Pointer[char],
                    # typically a freshly-malloc'd buffer being handed off as an
                    # owned string, as in read_file): wrap as an OWNED TrStr
                    # (rc=1) so the buffer is freed when the string is released.
                    # NOT a boxed-TrStr unbox (that's for `_tr_str_box`-produced
                    # void* slots, e.g. Dict.get(k) as str).
                    if cast_src_full_n == "Pointer":
                        return "_tr_str_wrap((char*)(" + self.gen_expr(expr) + "))"
                    return "_tr_str_unbox(" + self.gen_expr(expr) + ")"
                # TrStr -> Pointer[char]/char*: extract the raw char* via strz
                # (TrStr is a struct, can't C-cast it directly to a pointer).
                if _is_str_type(hir_expr_type(expr).name):
                    return "((" + self.type_to_c(target_ty) + ")(" + self.strz(self.gen_expr(expr)) + "))"
                return "((" + self.type_to_c(target_ty) + ")(" + self.gen_expr(expr) + "))"
            case HirExpr.EFString(parts, _): return self.gen_fstring(parts)
            case HirExpr.ETryExpr(expr, ok_ty):
                # Fallback: unsafe extract (proper propagation handled at statement level)
                mut inner_s2 = self.gen_expr(expr)
                mut ok_c = self.type_to_c(ok_ty)
                if ok_c == "void" or ok_c == "__auto_type": ok_c = "long long"
                if _is_int_type(ok_ty.name) or ok_ty.name == "bool":
                    return "((" + ok_c + ")(uintptr_t)((" + inner_s2 + ").data.Ok.val))"
                return "((" + ok_c + "*)((" + inner_s2 + ").data.Ok.val))"
            case HirExpr.ETuple(items, _): return self.gen_tuple(items)
            case HirExpr.EList(items, ty): return self.gen_list_literal(items, ty)
            case HirExpr.EDict(keys, vals, dict_ty): return self.gen_dict_literal(keys, vals, dict_ty)
            case HirExpr.EClosure(params, ret_ty, body, _, captures):
                return self.gen_closure(params, ret_ty, body, captures)
            case HirExpr.ERange(start, end, inclusive, _):
                return self.gen_expr(start)
            case HirExpr.ESuperMethodCall(base, method, args, _):
                mut super_mc: str = method
                if _is_c_keyword(super_mc):
                    super_mc = "_tr_fn_" + super_mc
                mut sig = base + "_" + super_mc + "((" + base + "*)self"
                mut i = 0
                while i < args.len:
                    sig = sig + ", " + self.gen_expr(args.get(i))
                    i = i + 1
                return sig + ")"
            case HirExpr.ESuperPropAccess(base, prop, _):
                return "(((" + base + "*)self)->" + prop + ")"
            case HirExpr.EAwait(expr, _):
                return self.gen_await_call(expr)
            case HirExpr.EAwaitTimeout(at_expr, at_ms, _):
                return self.gen_await_timeout_call(at_expr, at_ms)
            case HirExpr.EYield(expr, _):
                return self.gen_expr(expr)
            case HirExpr.ESet(items, _):
                mut set_ty = AstType.init("ptr")
                if items.len > 0:
                    mut first_ty_n: str = hir_expr_type(items.get(0)).name
                    set_ty = AstType.init(first_ty_n)
                return self.gen_list_literal(items, set_ty)
            case HirExpr.EListComp(element, generators, _):
                return self.gen_list_comp(element, generators)
            case HirExpr.EGeneratorExpr(element, generators, _):
                return self.gen_list_comp(element, generators)
            case HirExpr.ESlice(start, stop, step, _):
                if start as usize != 0 as usize: return self.gen_expr(start)
                return "0LL"
            case HirExpr.EIfElse(cond, then_e, else_e, ty):
                mut ts = self.gen_expr(then_e)
                mut es = self.gen_expr(else_e)
                if _is_int_type(ty.name):
                    if ts == "NULL": ts = "0LL"
                    if es == "NULL": es = "0LL"
                return "((" + self.gen_expr(cond) + ") ? (" + ts + ") : (" + es + "))"
            case HirExpr.EDo(do_body, _do_ty):
                # `do:` -> GCC statement-expression `({ stmts; T _dores=value; drops; _dores; })`.
                # The body is [real stmts..., SAutoDrop drops..., SExpr(value)].
                # To make the block's result ALWAYS an independent rc=1 owned value
                # (so operand/arg sites can release it), the yielded value is
                # captured into `_dores` BEFORE the block's scope-drops run:
                #   - a str value that is not already fresh-owned (an ident/field/
                #     borrow-call) is RETAINED, so a block-local that produced it
                #     is balanced by its own drop below, while an outer/param/field
                #     value yields an independent copy;
                #   - a fresh str value (concat/call/do) is already rc=1 — no retain.
                # The trailing `_dores;` is what the statement-expression yields.
                mut old_do_buf = self.buf
                self.buf = StringBuilder.init(256)
                mut _dn = do_body.stmts.len
                mut _val_e = Pointer[HirExpr](0)
                if _dn > 0:
                    match do_body.stmts.get(_dn - 1).read():
                        case HirStmt.SExpr(_vv): _val_e = _vv
                        case _: pass
                mut _upto = _dn
                if _val_e as usize != 0 as usize: _upto = _dn - 1
                # Emit real statements; defer the block's own scope-drops so the
                # value can be captured before they run.
                mut _ddrops = Vec[Pointer[HirStmt]].init(4)
                mut _di = 0
                while _di < _upto:
                    mut _ds = do_body.stmts.get(_di)
                    match _ds.read():
                        case HirStmt.SAutoDrop(_, _): _ddrops.push(_ds)
                        case _: self.gen_stmt(_ds, 0)
                    _di = _di + 1
                if _val_e as usize != 0 as usize:
                    mut _vs = self.gen_expr(_val_e)
                    _vs = self.flush_wraps(_vs, false)
                    if _is_str_type(hir_expr_type(_val_e).name) and not self._is_fresh_str_expr(_val_e):
                        self.w("TrStr _dores = (" + _vs + "); _tr_str_retain(_dores);\n")
                    else:
                        self.w("__auto_type _dores = (" + _vs + ");\n")
                    mut _dj = 0
                    while _dj < _ddrops.len:
                        self.gen_stmt(_ddrops.get(_dj), 0)
                        _dj = _dj + 1
                    self.w("_dores;\n")
                else:
                    mut _dj2 = 0
                    while _dj2 < _ddrops.len:
                        self.gen_stmt(_ddrops.get(_dj2), 0)
                        _dj2 = _dj2 + 1
                mut do_inner = self.buf.to_string().as_str()
                self.buf = old_do_buf
                return "({\n" + do_inner + "})"
            case HirExpr.EMatchExpr(m_subj, m_arms, m_ty):
                return self.gen_match_expr(m_subj, m_arms, m_ty)
            case HirExpr.ELoop(l_body, l_ty):
                # `loop:` -> `({ T _lresN = {0}; for(;;){ … } _lresN; })`; the value
                # is produced by `break <value>` inside (assigned to _lresN).
                mut l_old = self.buf
                self.buf = StringBuilder.init(256)
                mut l_ct = self.type_to_c(l_ty)
                if l_ct == "void" or l_ct == "__auto_type": l_ct = "long long"
                mut l_res = "_lres" + self.next_temp()
                self.w(l_ct + " " + l_res + " = (" + l_ct + "){0};\n")
                self.loop_res_stack.push(l_res)
                self.loop_done_stack.push("")
                self.w("for(;;){\n")
                self.gen_block(l_body, 0)
                self.w("}\n")
                self.loop_res_stack.len = self.loop_res_stack.len - 1
                self.loop_done_stack.len = self.loop_done_stack.len - 1
                self.w(l_res + ";\n")
                mut l_inner = self.buf.to_string().as_str()
                self.buf = l_old
                return "({\n" + l_inner + "})"
            case HirExpr.EWhileExpr(w_cond, w_body, w_else, w_ty):
                # `while c:` -> `({ T _lresN={0}; int _wdoneN=0; while(c){…}
                #                  if(!_wdoneN){ <else value -> _lresN> } _lresN; })`
                # A `break <value>` sets _lresN + _wdoneN; on normal exit (c false)
                # the else block's value (an EDo) becomes the result.
                mut w_old = self.buf
                self.buf = StringBuilder.init(256)
                mut w_ct = self.type_to_c(w_ty)
                if w_ct == "void" or w_ct == "__auto_type": w_ct = "long long"
                mut w_res = "_lres" + self.next_temp()
                mut w_done = "_wdone" + self.next_temp()
                self.w(w_ct + " " + w_res + " = (" + w_ct + "){0};\n")
                self.w("int " + w_done + " = 0;\n")
                self.loop_res_stack.push(w_res)
                self.loop_done_stack.push(w_done)
                self.w("while (" + self.gen_cond_expr(w_cond) + ") {\n")
                self.gen_block(w_body, 0)
                self.w("}\n")
                self.loop_res_stack.len = self.loop_res_stack.len - 1
                self.loop_done_stack.len = self.loop_done_stack.len - 1
                # Normal-exit (else) value: the else block is a single SExpr(EDo).
                mut w_else_e = Pointer[HirExpr](0)
                if w_else.stmts.len > 0:
                    match w_else.stmts.get(0).read():
                        case HirStmt.SExpr(_we): w_else_e = _we
                        case _: pass
                if w_else_e as usize != 0 as usize:
                    mut w_es = self.flush_wraps(self.gen_expr(w_else_e), false)
                    self.w("if (!" + w_done + ") { " + w_res + " = (" + w_es + "); }\n")
                self.w(w_res + ";\n")
                mut w_inner = self.buf.to_string().as_str()
                self.buf = w_old
                return "({\n" + w_inner + "})"
            case _: return "0 /* unsupported expr */"

    # match-EXPRESSION -> statement-expression with a result temp. Each arm body
    # is a single SExpr(EDo); the matching arm assigns `_mres = ({arm-do})` (a raw
    # owned move — the do-block already produced an rc=1 owned value) and breaks.
    pub def gen_match_expr(self, subj: Pointer[HirExpr], arms: Vec[HirMatchArm], ty: AstType) -> str:
        mut old_buf = self.buf
        self.buf = StringBuilder.init(256)
        mut mty = self.type_to_c(ty)
        if mty == "void" or mty == "__auto_type": mty = "long long"
        mut subj_t = self.next_temp()
        self.w("__auto_type " + subj_t + " = " + self.flush_wraps(self.gen_expr(subj), false) + ";\n")
        self.w(mty + " _mres = (" + mty + "){0};\n")
        self.w("do {\n")
        mut i = 0
        while i < arms.len:
            mut arm = arms.get(i)
            mut cond = "1"
            mut bindings = ""
            match arm.pat:
                case Pattern.PLitInt(v): cond = subj_t + " == " + v.to_str() + "LL"
                case Pattern.PLitBool(v):
                    if v: cond = subj_t
                    else: cond = "!" + subj_t
                case Pattern.PLitStr(v): cond = "_tr_str_eq(" + subj_t + ", \"" + _escape_str_for_c(v) + "\")"
                case Pattern.PVariant(tn, vn):
                    mut pv_vn = vn
                    if tn == "Option" and (vn == "" or vn == "none"): pv_vn = "None"
                    cond = subj_t + ".tag == " + tn + "_" + pv_vn
                case Pattern.PVariantBind(tn, vn, field):
                    cond = subj_t + ".tag == " + tn + "_" + vn
                    mut actual_fld = field
                    if tn == "Option" and vn == "Some": actual_fld = "val"
                    if tn == "Result" and vn == "Ok": actual_fld = "val"
                    if tn == "Result" and vn == "Err": actual_fld = "err"
                    if self.enums.contains(tn):
                        mut _ev_def = self.enums.get(tn)
                        mut _vi = 0
                        while _vi < _ev_def.variants.len:
                            mut _ev = _ev_def.variants.get(_vi)
                            if _ev.name == vn and _ev.fields.len > 0: actual_fld = _ev.fields.get(0).name
                            _vi = _vi + 1
                    self.decl_vars.insert(field, true)
                    bindings = "__auto_type " + _safe_c_varname(field) + " = " + subj_t + ".data." + vn + "." + _safe_c_varname(actual_fld) + ";\n"
                case Pattern.PVariantBindMany(tn, vn, fields):
                    cond = subj_t + ".tag == " + tn + "_" + vn
                    mut _bi = 0
                    while _bi < fields.len:
                        mut _bf = fields.get(_bi)
                        if _bf != "_":
                            mut _actual = _bf
                            if self.enums.contains(tn):
                                mut _ev_def2 = self.enums.get(tn)
                                mut _vi2 = 0
                                while _vi2 < _ev_def2.variants.len:
                                    mut _ev2 = _ev_def2.variants.get(_vi2)
                                    if _ev2.name == vn and _bi < _ev2.fields.len: _actual = _ev2.fields.get(_bi).name
                                    _vi2 = _vi2 + 1
                            self.decl_vars.insert(_bf, true)
                            bindings = bindings + "__auto_type " + _safe_c_varname(_bf) + " = " + subj_t + ".data." + vn + "." + _safe_c_varname(_actual) + ";\n"
                        _bi = _bi + 1
                case Pattern.PBind(n):
                    cond = "1"
                    self.decl_vars.insert(n, true)
                    bindings = "__auto_type " + _safe_c_varname(n) + " = " + subj_t + ";\n"
                case Pattern.PWild: cond = "1"
                case Pattern.POr(pats):
                    mut or_conds = ""
                    mut oi = 0
                    while oi < pats.len:
                        mut pp = pats.get(oi)
                        mut pc = "1"
                        match pp:
                            case Pattern.PVariant(tn, vn):
                                mut or_vn = vn
                                if tn == "Option" and (vn == "" or vn == "none"): or_vn = "None"
                                pc = subj_t + ".tag == " + tn + "_" + or_vn
                            case Pattern.PLitInt(vi): pc = subj_t + " == " + vi.to_str() + "LL"
                            case Pattern.PLitStr(vs): pc = "_tr_str_eq(" + subj_t + ", \"" + _escape_str_for_c(vs) + "\")"
                            case Pattern.PLitBool(bv):
                                if bv: pc = subj_t
                                else: pc = "!" + subj_t
                            case _: pc = "1"
                        if oi == 0: or_conds = pc
                        else: or_conds = or_conds + " || " + pc
                        oi = oi + 1
                    cond = "(" + or_conds + ")"
                case _: cond = "1"
            # Extract the arm's EDo value expression (the single SExpr in the body).
            mut arm_val = Pointer[HirExpr](0)
            if arm.body.stmts.len > 0:
                match arm.body.stmts.get(0).read():
                    case HirStmt.SExpr(_av): arm_val = _av
                    case _: pass
            self.w("  if (" + cond + ") {\n")
            if bindings != "": self.w("    " + bindings)
            mut arm_s = "0"
            if arm_val as usize != 0 as usize: arm_s = self.gen_expr(arm_val)
            if arm.guard as usize != 0 as usize:
                self.w("    if (" + self.gen_expr(arm.guard) + ") { _mres = (" + arm_s + "); break; }\n")
            else:
                self.w("    _mres = (" + arm_s + "); break;\n")
            self.w("  }\n")
            i = i + 1
        self.w("} while(0);\n")
        self.w("_mres;\n")
        mut inner = self.buf.to_string().as_str()
        self.buf = old_buf
        return "({\n" + inner + "})"

    pub def has_method(self, cls_name: str, method: str) -> bool:
        if cls_name == "" or cls_name == "void": return false
        if self.classes.contains(cls_name):
            mut cls = self.classes.get(cls_name)
            mut i = 0
            while i < cls.methods.len:
                if cls.methods.get(i).name == method: return true
                i = i + 1
            return false
        # Enum (and any other non-class) extend methods, e.g. `extend Color: __str__`
        if self.method_owners.contains(cls_name + "#" + method): return true
        mut cp = cls_name as Pointer[char]
        mut ui = 0
        while cp.offset(ui).read() as int != 0:
            if cp.offset(ui).read() as int == 95:
                mut candidate = cls_name.slice(0, ui)
                if self.classes.contains(candidate):
                    mut base_cls = self.classes.get(candidate)
                    mut bmi = 0
                    while bmi < base_cls.methods.len:
                        if base_cls.methods.get(bmi).name == method: return true
                        bmi = bmi + 1
                    return false
            ui = ui + 1
        return false

    pub def cls_method_ret_ty(self, cls_name: str, method: str) -> AstType:
        if cls_name == "" or cls_name == "void": return AstType.init("void")
        if self.classes.contains(cls_name):
            mut cls = self.classes.get(cls_name)
            mut i = 0
            while i < cls.methods.len:
                if cls.methods.get(i).name == method: return cls.methods.get(i).ret_ty
                i = i + 1
            return AstType.init("void")
        mut cp2 = cls_name as Pointer[char]
        mut ui2 = 0
        while cp2.offset(ui2).read() as int != 0:
            if cp2.offset(ui2).read() as int == 95:
                mut candidate2 = cls_name.slice(0, ui2)
                if self.classes.contains(candidate2):
                    mut base_cls2 = self.classes.get(candidate2)
                    mut i2 = 0
                    while i2 < base_cls2.methods.len:
                        if base_cls2.methods.get(i2).name == method: return base_cls2.methods.get(i2).ret_ty
                        i2 = i2 + 1
                    return AstType.init("void")
            ui2 = ui2 + 1
        return AstType.init("void")

    pub def cls_method_c_call(self, cls_name: str, method: str, obj_s: str, extra_args: str) -> str:
        mut safe_m = method
        if _is_c_keyword(safe_m): safe_m = "_tr_fn_" + safe_m
        if extra_args == "":
            return cls_name + "_" + safe_m + "(" + obj_s + ")"
        return cls_name + "_" + safe_m + "(" + obj_s + ", " + extra_args + ")"

    # Resolve the C class-name prefix to use for dunder dispatch (print, ==, etc.),
    # accounting for monomorphized generic classes (Box[int] -> Box_i64).
    # Resolve a generic type-parameter name (e.g. "T") to a concrete primitive
    # kind name ("int"/"float"/"bool"/"char"/"str") using the active type_subst
    # map (generic param -> concrete C type), inside a monomorphized method body.
    pub def resolve_generic_prim(self, n: str) -> str:
        if self.type_subst.contains(n):
            mut c = self.type_subst.get(n)
            if c == "long long" or c == "int" or c == "long" or c == "short" or c == "size_t" or c == "uint64_t" or c == "int64_t" or c == "int32_t" or c == "uint32_t" or c == "int16_t" or c == "uint16_t" or c == "int8_t" or c == "uint8_t": return "int"
            if c == "double" or c == "float": return "float"
            if c == "_Bool" or c == "bool": return "bool"
            if c == "char": return "char"
            if c == "char*": return "str"
            if c == "TrStr": return "str"
        return n

    # Resolve a generic type-param name to its concrete Tauraro type NAME under the
    # active monomorphization substitution — used to dispatch method calls on a
    # `T`-typed value (x.show() -> Cat_show) inside a monomorphized body. Primitives
    # map via resolve_generic_prim; a class/value-type maps from its C type ("Cat*")
    # back to the bare name ("Cat"). Returns n unchanged when not substituted.
    pub def resolve_generic_tyname(self, n: str) -> str:
        if not self.type_subst.contains(n): return n
        mut r = self.resolve_generic_prim(n)
        if r != n: return r
        mut c = self.type_subst.get(n)
        if c.ends_with("*"): c = c.slice(0, c.len() - 1)
        return c

    pub def mono_cls_name_for(self, ty: AstType) -> str:
        mut cn: str = ty.name
        if self.classes.contains(cn) and cn != "Vec" and cn != "Map" and cn != "Dict" and cn != "List":
            mut ucls = self.classes.get(cn)
            if ucls.generics.len > 0 and ty.args.len > 0:
                mut sfx = self.type_args_suffix(ty.args)
                self.ensure_mono(ucls, ty.args)
                return cn + "_" + sfx
        return cn

    # String representation of a class instance: __str__/__repr__ if defined,
    # else the default "ClassName.obj at 0xADDR" format.
    pub def obj_to_str_expr(self, mono: str, s: str) -> str:
        if self.has_method(mono, "__str__"):
            return self.cls_method_c_call(mono, "__str__", s, "")
        if self.has_method(mono, "__repr__"):
            return self.cls_method_c_call(mono, "__repr__", s, "")
        return "_tr_default_obj_str(\"" + mono + "\", (void*)(" + s + "))"

    # Resolve (and lazily emit, for class element types) a `char* (*)(const void*)`
    # element formatter used by _tr_collection_to_str / _tr_dict_to_str.
    pub def ensure_elem_fmt_fn(self, ty: AstType) -> str:
        mut tn: str = self.resolve_generic_prim(ty.name)
        if _is_int_type(tn):
            if tn == "i32": return "_tr_fmt_i32"
            if tn == "i16": return "_tr_fmt_i16"
            if tn == "i8": return "_tr_fmt_i8"
            if tn == "u8": return "_tr_fmt_u8"
            if tn == "u16": return "_tr_fmt_u16"
            if tn == "u32": return "_tr_fmt_u32"
            if tn == "u64" or tn == "usize": return "_tr_fmt_u64"
            return "_tr_fmt_i64"
        if _is_float_type(tn): return "_tr_fmt_f64"
        if tn == "bool": return "_tr_fmt_bool"
        if tn == "char": return "_tr_fmt_char"
        if _is_str_type(tn): return "_tr_fmt_str"
        if tn == "List" or tn == "Vec" or tn == "Set" or tn == "Dict" or tn == "Map":
            # Nested collection element: emit a formatter that recurses.
            mut nest_name = "_tr_fmt_nest_" + self.type_args_suffix(ty.args) + "_" + tn
            if self.elem_fmt_done.contains(nest_name): return nest_name
            self.elem_fmt_done.insert(nest_name, true)
            mut nest_empty = "[]"
            if tn == "Dict" or tn == "Map": nest_empty = "{}"
            mut nest_body = "static char* " + nest_name + "(const void* p) {\n"
            nest_body = nest_body + "    void* inner = *(void* const*)p;\n"
            nest_body = nest_body + "    if (!inner) return \"" + nest_empty + "\";\n"
            nest_body = nest_body + "    return " + self.gen_collection_to_str("((" + self.type_to_c(ty) + ")inner)", ty) + ";\n"
            nest_body = nest_body + "}\n"
            self.wp(nest_body)
            return nest_name
        # Class element type (List[ClassName] -> elements stored as pointers).
        mut mono = self.mono_cls_name_for(ty)
        mut fn_name = "_tr_fmt_obj_" + mono
        if self.elem_fmt_done.contains(fn_name): return fn_name
        self.elem_fmt_done.insert(fn_name, true)
        mut body = "static char* " + fn_name + "(const void* p) {\n"
        body = body + "    " + mono + "* o = *(" + mono + "* const*)p;\n"
        body = body + "    if (!o) return \"None\";\n"
        body = body + "    return " + self.obj_to_str_expr(mono, "o") + ";\n"
        body = body + "}\n"
        self.wp(body)
        return fn_name

    # Render a List[T]/Vec[T]/Set[T]/Dict[K,V] value as a Python-style string:
    # "[1, 2, 3]" / "{'a', 'b'}" / "{'a': 1, 'b': 2}".
    pub def gen_collection_to_str(self, s: str, ty: AstType) -> str:
        mut cn = ty.name
        if cn == "List" or cn == "Vec":
            if ty.args.len == 0:
                return "_tr_collection_to_str((void*)((_TrListHdr*)(" + s + "))->data, ((_TrListHdr*)(" + s + "))->len, sizeof(void*), _tr_fmt_str_raw, \"[\", \"]\", \", \")"
            mut elem_ty = ty.args.get(0).read()
            mut fmt_fn = self.ensure_elem_fmt_fn(elem_ty)
            mut elem_ct = self.type_to_c(elem_ty)
            return "_tr_collection_to_str((void*)((_TrListHdr*)(" + s + "))->data, ((_TrListHdr*)(" + s + "))->len, sizeof(" + elem_ct + "), " + fmt_fn + ", \"[\", \"]\", \", \")"
        if cn == "Set":
            mut set_elem_ty = AstType.init("str")
            if ty.args.len > 0: set_elem_ty = ty.args.get(0).read()
            mut set_tn: str = self.resolve_generic_prim(set_elem_ty.name)
            if _is_int_type(set_tn):
                return "({ List_i64* _sl = _tr_iset_to_list(" + s + "); _tr_collection_to_str((void*)_sl->data, _sl->len, sizeof(long long), _tr_fmt_i64, \"{\", \"}\", \", \"); })"
            mut set_fmt = "_tr_fmt_str_raw"
            if _is_str_type(set_tn): set_fmt = "_tr_fmt_str"
            return "({ List_TrStr* _sl = _tr_set_to_list(" + s + "); char* _r = _tr_collection_to_str((void*)_sl->data, _sl->len, sizeof(TrStr), " + set_fmt + ", \"{\", \"}\", \", \"); List_TrStr_free(_sl); _r; })"
        if cn == "Dict" or cn == "Map":
            mut val_ty = AstType.init("str")
            if ty.args.len > 1: val_ty = ty.args.get(1).read()
            mut val_tn: str = self.resolve_generic_prim(val_ty.name)
            mut vfmt = self.ensure_elem_fmt_fn(val_ty)
            # Dict/Map store str values BOXED (_tr_str_box -> TrStr*), so a plain
            # _tr_fmt_str would read the box pointer as a char* and print garbage.
            # Use the unboxing formatter for str values.
            if _is_str_type(val_tn): vfmt = "_tr_fmt_str_box"
            mut vsize = "sizeof(void*)"
            if _is_float_type(val_tn): vsize = "sizeof(double)"
            return "({ List_TrStr* _dk = _tr_dict_keys(" + s + "); List_ptr* _dv = _tr_dict_values(" + s + "); char* _r = _tr_dict_to_str((void*)_dk->data, (void*)_dv->data, _dk->len, " + vsize + ", _tr_fmt_str, " + vfmt + "); List_TrStr_free(_dk); List_ptr_free(_dv); _r; })"
        return "_tr_default_obj_str(\"" + cn + "\", (void*)(" + s + "))"

    # Extracts the raw `char*` from a TrStr-typed expression for passing to
    # legacy char*-based runtime helpers (_tr_str_*, strcmp, etc).
    #
    # If `e` is exactly a `_tr_str_wrap(...)` call, it produces a fresh,
    # unique, rc=1 TrStr (per _tr_str_wrap's contract) that nothing else
    # references. Extracting `.data` and discarding the TrStr struct (the
    # old behavior, `_tr_strz(_tr_str_wrap(...))`) leaked both of its heap
    # allocations. Instead, bind it to a named temp now and record it for
    # release once the enclosing top-level expression/statement has
    # consumed `.data` (see flush_wraps).
    pub def strz(self, e: str) -> str:
        if e.starts_with("_tr_str_wrap(") and e.ends_with(")"):
            mut tmp = "_wt" + self.next_temp()
            self.wrap_temp_decls.push("TrStr " + tmp + " = (" + e + ")")
            self.wrap_temp_names.push(tmp)
            return tmp + ".data"
        return "_tr_strz(" + e + ")"

    # If any `_tr_str_wrap(...)` temporaries were hoisted by `strz()` while
    # generating `expr_s` (a complete top-level expression/condition/value),
    # wrap it in a GCC statement-expression that declares the temps, computes
    # `expr_s`, releases the temps, then yields the result. `is_void` must be
    # true when `expr_s`'s value is discarded (e.g. an SExpr statement).
    # Clears the pending lists either way.
    pub def flush_wraps(self, expr_s: str, is_void: bool) -> str:
        if self.wrap_temp_decls.len == 0:
            return expr_s
        mut out = "({ "
        mut i = 0
        while i < self.wrap_temp_decls.len:
            out = out + self.wrap_temp_decls.get(i) + "; "
            i = i + 1
        if is_void:
            out = out + expr_s + "; "
        else:
            out = out + "__auto_type _wr = (" + expr_s + "); "
        i = 0
        while i < self.wrap_temp_names.len:
            out = out + "_tr_str_release(" + self.wrap_temp_names.get(i) + "); "
            i = i + 1
        # Release fresh-owned heap-class arg temps (a borrowing callee doesn't own
        # them; a callee that stored one retained it, so this nets correctly).
        i = 0
        while i < self.wrap_obj_names.len:
            out = out + "_tr_obj_release(" + self.wrap_obj_names.get(i) + ", " + self.wrap_obj_drops.get(i) + "); "
            i = i + 1
        if not is_void:
            out = out + "_wr; "
        out = out + "})"
        self.wrap_temp_decls = Vec[str].init(0)
        self.wrap_temp_names = Vec[str].init(0)
        self.wrap_obj_names = Vec[str].init(0)
        self.wrap_obj_drops = Vec[str].init(0)
        return out

    # Wraps a fresh heap char* (from a legacy _tr_str_* helper) into a
    # refcounted TrStr (rc=1) for use as a `str`-typed expression result.
    pub def wrapstr(self, e: str) -> str:
        return "_tr_str_wrap(" + e + ")"

    # Wrap `s` (the generated C expression for `e`) with `_tr_str_retain(...)`
    # when `e` is an ALIAS of an existing TrStr (an EIdent referencing a `str`
    # local/param) - i.e. `s` shares a buffer with something else whose
    # lifetime is independent. Fresh values (concat results, calls, literals)
    # and EPropAccess reads (borrowed field access) already own/borrow their
    # buffer correctly and pass through unchanged. For `is_return=true` with an
    # EIdent that's a tracked str local, no retain - ownership transfers to the
    # caller (matches the SAutoDrop exclusion for `return x`).
    # Load the current function's proven-borrow set (from the outlives engine), so
    # the SLet codegen can elide refcounts for those locals.
    pub def set_proven_borrows(self, pb: Vec[str]):
        self.cur_proven_borrows = Map[str, bool].init(8)
        if self.no_elide: return                  # --no-elide → pure ARC, elide nothing
        if (pb as usize) == 0 as usize: return   # field unset (synthetic fn) → empty
        mut spi = 0
        while spi < pb.len:
            self.cur_proven_borrows.insert(pb.get(spi), true)
            spi = spi + 1

    pub def str_retain_wrap(self, e: Pointer[HirExpr], s: str, is_return: bool) -> str:
        if _is_invalid_ptr(e as usize): return s
        mut ety = hir_expr_type(e)
        if ety.name != "str": return s
        match e.read():
            case HirExpr.EIdent(nm, _, _):
                if is_return and self.str_local_names.contains(nm): return s
                return "_tr_str_retain(" + s + ")"
            case HirExpr.EPropAccess(_, _, _):
                # A `str` FIELD read (e.g. `return self.nm`) aliases the object's
                # own buffer. When this is an OWNED return (`-> str`), the caller
                # will release the result, so we must retain to keep the field's
                # reference valid — otherwise the first drop frees the field's
                # buffer and the next read is a use-after-free / heap corruption.
                # (`-> ref` borrow returns never reach here; they pass the alias
                # through and the caller does not free it.)
                if is_return: return "_tr_str_retain(" + s + ")"
                return s
            case _:
                return s

    # True for a refcounted HEAP class type name (excludes value types, builtin
    # collections/concurrency/StringBuilder, and generic monos which aren't in
    # self.classes by their mono name — those stay conservatively un-rc'd).
    # Record every class name appearing as `Pointer[T]` inside `t` (recursively):
    # `Pointer[C]` → mark C; otherwise descend into type arguments (so
    # `Vec[Pointer[AstType]]`, `Map[str, Pointer[Symbol]]`, etc. are covered).
    pub def _scan_ptr_aliased(self, t: AstType):
        if _is_invalid_ptr(t as usize): return
        if _is_invalid_ptr(t.args as usize): return
        if t.name == "Pointer" and t.args.len > 0:
            mut ip = t.args.get(0)
            if not _is_invalid_ptr(ip as usize):
                mut inner = ip.read()
                if not _is_invalid_ptr(inner as usize):
                    self.raw_aliased.insert(inner.name, true)
                    self._scan_ptr_aliased(inner)
            return
        mut ai = 0
        while ai < t.args.len:
            mut ap = t.args.get(ai)
            if not _is_invalid_ptr(ap as usize):
                self._scan_ptr_aliased(ap.read())
            ai = ai + 1

    pub def _is_coll_type_name(self, n: str) -> bool:
        return n == "List" or n == "Vec" or n == "Dict" or n == "Map" or n == "Set"

    # True for an expression that builds a FRESH, uniquely-owned collection: a
    # literal (`[..]`/`{..}`), a comprehension, or a `List/Dict/Set/Map[..].init/new()`.
    # Anything else (an ident, a field read, an arbitrary call) may ALIAS an existing
    # collection, which — since collections aren't refcounted — must not be auto-freed.
    pub def _is_fresh_coll_expr(self, e: Pointer[HirExpr]) -> bool:
        if _is_invalid_ptr(e as usize): return false
        match e.read():
            case HirExpr.EList(_, _): return true
            case HirExpr.ESet(_, _): return true
            case HirExpr.EDict(_, _, _): return true
            case HirExpr.EListComp(_, _, _): return true
            case HirExpr.ECall(callee, _, _):
                match callee.read():
                    case HirExpr.EIdent(cn, _, _): return self._is_coll_type_name(cn)
                    case _: return false
            case HirExpr.EMethodCall(recv, m, _, _):
                if m != "init" and m != "new": return false
                match recv.read():
                    case HirExpr.EIdent(rn, _, _): return self._is_coll_type_name(rn)
                    case _: return false
            case _: return false

    # Populate coll_field_owned / coll_field_disq by scanning every function body
    # for `obj.field = <collection>` stores (see _trdrop_T's collection-field free).
    pub def _scan_coll_fields(self, prog: HirProgram):
        mut i = 0
        while i < prog.functions.len:
            self._scan_coll_fields_block(prog.functions.get(i).body)
            i = i + 1
        i = 0
        while i < prog.classes.len:
            mut c = prog.classes.get(i)
            mut mi = 0
            while mi < c.methods.len:
                self._scan_coll_fields_block(c.methods.get(mi).body)
                mi = mi + 1
            i = i + 1
        i = 0
        while i < prog.enums.len:
            mut en = prog.enums.get(i)
            mut emi = 0
            while emi < en.methods.len:
                self._scan_coll_fields_block(en.methods.get(emi).body)
                emi = emi + 1
            i = i + 1

    pub def _scan_coll_fields_block(self, b: HirBlock):
        if _is_invalid_ptr(b as usize): return
        mut i = 0
        while i < b.stmts.len:
            self._scan_coll_fields_stmt(b.stmts.get(i))
            i = i + 1

    pub def _scan_coll_fields_stmt(self, sp: Pointer[HirStmt]):
        if _is_invalid_ptr(sp as usize): return
        match sp.read():
            case HirStmt.SAssign(t, v):
                match t.read():
                    case HirExpr.EPropAccess(obj, fname, _):
                        if self._is_fresh_coll_expr(v):
                            mut ft = hir_expr_type(t).name
                            mut ocn = hir_expr_type(obj).name
                            if self._is_coll_type_name(ft) and self.classes.contains(ocn):
                                self.coll_field_owned.insert(ocn + "." + fname, true)
                        else:
                            # A non-fresh store to this field name anywhere disqualifies it
                            # (may alias a collection the object doesn't uniquely own).
                            self.coll_field_disq.insert(fname, true)
                    case _: pass
            case HirStmt.SIf(_, tb, eb):
                self._scan_coll_fields_block(tb)
                self._scan_coll_fields_block(eb)
            case HirStmt.SWhile(_, wb): self._scan_coll_fields_block(wb)
            case HirStmt.SFor(_, _, fb): self._scan_coll_fields_block(fb)
            case HirStmt.SForUnpack(_, _, fub): self._scan_coll_fields_block(fub)
            case HirStmt.SMatch(_, marms):
                mut ai = 0
                while ai < marms.len:
                    self._scan_coll_fields_block(marms.get(ai).body)
                    ai = ai + 1
            case HirStmt.SUnsafe(ub): self._scan_coll_fields_block(ub)
            case HirStmt.SWith(_, _, wb2): self._scan_coll_fields_block(wb2)
            case HirStmt.STaskGroup(tgb): self._scan_coll_fields_block(tgb)
            case HirStmt.SGpuBlock(gb): self._scan_coll_fields_block(gb)
            case HirStmt.SDefer(ds): self._scan_coll_fields_stmt(ds)
            case HirStmt.STry(tb2, catches, fb2):
                self._scan_coll_fields_block(tb2)
                mut ci = 0
                while ci < catches.len:
                    mut cc = catches.get(ci)
                    if not _is_invalid_ptr(cc as usize): self._scan_coll_fields_block(cc.read().body)
                    ci = ci + 1
                self._scan_coll_fields_block(fb2)
            case _: pass

    # The C free call that reclaims collection field `fld_c` of type `ty`, releasing
    # heap-class elements/values. Empty string if the type isn't a supported collection.
    pub def _coll_field_free_call(self, fld_c: str, ty: AstType) -> str:
        if ty.name == "List" or ty.name == "Vec":
            if ty.args.len > 0:
                mut et = ty.args.get(0).read().name
                if self.is_heap_class_tn(et):
                    return "List_ptr_free_obj(" + fld_c + ", " + self.obj_drop_fn(et) + ")"
                if _is_str_type(et): return "List_TrStr_free(" + fld_c + ")"
                return "List_" + self.list_sfx(self.list_elem_suffix(et)) + "_free(" + fld_c + ")"
            return "List_ptr_free(" + fld_c + ")"
        if ty.name == "Dict" or ty.name == "Map":
            mut _ik = ty.args.len > 0 and (_is_int_type(ty.args.get(0).read().name) or ty.args.get(0).read().name == "int")
            mut _vheap = ty.args.len > 1 and self.is_heap_class_tn(ty.args.get(1).read().name)
            mut _vstr = ty.args.len > 1 and _is_str_type(ty.args.get(1).read().name)
            if _vheap:
                mut _vc = ty.args.get(1).read().name
                if _ik: return "_tr_idict_free_objval(" + fld_c + ", " + self.obj_drop_fn(_vc) + ")"
                return "Dict_free_objval(" + fld_c + ", " + self.obj_drop_fn(_vc) + ")"
            if _vstr:
                if _ik: return "_tr_idict_free_strval(" + fld_c + ")"
                return "Dict_free_strval(" + fld_c + ")"
            if _ik: return "_tr_idict_free(" + fld_c + ")"
            return "Dict_free(" + fld_c + ")"
        if ty.name == "Set":
            if ty.args.len > 0 and self.is_heap_class_tn(ty.args.get(0).read().name):
                return "_tr_pset_free_obj(" + fld_c + ", " + self.obj_drop_fn(ty.args.get(0).read().name) + ")"
            return ""
        return ""

    pub def is_heap_class_tn(self, tn: str) -> bool:
        if not self.classes.contains(tn): return false
        if self.value_types.contains(tn): return false
        # Pointer-aliased types (e.g. AstType, HIR nodes) are shared via raw
        # Pointer[T] that bypasses the refcount — never auto-drop them.
        if self.raw_aliased.contains(tn): return false
        if tn == "Vec" or tn == "Map" or tn == "List" or tn == "Dict" or tn == "Set" or tn == "Box" or tn == "Mutex" or tn == "RwLock" or tn == "Atomic" or tn == "Shared" or tn == "Option" or tn == "Result" or tn == "Chan" or tn == "StringBuilder" or tn == "StringObj": return false
        return true

    # Class-instance analogue of str_retain_wrap: retain when a heap-class value
    # is bound/stored/returned so the new holder owns a counted reference. Fresh
    # constructions and owned (`-> T`) call results are already rc=1 (no retain);
    # aliases (a tracked local, a field read) and `-> ref` borrows are retained.
    # Returning a tracked local transfers ownership (excluded from drops) → no retain.
    pub def obj_retain_wrap(self, e: Pointer[HirExpr], s: str, is_return: bool) -> str:
        if _is_invalid_ptr(e as usize): return s
        if not self.is_heap_class_tn(hir_expr_type(e).name): return s
        match e.read():
            case HirExpr.EIdent(nm, _, _):
                if is_return and self.class_local_names.contains(nm): return s
                return "_tr_obj_retain(" + s + ")"
            case HirExpr.EPropAccess(_, _, _):
                return "_tr_obj_retain(" + s + ")"
            case _:
                return s

    # True when a heap-class SLet/first-assign RHS yields a reference this local
    # OWNS (so it must be released at scope exit). Owning forms: a fresh
    # construction `ClassName(...)`/free-function result (ECall), a static
    # factory `ClassName.method(...)` (EMethodCall whose receiver names a class),
    # or a retained alias (EIdent / EPropAccess — obj_retain_wrap added a retain).
    # An INSTANCE method call `obj.method(...)` returning a class by value
    # (e.g. `self.resolve(name)` → an alias into a scope map, `d.get(k)`) is a
    # BORROW we cannot prove owned: conservatively NOT owning, so it is never
    # released (a leak is safe; over-releasing an alias is a use-after-free).
    # (`-> ref` borrow calls are handled separately via _expr_is_borrow_call.)
    # Look up a fn/method key in the return-ownership map (missing → BORROWED).
    pub def _fn_owned_lookup(self, key: str) -> bool:
        if self.fn_owned.contains(key): return self.fn_owned.get(key)
        return false

    # Register a fn/method's return-ownership; on key collision (overloads) the
    # BORROWED verdict wins (never drop a value some overload returns as an alias).
    pub def _reg_fn_owned(self, key: str, v: bool):
        mut nv = v
        if self.fn_owned.contains(key):
            if not self.fn_owned.get(key): nv = false
        self.fn_owned.insert(key, nv)

    pub def _obj_expr_owns_ref(self, e: Pointer[HirExpr]) -> bool:
        if _is_invalid_ptr(e as usize): return false
        match e.read():
            case HirExpr.EIdent(_, _, _): return true
            case HirExpr.EPropAccess(_, _, _): return true
            case HirExpr.ECall(callee, _, _):
                # A constructor `ClassName(...)` yields a fresh owned instance.
                # A free-function call owns iff return-ownership inference proved it
                # OWNED (e.g. `make_named`); a borrow-returning fn (`site_for()` →
                # `out.get(i)`) stays NOT owning (leak-safe; dropping an alias = UAF).
                match callee.read():
                    case HirExpr.EIdent(cn, _, _):
                        if self.classes.contains(cn): return true
                        return self._fn_owned_lookup(cn)
                    case _: return false
            case HirExpr.EMethodCall(recv, m, _, _):
                # Owned iff the callee (`ClassName.factory` or an instance method) was
                # inferred to return an OWNED reference. Collection `.get/.first/.last`
                # and unknown callees key to nothing in the map → BORROWED (not dropped),
                # so `self.resolve(n)` → a scope-map alias is never over-released.
                mut rt = hir_expr_type(recv).name
                match recv.read():
                    case HirExpr.EIdent(rn, _, _):
                        if self.classes.contains(rn): rt = rn
                    case _: pass
                return self._fn_owned_lookup(rt + "." + m)
            case _: return false

    # When a heap-class value is STORED into a class FIELD (which now co-owns it and
    # releases it in _trdrop_T), does the store need an extra retain to establish
    # ownership? A fresh construction / owned-classified call TRANSFERS its rc=1 (no
    # retain). A collection-element borrow or a borrow-returning call is an ALIAS the
    # field must retain to co-own (else _trdrop over-releases → UAF). EIdent/EPropAccess
    # are already retained by obj_retain_wrap, so they return false here (no double).
    # True if `t` stores into a `ref T` (borrow) class field. Such a field does NOT
    # co-own its value: the drop side already skips releasing borrow fields (see
    # gen_class_struct), so the store side must likewise NOT retain — otherwise the
    # retain leaks (asymmetric). A plain store = a zero-cost borrow (Rc/Arc-free view).
    pub def _store_target_is_borrow_field(self, t: Pointer[HirExpr]) -> bool:
        if _is_invalid_ptr(t as usize): return false
        match t.read():
            case HirExpr.EPropAccess(obj, prop, _):
                mut on = hir_expr_type(obj).name
                if self.classes.contains(on):
                    mut cls = self.classes.get(on)
                    mut fi = 0
                    while fi < cls.fields.len:
                        if cls.fields.get(fi).name == prop:
                            return cls.fields.get(fi).ty.is_borrow
                        fi = fi + 1
            case _: pass
        return false

    pub def _obj_store_needs_retain(self, e: Pointer[HirExpr]) -> bool:
        if _is_invalid_ptr(e as usize): return false
        match e.read():
            case HirExpr.EIdent(_, _, _): return false
            case HirExpr.EPropAccess(_, _, _): return false
            case HirExpr.ECall(callee, _, _):
                match callee.read():
                    case HirExpr.EIdent(cn, _, _):
                        if self.classes.contains(cn): return false   # constructor transfer
                        return not self._fn_owned_lookup(cn)          # owned-call transfer; borrow retain
                    case _: return true
            case HirExpr.EMethodCall(recv, m, _, _):
                mut rt = hir_expr_type(recv).name
                if (rt == "Vec" or rt == "List" or rt == "Dict" or rt == "Map" or rt == "Set") and (m == "get" or m == "first" or m == "last"):
                    return true
                match recv.read():
                    case HirExpr.EIdent(rn, _, _):
                        if self.classes.contains(rn): rt = rn
                    case _: pass
                return not self._fn_owned_lookup(rt + "." + m)
            case _: return false

    # Name of the per-class field-drop function (releases owned str/class fields).
    pub def obj_drop_fn(self, tn: str) -> str:
        return "_trdrop_" + tn

    pub def gen_cond_expr(self, cond: Pointer[HirExpr]) -> str:
        mut cond_s = self.gen_expr(cond)
        mut ty_n: str = hir_expr_type(cond).name
        if self.has_method(ty_n, "__bool__"):
            cond_s = self.cls_method_c_call(ty_n, "__bool__", cond_s, "")
        return self.flush_wraps(cond_s, false)

    pub def gen_binop(self, op: str, l: Pointer[HirExpr], r: Pointer[HirExpr]) -> str:
        mut ls = self.gen_expr(l)
        mut rs = self.gen_expr(r)
        mut lt_n: str = hir_expr_type(l).name
        mut rt_n: str = hir_expr_type(r).name
        if op == "+" and (_is_str_type(lt_n) or _is_str_type(rt_n)):
            # `_tr_str_wrap(...)` always produces a freshly-owned, unique
            # TrStr (rc=1, not aliased to any other variable) - e.g. from
            # `.to_str()`, `.to_upper()`, etc. used inline in a concat. Same
            # for any ECall/EMethodCall/EBinOp operand (e.g. a nested `a + b`
            # concat, or `Str.to_upper(x)`): both return a fresh TrStr by
            # value with its own rc/data allocation. If an operand is one of
            # these, consume its `.data` and release it immediately after the
            # concat call so its (up to two) heap allocations don't leak.
            mut l_owned = (ls.starts_with("_tr_str_wrap(") and ls.ends_with(")")) or self._is_fresh_str_expr(l)
            mut r_owned = (rs.starts_with("_tr_str_wrap(") and rs.ends_with(")")) or self._is_fresh_str_expr(r)
            if l_owned and r_owned:
                return "({ TrStr _cl = (" + ls + "); TrStr _cr = (" + rs + "); TrStr _cres = _tr_strx_concat(_cl.data, _cr.data); _tr_str_release(_cl); _tr_str_release(_cr); _cres; })"
            elif l_owned:
                return "({ TrStr _cl = (" + ls + "); TrStr _cres = _tr_strx_concat(_cl.data, " + self.strz(rs) + "); _tr_str_release(_cl); _cres; })"
            elif r_owned:
                return "({ TrStr _cr = (" + rs + "); TrStr _cres = _tr_strx_concat(" + self.strz(ls) + ", _cr.data); _tr_str_release(_cr); _cres; })"
            return "_tr_strx_concat(" + self.strz(ls) + ", " + self.strz(rs) + ")"
        # String repetition: "ab" * 3  (or  3 * "ab"), Python-style.
        if op == "*" and (_is_str_type(lt_n) or _is_str_type(rt_n)):
            if _is_str_type(lt_n):
                return "_tr_strx_repeat(" + self.strz(ls) + ", (long long)(" + rs + "))"
            return "_tr_strx_repeat(" + self.strz(rs) + ", (long long)(" + ls + "))"
        if op == "and":
            mut lsa = ls
            mut rsa = rs
            if self.has_method(lt_n, "__bool__"): lsa = self.cls_method_c_call(lt_n, "__bool__", ls, "")
            if self.has_method(rt_n, "__bool__"): rsa = self.cls_method_c_call(rt_n, "__bool__", rs, "")
            return "(" + lsa + " && " + rsa + ")"
        if op == "or":
            mut lso = ls
            mut rso = rs
            if self.has_method(lt_n, "__bool__"): lso = self.cls_method_c_call(lt_n, "__bool__", ls, "")
            if self.has_method(rt_n, "__bool__"): rso = self.cls_method_c_call(rt_n, "__bool__", rs, "")
            return "(" + lso + " || " + rso + ")"
        if op == "is": return "(" + ls + " == " + rs + ")"
        if op == "in":
            if rt_n == "List" or rt_n == "Vec":
                mut in_sfx: str = self.list_elem_suffix(lt_n)
                return "List_" + self.list_sfx(in_sfx) + "_contains(" + rs + ", " + ls + ")"
            if rt_n == "Map" or rt_n == "Dict":
                return "_tr_dict_contains(" + rs + ", " + self.strz(ls) + ")"
            if self.has_method(rt_n, "__contains__"):
                return self.cls_method_c_call(rt_n, "__contains__", rs, ls)
            return "_tr_contains(" + self.strz(rs) + ", " + self.strz(ls) + ")"
        # Dunder dispatch for arithmetic and comparison ops
        mut dunder = ""
        if op == "+": dunder = "__add__"
        elif op == "-": dunder = "__sub__"
        elif op == "*": dunder = "__mul__"
        elif op == "/": dunder = "__truediv__"
        elif op == "%": dunder = "__mod__"
        elif op == "**": dunder = "__pow__"
        elif op == "//": dunder = "__floordiv__"
        elif op == "==": dunder = "__eq__"
        elif op == "!=": dunder = "__ne__"
        elif op == "<": dunder = "__lt__"
        elif op == "<=": dunder = "__le__"
        elif op == ">": dunder = "__gt__"
        elif op == ">=": dunder = "__ge__"
        if dunder != "":
            mut mono_l = self.mono_cls_name_for(hir_expr_type(l))
            if self.has_method(mono_l, dunder):
                return self.cls_method_c_call(mono_l, dunder, ls, rs)
        if op == "**": return "((long long)pow((double)(" + ls + "), (double)(" + rs + ")))"
        if op == "//": return "((long long)(" + ls + ") / (long long)(" + rs + "))"
        if (_is_str_type(lt_n) or _is_str_type(rt_n)) and (op == "==" or op == "!="):
            if op == "==": return "(strcmp(" + self.strz(ls) + ", " + self.strz(rs) + ") == 0)"
            return "(strcmp(" + self.strz(ls) + ", " + self.strz(rs) + ") != 0)"
        if (_is_str_type(lt_n) or _is_str_type(rt_n)) and (op == "<" or op == ">" or op == "<=" or op == ">="):
            return "(strcmp(" + self.strz(ls) + ", " + self.strz(rs) + ") " + op + " 0)"
        if self.enums.contains(lt_n) and (op == "==" or op == "!="):
            return "(" + ls + ".tag " + op + " " + rs + ".tag)"
        return "(" + ls + " " + op + " " + rs + ")"

    pub def gen_unary(self, op: str, expr: Pointer[HirExpr]) -> str:
        mut inner = self.gen_expr(expr)
        mut ty_n: str = hir_expr_type(expr).name
        if op == "not" or op == "!":
            if self.has_method(ty_n, "__bool__"):
                return "(!(" + self.cls_method_c_call(ty_n, "__bool__", inner, "") + "))"
            return "(!" + inner + ")"
        if op == "-" and self.has_method(ty_n, "__neg__"):
            return self.cls_method_c_call(ty_n, "__neg__", inner, "")
        if op == "+" and self.has_method(ty_n, "__pos__"):
            return self.cls_method_c_call(ty_n, "__pos__", inner, "")
        if op == "*" or op == "deref": return "(*" + inner + ")"
        if op == "&" or op == "ref": return "(&" + inner + ")"
        return "(" + op + inner + ")"

    pub def gen_prop_access(self, o: Pointer[HirExpr], p: str) -> str:
        mut t_n: str = hir_expr_type(o).name
        mut obj_s = self.gen_expr(o)
        # Shared var: unwrap _TrSharedBox* -> (TypeName*)obj->data
        if self.shared_vars.contains(obj_s):
            mut sh_ty = self.shared_vars.get(obj_s)
            return "((" + sh_ty + "*)(" + obj_s + "->data))->" + p
        # Shared[T]-TYPED receiver (e.g. a `cfg: Shared[Config]` param, not a
        # `shared` local): same unwrap — deref the atomic box to the inner T.
        if t_n == "Shared":
            mut _shp_ft = hir_expr_type(o)
            if _shp_ft.args.len > 0:
                return "((" + _shp_ft.args.get(0).read().name + "*)(" + obj_s + "->data))->" + p
        if self.enums.contains(t_n):
            if obj_s == t_n: return t_n + "_make_" + p + "()"
            return obj_s + ".data." + p
        if t_n == "Pointer": return "(*" + obj_s + ")." + p
        if t_n == "Array" and (p == "len" or p == "length"):
            return "((long long)" + hir_expr_type(o).array_size.to_str() + ")"   # compile-time N
        if _is_str_type(t_n) and (p == "len" or p == "length"):
            return "((long long)_tr_strlen(" + self.strz(obj_s) + "))"
        if t_n == "StringBuilder" and (p == "len" or p == "length"):
            return "(" + obj_s + "->buf->len)"
        if t_n == "Result":
            if p == "is_err": return "(" + obj_s + ".tag == Result_Err)"
            if p == "is_ok": return "(" + obj_s + ".tag == Result_Ok)"
            if p == "ok":
                mut full_ty = hir_expr_type(o)
                if full_ty.args.len > 0:
                    return self.unwrap_voidp_as("Result_unwrap(" + obj_s + ")", full_ty.args.get(0).read())
                return "Result_unwrap(" + obj_s + ")"
            if p == "err":
                mut full_ty2 = hir_expr_type(o)
                if full_ty2.args.len > 1:
                    return self.unwrap_voidp_as("Result_unwrap_err(" + obj_s + ")", full_ty2.args.get(1).read())
                return "_tr_str_lit((char*)Result_unwrap_err(" + obj_s + "))"
            return obj_s + "." + p
        if t_n == "Option":
            if p == "is_some": return "(" + obj_s + ".tag == Option_Some)"
            if p == "is_none": return "(" + obj_s + ".tag == Option_None)"
            if p == "value" or p == "val":
                mut full_opt_ty = hir_expr_type(o)
                if full_opt_ty.args.len > 0:
                    return self.unwrap_voidp_as("Option_unwrap(" + obj_s + ")", full_opt_ty.args.get(0).read())
                return "Option_unwrap(" + obj_s + ")"
            # Handle Option.None / Option.Some as static constructors (p may be empty if None is a keyword)
            if p == "" or p == "None" or p == "none": return "((Option){.tag=Option_None})"
            if p == "Some" or p == "some": return "((Option){.tag=Option_Some})"
            return obj_s + "." + p
        if self.interfaces.contains(t_n) and self.interfaces as usize != 0 as usize:
            return obj_s + "." + p
        # Value type (@value_type): field access by value, `.` not `->`. Inside a
        # MUTATING value-type method, `self` is a pointer -> `self->field`.
        if self.value_types.contains(t_n):
            if obj_s == "self" and self.cur_self_is_ptr:
                return obj_s + "->" + p
            return obj_s + "." + p
        return obj_s + "->" + p

    pub def gen_index(self, o: Pointer[HirExpr], idx: Pointer[HirExpr]) -> str:
        mut os = self.gen_expr(o)
        mut is_idx = self.gen_expr(idx)
        mut ty_n: str = hir_expr_type(o).name
        if ty_n == "Pointer": return os + "[" + is_idx + "]"
        if ty_n == "Array":
            # Fixed-size array: bounds-checked `.data[i]` (lvalue + rvalue). N is the
            # compile-time size carried on the type.
            mut arr_o_ty = hir_expr_type(o)
            return os + ".data[(_tr_bounds_check(" + is_idx + ", " + arr_o_ty.array_size.to_str() + "), " + is_idx + ")]"
        if ty_n == "List" or ty_n == "Vec":
            # Bounds-checked access - works as both lvalue and rvalue.
            # The comma operator in the subscript runs the check then uses the index.
            mut idx_r = os + "->data[(_tr_bounds_check(" + is_idx + ", " + os + "->len), " + is_idx + ")]"
            mut o_full_ty = hir_expr_type(o)
            if o_full_ty.args.len > 0 and _is_str_type(self.resolve_generic_prim(o_full_ty.args.get(0).read().name)):
                return "_tr_str_lit(" + idx_r + ")"
            return idx_r
        if self.classes.contains(ty_n) and ty_n != "Vec" and ty_n != "List" and ty_n != "Map" and ty_n != "Dict":
            if self.has_method(ty_n, "__getitem__"):
                return self.cls_method_c_call(ty_n, "__getitem__", os, is_idx)
            return ty_n + "_get_index(" + os + ", " + is_idx + ")"
        if _is_str_type(ty_n):
            return self.strz(os) + "[" + is_idx + "]"
        return os + "[" + is_idx + "]"

    # True when a call arg is a `Shared[T]` handle (a `shared` var — typed as its
    # inner T with a `_TrSharedBox*` runtime repr — or a `Shared[T]` value) being
    # passed to a param that expects the PLAIN inner class `T`. The call site must
    # then unwrap the atomic box to `((T*)box->data)`. This is what lets a worker
    # pass its shared `App`/`HttpConn` handles to functions taking `App`/`HttpConn`.
    pub def _call_arg_needs_shared_unwrap(self, arg: Pointer[HirExpr], param_ty: AstType) -> bool:
        mut pn = param_ty.name
        if pn == "Shared" or pn == "Weak" or pn == "Pointer": return false
        if not self.classes.contains(pn): return false
        mut at = hir_expr_type(arg)
        if at.name == "Shared" and at.args.len > 0 and at.args.get(0).read().name == pn: return true
        if at.name == pn:
            match arg.read():
                case HirExpr.EIdent(nm, _, _):
                    if self.shared_vars.contains(_safe_c_varname(nm)): return true
                case _: pass
        return false

    pub def gen_call(self, callee: Pointer[HirExpr], args: Vec[Pointer[HirExpr]], call_ty: AstType) -> str:
        mut callee_s = self.gen_expr(callee)
        
        # Check if callee is a generic built-in call target like alloc[T] or dealloc[T]
        mut base_callee = callee_s
        mut has_generic = false
        mut generic_ty = AstType.init("void")
        # Vec[T].init(n) / List[T].init(n) - static generic constructor
        match callee.read():
            case HirExpr.EPropAccess(inner_obj, variant, _):
                if variant == "init" or variant == "new":
                    match inner_obj.read():
                        case HirExpr.EIndex(base_expr, idx_expr, _):
                            match base_expr.read():
                                case HirExpr.EIdent(gn, _, _):
                                    if gn == "Vec" or gn == "List":
                                        match idx_expr.read():
                                            case HirExpr.EIdent(elem_n, _, _):
                                                mut sfx = self.list_elem_suffix(elem_n)
                                                return "(void*)List_" + self.list_sfx(sfx) + "_new()"
                                            case _: pass
                                case _: pass
                        case _: pass
            case _: pass

        match callee.read():
            case HirExpr.EIdent(raw_n, _, _):
                # Use raw identifier name (not gen_expr output) so C-keyword variable names
                # like `int`, `float`, `count` don't obscure builtin dispatch.
                base_callee = raw_n
            case HirExpr.EIndex(base_expr, idx_expr, idx_ty):
                match base_expr.read():
                    case HirExpr.EIdent(n, _, _):
                        if n == "alloc" or n == "core_alloc_alloc" or n == "dealloc" or n == "Pointer" or n == "resize" or n == "core_alloc_resize" or n == "copy" or n == "core_alloc_copy":
                            base_callee = n
                            has_generic = true
                            match idx_expr.read():
                                case HirExpr.EIdent(tname, _, _):
                                    generic_ty = AstType.init(tname)
                                case _: pass
                    case _: pass
            case _: pass

        # Mangle C reserved keywords used as call targets
        if _is_c_keyword(base_callee): base_callee = "_tr_fn_" + base_callee

        # Direct call to a known top-level function: use the plain name, not the
        # "(void*)name" value form that gen_expr emits for function references.
        match callee.read():
            case HirExpr.EIdent(_dc_n, _, _):
                if self.functions.contains(_dc_n): callee_s = base_callee
            case _: pass

        # print builtin
        if base_callee == "print":
            return self.gen_print_call(args)

        # len builtin
        if base_callee == "len":
            if args.len > 0:
                mut arg0 = args.get(0)
                mut arg0_ty_n: str = hir_expr_type(arg0).name
                if _is_str_type(arg0_ty_n): return "_tr_strlen(" + self.strz(self.gen_expr(arg0)) + ")"
                if self.has_method(arg0_ty_n, "__len__"):
                    return self.cls_method_c_call(arg0_ty_n, "__len__", self.gen_expr(arg0), "")
                return self.gen_expr(arg0) + "->len"
            return "0LL"

        # range builtin (used in for loops - returns range struct)
        if base_callee == "range":
            if args.len == 1:
                return "_tr_range(0, " + self.gen_expr(args.get(0)) + ", 1)"
            elif args.len == 2:
                return "_tr_range(" + self.gen_expr(args.get(0)) + ", " + self.gen_expr(args.get(1)) + ", 1)"
            elif args.len == 3:
                return "_tr_range(" + self.gen_expr(args.get(0)) + ", " + self.gen_expr(args.get(1)) + ", " + self.gen_expr(args.get(2)) + ")"
            return "_tr_range(0, 0, 1)"

        # _tr_exit
        if base_callee == "_tr_exit":
            if args.len > 0: return "exit((int)(" + self.gen_expr(args.get(0)) + "))"
            return "exit(0)"

        # ord / chr - character conversions
        if base_callee == "ord":
            if args.len > 0:
                mut ord_t_n: str = hir_expr_type(args.get(0)).name
                if ord_t_n == "char": return "((long long)(unsigned char)(" + self.gen_expr(args.get(0)) + "))"
                return "((long long)(unsigned char)(" + self.gen_expr(args.get(0)) + ")[0])"
            return "0LL"
        if base_callee == "chr":
            if args.len > 0: return "((char)(" + self.gen_expr(args.get(0)) + "))"
            return "'\\0'"

        # abs - absolute value
        if base_callee == "abs":
            if args.len > 0:
                mut abs_a = self.gen_expr(args.get(0))
                mut abs_t_n: str = hir_expr_type(args.get(0)).name
                if _is_float_type(abs_t_n): return "fabs((double)(" + abs_a + "))"
                return "llabs((long long)(" + abs_a + "))"
            return "0LL"

        # max / min - pairwise comparisons
        if base_callee == "max":
            if args.len == 2:
                mut ma = self.next_temp()
                mut mb = self.next_temp()
                return "({ __auto_type " + ma + " = " + self.gen_expr(args.get(0)) + "; __auto_type " + mb + " = " + self.gen_expr(args.get(1)) + "; " + ma + " > " + mb + " ? " + ma + " : " + mb + "; })"
            return "0LL"
        if base_callee == "min":
            if args.len == 2:
                mut mna = self.next_temp()
                mut mnb = self.next_temp()
                return "({ __auto_type " + mna + " = " + self.gen_expr(args.get(0)) + "; __auto_type " + mnb + " = " + self.gen_expr(args.get(1)) + "; " + mna + " < " + mnb + " ? " + mna + " : " + mnb + "; })"
            return "0LL"

        # assert_eq / assert_ne / assert_lt / assert_le / assert_gt / assert_ge
        # Prints both values on failure so the user sees what was expected vs got.
        if base_callee == "assert_eq" or base_callee == "assert_ne" or base_callee == "assert_lt" or base_callee == "assert_le" or base_callee == "assert_gt" or base_callee == "assert_ge":
            if args.len >= 2:
                mut _aa = self.gen_expr(args.get(0))
                mut _ab = self.gen_expr(args.get(1))
                mut _ta = self.next_temp()
                mut _tb = self.next_temp()
                mut _op = "=="
                mut _op_msg = "expected equal"
                if base_callee == "assert_ne": _op = "!="; _op_msg = "expected not-equal"
                elif base_callee == "assert_lt": _op = "<";  _op_msg = "expected less-than"
                elif base_callee == "assert_le": _op = "<="; _op_msg = "expected less-or-equal"
                elif base_callee == "assert_gt": _op = ">";  _op_msg = "expected greater-than"
                elif base_callee == "assert_ge": _op = ">="; _op_msg = "expected greater-or-equal"
                mut _ty_a = hir_expr_type(args.get(0)).name
                mut _cvt = "(long long)"
                if _is_float_type(_ty_a): _cvt = "(double)"
                elif not _is_int_type(_ty_a): _cvt = "(long long)(uintptr_t)"
                return "({ __auto_type " + _ta + " = " + _aa + "; __auto_type " + _tb + " = " + _ab + "; if (!(" + _ta + " " + _op + " " + _tb + ")) { fprintf(stderr, \"[assert_" + _op + "] " + _op_msg + ": lhs=%lld rhs=%lld\\n\", (long long)" + _ta + ", (long long)" + _tb + "); abort(); } })"
            return "(void)0"

        # checked_add / checked_sub / checked_mul - returns Option[int]
        if base_callee == "checked_add" or base_callee == "checked_mul":
            if args.len == 2:
                mut _ca = self.gen_expr(args.get(0))
                mut _cb = self.gen_expr(args.get(1))
                mut _tres = self.next_temp()
                mut _op_c = "+"
                if base_callee == "checked_mul": _op_c = "*"
                return "({ long long " + _tres + "; _Bool _ov = __builtin_add_overflow((long long)(" + _ca + "), (long long)(" + _cb + "), &" + _tres + "); _ov ? ((Option){.tag=Option_None}) : ((Option){.tag=Option_Some,.data.Some.val=(void*)(uintptr_t)" + _tres + "}); })"
            return "((Option){.tag=Option_None})"
        if base_callee == "checked_sub":
            if args.len == 2:
                mut _ca2 = self.gen_expr(args.get(0))
                mut _cb2 = self.gen_expr(args.get(1))
                mut _tres2 = self.next_temp()
                return "({ long long " + _tres2 + "; _Bool _ov = __builtin_sub_overflow((long long)(" + _ca2 + "), (long long)(" + _cb2 + "), &" + _tres2 + "); _ov ? ((Option){.tag=Option_None}) : ((Option){.tag=Option_Some,.data.Some.val=(void*)(uintptr_t)" + _tres2 + "}); })"
            return "((Option){.tag=Option_None})"

        # round - rounding a float
        if base_callee == "round":
            if args.len > 0: return "(double)round((double)(" + self.gen_expr(args.get(0)) + "))"
            return "0.0"

        # str() - convert to string
        if base_callee == "str":
            if args.len > 0:
                mut str_arg = args.get(0)
                mut str_t_n: str = self.resolve_generic_prim(hir_expr_type(str_arg).name)
                if _is_int_type(str_t_n): return "_tr_str_wrap(_tr_int_to_str((long long)(" + self.gen_expr(str_arg) + ")))"
                if _is_float_type(str_t_n): return "_tr_str_wrap(_tr_float_to_str((double)(" + self.gen_expr(str_arg) + ")))"
                if str_t_n == "bool": return "((" + self.gen_expr(str_arg) + ") ? _tr_str_lit(\"true\") : _tr_str_lit(\"false\"))"
                if self.has_method(str_t_n, "__str__"):
                    return self.cls_method_c_call(str_t_n, "__str__", self.gen_expr(str_arg), "")
                if self.has_method(str_t_n, "__repr__"):
                    return self.cls_method_c_call(str_t_n, "__repr__", self.gen_expr(str_arg), "")
                if _is_str_type(str_t_n): return self.gen_expr(str_arg)
                return "_tr_str_wrap((char*)(" + self.gen_expr(str_arg) + "))"
            return "_tr_str_lit(\"\")"

        # repr() - detailed string representation
        if base_callee == "repr":
            if args.len > 0:
                mut repr_arg = args.get(0)
                mut repr_t_n: str = hir_expr_type(repr_arg).name
                if self.has_method(repr_t_n, "__repr__"):
                    return self.cls_method_c_call(repr_t_n, "__repr__", self.gen_expr(repr_arg), "")
                if self.has_method(repr_t_n, "__str__"):
                    return self.cls_method_c_call(repr_t_n, "__str__", self.gen_expr(repr_arg), "")
                if _is_str_type(repr_t_n): return self.gen_expr(repr_arg)
                return "_tr_str_wrap((char*)(" + self.gen_expr(repr_arg) + "))"
            return "_tr_str_lit(\"\")"

        # int() / float() / bool() - type coercions; int/float from str -> parse
        if base_callee == "int" or base_callee == "_tr_fn_int":
            if args.len > 0:
                if _is_str_type(hir_expr_type(args.get(0)).name): return "_tr_str_to_int(" + self.strz(self.gen_expr(args.get(0))) + ")"
                return "(long long)(" + self.gen_expr(args.get(0)) + ")"
            return "0LL"
        if base_callee == "float" or base_callee == "_tr_fn_float":
            if args.len > 0:
                if _is_str_type(hir_expr_type(args.get(0)).name): return "_tr_str_to_float(" + self.strz(self.gen_expr(args.get(0))) + ")"
                return "(double)(" + self.gen_expr(args.get(0)) + ")"
            return "0.0"
        if base_callee == "bool":
            if args.len > 0: return "(_Bool)(" + self.gen_expr(args.get(0)) + ")"
            return "0"

        # type() - returns a string representation of the type
        if base_callee == "type":
            return "\"<object>\""

        # await_all(f1(args), f2(args), ...) - run all calls concurrently, wait for completion
        if base_callee == "await_all":
            if args.len == 0: return "0LL"
            mut aa_code = "({ _tr_tg_begin(); "
            mut aa_i = 0
            while aa_i < args.len:
                mut aa_fn = ""
                mut aa_call_args: Vec[Pointer[HirExpr]] = []
                match args.get(aa_i).read():
                    case HirExpr.ECall(aa_c, aa_a, _):
                        match aa_c.read():
                            case HirExpr.EIdent(aa_n, _, _): aa_fn = aa_n
                            case _: pass
                        aa_call_args = aa_a
                    case _: pass
                if aa_fn != "":
                    if aa_call_args.len == 0:
                        aa_code = aa_code + "_tr_tg_push(_tr_thread_start(_tr_spawn_wrap_" + aa_fn + ", NULL)); "
                    elif aa_call_args.len == 1:
                        mut aa_aty = hir_expr_type(aa_call_args.get(0)).name
                        mut aa_vcast = "(void*)(uintptr_t)(" + self.gen_expr(aa_call_args.get(0)) + ")"
                        if not _is_int_type(aa_aty) and aa_aty != "bool" and aa_aty != "char":
                            aa_vcast = "(void*)(" + self.gen_expr(aa_call_args.get(0)) + ")"
                        aa_code = aa_code + "_tr_tg_push(_tr_thread_start(_tr_spawn_wrap_" + aa_fn + ", " + aa_vcast + ")); "
                    else:
                        # multi-arg: heap-pack
                        mut aa_na = aa_call_args.len
                        aa_code = aa_code + "{ long long* _aab" + str(aa_i) + " = (long long*)malloc(" + str(aa_na + 1) + " * sizeof(long long)); "
                        mut aa_ai2 = 0
                        while aa_ai2 < aa_na:
                            mut aa_atn = hir_expr_type(aa_call_args.get(aa_ai2)).name
                            if not _is_int_type(aa_atn) and aa_atn != "bool" and aa_atn != "char":
                                aa_code = aa_code + "_aab" + str(aa_i) + "[" + str(aa_ai2 + 1) + "] = (long long)" + self.gen_expr(aa_call_args.get(aa_ai2)) + "; "
                            else:
                                aa_code = aa_code + "_aab" + str(aa_i) + "[" + str(aa_ai2 + 1) + "] = (long long)(" + self.gen_expr(aa_call_args.get(aa_ai2)) + "); "
                            aa_ai2 = aa_ai2 + 1
                        aa_code = aa_code + "_tr_tg_push(_tr_thread_start(_tr_spawn_wrap_" + aa_fn + ", _aab" + str(aa_i) + ")); } "
                else:
                    aa_code = aa_code + self.gen_expr(args.get(aa_i)) + "; "
                aa_i = aa_i + 1
            aa_code = aa_code + "_tr_taskgroup_wait(); 0LL; })"
            return aa_code

        # iter / enumerate / sorted / reversed - identity for now
        if base_callee == "iter" or base_callee == "enumerate" or base_callee == "sorted" or base_callee == "reversed":
            if args.len > 0: return self.gen_expr(args.get(0))
            return "NULL"

        # sum - sum all elements of a list
        if base_callee == "sum":
            if args.len > 0:
                mut sum_tmp = self.next_temp()
                mut sum_l = self.next_temp()
                return "({ long long " + sum_tmp + " = 0; __auto_type " + sum_l + " = " + self.gen_expr(args.get(0)) + "; for (long long _si = 0; _si < " + sum_l + "->len; _si++) " + sum_tmp + " += (long long)" + sum_l + "->data[_si]; " + sum_tmp + "; })"
            return "0LL"

        # any / all - short-circuit list scan
        if base_callee == "any":
            if args.len > 0:
                mut any_l = self.next_temp()
                return "({ _Bool _any_r = 0; __auto_type " + any_l + " = " + self.gen_expr(args.get(0)) + "; for (long long _ai = 0; _ai < " + any_l + "->len; _ai++) if (" + any_l + "->data[_ai]) { _any_r = 1; break; } _any_r; })"
            return "0"
        if base_callee == "all":
            if args.len > 0:
                mut all_l = self.next_temp()
                return "({ _Bool _all_r = 1; __auto_type " + all_l + " = " + self.gen_expr(args.get(0)) + "; for (long long _ai = 0; _ai < " + all_l + "->len; _ai++) if (!" + all_l + "->data[_ai]) { _all_r = 0; break; } _all_r; })"
            return "1"

        # Option / Result constructors
        if base_callee == "Some":
            mut some_cv2 = "NULL"
            if args.len > 0: some_cv2 = self.wrap_voidp_arg(args.get(0))
            return "((Option){.tag=Option_Some, .data.Some.val=" + some_cv2 + "})"
        if base_callee == "Ok":
            mut ok_cv2 = "NULL"
            if args.len > 0: ok_cv2 = self.wrap_voidp_arg(args.get(0))
            return "((Result){.tag=Result_Ok, .data.Ok.val=" + ok_cv2 + "})"
        if base_callee == "Err":
            mut err_cv2 = "NULL"
            if args.len > 0: err_cv2 = self.wrap_voidp_arg(args.get(0))
            return "((Result){.tag=Result_Err, .data.Err.err=" + err_cv2 + "})"

        # Intercept alloc
        if base_callee == "alloc" or base_callee == "core_alloc_alloc":
            mut count_s = "1LL"
            if args.len > 0: count_s = self.gen_expr(args.get(0))
            mut alloc_ty = "void"
            if has_generic and generic_ty.name != "void":
                alloc_ty = self.type_to_c(generic_ty)
            elif call_ty.name == "Pointer" and call_ty.args.len > 0:
                alloc_ty = self.type_to_c(call_ty.args.get(0).read())
            else:
                match callee.read():
                    case HirExpr.EIdent(_, ident_ty, _):
                        if ident_ty.args.len > 0:
                            alloc_ty = self.type_to_c(ident_ty.args.get(0).read())
                    case _: pass
            if alloc_ty == "void":
                return "malloc((size_t)(" + count_s + "))"
            if alloc_ty == "void*":
                return "((void**)_tr_c_calloc((size_t)(" + count_s + "), sizeof(void*)))"
            return "((" + alloc_ty + "*)_tr_c_calloc((size_t)(" + count_s + "), sizeof(" + alloc_ty + ")))"

        # Intercept dealloc
        if base_callee == "dealloc":
            if args.len > 0:
                return "_tr_free((void*)(" + self.gen_expr(args.get(0)) + "))"
            return ""

        # Intercept resize[T](ptr, n) -> _tr_c_realloc
        if base_callee == "resize" or base_callee == "core_alloc_resize":
            if args.len >= 2:
                mut rptr_s = self.gen_expr(args.get(0))
                mut rcnt_s = self.gen_expr(args.get(1))
                mut resize_ty = "void"
                if has_generic and generic_ty.name != "void":
                    resize_ty = self.type_to_c(generic_ty)
                if resize_ty == "void" or resize_ty == "void*":
                    return "(void*)_tr_c_realloc((void*)(" + rptr_s + "), (size_t)(" + rcnt_s + "))"
                return "((" + resize_ty + "*)_tr_c_realloc((void*)(" + rptr_s + "), (size_t)(" + rcnt_s + ") * sizeof(" + resize_ty + ")))"
            return "NULL"

        # Intercept copy[T](dst, src, n) -> _tr_c_memcpy
        if base_callee == "copy" or base_callee == "core_alloc_copy":
            if args.len >= 3:
                mut cdst_s = self.gen_expr(args.get(0))
                mut csrc_s = self.gen_expr(args.get(1))
                mut ccnt_s = self.gen_expr(args.get(2))
                mut copy_ty = "void"
                if has_generic and generic_ty.name != "void":
                    copy_ty = self.type_to_c(generic_ty)
                if copy_ty == "void" or copy_ty == "void*":
                    return "_tr_c_memcpy((void*)(" + cdst_s + "), (void*)(" + csrc_s + "), (size_t)(" + ccnt_s + "))"
                return "_tr_c_memcpy((void*)(" + cdst_s + "), (void*)(" + csrc_s + "), (size_t)(" + ccnt_s + ") * sizeof(" + copy_ty + "))"
            return ""

        # input() - read a line from stdin
        if base_callee == "input":
            if args.len > 0: return "_tr_input(" + self.gen_expr(args.get(0)) + ")"
            return "_tr_input(NULL)"

        # Pointer[T](addr) -> (T*)addr  (null pointer construction)
        if base_callee == "Pointer":
            if args.len > 0:
                mut ptr_arg = self.gen_expr(args.get(0))
                if has_generic and generic_ty.name != "void":
                    mut ct = self.type_to_c(generic_ty)
                    return "(" + ct + "*)(" + ptr_arg + ")"
                match callee.read():
                    case HirExpr.EIdent(_, ident_ty, _):
                        if ident_ty.args.len > 0:
                            mut elem = ident_ty.args.get(0).read()
                            mut ct = self.type_to_c(elem)
                            return "(" + ct + "*)(" + ptr_arg + ")"
                    case _: pass
                return "(void*)(" + ptr_arg + ")"
            return "NULL"

        # Class constructor call: ClassName() or GenericClass[T]()
        match callee.read():
            case HirExpr.EIdent(n, ident_ty, _):
                if self.classes.contains(n) and n != "Vec" and n != "Map" and n != "Dict" and n != "List":
                    mut ucls = self.classes.get(n)
                    # Value type (@value_type): construct on the STACK by value, no
                    # heap allocation, no refcount. Resolve the monomorphized name
                    # for a generic value type (`Box[T]()` -> `(Box_i64){0}`).
                    if self.value_types.contains(n):
                        if ucls.generics.len > 0 and ident_ty.args.len > 0:
                            self.ensure_mono(ucls, ident_ty.args)
                            return "(" + n + "_" + self.type_args_suffix(ident_ty.args) + "){0}"
                        if ucls.generics.len > 0:
                            mut vsfx = self.synth_class_suffix(ucls)
                            if vsfx != "": return "(" + n + "_" + vsfx + "){0}"
                        return "(" + n + "){0}"
                    if ucls.generics.len > 0 and ident_ty.args.len > 0:
                        mut sfx = self.type_args_suffix(ident_ty.args)
                        self.ensure_mono(ucls, ident_ty.args)
                        mut mn = n + "_" + sfx
                        return "((" + mn + "*)_tr_obj_alloc(sizeof(" + mn + ")))"
                    # Synthesize mono name from active type_subst when args absent in HIR
                    if ucls.generics.len > 0:
                        mut sfx2 = self.synth_class_suffix(ucls)
                        if sfx2 != "":
                            mut mn2 = n + "_" + sfx2
                            return "((" + mn2 + "*)_tr_obj_alloc(sizeof(" + mn2 + ")))"
                    return "((" + n + "*)_tr_obj_alloc(sizeof(" + n + ")))"
                if self.enums.contains(n):
                    return "(" + n + "){.tag=" + n + "_" + n + "}"
            case HirExpr.EPropAccess(obj_inner, variant, _):
                # Intercept Chan/Mutex/RwLock/ThreadPool static constructors
                mut oi_ctor_name = ""
                match obj_inner.read():
                    case HirExpr.EIdent(oin, _, _): oi_ctor_name = oin
                    case _: pass
                if oi_ctor_name == "Chan":
                    if variant == "init":
                        mut ch_cap = "1LL"
                        if args.len > 0: ch_cap = self.gen_expr(args.get(0))
                        return "_tr_chan_new(" + ch_cap + ")"
                if oi_ctor_name == "Mutex":
                    if variant == "init":
                        mut mx_val = "0LL"
                        if args.len > 0: mx_val = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                        return "_tr_mutexbox_new(" + mx_val + ")"
                if oi_ctor_name == "RwLock":
                    if variant == "init":
                        mut rw_val = "0LL"
                        if args.len > 0: rw_val = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                        return "_tr_rwlbox_new(" + rw_val + ")"
                if oi_ctor_name == "ThreadPool":
                    if variant == "new":
                        mut tp_n = "4LL"
                        if args.len > 0: tp_n = self.gen_expr(args.get(0))
                        return "_tr_threadpool_new(" + tp_n + ")"
                    if variant == "auto":
                        return "_tr_threadpool_auto()"
                if oi_ctor_name == "Thread":
                    if variant == "spawn" or variant == "new":
                        if args.len >= 2:
                            mut th2_fn_nm = ""
                            match args.get(0).read():
                                case HirExpr.EIdent(thn3, _, _): th2_fn_nm = thn3
                                case _: pass
                            mut th2_arg_s = "(void*)(" + self.gen_expr(args.get(1)) + ")"
                            mut th2_aty = hir_expr_type(args.get(1)).name
                            if _is_int_type(th2_aty) or th2_aty == "bool" or th2_aty == "char":
                                th2_arg_s = "(void*)(uintptr_t)(" + self.gen_expr(args.get(1)) + ")"
                            if th2_fn_nm != "":
                                return "_tr_threadobj_spawn(_tr_spawn_wrap_" + th2_fn_nm + ", " + th2_arg_s + ")"
                            return "_tr_threadobj_spawn((void*(*)(void*))(" + self.gen_expr(args.get(0)) + "), " + th2_arg_s + ")"
                        elif args.len == 1:
                            mut th2_fn_nm2 = ""
                            match args.get(0).read():
                                case HirExpr.EIdent(thn4, _, _): th2_fn_nm2 = thn4
                                case _: pass
                            if th2_fn_nm2 != "":
                                return "_tr_threadobj_spawn(_tr_spawn_wrap_" + th2_fn_nm2 + ", NULL)"
                            return "_tr_threadobj_spawn((void*(*)(void*))(" + self.gen_expr(args.get(0)) + "), NULL)"
                    if variant == "sleep" or variant == "sleep_ms":
                        mut th2_ms = "0LL"
                        if args.len > 0: th2_ms = self.gen_expr(args.get(0))
                        return "_tr_thread_sleep_ms((long long)(" + th2_ms + "))"
                    if variant == "id" or variant == "current_id":
                        return "_tr_thread_current_id()"
                if oi_ctor_name == "Atomic":
                    if variant == "new" or variant == "init":
                        mut at2_v = "0LL"
                        if args.len > 0: at2_v = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                        return "_tr_atomic_new(" + at2_v + ")"
                if oi_ctor_name == "ThreadLocal":
                    if variant == "new" or variant == "init":
                        mut tl2_v = "0LL"
                        if args.len > 0: tl2_v = "(long long)(" + self.gen_expr(args.get(0)) + ")"
                        return "_tr_tls_new(" + tl2_v + ")"
                mut oi_type_n = hir_expr_type(obj_inner).name
                if oi_type_n == "Result":
                    if variant == "ok":
                        mut ok_val = "NULL"
                        if args.len > 0:
                            ok_val = self.wrap_voidp_arg(args.get(0))
                        return "((Result){.tag=Result_Ok, .data.Ok.val=" + ok_val + "})"
                    elif variant == "err":
                        mut err_val = "NULL"
                        if args.len > 0:
                            err_val = self.wrap_voidp_arg(args.get(0))
                        return "((Result){.tag=Result_Err, .data.Err.err=" + err_val + "})"
                elif oi_type_n == "Option":
                    if variant == "some" or variant == "Some":
                        mut sv = "NULL"
                        if args.len > 0:
                            sv = self.wrap_voidp_arg(args.get(0))
                        return "((Option){.tag=Option_Some, .data.Some.val=" + sv + "})"
                    elif variant == "none" or variant == "None":
                        return "((Option){.tag=Option_None})"
                if self.enums.contains(oi_type_n):
                    if args.len > 0:
                        return oi_type_n + "_ctor_" + variant + "(" + self.gen_args(args) + ")"
                    else:
                        return oi_type_n + "_make_" + variant + "()"
            case _: pass

        # If callee is a known function, auto-wrap class args that target interface params
        if self.functions.contains(callee_s):
            mut fn_def = self.functions.get(callee_s)
            mut self_skip = 0
            if fn_def.params as usize != 0 as usize and fn_def.params.len > 0 and fn_def.params.get(0).name == "self":
                self_skip = 1
            # Generic free function called by inference (no explicit [T]): specialize it.
            # Infer the single type param from a parameter declared directly as that
            # param (x: T), emit a monomorphized copy, and dispatch to it — zero-cost,
            # like a Rust generic. (Explicit fname[T](..) is mangled in sema and driven
            # by the mono scan; multi-param generics keep the erased path for now.)
            if fn_def.class_name == "" and fn_def.generics.len == 1:
                mut _targ = self.infer_generic_targ(callee_s, args)
                if _targ != "":
                    self.ensure_mono_func(callee_s, _targ)
                    return callee_s + "__MONO_" + _targ + "(" + self.gen_args(args) + ")"
            mut any_wrapped = false
            mut ai = 0
            while ai < args.len:
                mut pi = ai + self_skip
                if fn_def.params as usize != 0 as usize and pi < fn_def.params.len:
                    if self.interfaces.contains(fn_def.params.get(pi).ty.name):
                        mut actual_ty_n = hir_expr_type(args.get(ai)).name
                        if self.classes.contains(actual_ty_n):
                            any_wrapped = true
                    elif self._call_arg_needs_shared_unwrap(args.get(ai), fn_def.params.get(pi).ty):
                        any_wrapped = true
                ai = ai + 1
            if any_wrapped:
                mut wrapped_args = ""
                ai = 0
                while ai < args.len:
                    if ai > 0: wrapped_args = wrapped_args + ", "
                    mut pi = ai + self_skip
                    mut arg_s = self.gen_expr(args.get(ai))
                    if fn_def.params as usize != 0 as usize and pi < fn_def.params.len and self._call_arg_needs_shared_unwrap(args.get(ai), fn_def.params.get(pi).ty):
                        # Shared[T] handle -> plain T param: unwrap the atomic box.
                        arg_s = "((" + fn_def.params.get(pi).ty.name + "*)(" + arg_s + ")->data)"
                    if fn_def.params as usize != 0 as usize and pi < fn_def.params.len:
                        mut _p_iface_ty = fn_def.params.get(pi).ty
                        mut expected_iface = _p_iface_ty.name
                        if self.interfaces.contains(expected_iface):
                            mut _ep_iface = self.interfaces.get(expected_iface)
                            if _ep_iface.generics.len > 0 and _p_iface_ty.args.len > 0:
                                expected_iface = expected_iface + "_" + self.type_args_suffix(_p_iface_ty.args)
                            mut actual_ty_e = hir_expr_type(args.get(ai))
                            mut actual_ty_n = actual_ty_e.name
                            if self.classes.contains(actual_ty_n):
                                mut _acls = self.classes.get(actual_ty_n)
                                if _acls.generics.len > 0 and actual_ty_e.args.len > 0:
                                    actual_ty_n = actual_ty_n + "_" + self.type_args_suffix(actual_ty_e.args)
                                arg_s = actual_ty_n + "_as_" + expected_iface + "(" + arg_s + ")"
                    wrapped_args = wrapped_args + arg_s
                    ai = ai + 1
                return callee_s + "(" + wrapped_args + ")"

        # Lambda / void* function pointer: cast to typed function pointer before calling
        mut callee_ty_n: str = hir_expr_type(callee).name
        # Indirect call through a function-pointer VALUE (a variable/element of
        # type def(...)->R, or a lambda). A direct call to a named top-level
        # function is excluded - it emits a plain call below.
        mut _callee_direct_fn = false
        match callee.read():
            case HirExpr.EIdent(_lc_n, _, _):
                if self.functions.contains(_lc_n): _callee_direct_fn = true
            case _: pass
        if (callee_ty_n == "lambda" or callee_ty_n == "void*" or callee_ty_n == "def") and not _callee_direct_fn:
            mut ret_cty = self.type_to_c(call_ty)
            if ret_cty == "void" or ret_cty == "void*": ret_cty = "long long"
            mut arg_types = ""
            mut ai2 = 0
            while ai2 < args.len:
                if ai2 > 0: arg_types = arg_types + ", "
                arg_types = arg_types + self.type_to_c(hir_expr_type(args.get(ai2)))
                ai2 = ai2 + 1
            # A def-typed value is either a CLOSURE (a tagged heap env whose first
            # word is the fn pointer, called with the env as the first arg) or a
            # bare NAMED-function pointer (untagged, called directly). Branch on
            # the tag. `gen_args` is emitted once and reused in both arms; only the
            # taken arm runs at runtime.
            mut _cargs = self.gen_args(args)
            mut env_sig = "void*"
            if arg_types != "": env_sig = "void*, " + arg_types
            mut dir_sig = arg_types
            if dir_sig == "": dir_sig = "void"
            mut env_args = "__ce"
            if args.len > 0: env_args = "__ce, " + _cargs
            mut dir_args = _cargs
            return "({ void* __cl = (void*)(" + callee_s + "); void* __ce = (void*)((uintptr_t)__cl & ~(uintptr_t)1); ((uintptr_t)__cl & 1) ? ((" + ret_cty + "(*)(" + env_sig + "))(*(void**)__ce))(" + env_args + ") : ((" + ret_cty + "(*)(" + dir_sig + "))__cl)(" + dir_args + "); })"

        # __call__ dispatch: callee is a variable holding a callable object
        mut callee_cls_ty: str = hir_expr_type(callee).name
        if self.classes.contains(callee_cls_ty) and self.has_method(callee_cls_ty, "__call__"):
            mut is_fn_or_cls = false
            match callee.read():
                case HirExpr.EIdent(cname, _, _):
                    if self.functions.contains(cname): is_fn_or_cls = true
                    if self.classes.contains(cname): is_fn_or_cls = true
                case _: pass
            if not is_fn_or_cls:
                return self.cls_method_c_call(callee_cls_ty, "__call__", callee_s, self.gen_args(args))
        # `unsafe: _tr_c_free(x as Pointer[char])` is the pre-TrStr-migration
        # idiom for releasing a heap string's buffer. For a TrStr-typed `x`,
        # `x as Pointer[char]` lowers to `_tr_strz(x)` (just `.data`), so
        # `_tr_c_free(_tr_strz(x))` frees `.data` but leaks `x`'s separately
        # allocated `.rc` block. Rewrite to `_tr_str_release(x)`, which frees
        # both when the refcount drops to zero (and is a no-op for
        # rc==NULL literals/borrows).
        if base_callee == "_tr_c_free" and args.len == 1:
            match args.get(0).read():
                case HirExpr.ECast(_cf_inner, _):
                    if _is_str_type(hir_expr_type(_cf_inner).name):
                        return "_tr_str_release(" + self.gen_expr(_cf_inner) + ")"
                case _: pass

        # Direct calls to legacy runtime helpers (named `_tr_*`) from .tr source
        # take raw char* for str params and return char*; unwrap TrStr-typed
        # args and rewrap a char*-returning result at the boundary.
        # Exception: names starting with `_tr_` that are actually user-defined
        # Tauraro functions (e.g. hir.tr's `_tr_str_len`, imported across
        # modules so not present in self.functions) use normal TrStr ABI.
        # `extern "C": def _tr_xxx(...)` declarations ARE present in
        # self.functions (with is_extern=true) since prog.functions includes
        # extern decls -- those must still go through the char*-unwrapping
        # path below, so check is_extern rather than mere presence.
        mut _bc_is_user_fn = self.functions.contains(base_callee) and not self.functions.get(base_callee).is_extern
        if _starts_with_tr(base_callee) and not _bc_is_user_fn and base_callee != "_tr_str_len":
            mut _ext_call = callee_s + "(" + self.gen_args_extern(args) + ")"
            if _is_str_type(call_ty.name):
                if base_callee == "_tr_getenv": return "_tr_str_lit(" + _ext_call + ")"
                return self.wrapstr(_ext_call)
            # Known char*-returning helpers whose return type isn't tracked by
            # sema (call_ty.name not "str") still allocate a fresh heap buffer
            # and must be wrapped into TrStr (rc=1) for the new ABI.
            if base_callee == "_tr_char_to_str" or base_callee == "_tr_char_to_str_alloc":
                return self.wrapstr(_ext_call)
            return _ext_call
        return callee_s + "(" + self.gen_args(args) + ")"

    pub def gen_print_call(self, args: Vec[Pointer[HirExpr]]) -> str:
        if args.len == 0: return "printf(\"\\n\")"
        # Python-style print: each argument is written with its own type-correct
        # format, separated by a single space, with one trailing newline.
        if args.len == 1:
            return "({ " + self.gen_print_one(args.get(0)) + "; printf(\"\\n\"); })"
        mut out = "({ "
        mut i = 0
        while i < args.len:
            if i > 0: out = out + "printf(\" \"); "
            out = out + self.gen_print_one(args.get(i)) + "; "
            i = i + 1
        out = out + "printf(\"\\n\"); })"
        return out

    # A single `print` argument formatted with `printf` and NO trailing newline.
    pub def gen_print_one(self, arg: Pointer[HirExpr]) -> str:
        mut ty_n: str = self.resolve_generic_prim(hir_expr_type(arg).name)
        mut s: str = self.gen_expr(arg)
        if _is_int_type(ty_n): return "printf(\"%lld\", (long long)(" + s + "))"
        if _is_float_type(ty_n): return "printf(\"%g\", (double)(" + s + "))"
        if ty_n == "bool": return "printf(\"%s\", (" + s + ") ? \"true\" : \"false\")"
        if ty_n == "char": return "printf(\"%c\", " + s + ")"
        if ty_n == "Pointer": return "printf(\"0x%llx\", (unsigned long long)(uintptr_t)(" + s + "))"
        if ty_n == "List" or ty_n == "Vec" or ty_n == "Set" or ty_n == "Dict" or ty_n == "Map":
            return "printf(\"%s\", " + self.gen_collection_to_str(s, hir_expr_type(arg)) + ")"
        if ty_n == "Tuple" or ty_n == "tuple":
            return "printf(\"%s\", " + self.gen_tuple_to_str(s, hir_expr_type(arg)) + ")"
        if _is_str_type(ty_n): return "printf(\"%s\", _tr_strz(" + s + "))"
        mut mono0 = self.mono_cls_name_for(hir_expr_type(arg))
        if self.has_method(mono0, "__str__"):
            return "printf(\"%s\", _tr_strz(" + self.cls_method_c_call(mono0, "__str__", s, "") + "))"
        if self.has_method(mono0, "__repr__"):
            return "printf(\"%s\", _tr_strz(" + self.cls_method_c_call(mono0, "__repr__", s, "") + "))"
        if self.classes.contains(mono0):
            return "printf(\"%s\", " + self.obj_to_str_expr(mono0, s) + ")"
        return "printf(\"%s\", _TR_AUTO_STR(" + s + "))"

    # Wrap an Option[T]/Result[T,E] payload expression for storage in the
    # generic `void* val` slot. Floats can't be cast to/from void* directly
    # in C (hard error), so they're bit-reinterpreted via _tr_f64_to_ptr.
    pub def wrap_voidp_arg(self, arg: Pointer[HirExpr]) -> str:
        mut a_ty_n: str = self.resolve_generic_prim(hir_expr_type(arg).name)
        mut s = self.gen_expr(arg)
        if _is_float_type(a_ty_n):
            return "_tr_f64_to_ptr((double)(" + s + "))"
        if _is_str_type(a_ty_n):
            return "_tr_str_box(" + s + ")"
        return "(void*)(" + s + ")"

    # Unwrap a `void*` Option[T]/Result[T,E] payload back to type `ty`.
    pub def unwrap_voidp_as(self, expr_s: str, ty: AstType) -> str:
        mut tn: str = self.resolve_generic_prim(ty.name)
        if _is_float_type(tn):
            return "_tr_ptr_to_f64(" + expr_s + ")"
        if _is_str_type(tn):
            return "_tr_str_unbox(" + expr_s + ")"
        mut ct = self.type_to_c(ty)
        return "((" + ct + ")(" + expr_s + "))"

    # Dict key arg: TrMap keys are char*, so str-typed keys must be unwrapped.
    # Dict key arg: TrMap keys are stored as the dict's OWN strdup'd copy of the
    # char*, so the caller's TrStr is only borrowed for the duration of the set.
    # A FRESH str key (concat/call/method, e.g. Str.slice(pat,...) used INLINE as
    # a route ':name' param key) is rc=1 and bound to no local, so a bare
    # _tr_strz() would extract its .data, let the dict copy it, then leak the
    # orphaned TrStr (struct + .data) - one per insert. Hoist it to a temp that
    # the enclosing statement's flush_wraps releases (mirrors dict_val_arg's
    # _dvt hoist), so the fresh key is freed after the dict has copied it. A
    # borrowed key (str local/param/field) is released by its own scope-exit
    # auto-drop, so it needs no hoist here.
    pub def dict_key_arg(self, e: Pointer[HirExpr]) -> str:
        mut e_s = self.gen_expr(e)
        if _is_str_type(hir_expr_type(e).name):
            if self._is_fresh_str_expr(e):
                mut tmp = "_dkt" + self.next_temp()
                self.wrap_temp_decls.push("TrStr " + tmp + " = (" + e_s + ")")
                self.wrap_temp_names.push(tmp)
                return self.strz(tmp)
            return self.strz(e_s)
        return e_s

    # Dict value arg: TrMap values are void*, so str-typed values must be boxed.
    # The box takes its OWN reference (_tr_str_retain), mirroring
    # List_TrStr_append's retain-on-insert (#52): each stored box owns a ref
    # that Dict_free_strval/_tr_idict_free_strval releases at dict teardown.
    # Without the retain, set'ing the SAME str local under two keys would make
    # two boxes alias one reference -> double-free when the dict is freed.
    #
    # A FRESH str value (concat/call/method, rc=1, not bound to a local) is
    # hoisted to a temp and released by the enclosing statement's flush_wraps,
    # so retain(+1)+release(-1) nets to the single ref now owned by the box.
    # A borrowed value (str local/param/field) keeps its own ref (released by
    # its own scope-exit auto-drop, now that mark_escaped_str_args no longer
    # excludes Dict/Map value args - see sema.tr); the box's retain is the
    # independent reference the dict needs.
    pub def dict_val_arg(self, e: Pointer[HirExpr]) -> str:
        mut e_s = self.gen_expr(e)
        if _is_str_type(hir_expr_type(e).name):
            if self._is_fresh_str_expr(e):
                mut tmp = "_dvt" + self.next_temp()
                self.wrap_temp_decls.push("TrStr " + tmp + " = (" + e_s + ")")
                self.wrap_temp_names.push(tmp)
                return "_tr_str_box(_tr_str_retain(" + tmp + "))"
            return "_tr_str_box(_tr_str_retain(" + e_s + "))"
        # Heap-class value: the dict holds a reference. Retain an alias; move a
        # fresh ctor result (obj_retain_wrap decides). Without this the instance is
        # freed at the source local's scope exit while the dict points at it (UAF).
        if self.is_heap_class_tn(hir_expr_type(e).name):
            mut _dvr = self.obj_retain_wrap(e, e_s, false)
            if self._obj_store_needs_retain(e): _dvr = "_tr_obj_retain(" + _dvr + ")"
            return _dvr
        return e_s

    # Like gen_args, but unwraps any TrStr-typed argument to raw char* via
    # _tr_strz - for direct calls to legacy `_tr_*` runtime helpers.
    #
    # A FRESH str arg (concat/call/method) produces a rc=1 TrStr that is never
    # bound to a local, so extracting its `.data` via a bare `_tr_strz()` and
    # discarding the struct leaks both of its heap blocks. Mirror gen_args:
    # hoist the fresh TrStr to a temp, use `tmp.data`, and record the temp for
    # release by the enclosing statement's flush_wraps. Borrowed args (idents/
    # literals/`_tr_str_wrap(...)` results) go through strz() unchanged - strz
    # already hoists the wrap case and `_tr_strz` on a borrowed value is safe.
    pub def gen_args_extern(self, args: Vec[Pointer[HirExpr]]) -> str:
        mut s = ""
        mut i = 0
        while i < args.len:
            if i > 0: s = s + ", "
            mut a = args.get(i)
            mut a_ty_n: str = hir_expr_type(a).name
            if _is_str_type(a_ty_n):
                mut a_s = self.gen_expr(a)
                if self._is_fresh_str_expr(a):
                    mut tmp = "_aet" + self.next_temp()
                    self.wrap_temp_decls.push("TrStr " + tmp + " = (" + a_s + ")")
                    self.wrap_temp_names.push(tmp)
                    s = s + tmp + ".data"
                else:
                    s = s + self.strz(a_s)
            else: s = s + self.gen_expr(a)
            i = i + 1
        return s

    # True for `str`-typed expressions that produce a FRESH, independently-
    # owned TrStr (rc=1 new allocation): nested calls and concatenations.
    # Such a value, if passed directly as a call argument, is never bound to
    # a local (so SAutoDrop can't release it) and the callee's parameter is
    # never auto-dropped either - it would leak. EIdent/EPropAccess/literals
    # are borrowed/immortal and don't need this.
    pub def _is_fresh_str_expr(self, e: Pointer[HirExpr]) -> bool:
        match e.read():
            case HirExpr.ECall(_, _, ce_fty):
                if ce_fty.is_borrow: return false   # `-> ref` call returns a BORROW, not fresh-owned: don't free it inline
                return true
            case HirExpr.EMethodCall(_, _, _, me_fty):
                if me_fty.is_borrow: return false
                return true
            case HirExpr.EBinOp(_, _, _, _): return true
            # A conditional (`if`-expression OR the `a if c else b` ternary) is
            # fresh-owned exactly when BOTH arms are fresh-owned: an if-expression's
            # arms are `do:` blocks (owned when str), while a plain ternary of two
            # borrowed locals is NOT owned and must not be released at use sites.
            case HirExpr.EIfElse(_, _ft, _fe, _): return self._is_fresh_str_expr(_ft) and self._is_fresh_str_expr(_fe)
            # A `do:` block-expression yields a return-style OWNED value (see the
            # EDo codegen's str_retain_wrap): a str-typed result is always rc=1
            # owned, so operand/arg sites must wrap-and-release the temporary it
            # produces (e.g. `"[" + (do: ... s)`), exactly like a call result.
            case HirExpr.EDo(_fb, _fdty): return _is_str_type(_fdty.name)
            # A match-EXPRESSION assigns each matching arm an owned `do:` result
            # into its result temp, so a str-typed result is always rc=1 owned.
            case HirExpr.EMatchExpr(_, _, _fmty): return _is_str_type(_fmty.name)
            # loop/while EXPRESSIONS: a str result is an owned value (the break
            # value is retained into the result temp), so release at use sites.
            case HirExpr.ELoop(_, _floty): return _is_str_type(_floty.name)
            case HirExpr.EWhileExpr(_, _, _, _fwty): return _is_str_type(_fwty.name)
            case _: return false

    # True if `e` is a call to a `-> ref` function/method: its result is a BORROW
    # (the callee did NOT retain it), so any owner-position use must retain to own it.
    pub def _expr_is_borrow_call(self, e: Pointer[HirExpr]) -> bool:
        match e.read():
            case HirExpr.ECall(_, _, ce_bty): return ce_bty.is_borrow
            case HirExpr.EMethodCall(_, _, _, me_bty): return me_bty.is_borrow
            case _: return false

    # True for a heap-class expression that produces a FRESH, OWNED (rc=1)
    # instance not bound to any local: a constructor `ClassName(...)`, an
    # owned-classified free-function/factory call. Passed directly as a call
    # argument, such a temp is borrowed by the callee and released by no one →
    # it leaks; gen_args hoists it and flush_wraps releases it. Idents/fields
    # (borrows/live locals) and collection-element reads are NOT fresh.
    pub def _is_fresh_obj_expr(self, e: Pointer[HirExpr]) -> bool:
        if _is_invalid_ptr(e as usize): return false
        if not self.is_heap_class_tn(hir_expr_type(e).name): return false
        match e.read():
            case HirExpr.ECall(callee, _, ce_bty):
                if ce_bty.is_borrow: return false
                match callee.read():
                    case HirExpr.EIdent(cn, _, _):
                        if self.classes.contains(cn): return true   # constructor
                        return self._fn_owned_lookup(cn)            # owned free-fn
                    case _: return false
            case HirExpr.EMethodCall(recv, m, _, me_bty):
                if me_bty.is_borrow: return false
                mut rt = hir_expr_type(recv).name
                if (rt == "Vec" or rt == "List" or rt == "Dict" or rt == "Map" or rt == "Set") and (m == "get" or m == "first" or m == "last"):
                    return false
                match recv.read():
                    case HirExpr.EIdent(rn, _, _):
                        if self.classes.contains(rn): rt = rn
                    case _: pass
                return self._fn_owned_lookup(rt + "." + m)
            case _: return false

    pub def gen_args(self, args: Vec[Pointer[HirExpr]]) -> str:
        mut s = ""
        mut i = 0
        while i < args.len:
            if i > 0: s = s + ", "
            mut a = args.get(i)
            mut a_s = self.gen_expr(a)
            if _is_str_type(hir_expr_type(a).name) and self._is_fresh_str_expr(a):
                mut tmp = "_at" + self.next_temp()
                self.wrap_temp_decls.push("TrStr " + tmp + " = (" + a_s + ")")
                self.wrap_temp_names.push(tmp)
                a_s = tmp
            elif self._is_fresh_obj_expr(a):
                mut otmp = "_aot" + self.next_temp()
                self.wrap_temp_decls.push(self.type_to_c(hir_expr_type(a)) + " " + otmp + " = (" + a_s + ")")
                self.wrap_obj_names.push(otmp)
                self.wrap_obj_drops.push(self.obj_drop_fn(hir_expr_type(a).name))
                a_s = otmp
            s = s + a_s
            i = i + 1
        return s

    # Like gen_args, but when elem_sfx == "str" (legacy char*-backed List_str),
    # extracts the raw char* from any str(TrStr)-typed argument so it matches
    # the legacy List_str_* signatures.
    pub def gen_args_strify(self, args: Vec[Pointer[HirExpr]], elem_sfx: str) -> str:
        if elem_sfx != "str": return self.gen_args(args)
        mut s = ""
        mut i = 0
        while i < args.len:
            if i > 0: s = s + ", "
            mut a = args.get(i)
            mut a_ty_n: str = self.resolve_generic_prim(hir_expr_type(a).name)
            if _is_str_type(a_ty_n):
                s = s + self.strz(self.gen_expr(a))
            else:
                s = s + self.gen_expr(a)
            i = i + 1
        return s

    pub def gen_method_call(self, obj: Pointer[HirExpr], method: str, args: Vec[Pointer[HirExpr]], call_ty: AstType) -> str:
        mut obj_s = self.gen_expr(obj)
        mut t_n: str = hir_expr_type(obj).name

        # Inside a monomorphized body, a receiver typed as a generic param (x: T) must
        # dispatch to the concrete type's method (x.show() -> Cat_show, not T_show).
        if self.type_subst.contains(t_n):
            t_n = self.resolve_generic_tyname(t_n)

        # Fixed-size array element read a[i]: sema lowers to EMethodCall(a,"get_index",[i]).
        # Emit a bounds-checked aggregate index; N is the compile-time length on the type.
        if t_n == "Array" and (method == "get_index" or method == "get") and args.len > 0:
            mut _ar_ty_r = hir_expr_type(obj)
            mut _ar_idx_r = self.gen_expr(args.get(0))
            return obj_s + ".data[(_tr_bounds_check(" + _ar_idx_r + ", " + _ar_ty_r.array_size.to_str() + "), " + _ar_idx_r + ")]"

        # Fixed-size array base pointer a.as_ptr() -> Pointer[T]: the inline `T data[N]`
        # aggregate decays to `T*` at element 0 — usable for buffer/DMA/bump-alloc interop.
        if t_n == "Array" and method == "as_ptr":
            return obj_s + ".data"

        # Fallback: when HIR stores void for an EPropAccess type (cross-module field lookup),
        # recover the actual type from the parent class field declaration
        if t_n == "void" or t_n == "":
            match obj.read():
                case HirExpr.EPropAccess(inner_obj_fb, field_name_fb, _):
                    mut inner_t_n_fb: str = hir_expr_type(inner_obj_fb).name
                    if inner_t_n_fb == "void" or inner_t_n_fb == "":
                        inner_t_n_fb = self.cur_class
                    if self.classes.contains(inner_t_n_fb):
                        mut parent_cls_fb = self.classes.get(inner_t_n_fb)
                        mut fi_fb = 0
                        while fi_fb < parent_cls_fb.fields.len:
                            mut fld_fb = parent_cls_fb.fields.get(fi_fb)
                            if fld_fb.name == field_name_fb and fld_fb.ty.name != "" and fld_fb.ty.name != "void":
                                t_n = fld_fb.ty.name
                            fi_fb = fi_fb + 1
                case _: pass

        # Weak[T] handle methods (non-owning ref to a Shared box).
        if t_n == "Weak":
            if method == "is_alive": return "_tr_weak_is_alive(" + obj_s + ")"
            if method == "upgrade":
                # Option[T]: Some(payload) while the strong target is alive, else None.
                # A borrow-style upgrade (no refcount change) — sound single-threaded.
                return "({ _TrWeakBox* _wu = (" + obj_s + "); _tr_weak_is_alive(_wu) ? ((Option){.tag=Option_Some, .data.Some.val=(void*)(_wu->box->data)}) : ((Option){.tag=Option_None}); })"
            if method == "drop" or method == "free": return "_tr_weak_drop(" + obj_s + ")"
        # Shared var: unwrap _TrSharedBox* -> (TypeName*)obj->data for method dispatch
        if self.shared_vars.contains(obj_s):
            mut sh_ty = self.shared_vars.get(obj_s)
            # Shared-specific built-in methods - operate on the box, NOT the inner object
            if method == "clone": return "_tr_shared_clone(" + obj_s + ")"
            if method == "drop": return "_tr_shared_drop(" + obj_s + ")"
            if method == "is_null": return "(" + obj_s + " == NULL || " + obj_s + "->data == NULL)"
            if method == "downgrade": return "_tr_weak_new(" + obj_s + ")"
            # All other methods: unwrap and dispatch as user-defined class method
            mut sh_unwrapped = "((" + sh_ty + "*)(" + obj_s + "->data))"
            mut sh_sig = sh_ty + "_" + method + "(" + sh_unwrapped
            if args.len > 0:
                sh_sig = sh_sig + ", " + self.gen_args(args)
            return sh_sig + ")"
        # Shared[T]-TYPED receiver (a `cfg: Shared[Config]` PARAM, not a `shared`
        # local): unwrap the atomic box and dispatch as the inner type's method —
        # this is what makes `Shared[T]` usable across a thread boundary (the sound
        # cross-thread pattern [T-7] points to).
        if t_n == "Shared":
            mut _shm_ft = hir_expr_type(obj)
            if _shm_ft.args.len > 0:
                mut _shm_ty = _shm_ft.args.get(0).read().name
                if method == "clone": return "_tr_shared_clone(" + obj_s + ")"
                if method == "drop": return "_tr_shared_drop(" + obj_s + ")"
                if method == "is_null": return "(" + obj_s + " == NULL || " + obj_s + "->data == NULL)"
                if method == "downgrade": return "_tr_weak_new(" + obj_s + ")"
                mut _shm_unwrapped = "((" + _shm_ty + "*)(" + obj_s + "->data))"
                mut _shm_sig = _shm_ty + "_" + method + "(" + _shm_unwrapped
                if args.len > 0: _shm_sig = _shm_sig + ", " + self.gen_args(args)
                return _shm_sig + ")"

        # Interface vtable dispatch: obj.vtable->method(obj.data, extra_args...)
        if self.interfaces.contains(t_n):
            mut s = obj_s + ".vtable->" + method + "(" + obj_s + ".data"
            if args.len > 0:
                s = s + ", " + self.gen_args(args)
            return s + ")"

        # Result[T,E] method dispatch
        if t_n == "Result":
            if obj_s == "Result":
                # Static constructor: Result[T,E].ok(val) or Result[T,E].err(val)
                if method == "ok":
                    mut ok_cv = "NULL"
                    if args.len > 0:
                        ok_cv = self.wrap_voidp_arg(args.get(0))
                    return "((Result){.tag=Result_Ok, .data.Ok.val=" + ok_cv + "})"
                elif method == "err":
                    mut err_cv = "NULL"
                    if args.len > 0:
                        err_cv = self.wrap_voidp_arg(args.get(0))
                    return "((Result){.tag=Result_Err, .data.Err.err=" + err_cv + "})"
            # Instance methods on a Result value
            if method == "is_err": return "(" + obj_s + ".tag == Result_Err)"
            if method == "is_ok": return "(" + obj_s + ".tag == Result_Ok)"
            if method == "unwrap":
                if call_ty.name != "" and call_ty.name != "void":
                    return self.unwrap_voidp_as("Result_unwrap(" + obj_s + ")", call_ty)
                return "Result_unwrap(" + obj_s + ")"
            if method == "unwrap_err":
                if call_ty.name != "" and call_ty.name != "void":
                    return self.unwrap_voidp_as("Result_unwrap_err(" + obj_s + ")", call_ty)
                return "Result_unwrap_err(" + obj_s + ")"
            mut res_extra = ""
            if args.len > 0:
                res_extra = ", " + self.gen_args(args)
            return "Result_" + method + "(" + obj_s + res_extra + ")"

        # Option[T] method dispatch
        if t_n == "Option":
            if obj_s == "Option":
                # Static constructor
                if method == "some" or method == "Some":
                    mut sv2 = "NULL"
                    if args.len > 0:
                        sv2 = self.wrap_voidp_arg(args.get(0))
                    return "((Option){.tag=Option_Some, .data.Some.val=" + sv2 + "})"
                elif method == "none" or method == "None":
                    return "((Option){.tag=Option_None})"
            # Instance methods
            if method == "is_some": return "(" + obj_s + ".tag == Option_Some)"
            if method == "is_none": return "(" + obj_s + ".tag == Option_None)"
            if method == "unwrap":
                mut full_opt_ty2 = hir_expr_type(obj)
                if full_opt_ty2.args.len > 0:
                    return self.unwrap_voidp_as("Option_unwrap(" + obj_s + ")", full_opt_ty2.args.get(0).read())
                return "Option_unwrap(" + obj_s + ")"
            mut opt_extra = ""
            if args.len > 0:
                opt_extra = ", " + self.gen_args(args)
            return "Option_" + method + "(" + obj_s + opt_extra + ")"

        # Str.join static call: Str.join(parts, sep) -> _tr_trstr_join((List_TrStr*)parts, sep)
        if obj_s == "Str" and method == "join":
            if args.len >= 2: return "_tr_trstr_join((List_TrStr*)" + self.gen_expr(args.get(0)) + ", " + self.strz(self.gen_expr(args.get(1))) + ")"
            if args.len == 1: return "_tr_trstr_join((List_TrStr*)" + self.gen_expr(args.get(0)) + ", \"\")"

        # str primitive method dispatch - "hello".trim() -> _tr_str_strip("hello")
        # See note above _is_str_type(t_n) block re: TrStr interim semantics.
        if t_n == "str":
            mut os: str = self.strz(obj_s)
            mut str_arg0 = ""
            if args.len > 0: str_arg0 = self.gen_expr(args.get(0))
            mut str_arg1 = ""
            if args.len > 1: str_arg1 = self.gen_expr(args.get(1))
            mut sa0: str = self.strz(str_arg0)
            mut sa1: str = self.strz(str_arg1)
            if method == "split":         return "_tr_str_split(" + os + ", " + sa0 + ")"
            if method == "split_to_vec":  return "_tr_str_split(" + os + ", " + sa0 + ")"
            if method == "trim" or method == "strip": return self.wrapstr("_tr_str_strip(" + os + ")")
            if method == "trim_left":     return self.wrapstr("_tr_str_trim_left(" + os + ")")
            if method == "trim_right":    return self.wrapstr("_tr_str_trim_right(" + os + ")")
            if method == "to_upper":      return self.wrapstr("_tr_str_upper(" + os + ")")
            if method == "to_lower":      return self.wrapstr("_tr_str_lower(" + os + ")")
            if method == "capitalize":    return self.wrapstr("_tr_str_capitalize(" + os + ")")
            if method == "title":         return self.wrapstr("_tr_str_title(" + os + ")")
