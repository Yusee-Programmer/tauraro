                return "((double)pow((double)(" + obj_s + "), (double)(" + self.gen_expr(args.get(0)) + ")))"
            if method == "sign":
                return "((double)(((" + obj_s + ") > 0.0) - ((" + obj_s + ") < 0.0)))"
            if method == "clamp" and args.len == 2:
                mut _ca = self.gen_expr(args.get(0))
                mut _cb = self.gen_expr(args.get(1))
                return "({ double _v = (double)(" + obj_s + "); double _lo = (double)(" + _ca + "); double _hi = (double)(" + _cb + "); _v < _lo ? _lo : (_v > _hi ? _hi : _v); })"
            if method == "is_nan":  return "_tr_float_is_nan((double)(" + obj_s + "))"
            if method == "is_inf":  return "_tr_float_is_inf((double)(" + obj_s + "))"

        # Int utility methods - format and math on integer types.
        if _is_int_type(t_n):
            if method == "to_hex":
                return self.wrapstr("({ char* _hb = (char*)_tr_checked_alloc(32); snprintf(_hb, 32, \"%llx\", (long long)(" + obj_s + ")); _hb; })")
            if method == "to_HEX" or method == "to_hex_upper":
                return self.wrapstr("({ char* _hb = (char*)_tr_checked_alloc(32); snprintf(_hb, 32, \"%llX\", (long long)(" + obj_s + ")); _hb; })")
            if method == "to_octal" or method == "to_oct":
                return self.wrapstr("({ char* _ob = (char*)_tr_checked_alloc(32); snprintf(_ob, 32, \"%llo\", (long long)(" + obj_s + ")); _ob; })")
            if method == "to_binary" or method == "to_bin":
                return self.wrapstr("_tr_int_to_binary((long long)(" + obj_s + "))")
            if method == "sign":
                return "((long long)(((" + obj_s + ") > 0LL) - ((" + obj_s + ") < 0LL)))"
            if method == "clamp" and args.len == 2:
                mut _ia = self.gen_expr(args.get(0))
                mut _ib = self.gen_expr(args.get(1))
                return "({ long long _v = (long long)(" + obj_s + "); long long _lo = (long long)(" + _ia + "); long long _hi = (long long)(" + _ib + "); _v < _lo ? _lo : (_v > _hi ? _hi : _v); })"
            if method == "gcd" and args.len > 0:
                return "_tr_int_gcd((long long)(" + obj_s + "), (long long)(" + self.gen_expr(args.get(0)) + "))"
            if method == "lcm" and args.len > 0:
                return "_tr_int_lcm((long long)(" + obj_s + "), (long long)(" + self.gen_expr(args.get(0)) + "))"

        # Checked arithmetic - returns Option[int]: Some(result) or None on overflow.
        if _is_int_type(t_n) or _is_int_type(t_n):
            if method == "checked_add" and args.len > 0:
                mut _ca = obj_s
                mut _cb = self.gen_expr(args.get(0))
                mut _cr = self.next_temp()
                return "({ long long " + _cr + "; __builtin_add_overflow((long long)(" + _ca + "),(long long)(" + _cb + "),&" + _cr + ") ? ((Option){.tag=Option_None}) : ((Option){.tag=Option_Some,.data.Some.val=(void*)(uintptr_t)" + _cr + "}); })"
            if method == "checked_sub" and args.len > 0:
                mut _sa = obj_s
                mut _sb = self.gen_expr(args.get(0))
                mut _sr = self.next_temp()
                return "({ long long " + _sr + "; __builtin_sub_overflow((long long)(" + _sa + "),(long long)(" + _sb + "),&" + _sr + ") ? ((Option){.tag=Option_None}) : ((Option){.tag=Option_Some,.data.Some.val=(void*)(uintptr_t)" + _sr + "}); })"
            if method == "checked_mul" and args.len > 0:
                mut _ma = obj_s
                mut _mb = self.gen_expr(args.get(0))
                mut _mr = self.next_temp()
                return "({ long long " + _mr + "; __builtin_mul_overflow((long long)(" + _ma + "),(long long)(" + _mb + "),&" + _mr + ") ? ((Option){.tag=Option_None}) : ((Option){.tag=Option_Some,.data.Some.val=(void*)(uintptr_t)" + _mr + "}); })"
            if method == "abs": return "llabs((long long)(" + obj_s + "))"
            if method == "min" and args.len > 0:
                mut _mn = self.next_temp()
                return "({ long long " + _mn + " = (long long)(" + obj_s + "); long long _b = (long long)(" + self.gen_expr(args.get(0)) + "); " + _mn + " < _b ? " + _mn + " : _b; })"
            if method == "max" and args.len > 0:
                mut _mx = self.next_temp()
                return "({ long long " + _mx + " = (long long)(" + obj_s + "); long long _b = (long long)(" + self.gen_expr(args.get(0)) + "); " + _mx + " > _b ? " + _mx + " : _b; })"
            if method == "pow" and args.len > 0:
                return "((long long)pow((double)(" + obj_s + "),(double)(" + self.gen_expr(args.get(0)) + ")))"
        if method == "as_str":
            # StringObj_as_str/StringBuilder_as_str already return TrStr
            # (str return type -> TrStr); no extra wrapping needed.
            if t_n == "StringObj": return "StringObj_as_str(" + obj_s + ")"
            if t_n == "StringBuilder": return "StringBuilder_as_str(" + obj_s + ")"
            if _is_str_type(t_n): return obj_s
            return "(char*)(" + obj_s + ")"
        if method == "starts_with" and args.len > 0 and _is_str_type(t_n):
            return "_tr_str_starts_with(" + self.strz(obj_s) + ", " + self.strz(self.gen_expr(args.get(0))) + ")"
        if method == "ends_with" and args.len > 0 and _is_str_type(t_n):
            return "_tr_str_ends_with(" + self.strz(obj_s) + ", " + self.strz(self.gen_expr(args.get(0))) + ")"
        if method == "contains" and args.len > 0 and _is_str_type(t_n):
            return "_tr_str_contains(" + self.strz(obj_s) + ", " + self.strz(self.gen_expr(args.get(0))) + ")"

        # String method dispatch - must be before the generic TrStr_ fallback
        # NOTE on interim string semantics: scalar `str`
        # values are TrStr (refcounted). List[str]/Dict/Set string elements
        # remain legacy char* (List_str etc, task #52, not yet migrated).
        # Boundary: TrStr -> char* via _tr_strz(); char* -> TrStr from a
        # legacy container/helper is wrapped via _tr_str_wrap() (fresh
        # heap result, rc=1) so it participates in refcounting going forward.
        if _is_str_type(t_n):
            mut os: str = self.strz(obj_s)
            if method == "upper" or method == "to_upper": return self.wrapstr("_tr_str_upper(" + os + ")")
            if method == "lower" or method == "to_lower": return self.wrapstr("_tr_str_lower(" + os + ")")
            if method == "strip" or method == "trim": return self.wrapstr("_tr_str_strip(" + os + ")")
            if method == "trim_left": return self.wrapstr("_tr_str_trim_left(" + os + ")")
            if method == "trim_right": return self.wrapstr("_tr_str_trim_right(" + os + ")")
            if method == "replace" and args.len == 2:
                return self.wrapstr("_tr_str_replace(" + os + ", " + self.strz(self.gen_expr(args.get(0))) + ", " + self.strz(self.gen_expr(args.get(1))) + ")")
            if method == "split" and args.len > 0:
                return "_tr_str_split(" + os + ", " + self.strz(self.gen_expr(args.get(0))) + ")"
            if method == "find" and args.len > 0:
                mut tmp_find: str = self.next_temp()
                return "({ char* " + tmp_find + " = strstr(" + os + ", " + self.strz(self.gen_expr(args.get(0))) + "); " + tmp_find + " ? (long long)(" + tmp_find + " - (" + os + ")) : -1LL; })"
            if method == "slice" and args.len == 2:
                return self.wrapstr("_tr_str_slice(" + os + ", " + self.gen_expr(args.get(0)) + ", " + self.gen_expr(args.get(1)) + ")")
            if method == "index_of" and args.len > 0:
                return "_tr_str_index_of(" + os + ", " + self.strz(self.gen_expr(args.get(0))) + ")"
            if method == "last_index_of" and args.len > 0:
                return "_tr_str_last_index_of(" + os + ", " + self.strz(self.gen_expr(args.get(0))) + ")"
            if method == "len" or method == "length":
                return "_tr_strlen(" + os + ")"
            if method == "starts_with" and args.len > 0:
                return "_tr_str_starts_with(" + os + ", " + self.strz(self.gen_expr(args.get(0))) + ")"
            if method == "ends_with" and args.len > 0:
                return "_tr_str_ends_with(" + os + ", " + self.strz(self.gen_expr(args.get(0))) + ")"
            if method == "contains" and args.len > 0:
                return "_tr_str_contains(" + os + ", " + self.strz(self.gen_expr(args.get(0))) + ")"
            if method == "strip_prefix" and args.len > 0:
                return self.wrapstr("_tr_str_strip_prefix(" + os + ", " + self.strz(self.gen_expr(args.get(0))) + ")")
            if method == "strip_suffix" and args.len > 0:
                return self.wrapstr("_tr_str_strip_suffix(" + os + ", " + self.strz(self.gen_expr(args.get(0))) + ")")
            if method == "repeat" and args.len > 0:
                return self.wrapstr("_tr_str_repeat(" + os + ", " + self.gen_expr(args.get(0)) + ")")
            if method == "reverse": return self.wrapstr("_tr_str_reverse(" + os + ")")
            if method == "parse_int": return "_tr_str_to_int(" + os + ")"
            if method == "parse_float": return "_tr_str_to_float(" + os + ")"
            if method == "parse_bool": return "_tr_str_parse_bool(" + os + ")"
            if method == "char_at" and args.len > 0:
                return "_tr_str_char_at_code(" + os + ", " + self.gen_expr(args.get(0)) + ")"
            # str.split_once(sep) -> (left, right) at first occurrence; right="" if not found
            if method == "split_once" and args.len > 0:
                mut _so_sep = self.strz(self.gen_expr(args.get(0)))
                mut _so_t = self.next_temp()
                mut _so_p = self.next_temp()
                return "({ char* " + _so_p + " = strstr(" + os + ", " + _so_sep + "); " + _so_p + " ? _tr_str_tuple2(_tr_str_wrap(_tr_str_slice(" + os + ", 0LL, (long long)(" + _so_p + " - (" + os + ")))), _tr_str_wrap(_tr_str_slice(" + _so_p + ", _tr_strlen(" + _so_sep + "), _tr_strlen(" + _so_p + ")))) : _tr_str_tuple2(_tr_str_lit(" + os + "), _tr_str_lit(\"\")); })"

        # When sema returns void/empty type, still dispatch known string methods on the object.
        # This handles chained calls like Process.shell_output(cmd).trim() where the intermediate
        # return type is unknown to sema. (obj_s here is still legacy char* since its type was
        # unresolved - leave as-is, do NOT wrap in TrStr.)
        if t_n == "void" or t_n == "":
            if method == "strip" or method == "trim": return "_tr_str_strip(" + obj_s + ")"
            if method == "upper" or method == "to_upper": return "_tr_str_upper(" + obj_s + ")"
            if method == "lower" or method == "to_lower": return "_tr_str_lower(" + obj_s + ")"
            if method == "trim_left": return "_tr_str_trim_left(" + obj_s + ")"
            if method == "trim_right": return "_tr_str_trim_right(" + obj_s + ")"
            if method == "slice" and args.len == 2:
                return "_tr_str_slice(" + obj_s + ", " + self.gen_expr(args.get(0)) + ", " + self.gen_expr(args.get(1)) + ")"
            if method == "index_of" and args.len > 0:
                return "_tr_str_index_of(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "starts_with" and args.len > 0:
                return "_tr_str_starts_with(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "ends_with" and args.len > 0:
                return "_tr_str_ends_with(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "contains" and args.len > 0:
                return "_tr_str_contains(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "split" and args.len > 0:
                return "_tr_str_split(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "replace" and args.len == 2:
                return "_tr_str_replace(" + obj_s + ", " + self.gen_expr(args.get(0)) + ", " + self.gen_expr(args.get(1)) + ")"
            if method == "len" or method == "length": return "_tr_strlen(" + obj_s + ")"
            if method == "char_at" and args.len > 0:
                return "_tr_str_char_at_code(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"

        mut class_name: str = t_n
        if _is_str_type(class_name): class_name = "TrStr"

        # Resolve user type aliases so `type NodeList = List[str]` is transparent.
        if class_name != "" and class_name != "void" and self.type_alias_map.contains(class_name):
            mut resolved_c = self.type_alias_map.get(class_name)
            # Map C type strings back to Tauraro-level names for dispatch
            if resolved_c.starts_with("List_"):
                class_name = "List"
            elif resolved_c.starts_with("Map_") or resolved_c == "TrMap*":
                class_name = "Map"

        # Built-in module static dispatch: OS, Process, Env, Hash, File
        if obj_s == "OS" or class_name == "OS":
            if method == "cwd":        return self.wrapstr("_tr_cwd()")
            if method == "is_windows": return "_tr_is_windows()"
            if method == "is_linux":   return "(!_tr_is_windows())"
            if method == "platform":   return "(_tr_is_windows() ? _tr_str_lit(\"windows\") : _tr_str_lit(\"linux\"))"
        if obj_s == "Process" or class_name == "Process":
            if method == "system" and args.len > 0:
                return "_tr_system(" + self.strz(self.gen_expr(args.get(0))) + ")"
            if method == "shell_output" and args.len > 0:
                return self.wrapstr("_tr_popen_read(" + self.strz(self.gen_expr(args.get(0))) + ")")
            if method == "exit" and args.len > 0:
                return "_tr_exit(" + self.gen_expr(args.get(0)) + ")"
        if obj_s == "Env" or class_name == "Env":
            if method == "get_var" and args.len > 0:
                return "_tr_str_lit(_tr_getenv(" + self.strz(self.gen_expr(args.get(0))) + "))"
            if method == "set_var" and args.len > 1:
                return "_tr_setenv(" + self.strz(self.gen_expr(args.get(0))) + ", " + self.strz(self.gen_expr(args.get(1))) + ")"
        if obj_s == "Hash" or class_name == "Hash":
            if method == "sha256" and args.len > 0:
                return self.wrapstr("_tr_sha256_hex(" + self.strz(self.gen_expr(args.get(0))) + ")")
            if method == "md5" and args.len > 0:
                return self.wrapstr("_tr_md5_hex(" + self.strz(self.gen_expr(args.get(0))) + ")")
        if obj_s == "File" or class_name == "File":
            if method == "dir_exists" and args.len > 0:
                return "_tr_dir_exists(" + self.strz(self.gen_expr(args.get(0))) + ")"

        # Static call: Task.init(...) - obj is a type-name ident, hir_expr_type returns void/empty.
        # Recover class_name from obj_s when it matches a known user class.
        if (class_name == "void" or class_name == "") and self.classes.contains(obj_s):
            class_name = obj_s
        # Also recover for built-in collection types used in static calls (Vec.init, List.init, etc.)
        if (class_name == "void" or class_name == "") and (obj_s == "Vec" or obj_s == "List" or obj_s == "Map" or obj_s == "Dict"):
            class_name = obj_s

        # StringBuilder special handling (must be before len/length shortcut)
        if class_name == "StringBuilder":
            if method == "init": return "StringBuilder_init(" + self.gen_args(args) + ")"
            if method == "append":
                # append() COPIES its argument into the builder, so a FRESH str
                # arg (concat / call / method result, e.g. sb.append(html_escape(x))
                # or sb.append(n.to_str())) must be released after the call.
                # The special-case above bypasses gen_args' arg hoisting, so do it
                # here: hoist the fresh value into a temp that the statement's
                # flush_wraps releases (mirrors dict_val_arg). Without this, every
                # sb.append(<computed string>) leaked the computed string.
                mut _ap_e = args.get(0)
                mut _ap_s = self.gen_expr(_ap_e)
                if _is_str_type(hir_expr_type(_ap_e).name) and self._is_fresh_str_expr(_ap_e):
                    mut _ap_t = "_sbt" + self.next_temp()
                    self.wrap_temp_decls.push("TrStr " + _ap_t + " = (" + _ap_s + ")")
                    self.wrap_temp_names.push(_ap_t)
                    return "StringBuilder_append(" + obj_s + ", " + _ap_t + ")"
                return "StringBuilder_append(" + obj_s + ", " + _ap_s + ")"
            if method == "append_char": return "StringBuilder_append_char(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "to_string": return "StringBuilder_to_string(" + obj_s + ")"
            if method == "len" or method == "length": return obj_s + "->buf->len"
            if method == "free": return "StringBuilder__tr_fn_free(" + obj_s + ")"

        # len/length - only shortcut for non-user-class types
        if (method == "len" or method == "__len__" or method == "length") and not (self.classes.contains(t_n) and t_n != "Vec" and t_n != "Map" and t_n != "Dict" and t_n != "List") and not self.enums.contains(t_n):
            if _is_str_type(t_n): return "_tr_strlen(" + self.strz(obj_s) + ")"
            return "((long long)" + obj_s + "->len)"

        # __getitem__ dunder: sema lowers bag[i] -> EMethodCall(bag, "get_index", [i], void)
        if method == "get_index" and self.has_method(class_name, "__getitem__") and args.len > 0:
            return self.cls_method_c_call(class_name, "__getitem__", obj_s, self.gen_args(args))

        # User-defined generic class: dispatch through monomorphized name
        if self.classes.contains(class_name) and class_name != "Vec" and class_name != "Map" and class_name != "Dict" and class_name != "List":
            mut ucls = self.classes.get(class_name)
            if ucls.generics.len > 0:
                if hir_expr_type(obj).args.len > 0:
                    mut sfx = self.type_args_suffix(hir_expr_type(obj).args)
                    mut mono_name = class_name + "_" + sfx
                    self.ensure_mono(ucls, hir_expr_type(obj).args)
                    mut gmethod_c: str = method
                    if _is_c_keyword(gmethod_c): gmethod_c = "_tr_fn_" + gmethod_c
                    if method == "init" or method == "new":
                        return mono_name + "_" + gmethod_c + "(" + self.gen_args(args) + ")"
                    if obj_s == class_name:
                        return mono_name + "_" + gmethod_c + "(" + self.gen_args(args) + ")"
                    mut ms = mono_name + "_" + gmethod_c + "(" + obj_s
                    if args.len > 0: ms = ms + ", " + self.gen_args(args)
                    return ms + ")"
                # Recover type args from the parent class field declaration when HIR type args
                # are absent (bootstrap stores AstType* that can point to freed stack memory).
                match obj.read():
                    case HirExpr.EPropAccess(inner_obj2, fld_name2, _):
                        mut parent_ty_n2 = hir_expr_type(inner_obj2).name
                        if self.classes.contains(parent_ty_n2):
                            mut parent_cls2 = self.classes.get(parent_ty_n2)
                            mut fld_i2 = 0
                            while fld_i2 < parent_cls2.fields.len:
                                mut fld2 = parent_cls2.fields.get(fld_i2)
                                if fld2.name == fld_name2 and fld2.ty.name == class_name and fld2.ty.args.len > 0:
                                    mut sfx3 = self.type_args_suffix(fld2.ty.args)
                                    mut mn3 = class_name + "_" + sfx3
                                    self.ensure_mono(ucls, fld2.ty.args)
                                    mut method_c3 = method
                                    if _is_c_keyword(method_c3): method_c3 = "_tr_fn_" + method_c3
                                    if method == "init" or method == "new":
                                        return mn3 + "_" + method_c3 + "(" + self.gen_args(args) + ")"
                                    if obj_s == class_name:
                                        return mn3 + "_" + method_c3 + "(" + self.gen_args(args) + ")"
                                    mut ms3 = mn3 + "_" + method_c3 + "(" + obj_s
                                    if args.len > 0: ms3 = ms3 + ", " + self.gen_args(args)
                                    return ms3 + ")"
                                fld_i2 = fld_i2 + 1
                    case _: pass
                # self param has no type args in HIR (sema stores class_name without generics).
                # When inside a monomorphized body, use cur_class as the dispatch prefix.
                if self.cur_class != "":
                    mut method_c_g: str = method
                    if _is_c_keyword(method_c_g):
                        method_c_g = "_tr_fn_" + method_c_g
                    if method == "init" or method == "new":
                        return self.cur_class + "_" + method_c_g + "(" + self.gen_args(args) + ")"
                    if obj_s == class_name:
                        return self.cur_class + "_" + method_c_g + "(" + self.gen_args(args) + ")"
                    mut ms_g = self.cur_class + "_" + method_c_g + "(" + obj_s
                    if args.len > 0:
                        ms_g = ms_g + ", " + self.gen_args(args)
                    return ms_g + ")"

        # Non-generic user class dispatch
        if self.classes.contains(class_name) and class_name != "Vec" and class_name != "Map" and class_name != "Dict" and class_name != "List":
            mut method_c: str = method
            if _is_c_keyword(method_c): method_c = "_tr_fn_" + method_c
            if method == "init" or method == "new":
                return class_name + "_" + method_c + "(" + self.gen_args(args) + ")"
            if obj_s == class_name:
                return class_name + "_" + method_c + "(" + self.gen_args(args) + ")"
            # Check if method exists in own class; if not, fall back to base class dispatch
            mut ucls_inh: HirClass = self.classes.get(class_name)
            mut has_own_method: bool = false
            mut mci: int = 0
            while mci < ucls_inh.methods.len:
                mut mdef: HirFunction = ucls_inh.methods.get(mci)
                if mdef.name == method:
                    has_own_method = true
                mci = mci + 1
            if not has_own_method and ucls_inh.base_classes.len > 0:
                mut base_cls_n: str = ucls_inh.base_classes.get(0)
                if self.classes.contains(base_cls_n):
                    mut s_base: str = base_cls_n + "_" + method_c + "((" + base_cls_n + "*)" + obj_s
                    if args.len > 0:
                        s_base = s_base + ", " + self.gen_args(args)
                    return s_base + ")"
            # Check for method overloading: if multiple overloads exist, mangle by arg count.
            mut dispatch_name = class_name + "_" + method_c
            if self.overloaded_sigs.contains(dispatch_name):
                dispatch_name = dispatch_name + "_" + args.len.to_str() + "arg"
            # Mutating @value_type method: pass the receiver by address so writes
            # to `self.<field>` persist to the caller's value.
            mut self_arg = obj_s
            if self.vt_call_needs_ptr_self(class_name, method): self_arg = "&(" + obj_s + ")"
            mut s = dispatch_name + "(" + self_arg
            if args.len > 0: s = s + ", " + self.gen_args(args)
            return s + ")"

        if self.enums.contains(class_name):
            mut _evdef = self.enums.get(class_name)
            mut _is_var = false
            mut _vi2 = 0
            while _vi2 < _evdef.variants.len:
                if _evdef.variants.get(_vi2).name == method: _is_var = true
                _vi2 = _vi2 + 1
            if _is_var:
                if args.len > 0:
                    return class_name + "_ctor_" + method + "(" + self.gen_args(args) + ")"
                else:
                    return class_name + "_make_" + method + "()"
            mut enum_dispatch_name = class_name + "_" + method
            if self.overloaded_sigs.contains(enum_dispatch_name):
                enum_dispatch_name = enum_dispatch_name + "_" + args.len.to_str() + "arg"
            mut s = enum_dispatch_name + "(" + obj_s
            if args.len > 0: s = s + ", " + self.gen_args(args)
            return s + ")"

        # Extract List/Vec element suffix from the obj expression's type args
        mut elem_sfx: str = "ptr"
        match obj.read():
            case HirExpr.EIdent(_, ity, _):
                if ity.args.len > 0:
                    mut _me = ity.args.get(0).read()
                    # Generic value-type element -> monomorphized list suffix.
                    if self.value_types.contains(_me.name) and _me.args.len > 0 and self.classes.contains(_me.name):
                        self.ensure_mono(self.classes.get(_me.name), _me.args)
                        elem_sfx = _me.name + "_" + self.type_args_suffix(_me.args)
                    else:
                        elem_sfx = self.list_elem_suffix(_me.name)
                elif self.type_alias_map.contains(ity.name):
                    # Type alias e.g. NodeList -> "List_str*" - extract elem suffix from C name.
                    mut _alias_raw = self.type_alias_map.get(ity.name)
                    mut _alias_c = _alias_raw.trim()
                    if _alias_c.ends_with("*"):
                        mut _alias_sl = _alias_c.slice(0, _alias_c.len() - 1)
                        _alias_c = _alias_sl.trim()
                    if _alias_c.starts_with("List_"): elem_sfx = _alias_c.slice(5, _alias_c.len())
            case HirExpr.EMethodCall(_, _, _, mty):
                if mty.args.len > 0: elem_sfx = self.list_elem_suffix(mty.args.get(0).read().name)
            case HirExpr.ECall(_, _, cty):
                if cty.args.len > 0: elem_sfx = self.list_elem_suffix(cty.args.get(0).read().name)
            case HirExpr.EPropAccess(_, _, pty):
                if pty.args.len > 0: elem_sfx = self.list_elem_suffix(pty.args.get(0).read().name)
            case _: pass

        # List[T] / Vec[T] method dispatch (Vec maps to List in the C runtime)
        mut is_list_vec: bool = class_name == "List" or class_name == "Vec" or (class_name == "int" and (method == "append" or method == "push" or method == "pop" or method == "set" or method == "get" or method == "free" or method == "contains"))
        if not is_list_vec and class_name as usize != 0 as usize:
            mut cp2 = class_name as Pointer[char]
            if cp2.offset(0).read() as int == 86 and cp2.offset(1).read() as int == 101 and cp2.offset(2).read() as int == 99 and cp2.offset(3).read() as int == 95:
                is_list_vec = true
            elif cp2.offset(0).read() as int == 76 and cp2.offset(1).read() as int == 105 and cp2.offset(2).read() as int == 115 and cp2.offset(3).read() as int == 116 and cp2.offset(4).read() as int == 95:
                is_list_vec = true
 
        if is_list_vec:
            mut lsfx: str = self.list_sfx(elem_sfx)
            if method == "append" or method == "push":
                # If elem_sfx is still "ptr" but the argument is a known primitive, infer the right suffix
                if elem_sfx == "ptr" and args.len > 0:
                    mut push_arg_ty = hir_expr_type(args.get(0)).name
                    if _is_int_type(push_arg_ty) or push_arg_ty == "bool": elem_sfx = "i64"
                    elif _is_float_type(push_arg_ty): elem_sfx = "f64"
                    elif push_arg_ty == "str" or push_arg_ty == "char*": elem_sfx = "str"
                    lsfx = self.list_sfx(elem_sfx)
                # Heap-class element: the list holds a reference. Retain an ALIAS
                # (a local/field); MOVE a fresh ctor result (rc=1) — obj_retain_wrap
                # picks correctly, so fresh temps aren't double-counted.
                if args.len > 0 and self.is_heap_class_tn(hir_expr_type(args.get(0)).name):
                    mut _ael = self.obj_retain_wrap(args.get(0), self.gen_expr(args.get(0)), false)
                    if self._obj_store_needs_retain(args.get(0)): _ael = "_tr_obj_retain(" + _ael + ")"
                    return "List_" + lsfx + "_append(" + obj_s + ", " + _ael + ")"
                mut append_args = self.gen_args_strify(args, elem_sfx)
                if lsfx == "TrStr": append_args = self.gen_args(args)
                return "List_" + lsfx + "_append(" + obj_s + ", " + append_args + ")"
            if method == "free": return "List_" + lsfx + "_free(" + obj_s + ")"
            if method == "pop":
                mut pop_r = "List_" + lsfx + "_pop(" + obj_s + ")"
                if lsfx == "TrStr": return pop_r
                if elem_sfx == "ptr" and call_ty.name != "" and call_ty.name != "void" and call_ty.name != "Pointer":
                    if _tr_strlen(call_ty.name) > 1:
                        return "((" + call_ty.name + "*)" + pop_r + ")"
                return pop_r
            if method == "set":
                mut set_args = self.gen_args_strify(args, elem_sfx)
                if lsfx == "TrStr": set_args = self.gen_args(args)
                return "List_" + lsfx + "_set(" + obj_s + ", " + set_args + ")"
            if method == "contains":
                mut contains_args = self.gen_args_strify(args, elem_sfx)
                if lsfx == "TrStr": contains_args = self.gen_args(args)
                return "List_" + lsfx + "_contains(" + obj_s + ", " + contains_args + ")"
            if method == "get":
                mut get_r = "List_" + lsfx + "_get(" + obj_s + ", " + self.gen_args(args) + ")"
                if lsfx == "TrStr": return get_r
                if elem_sfx == "ptr" and call_ty.name == "Pointer" and call_ty.args.len > 0:
                    mut inner_ct = self.type_to_c(call_ty.args.get(0).read())
                    return "((" + inner_ct + "*)" + get_r + ")"
                if elem_sfx == "ptr" and call_ty.name != "" and call_ty.name != "void" and call_ty.name != "Pointer" and call_ty.name != "List" and call_ty.name != "Vec" and call_ty.name != "Map" and call_ty.name != "Dict" and call_ty.name != "str" and call_ty.name != "def":
                    if _tr_strlen(call_ty.name) > 1:
                        return "((" + call_ty.name + "*)" + get_r + ")"
                return get_r
            if method == "len" or method == "length": return "((long long)" + obj_s + "->len)"
            if method == "new" or method == "init":
                return "(void*)List_" + lsfx + "_new()"
            if method == "remove":
                return "List_" + lsfx + "_remove(" + obj_s + ", " + self.gen_args(args) + ")"
            if method == "swap":
                return "List_" + lsfx + "_swap(" + obj_s + ", " + self.gen_args(args) + ")"
            if method == "clear":
                return "List_" + lsfx + "_clear(" + obj_s + ")"
            if method == "is_empty":
                return "List_" + lsfx + "_is_empty(" + obj_s + ")"
            if method == "extend":
                return "List_" + lsfx + "_extend(" + obj_s + ", " + self.gen_args(args) + ")"
            if method == "index_of":
                mut idx_args = self.gen_args_strify(args, elem_sfx)
                if lsfx == "TrStr": idx_args = self.gen_args(args)
                return "List_" + lsfx + "_index_of(" + obj_s + ", " + idx_args + ")"
            # sort() / sort_by(cmp_fn) - in-place sort
            if method == "sort" or method == "sort_asc":
                return "_tr_list_sort_" + lsfx + "(" + obj_s + ", 1)"
            if method == "sort_desc":
                return "_tr_list_sort_" + lsfx + "(" + obj_s + ", -1)"
            if method == "sort_by" and args.len > 0:
                return "_tr_list_sort_by_" + lsfx + "(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            # first / last - aliases for get(0) / get(len-1)
            if method == "first":
                mut first_r = "List_" + lsfx + "_get(" + obj_s + ", 0LL)"
                if lsfx == "TrStr": return first_r
                return first_r
            if method == "last":
                mut last_r = "List_" + lsfx + "_get(" + obj_s + ", (long long)(" + obj_s + "->len - 1LL))"
                if lsfx == "TrStr": return last_r
                return last_r
            # any(pred) / all(pred) - boolean short-circuit over list
            if method == "any" and args.len > 0:
                return "_tr_list_any_" + lsfx + "(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "all" and args.len > 0:
                return "_tr_list_all_" + lsfx + "(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            # sum / min_val / max_val - numeric aggregates
            if method == "sum":
                return "_tr_list_sum_" + lsfx + "(" + obj_s + ")"
            if method == "min_val" or method == "min":
                return "_tr_list_min_" + lsfx + "(" + obj_s + ")"
            if method == "max_val" or method == "max":
                return "_tr_list_max_" + lsfx + "(" + obj_s + ")"
            # join(sep) - concatenate string elements with separator
            if method == "join":
                mut sep_s = "\"\""
                if args.len > 0: sep_s = self.gen_expr(args.get(0))
                return "_tr_trstr_join((List_TrStr*)" + obj_s + ", " + self.strz(sep_s) + ")"
            # reversed_copy() - return a new reversed list
            if method == "reversed" or method == "reversed_copy":
                return "_tr_list_reversed_" + lsfx + "(" + obj_s + ")"
            # reverse in place
            if method == "reverse":
                return "_tr_list_reverse_" + lsfx + "(" + obj_s + ")"
            # clone: shallow copy with a fresh backing buffer
            if method == "clone" or method == "copy":
                return "_tr_list_clone_" + lsfx + "(" + obj_s + ")"

        # Set[T] method dispatch - backed by _TrSet (hash set via TrMap with bool values)
        if class_name == "Set":
            # Value-type element -> typed inline set (Set_<Vname>), element by value.
            mut set_full_ty = hir_expr_type(obj)
            mut vt_set = ""
            if set_full_ty.args.len > 0:
                mut se2 = set_full_ty.args.get(0).read()
                if self.value_types.contains(se2.name) and se2.args.len == 0: vt_set = se2.name
            if vt_set != "":
                mut sp = "Set_" + vt_set
                if method == "init" or method == "new":
                    if args.len == 0: return sp + "_new(16)"
                    return sp + "_new(" + self.gen_args(args) + ")"
                if method == "add" and args.len > 0:
                    if self.is_heap_class_tn(hir_expr_type(args.get(0)).name):
                        return sp + "_add(" + obj_s + ", " + self.obj_retain_wrap(args.get(0), self.gen_expr(args.get(0)), false) + ")"
                    return sp + "_add(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
                if method == "contains" or method == "has": return sp + "_contains(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
                if method == "remove" and args.len > 0: return sp + "_remove(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
                if method == "len" or method == "length": return sp + "_len(" + obj_s + ")"
                if method == "is_empty": return "(" + sp + "_len(" + obj_s + ") == 0LL)"
                if method == "clear": return sp + "_clear(" + obj_s + ")"
                if method == "to_list": return sp + "_to_list(" + obj_s + ")"
                if method == "free": return sp + "_free(" + obj_s + ")"
            # Heap-class element -> pointer-identity set (_TrPtrSet), owns+releases elements.
            mut _pset_heap = ""
            if set_full_ty.args.len > 0 and self.is_heap_class_tn(set_full_ty.args.get(0).read().name):
                _pset_heap = set_full_ty.args.get(0).read().name
            if _pset_heap != "":
                if method == "init" or method == "new":
                    if args.len == 0: return "_tr_pset_new(16)"
                    return "_tr_pset_new(" + self.gen_args(args) + ")"
                if method == "add" and args.len > 0:
                    mut _pa = self.obj_retain_wrap(args.get(0), self.gen_expr(args.get(0)), false)
                    if self._obj_store_needs_retain(args.get(0)): _pa = "_tr_obj_retain(" + _pa + ")"
                    return "_tr_pset_add(" + obj_s + ", " + _pa + ")"
                if method == "contains" or method == "has": return "_tr_pset_contains(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
                if method == "remove" and args.len > 0: return "_tr_pset_remove(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
                if method == "len" or method == "length": return "_tr_pset_len(" + obj_s + ")"
                if method == "is_empty": return "(_tr_pset_len(" + obj_s + ") == 0LL)"
                if method == "clear": return "_tr_pset_clear(" + obj_s + ")"
                if method == "to_list": return "_tr_pset_to_list(" + obj_s + ")"
                if method == "free": return "_tr_pset_free(" + obj_s + ")"
            mut set_elem = elem_sfx
            if set_elem == "ptr": set_elem = "str"  # default element type
            # Choose runtime prefix: int-keyed sets use _tr_iset_*, others _tr_set_*
            mut sfn = "_tr_set_"
            if set_elem == "i64": sfn = "_tr_iset_"
            if method == "init" or method == "new":
                if args.len == 0: return sfn + "new(16)"
                return sfn + "new(" + self.gen_args(args) + ")"
            if method == "add" and args.len > 0:
                return sfn + "add(" + obj_s + ", " + self.gen_args_strify(args, set_elem) + ")"
            if method == "contains" or method == "has":
                return sfn + "contains(" + obj_s + ", " + self.gen_args_strify(args, set_elem) + ")"
            if method == "remove" and args.len > 0:
                return sfn + "remove(" + obj_s + ", " + self.gen_args_strify(args, set_elem) + ")"
            if method == "len" or method == "length":
                return sfn + "len(" + obj_s + ")"
            if method == "is_empty":
                return "(" + sfn + "len(" + obj_s + ") == 0LL)"
            if method == "clear":
                return sfn + "clear(" + obj_s + ")"
            if method == "to_list":
                return sfn + "to_list(" + obj_s + ")"
            if method == "union" and args.len > 0:
                return sfn + "union(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "intersection" and args.len > 0:
                return sfn + "intersection(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "difference" and args.len > 0:
                return sfn + "difference(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "is_subset" and args.len > 0:
                return sfn + "is_subset(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            if method == "free":
                return sfn + "free(" + obj_s + ")"

        # Map/Dict method dispatch
        mut is_map_dict: bool = class_name == "Map" or class_name == "Dict" or class_name == "TrMap"
        if not is_map_dict and class_name as usize != 0 as usize:
            mut cp = class_name as Pointer[char]
            if cp.offset(0).read() as int == 77 and cp.offset(1).read() as int == 97 and cp.offset(2).read() as int == 112 and cp.offset(3).read() as int == 95:
                is_map_dict = true
            elif cp.offset(0).read() as int == 68 and cp.offset(1).read() as int == 105 and cp.offset(2).read() as int == 99 and cp.offset(3).read() as int == 116 and cp.offset(4).read() as int == 95:
                is_map_dict = true

        if is_map_dict:
            # Detect int-keyed dict from type args
            mut obj_full_ty = hir_expr_type(obj)
            # Map[K,V] / Dict[K,V]: first type arg is the key type.
            mut dict_key_ty = "str"
            if obj_full_ty.args.len > 0:
                mut ka = obj_full_ty.args.get(0).read()
                if _is_int_type(ka.name) or ka.name == "int" or ka.name == "i64" or ka.name == "i32" or ka.name == "usize":
                    dict_key_ty = "int"
            mut is_idict = dict_key_ty == "int"
            # Value-type VALUE -> typed inline dict (Dict_<kc>_<Vname>); value stored
            # and returned BY VALUE (no void* boxing, no str retain/unbox).
            mut vt_dict = ""
            if obj_full_ty.args.len > 1:
                mut vv = obj_full_ty.args.get(1).read()
                if self.value_types.contains(vv.name) and vv.args.len == 0: vt_dict = vv.name
            if vt_dict != "":
                mut kc = "str"
                if is_idict: kc = "i64"
                mut dp = "Dict_" + kc + "_" + vt_dict
                if method == "init" or method == "new":
                    if args.len == 0: return dp + "_new(16)"
                    return dp + "_new(" + self.gen_args(args) + ")"
                mut dkey = ""
                if args.len > 0:
                    if is_idict: dkey = self.gen_expr(args.get(0))
                    else: dkey = self.dict_key_arg(args.get(0))
                if method == "get" or method == "get_index":
                    return dp + "_get(" + obj_s + ", " + dkey + ")"
                if method == "set" or method == "insert":
                    return dp + "_set(" + obj_s + ", " + dkey + ", " + self.gen_expr(args.get(1)) + ")"
                if method == "contains" or method == "has":
                    return dp + "_has(" + obj_s + ", " + dkey + ")"
                if method == "remove":
                    return dp + "_remove(" + obj_s + ", " + dkey + ")"
                if method == "len" or method == "length":
                    return dp + "_len(" + obj_s + ")"
                if method == "is_empty":
                    return "(" + dp + "_len(" + obj_s + ") == 0LL)"
                if method == "keys":
                    return dp + "_keys(" + obj_s + ")"
                if method == "values":
                    return dp + "_values(" + obj_s + ")"
                if method == "clear":
                    return dp + "_clear(" + obj_s + ")"
                if method == "free":
                    return dp + "_free(" + obj_s + ")"
                if method == "get_or" and args.len >= 2:
                    return "(" + dp + "_has(" + obj_s + ", " + dkey + ") ? " + dp + "_get(" + obj_s + ", " + dkey + ") : (" + self.gen_expr(args.get(1)) + "))"
            if method == "init" or method == "new":
                if is_idict: return "_tr_idict_new(" + self.gen_args(args) + ")"
                return "_tr_dict_new(" + self.gen_args(args) + ")"
            # `get_index` is the desugaring of d[key] (read context); treat it
            # exactly like `.get` so str values are unboxed.
            if method == "get" or method == "get_index":
                mut c_ty_c = self.type_to_c(call_ty)
                if is_idict:
                    mut iget_r = "_tr_idict_get(" + obj_s + ", " + self.gen_args(args) + ")"
                    if _is_str_type(call_ty.name):
                        if self.eliding_get_retain: return "_tr_str_unbox(" + iget_r + ")"
                        return "_tr_str_retain(_tr_str_unbox(" + iget_r + "))"
                    if c_ty_c != "void" and c_ty_c != "":
                        return "((" + c_ty_c + ")(uintptr_t)" + iget_r + ")"
                    return iget_r
                mut mget_r = "_tr_dict_get(" + obj_s + ", " + self.dict_key_arg(args.get(0)) + ")"
                if _is_str_type(call_ty.name):
                    if self.eliding_get_retain: return "_tr_str_unbox(" + mget_r + ")"
                    return "_tr_str_retain(_tr_str_unbox(" + mget_r + "))"
                if c_ty_c != "void" and c_ty_c != "":
                    return "((" + c_ty_c + ")(uintptr_t)" + mget_r + ")"
                return mget_r
            if method == "set" or method == "insert":
                if is_idict: return "_tr_idict_set(" + obj_s + ", " + self.gen_expr(args.get(0)) + ", " + self.dict_val_arg(args.get(1)) + ")"
                return "_tr_dict_set(" + obj_s + ", " + self.dict_key_arg(args.get(0)) + ", " + self.dict_val_arg(args.get(1)) + ")"
            if method == "contains" or method == "has":
                if is_idict: return "_tr_idict_contains(" + obj_s + ", " + self.gen_args(args) + ")"
                return "_tr_dict_contains(" + obj_s + ", " + self.dict_key_arg(args.get(0)) + ")"
            if method == "remove":
                if is_idict: return "_tr_idict_remove(" + obj_s + ", " + self.gen_args(args) + ")"
                return "_tr_dict_remove(" + obj_s + ", " + self.dict_key_arg(args.get(0)) + ")"
            if method == "len" or method == "length":
                if is_idict: return "_tr_idict_len(" + obj_s + ")"
                return "_tr_dict_len(" + obj_s + ")"
            if method == "keys":
                if is_idict: return "_tr_idict_keys(" + obj_s + ")"
                return "_tr_dict_keys(" + obj_s + ")"
            if method == "values":
                mut _vals_strval = call_ty.name == "List" and call_ty.args.len > 0 and _is_str_type(call_ty.args.get(0).read().name)
                if is_idict:
                    if _vals_strval: return "_tr_idict_values_strval(" + obj_s + ")"
                    return "_tr_idict_values(" + obj_s + ")"
                if _vals_strval: return "_tr_dict_values_strval(" + obj_s + ")"
                return "_tr_dict_values(" + obj_s + ")"
            if method == "items":
                if is_idict: return "_tr_idict_items(" + obj_s + ")"
                return "_tr_dict_items(" + obj_s + ")"
            # update(other) - merge all entries from other map into self
            if method == "update" and args.len > 0:
                if is_idict: return "_tr_idict_update(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
                return "_tr_dict_update(" + obj_s + ", " + self.gen_expr(args.get(0)) + ")"
            # clear() - remove all entries
            if method == "clear":
                if is_idict: return "_tr_idict_clear(" + obj_s + ")"
                return "_tr_dict_clear(" + obj_s + ")"
            # is_empty() - true if len == 0
            if method == "is_empty":
                if is_idict: return "(_tr_idict_len(" + obj_s + ") == 0LL)"
                return "(_tr_dict_len(" + obj_s + ") == 0LL)"
            # get_or(key, default) - get with fallback
            if method == "get_or" and args.len >= 2:
                mut _is_str_val = _is_str_type(call_ty.name)
                mut _d = self.gen_expr(args.get(1))
                if _is_str_val: _d = "_tr_str_box(" + _d + ")"
                mut _res = ""
                if is_idict:
                    mut _ik = self.gen_expr(args.get(0))
                    _res = "(_tr_idict_contains(" + obj_s + ", " + _ik + ") ? _tr_idict_get(" + obj_s + ", " + _ik + ") : (void*)(uintptr_t)(" + _d + "))"
                else:
                    mut _k = self.dict_key_arg(args.get(0))
                    _res = "(_tr_dict_contains(" + obj_s + ", " + _k + ") ? _tr_dict_get(" + obj_s + ", " + _k + ") : (void*)(uintptr_t)(" + _d + "))"
                if _is_str_val: return "_tr_str_unbox(" + _res + ")"
                mut _getor_c_ty = self.type_to_c(call_ty)
                if _getor_c_ty != "void" and _getor_c_ty != "" and _getor_c_ty != "TrStr":
                    return "((" + _getor_c_ty + ")(uintptr_t)" + _res + ")"
                return _res
            # free() - release the underlying TrMap/TrIDict (buckets, nodes,
            # key strings for str-keyed maps, and the struct itself). For
            # Map[K,str]/Dict[K,str], values are _tr_str_box(TrStr)-allocated
            # boxes (#54): use the _strval variant to release each boxed
            # TrStr and free its box, avoiding a per-entry leak.
            if method == "free":
                mut _val_is_str = obj_full_ty.args.len > 1 and _is_str_type(obj_full_ty.args.get(1).read().name)
                if is_idict:
                    if _val_is_str: return "_tr_idict_free_strval(" + obj_s + ")"
                    return "_tr_idict_free(" + obj_s + ")"
                if _val_is_str: return "Dict_free_strval(" + obj_s + ")"
                return "Dict_free(" + obj_s + ")"

        mut extra_args = ""
        if args.len > 0:
            extra_args = ", " + self.gen_args(args)
        # Fallback: when class_name is known but the method wasn't handled above,
        # emit ClassNme_method(obj, ...) - prevents bare calls that collide with C stdlib.
        # Only skip the prefix for truly primitive/unresolvable types.
        mut safe_method = method
        if _is_c_keyword(safe_method): safe_method = "_tr_fn_" + safe_method
        if class_name != "" and class_name != "void" and class_name != "int" and class_name != "float" and class_name != "bool" and class_name != "char" and class_name != "str":
            if not _is_primitive(class_name) and not _is_str_type(class_name):
                return class_name + "_" + safe_method + "(" + obj_s + extra_args + ")"
        return safe_method + "(" + obj_s + extra_args + ")"

    pub def gen_fstring(self, parts: Vec[HirFStringPart]) -> str:
        if parts.len == 0: return "\"\""
        mut fmt = ""
        mut fargs = ""
        mut i = 0
        while i < parts.len:
            mut part = parts.get(i)
            if not part.is_expr:
                fmt = fmt + _escape_str_for_c(part.text)
            else:
                mut s = self.gen_expr(part.expr)
                mut ty_n: str = hir_expr_type(part.expr).name
                mut spec = part.fmt_spec  # e.g. ".2f", ">10", "05d"

                if spec.len() > 0:
                    # User supplied a format spec - map to printf format.
                    # Detect the conversion type character at the end of spec.
                    mut spec_n = spec.len()
                    mut last_c = spec.char_at(spec_n - 1)
                    # Float specs: f, e, E, g, G
                    if last_c == 102 or last_c == 101 or last_c == 69 or last_c == 103 or last_c == 71:
                        fmt = fmt + "%" + spec
                        fargs = fargs + ", (double)(" + s + ")"
                    # Integer specs: d, i, u, o, x, X
                    elif last_c == 100 or last_c == 105 or last_c == 117 or last_c == 111 or last_c == 120 or last_c == 88:
                        fmt = fmt + "%" + spec
                        fargs = fargs + ", (long long)(" + s + ")"
                    # String specs: s (width/alignment)
                    elif last_c == 115:
                        fmt = fmt + "%" + spec
                        if _is_int_type(ty_n):
                            fargs = fargs + ", _tr_int_to_str(" + s + ")"
                        elif _is_float_type(ty_n):
                            fargs = fargs + ", _tr_float_to_str(" + s + ")"
                        elif _is_str_type(ty_n):
                            fargs = fargs + ", " + self.strz(s)
                        else:
                            fargs = fargs + ", (char*)(" + s + ")"
                    # Alignment / width only: ">10", "<10", "^10", "10"
                    # Map Python alignment chars to printf width specifiers.
                    else:
                        mut _align_spec = spec
                        mut _left_align = false
                        if _align_spec.starts_with(">"):
                            _align_spec = _align_spec.slice(1, _align_spec.len())  # right = default %Ws
                        elif _align_spec.starts_with("<"):
                            _align_spec = _align_spec.slice(1, _align_spec.len())
                            _left_align = true
                        elif _align_spec.starts_with("^"):
                            _align_spec = _align_spec.slice(1, _align_spec.len())  # center ~= right
                        if _is_int_type(ty_n):
                            if _left_align: fmt = fmt + "%-" + _align_spec + "lld"
                            else:           fmt = fmt + "%" + _align_spec + "lld"
                            fargs = fargs + ", (long long)(" + s + ")"
                        elif _is_float_type(ty_n):
                            if _left_align: fmt = fmt + "%-" + _align_spec + "g"
                            else:           fmt = fmt + "%" + _align_spec + "g"
                            fargs = fargs + ", (double)(" + s + ")"
                        else:
                            if _left_align: fmt = fmt + "%-" + _align_spec + "s"
                            else:           fmt = fmt + "%" + _align_spec + "s"
                            if _is_str_type(ty_n):
                                fargs = fargs + ", " + self.strz(s)
                            else:
                                fargs = fargs + ", (char*)(" + s + ")"
                elif _is_int_type(ty_n):
                    fmt = fmt + "%lld"
                    fargs = fargs + ", (long long)(" + s + ")"
                elif _is_float_type(ty_n):
                    fmt = fmt + "%g"
                    fargs = fargs + ", (double)(" + s + ")"
                elif ty_n == "bool":
                    fmt = fmt + "%s"
                    fargs = fargs + ", ((" + s + ") ? \"true\" : \"false\")"
                elif ty_n == "char":
                    fmt = fmt + "%c"
                    fargs = fargs + ", (char)(" + s + ")"
                elif ty_n == "void" or ty_n == "":
                    fmt = fmt + "%s"
                    fargs = fargs + ", _TR_AUTO_STR(" + s + ")"
                elif ty_n == "List" or ty_n == "Vec" or ty_n == "Set" or ty_n == "Dict" or ty_n == "Map":
                    fmt = fmt + "%s"
                    fargs = fargs + ", " + self.gen_collection_to_str(s, hir_expr_type(part.expr))
                elif _is_str_type(ty_n):
                    fmt = fmt + "%s"
                    fargs = fargs + ", " + self.strz(s)
                else:
                    fmt = fmt + "%s"
                    mut mono_fs = self.mono_cls_name_for(hir_expr_type(part.expr))
                    if self.has_method(mono_fs, "__str__"):
                        fargs = fargs + ", " + self.strz(self.cls_method_c_call(mono_fs, "__str__", s, ""))
                    elif self.has_method(mono_fs, "__repr__"):
                        fargs = fargs + ", " + self.strz(self.cls_method_c_call(mono_fs, "__repr__", s, ""))
                    elif self.classes.contains(mono_fs):
                        fargs = fargs + ", " + self.obj_to_str_expr(mono_fs, s)
                    else:
                        fargs = fargs + ", (char*)(" + s + ")"
            i = i + 1
        return "_tr_str_wrap(({ int _fz = snprintf(NULL,0,\"" + fmt + "\"" + fargs + "); char* _fr=(char*)_tr_checked_alloc(_fz+1); snprintf(_fr,_fz+1,\"" + fmt + "\"" + fargs + "); _fr; }))"

    pub def gen_tuple(self, items: Vec[Pointer[HirExpr]]) -> str:
        if items.len == 0: return "((TrTuple){.data={0}})"
        mut s = "((TrTuple){.data={"
        mut i = 0
        while i < items.len:
            if i > 0: s = s + ", "
            mut tup_e = items.get(i)
            mut tup_es = self.gen_expr(tup_e)
            mut tup_tn: str = self.resolve_generic_prim(hir_expr_type(tup_e).name)
            if _is_str_type(tup_tn):
                # Retain before boxing: the box's TrStr shares .data/.rc with
                # tup_es's source; without a retain, the source's auto-drop
                # would free .data while the box still points at it (UAF).
                s = s + "(long long)(uintptr_t)_tr_str_box(_tr_str_retain(" + tup_es + "))"
            elif _is_float_type(tup_tn):
                # Bit-preserve the double in the long long slot (a plain cast
                # would truncate 3.14 -> 3). Read back via _tr_ptr_to_f64.
                s = s + "(long long)(uintptr_t)_tr_f64_to_ptr((double)(" + tup_es + "))"
            else:
                s = s + "(long long)(uintptr_t)(" + tup_es + ")"
            i = i + 1
        return s + "}})"

    # Render a tuple value as a Python-style string: "(1, 'hello', 3.14)".
    # Tuple elements are heterogeneous; emitted as a self-contained GCC
    # statement-expression (no helper fn) so it works in any context, including
    # top-level code (the lazy proto_buf path is only flushed during mono gen).
    # The tuple is bound to a temp so the source expression is evaluated once.
    pub def gen_tuple_to_str(self, s: str, ty: AstType) -> str:
        if ty.args.len == 0:
            return "\"(...)\""
        mut tt = self.next_temp()
        mut body = "({ TrTuple " + tt + " = (" + s + "); size_t _cap, _bl = 0; char* _b = _tr_sb_init(&_cap); "
        body = body + "_b = _tr_sb_append(_b, &_bl, &_cap, \"(\"); "
        mut ei = 0
        while ei < ty.args.len:
            if ei > 0:
                body = body + "_b = _tr_sb_append(_b, &_bl, &_cap, \", \"); "
            mut etn: str = self.resolve_generic_prim(ty.args.get(ei).read().name)
            mut slot = tt + ".data[" + ei.to_str() + "]"
            if _is_str_type(etn):
                # Boxed TrStr slot: quote its .data via _tr_fmt_str.
                body = body + "{ TrStr* _bx" + ei.to_str() + " = (TrStr*)(uintptr_t)" + slot + "; const char* _sv" + ei.to_str() + " = _bx" + ei.to_str() + " ? _bx" + ei.to_str() + "->data : \"\"; _b = _tr_sb_append(_b, &_bl, &_cap, _tr_fmt_str(&_sv" + ei.to_str() + ")); } "
            elif _is_float_type(etn):
                body = body + "_b = _tr_sb_append(_b, &_bl, &_cap, _tr_float_to_str(_tr_ptr_to_f64((void*)(uintptr_t)" + slot + "))); "
            elif etn == "bool":
                body = body + "_b = _tr_sb_append(_b, &_bl, &_cap, _tr_bool_to_str((_Bool)" + slot + ")); "
            elif etn == "char":
                body = body + "{ char _cv" + ei.to_str() + " = (char)" + slot + "; char _cb" + ei.to_str() + "[2] = { _cv" + ei.to_str() + ", 0 }; _b = _tr_sb_append(_b, &_bl, &_cap, _cb" + ei.to_str() + "); } "
            else:
                body = body + "_b = _tr_sb_append(_b, &_bl, &_cap, _tr_int_to_str((long long)" + slot + ")); "
            ei = ei + 1
        body = body + "_b = _tr_sb_append(_b, &_bl, &_cap, \")\"); _b; })"
        return body

    # -- Real async/await -----------------------------------------------------

    # Emit a coroutine entry wrapper for an async function call. The wrapper
    # runs as a green-thread (_tr_co_go), unpacks its boxed args, calls the
    # target, and RETURNS the (boxed) result — the scheduler stores it as the
    # coroutine's result, which `await` reads via _tr_co_await. Args are packed
    # starting at index 0 (no task-state slot in the coroutine model).
    pub def emit_async_wrapper_for_call(self, fn_name: str, args: Vec[Pointer[HirExpr]], ret_name: str):
        if self.async_wrappers.contains(fn_name): return
        self.async_wrappers.insert(fn_name, true)
        mut nargs = args.len
        self.w("static void* _tr_async_wrap_" + fn_name + "(void* _vp) {\n")
        self.w("    long long* _a = (long long*)_vp;\n")
        self.w("    (void)_a;\n")
        mut ci = 0
        while ci < nargs:
            mut arg_ty_name = hir_expr_type(args.get(ci)).name
            mut c_arg_ty = self.type_to_c(hir_expr_type(args.get(ci)))
            if c_arg_ty == "void" or c_arg_ty == "": c_arg_ty = "long long"
            mut is_int = _is_int_type(arg_ty_name) or arg_ty_name == "bool" or arg_ty_name == "char"
            if is_int:
                self.w("    " + c_arg_ty + " _arg" + ci.to_str() + " = (" + c_arg_ty + ")_a[" + ci.to_str() + "];\n")
            elif _is_str_type(arg_ty_name):
                self.w("    TrStr _arg" + ci.to_str() + " = _tr_str_unbox((void*)(uintptr_t)_a[" + ci.to_str() + "]);\n")
            else:
                self.w("    " + c_arg_ty + " _arg" + ci.to_str() + " = (" + c_arg_ty + ")(uintptr_t)_a[" + ci.to_str() + "];\n")
            ci = ci + 1
        mut call_s = fn_name + "("
        mut ai = 0
        while ai < nargs:
            if ai > 0: call_s = call_s + ", "
            call_s = call_s + "_arg" + ai.to_str()
            ai = ai + 1
        call_s = call_s + ")"
        if ret_name == "void" or ret_name == "":
            self.w("    " + call_s + ";\n")
            self.w("    free(_a);\n")
            self.w("    return NULL;\n")
        elif _is_str_type(ret_name):
            self.w("    void* _r = (void*)(uintptr_t)_tr_str_box(" + call_s + ");\n")
            self.w("    free(_a);\n")
            self.w("    return _r;\n")
        else:
            self.w("    void* _r = (void*)(uintptr_t)(" + call_s + ");\n")
            self.w("    free(_a);\n")
            self.w("    return _r;\n")
        self.w("}\n")

    pub def gen_await_call(self, expr: Pointer[HirExpr]) -> str:
        if _is_invalid_ptr(expr as usize): return "0LL"
        match expr.read():
            case HirExpr.ECall(callee, args, call_ty):
                mut fn_name = ""
                match callee.read():
                    case HirExpr.EIdent(n, _, _): fn_name = n
                    case _: pass
                if fn_name == "":
                    # Fallback: can't wrap, call directly
                    return self.gen_expr(expr)
                mut ret_name = call_ty.name
                if ret_name == "": ret_name = "void"
                self.emit_async_wrapper_for_call(fn_name, args, ret_name)
                mut nargs = args.len
                mut tmp = self.next_temp()
                # Pack args (at least one slot - the wrapper frees this buffer).
                mut buf_size = nargs.to_str()
                if nargs == 0: buf_size = "1"
                mut s = "({ long long* _ab" + tmp + " = (long long*)_tr_checked_alloc(" + buf_size + " * sizeof(long long)); "
                mut ai = 0
                while ai < nargs:
                    mut arg_ty_name = hir_expr_type(args.get(ai)).name
                    mut is_int = _is_int_type(arg_ty_name) or arg_ty_name == "bool" or arg_ty_name == "char"
                    if is_int:
                        s = s + "_ab" + tmp + "[" + ai.to_str() + "] = (long long)(" + self.gen_expr(args.get(ai)) + "); "
                    elif _is_str_type(arg_ty_name):
                        s = s + "_ab" + tmp + "[" + ai.to_str() + "] = (long long)(uintptr_t)_tr_str_box(" + self.gen_expr(args.get(ai)) + "); "
                    else:
                        s = s + "_ab" + tmp + "[" + ai.to_str() + "] = (long long)(uintptr_t)(" + self.gen_expr(args.get(ai)) + "); "
                    ai = ai + 1
                # Spawn a coroutine for the call and cooperatively await it.
                s = s + "_TrCoro* _co" + tmp + " = _tr_co_go(_tr_async_wrap_" + fn_name + ", _ab" + tmp + "); "
                s = s + "long long _r" + tmp + " = _tr_co_await(_co" + tmp + "); "
                s = s + "_tr_co_free(_co" + tmp + "); "
                if ret_name == "void":
                    s = s + "0LL; })"
                elif _is_int_type(ret_name) or ret_name == "bool" or ret_name == "char":
                    mut c_ret = self.type_to_c(call_ty)
                    s = s + "(" + c_ret + ")_r" + tmp + "; })"
                elif _is_str_type(ret_name):
                    s = s + "_tr_str_unbox((void*)(uintptr_t)_r" + tmp + "); })"
                else:
                    mut c_ret2 = self.type_to_c(call_ty)
                    if c_ret2 == "void" or c_ret2 == "": c_ret2 = "void*"
                    s = s + "(" + c_ret2 + ")(uintptr_t)_r" + tmp + "; })"
                return s
            case _:
                # Not a call - just evaluate synchronously
                return self.gen_expr(expr)

    # -- await_timeout(expr, ms): like gen_await_call but with timeout ----------

    pub def gen_await_timeout_call(self, expr: Pointer[HirExpr], ms_expr: Pointer[HirExpr]) -> str:
        if _is_invalid_ptr(expr as usize): return "0LL"
        match expr.read():
            case HirExpr.ECall(callee, args, call_ty):
                mut fn_name = ""
                match callee.read():
                    case HirExpr.EIdent(n, _, _): fn_name = n
                    case _: pass
                if fn_name == "":
                    return self.gen_expr(expr)
                mut ret_name = call_ty.name
                if ret_name == "": ret_name = "void"
                self.emit_async_wrapper_for_call(fn_name, args, ret_name)
                mut nargs = args.len
                mut tmp = self.next_temp()
                mut buf_size = nargs.to_str()
                if nargs == 0: buf_size = "1"
                mut ms_s = self.gen_expr(ms_expr)
                mut s = "({ long long* _ab" + tmp + " = (long long*)_tr_checked_alloc(" + buf_size + " * sizeof(long long)); "
                mut ai = 0
                while ai < nargs:
                    mut arg_ty_name = hir_expr_type(args.get(ai)).name
                    mut is_int = _is_int_type(arg_ty_name) or arg_ty_name == "bool" or arg_ty_name == "char"
                    if is_int:
                        s = s + "_ab" + tmp + "[" + ai.to_str() + "] = (long long)(" + self.gen_expr(args.get(ai)) + "); "
                    elif _is_str_type(arg_ty_name):
                        s = s + "_ab" + tmp + "[" + ai.to_str() + "] = (long long)(uintptr_t)_tr_str_box(" + self.gen_expr(args.get(ai)) + "); "
                    else:
                        s = s + "_ab" + tmp + "[" + ai.to_str() + "] = (long long)(uintptr_t)(" + self.gen_expr(args.get(ai)) + "); "
                    ai = ai + 1
                s = s + "_TrCoro* _co" + tmp + " = _tr_co_go(_tr_async_wrap_" + fn_name + ", _ab" + tmp + "); "
                s = s + "long long _rto" + tmp + " = 0LL; "
                s = s + "_tr_co_await_timeout(_co" + tmp + ", (long long)(" + ms_s + "), &_rto" + tmp + "); "
                s = s + "_tr_co_free(_co" + tmp + "); "
                if ret_name == "void":
                    s = s + "0LL; })"
                elif _is_int_type(ret_name) or ret_name == "bool" or ret_name == "char":
                    mut c_ret = self.type_to_c(call_ty)
                    s = s + "(" + c_ret + ")_rto" + tmp + "; })"
                elif _is_str_type(ret_name):
                    s = s + "_tr_str_unbox((void*)(uintptr_t)_rto" + tmp + "); })"
                else:
                    mut c_ret2 = self.type_to_c(call_ty)
                    if c_ret2 == "void" or c_ret2 == "": c_ret2 = "void*"
                    s = s + "(" + c_ret2 + ")(uintptr_t)_rto" + tmp + "; })"
                return s
            case _:
                return self.gen_expr(expr)

    # -- SMultiLet (tuple unpacking) -----------------------------------------

    pub def gen_multi_let(self, names: Vec[str], is_mut: bool, val: Pointer[HirExpr], indent: int):
        pad = _indent_str(indent)
        mut tmp = "_tup" + self.next_temp()
        self.w(pad + "TrTuple " + tmp + " = " + self.gen_expr(val) + ";\n")
        mut val_ty = hir_expr_type(val)
        mut i = 0
        while i < names.len:
            mut vname = _safe_c_varname(names.get(i))
            mut elem_ty_n = ""
            if val_ty.args.len > i: elem_ty_n = self.resolve_generic_prim(val_ty.args.get(i).read().name)
            if _is_str_type(elem_ty_n):
                # Retain: _tr_str_unbox is non-destructive and shares the
                # box's refcount. Without retaining, an auto-drop of `vname`
                # could free data the (leaked) box's TrStr still points at.
                self.w(pad + "TrStr " + vname + " = _tr_str_retain(_tr_str_unbox((void*)(uintptr_t)" + tmp + ".data[" + i.to_str() + "]));\n")
            else:
                self.w(pad + "long long " + vname + " = " + tmp + ".data[" + i.to_str() + "];\n")
            self.decl_vars.insert(names.get(i), true)
            i = i + 1

    pub def gen_list_literal(self, items: Vec[Pointer[HirExpr]], ty: AstType) -> str:
        mut sfx = "ptr"
        if ty.args.len > 0:
            mut _le = ty.args.get(0).read()
            # Generic value-type element -> monomorphized inline suffix (Box_i64).
            if self.value_types.contains(_le.name) and _le.args.len > 0 and self.classes.contains(_le.name):
                self.ensure_mono(self.classes.get(_le.name), _le.args)
                sfx = _le.name + "_" + self.type_args_suffix(_le.args)
            else:
                sfx = self.list_elem_suffix(_le.name)
        elif items.len > 0:
            sfx = self.list_elem_suffix(hir_expr_type(items.get(0)).name)
        mut lsfx = self.list_sfx(sfx)
        mut l = "_l_" + self.next_temp()
        mut s = "({ List_" + lsfx + "* " + l + " = List_" + lsfx + "_new(); "
        mut i = 0
        while i < items.len:
            mut item_s = self.gen_expr(items.get(i))
            # Heap-class element: the list co-owns it (retain alias / transfer fresh),
            # so element-release on the list's drop is balanced.
            if self.is_heap_class_tn(hir_expr_type(items.get(i)).name):
                item_s = self.obj_retain_wrap(items.get(i), item_s, false)
                if self._obj_store_needs_retain(items.get(i)): item_s = "_tr_obj_retain(" + item_s + ")"
            s = s + "List_" + lsfx + "_append(" + l + ", " + item_s + "); "
            i = i + 1
        return s + l + "; })"

    pub def gen_dict_literal(self, keys: Vec[Pointer[HirExpr]], vals: Vec[Pointer[HirExpr]], hint_ty: AstType) -> str:
        # Detect int-keyed from type args (works for empty dicts too)
        mut is_int_key = false
        if hint_ty.args.len > 0:
            mut ka_h = hint_ty.args.get(0).read()
            if _is_int_type(ka_h.name) or ka_h.name == "int" or ka_h.name == "i64" or ka_h.name == "i32" or ka_h.name == "usize":
                is_int_key = true
        if keys.len == 0:
            if is_int_key: return "_tr_idict_new(0LL)"
            return "_tr_dict_new(0LL)"
        # Detect int-keyed literal from key type (fallback when no hint)
        if not is_int_key and keys.len > 0:
            mut k0_ty = hir_expr_type(keys.get(0)).name
            if _is_int_type(k0_ty) or k0_ty == "int" or k0_ty == "i64":
                is_int_key = true
        mut tmp = self.next_temp()
        if is_int_key:
            mut s = "({ TrIDict* " + tmp + " = _tr_idict_new(" + str(keys.len) + "LL); "
            mut i = 0
            while i < keys.len:
                s = s + "_tr_idict_set(" + tmp + ", " + self.gen_expr(keys.get(i)) + ", " + self.dict_val_arg(vals.get(i)) + "); "
                i = i + 1
            s = s + tmp + "; })"
            return s
        mut s = "({ TrMap* " + tmp + " = _tr_dict_new(" + str(keys.len) + "LL); "
        mut i = 0
        while i < keys.len:
            s = s + "_tr_dict_set(" + tmp + ", " + self.dict_key_arg(keys.get(i)) + ", " + self.dict_val_arg(vals.get(i)) + "); "
            i = i + 1
        s = s + tmp + "; })"
        return s

    pub def gen_list_comp(self, element: Pointer[HirExpr], generators: Vec[Pointer[HirComprehension]]) -> str:
        mut tmp = self.next_temp()
        mut elem_ty_n: str = hir_expr_type(element).name
        mut sfx = self.list_sfx(self.list_elem_suffix(elem_ty_n))
        mut s = "({ List_" + sfx + "* " + tmp + " = List_" + sfx + "_new(); "
        mut i = 0
        while i < generators.len:
            mut gen = generators.get(i).read()
            mut iter_s = self.gen_expr(gen.iter)
            s = s + "{ __auto_type _gc" + i.to_str() + " = " + iter_s + "; long long _gi" + i.to_str() + " = 0;"
            s = s + " while (_gi" + i.to_str() + " < _gc" + i.to_str() + "->len) {"
            s = s + " __auto_type " + gen.target + " = _gc" + i.to_str() + "->data[_gi" + i.to_str() + "]; "
            mut fi = 0
            while fi < gen.ifs.len:
                s = s + "if (" + self.gen_expr(gen.ifs.get(fi)) + ") { "
                fi = fi + 1
            i = i + 1
        # For a FRESH str element (e.g. `x.to_str()`, a concat), transfer
        # ownership into the list via _append_owned instead of _append: the
        # plain List_TrStr_append RETAINS its arg, so appending a fresh rc=1
        # string without a matching release leaks it once per element. A
        # borrowed str element (e.g. `[s for s in strs]`) still uses the
        # retaining _append so the result keeps its own reference.
        mut _elem_s = self.gen_expr(element)
        mut _app_sfx = "_append"
        if sfx == "TrStr" and self._is_fresh_str_expr(element): _app_sfx = "_append_owned"
        s = s + "List_" + sfx + _app_sfx + "(" + tmp + ", " + _elem_s + "); "
        i = 0
        while i < generators.len:
            mut gen2 = generators.get(i).read()
            mut fi = 0
            while fi < gen2.ifs.len:
                s = s + "} "
                fi = fi + 1
            # Free the comprehension's source iterable when it is a freshly
            # allocated, owned list (a literal or range) with PRIMITIVE
            # elements - otherwise it leaks every evaluation (e.g.
            # `[x.to_str() for x in [a,b,c]]`). The free goes inside the
            # `{ __auto_type _gc<i> = ...; }` block (after the while, before the
            # block's closing brace). Restricted to single-generator comps and
            # primitive element types: a borrowed source (variable/field) must
            # not be freed (UAF), and a str/class-element source could share
            # refcounted elements with the result via append (double-free).
            mut src_free = ""
            if generators.len == 1:
                src_free = self._comp_src_free_stmt(gen2.iter, i)
            s = s + "_gi" + i.to_str() + "++; } " + src_free + "} "
            i = i + 1
        return s + tmp + "; })"

    # Returns "List_<sfx>_free(_gc<idx>); " when the comprehension source `iter_e`
    # is a fresh, owned collection (list literal or range) with primitive
    # elements, else "" (leave borrowed / refcounted-element sources alone).
    pub def _comp_src_free_stmt(self, iter_e: Pointer[HirExpr], idx: int) -> str:
        mut is_fresh = false
        match iter_e.read():
            case HirExpr.EList(_, _): is_fresh = true
            case HirExpr.ERange(_, _, _, _): is_fresh = true
            case _: is_fresh = false
        if not is_fresh: return ""
        mut src_ty = hir_expr_type(iter_e)
        mut elem_n = "int"
        if src_ty.args.len > 0: elem_n = src_ty.args.get(0).read().name
        mut src_sfx = self.list_sfx(self.list_elem_suffix(elem_n))
        # Only primitive element suffixes are safe to free here. TrStr (str
        # elements) and ptr (class/heap elements) may have been shared into the
        # result by append, so skip them.
        if src_sfx == "TrStr" or src_sfx == "ptr": return ""
        return "List_" + src_sfx + "_free(_gc" + idx.to_str() + "); "

    # Portable (GCC+Clang) closure: the body is OUTLINED to a top-level `static`
    # function taking an explicit env pointer, and the closure VALUE is a heap env
    # holding POINTERS to the captured variables (capture-by-reference, so reads
    # see live updates and writes are visible outside — matching the previous
    # GCC-nested-function semantics). Inside the body, a reference to a captured
    # name lowers to `(*__env->p_<name>)` (see gen_expr EIdent / SAssign).
    #   value layout:  { void* __fn; <cty>* p_cap; … }  (env, first word = fn)
    #   call:          (*(void**)f)(f, args)             (see the lambda call site)
    # NOTE: the env is heap-allocated and not yet freed (a small per-creation leak;
    # freeing it needs closure-local drop tracking — a follow-up). Escaping closures
    # behave as before (their captures' frame is gone), now without a dangling fn.
    pub def gen_closure(self, params: Vec[HirParam], ret_ty: AstType, body: HirBlock, captures: Vec[HirParam]) -> str:
        self.closure_count = self.closure_count + 1
        mut cname = "_closure_" + self.closure_count.to_str()
        mut ename = "_ClosureEnv_" + self.closure_count.to_str()
        mut ret_c = self.type_to_c(ret_ty)
        if ret_c == "void": ret_c = "long long"

        # Seed closure params + captured vars into decl_vars so SAssign emits plain
        # assignment (captures are additionally redirected through the env below).
        mut pi = 0
        while pi < params.len:
            self.decl_vars.insert(params.get(pi).name, true)
            pi = pi + 1
        mut ci = 0
        while ci < captures.len:
            self.decl_vars.insert(captures.get(ci).name, true)
            ci = ci + 1

        # The env is an INLINE anonymous struct (same layout at the def and the
        # creation site, matched through the void* cast) so no typedef ordering
        # matters: { void* __fn; <cty>* p_cap; … }.
        mut estruct = "struct { void* __fn;"
        mut ti = 0
        while ti < captures.len:
            mut cp = captures.get(ti)
            estruct = estruct + " " + self.type_to_c(cp.ty) + "* p_" + _safe_c_varname(cp.name) + ";"
            ti = ti + 1
        estruct = estruct + " }"
        # Parameter type list (after the env pointer) — for the block-scope
        # prototype at the creation site.
        mut ptypes = ""
        mut i2 = 0
        while i2 < params.len:
            ptypes = ptypes + ", " + self.type_to_c(params.get(i2).ty)
            i2 = i2 + 1

        # Emit the static function into a FRESH buffer, then append to closure_buf
        # (flushed ONCE at file end). Inside the body a captured name lowers to
        # (*__env->p_<name>) — see gen_expr EIdent / SAssign.
        mut saved_buf = self.buf
        mut saved_cap = self.closure_cap_set
        mut saved_env = self.closure_env_var
        self.buf = StringBuilder.init(512)
        self.closure_cap_set = Map[str, bool].init(8)
        mut cj = 0
        while cj < captures.len:
            self.closure_cap_set.insert(captures.get(cj).name, true)
            cj = cj + 1
        self.closure_env_var = ename
        # External linkage (unique names): a block-scope prototype at the creation
        # site cannot carry `static`, so the definition must match (extern).
        self.w(ret_c + " " + cname + "(void* __envp")
        mut i: int = 0
        while i < params.len:
            mut p: HirParam = params.get(i)
            self.w(", " + self.type_to_c(p.ty) + " " + _safe_c_varname(p.name))
            i = i + 1
        self.w(") {\n")
        self.w("    " + estruct + "* __env = __envp; (void)__env;\n")
        self.gen_block(body, 1)
        self.w("}\n")
        mut thisdef = self.buf.to_string().as_str()
        self.buf = saved_buf
        self.closure_cap_set = saved_cap
        self.closure_env_var = saved_env
        self.closure_buf.append(thisdef)

        # Capture-address list (shared by heap and stack forms). If we are inside
        # an ENCLOSING closure and a name is one of ITS captures, the value already
        # lives behind that env pointer — reuse it (`__env->p_x`) so transitive
        # captures chain, rather than `&x` (a non-existent local).
        mut addrs = ""
        mut ki = 0
        while ki < captures.len:
            mut kp = captures.get(ki)
            mut sn = _safe_c_varname(kp.name)
            mut addr = "&" + sn
            if self.closure_env_var != "" and self.closure_cap_set.contains(kp.name):
                addr = "__env->p_" + sn
            addrs = addrs + ", " + addr
            ki = ki + 1
        # Stash the pieces so a `let`-bound closure can build a STACK env (no heap,
        # no leak — see the SLet EClosure path). A tagged low bit marks a closure
        # env vs a bare named-function pointer at the call site.
        self.last_clo_cname = cname
        self.last_clo_estruct = estruct
        self.last_clo_ptypes = ptypes
        self.last_clo_ret = ret_c
        self.last_clo_init = "{ (void*)&" + cname + addrs + " }"

        # Heap (malloc) creation — the fallback for closures NOT bound to a local
        # (e.g. passed inline as an argument), where there is no statement to hold a
        # stack env. Field-by-field (the two written-out `struct{…}` are distinct
        # anonymous C types, so a compound-literal assignment would mismatch).
        mut crt = "({ " + ret_c + " " + cname + "(void*" + ptypes + ");"
        crt = crt + " " + estruct + "* __c = malloc(sizeof(" + estruct + ")); __c->__fn = (void*)&" + cname + ";"
        mut kj = 0
        while kj < captures.len:
            mut kp2 = captures.get(kj)
            mut sn2 = _safe_c_varname(kp2.name)
            mut addr2 = "&" + sn2
            if self.closure_env_var != "" and self.closure_cap_set.contains(kp2.name):
                addr2 = "__env->p_" + sn2
            crt = crt + " __c->p_" + sn2 + " = " + addr2 + ";"
            kj = kj + 1
        crt = crt + " (void*)((uintptr_t)__c | (uintptr_t)1); })"
        return crt

    # -- Spawn wrapper pre-scan ------------------------------------------------

    # The C type to cast a spawn wrapper's void* arg to: the WORKER's declared
    # param type (a shared value / x.clone() is typed as its inner T, but the
    # worker's param is Shared[T] -> _TrSharedBox*). Falls back to the arg type.
    pub def _spawn_wrap_cast_ty(self, fn_name: str, arg_expr: Pointer[HirExpr]) -> str:
        if self.functions.contains(fn_name):
            mut _wf = self.functions.get(fn_name)
            if _wf.params.len > 0:
                return self.type_to_c(_wf.params.get(0).ty)
        return self.type_to_c(hir_expr_type(arg_expr))


    pub def emit_spawn_wrapper_for_expr(self, e: Pointer[HirExpr]):
        if _is_invalid_ptr(e as usize): return
        match e.read():
            case HirExpr.ECall(callee, args, ew_ret_ty):
                mut fn_name = ""
                match callee.read():
                    case HirExpr.EIdent(n, _, _): fn_name = n
                    case _: return
                if fn_name == "": return
                if self.spawn_wrappers.contains(fn_name): return
                self.spawn_wrappers.insert(fn_name, true)
                if args.len == 0:
                    self.w("static void* _tr_spawn_wrap_" + fn_name + "(void* _vp) { (void)_vp; " + fn_name + "(); return NULL; }\n")
                elif args.len == 1:
                    mut arg_ty_n = hir_expr_type(args.get(0)).name
                    mut cast_back = "(long long)(uintptr_t)_vp"
                    if not _is_int_type(arg_ty_n) and arg_ty_n != "bool" and arg_ty_n != "char":
                        mut c_arg_ty = self.type_to_c(hir_expr_type(args.get(0)))
                        # Cast to the WORKER's declared param type, not the arg's: a
                        # `shared` var is typed as its inner T, but the worker's param is
                        # Shared[T] -> _TrSharedBox*, so the arg type alone is wrong.
                        if self.functions.contains(fn_name):
                            mut _wf = self.functions.get(fn_name)
                            if _wf.params.len > 0:
                                c_arg_ty = self.type_to_c(_wf.params.get(0).ty)
                        cast_back = "(" + c_arg_ty + ")_vp"
                    self.w("static void* _tr_spawn_wrap_" + fn_name + "(void* _vp) { " + fn_name + "(" + cast_back + "); return NULL; }\n")
                else:
                    # multi-arg: wrapper receives heap long long[N+1] where [0]=return slot, [1..N]=args
                    mut ma_nargs = args.len
                    mut ew_is_void = ew_ret_ty.name == "void" or ew_ret_ty.name == ""
                    self.w("static void* _tr_spawn_wrap_" + fn_name + "(void* _vp) {\n")
                    self.w("    long long* _ab = (long long*)_vp;\n")
                    mut ma_call_s = ""
                    mut ma_ai = 0
                    while ma_ai < ma_nargs:
                        if ma_ai > 0: ma_call_s = ma_call_s + ", "
                        mut ma_atn = hir_expr_type(args.get(ma_ai)).name
                        if not _is_int_type(ma_atn) and ma_atn != "bool" and ma_atn != "char":
                            mut ma_cty = self.type_to_c(hir_expr_type(args.get(ma_ai)))
                            ma_call_s = ma_call_s + "(" + ma_cty + ")_ab[" + str(ma_ai + 1) + "]"
                        else:
                            ma_call_s = ma_call_s + "_ab[" + str(ma_ai + 1) + "]"
                        ma_ai = ma_ai + 1
                    if ew_is_void:
                        self.w("    " + fn_name + "(" + ma_call_s + ");\n")
                    else:
                        self.w("    _ab[0] = (long long)" + fn_name + "(" + ma_call_s + ");\n")
                    self.w("    free(_ab); return NULL;\n")
                    self.w("}\n")
            case _: pass

    pub def prescan_block_spawns(self, block: HirBlock):
        if _is_invalid_ptr(block as usize): return
        if _is_invalid_ptr(block.stmts as usize): return
        if _is_invalid_ptr(block.stmts.data as usize): return
        mut blen = block.stmts.len
        mut i = 0
        while i < blen:
            mut sp = block.stmts.get(i)
            self.prescan_stmt_spawns(sp)
            i = i + 1

    pub def prescan_stmt_spawns(self, s: Pointer[HirStmt]):
        if _is_invalid_ptr(s as usize): return
        match s.read():
            case HirStmt.SSpawn(e):
                self.emit_spawn_wrapper_for_expr(e)
            case HirStmt.STaskGroup(body):
                self.prescan_block_spawns(body)
            case HirStmt.SIf(_, t, e):
                self.prescan_block_spawns(t)
                if not _is_invalid_ptr(e as usize):
                    self.prescan_block_spawns(e)
            case HirStmt.SWhile(_, body):
                self.prescan_block_spawns(body)
            case HirStmt.SFor(_, _, body):
                self.prescan_block_spawns(body)
            case HirStmt.SForUnpack(_, _, body):
                self.prescan_block_spawns(body)
            case HirStmt.STry(tb, catches, fin):
                self.prescan_block_spawns(tb)
                if not _is_invalid_ptr(fin as usize):
                    self.prescan_block_spawns(fin)
                mut ci = 0
                while ci < catches.len:
                    mut cc = catches.get(ci).read()
                    self.prescan_block_spawns(cc.body)
                    ci = ci + 1
            case HirStmt.SExpr(se):
                self.prescan_await_all_in_expr(se)
            case HirStmt.SLet(_, _, _, _, _, _, se_v):
                self.prescan_await_all_in_expr(se_v)
            case HirStmt.SReturn(se_r):
                if not _is_invalid_ptr(se_r as usize):
                    self.prescan_await_all_in_expr(se_r)
            case _:
                pass

    pub def prescan_await_all_in_expr(self, e: Pointer[HirExpr]):
        if _is_invalid_ptr(e as usize): return
        match e.read():
            case HirExpr.ECall(aa_callee, aa_args, _):
                mut aa_fn_n = ""
                match aa_callee.read():
                    case HirExpr.EIdent(nn, _, _): aa_fn_n = nn
                    case HirExpr.EPropAccess(th_obj2, th_var2, _):
                        # Thread.spawn(fn, arg) static call - emit spawn wrapper
                        mut th_ctor2 = ""
                        match th_obj2.read():
                            case HirExpr.EIdent(thn2, _, _): th_ctor2 = thn2
                            case _: pass
                        if th_ctor2 == "Thread" and (th_var2 == "spawn" or th_var2 == "new"):
                            if aa_args.len >= 1:
                                mut th2_fn_nm = ""
                                match aa_args.get(0).read():
                                    case HirExpr.EIdent(tspn2, _, _): th2_fn_nm = tspn2
                                    case _: pass
                                if th2_fn_nm != "" and not self.spawn_wrappers.contains(th2_fn_nm):
                                    self.spawn_wrappers.insert(th2_fn_nm, true)
                                    if aa_args.len == 1:
                                        self.w("static void* _tr_spawn_wrap_" + th2_fn_nm + "(void* _vp) { (void)_vp; " + th2_fn_nm + "(); return NULL; }\n")
                                    else:
                                        mut th2_sp_aty = hir_expr_type(aa_args.get(1)).name
                                        mut th2_sp_cast = "(long long)(uintptr_t)_vp"
                                        if not _is_int_type(th2_sp_aty) and th2_sp_aty != "bool" and th2_sp_aty != "char":
                                            mut th2_sp_cty = self._spawn_wrap_cast_ty(th2_fn_nm, aa_args.get(1))
                                            th2_sp_cast = "(" + th2_sp_cty + ")_vp"
                                        self.w("static void* _tr_spawn_wrap_" + th2_fn_nm + "(void* _vp) { " + th2_fn_nm + "(" + th2_sp_cast + "); return NULL; }\n")
                    case _: pass
                if aa_fn_n == "await_all":
                    mut aa_pi = 0
                    while aa_pi < aa_args.len:
                        self.emit_spawn_wrapper_for_expr(aa_args.get(aa_pi))
                        aa_pi = aa_pi + 1
            case HirExpr.EMethodCall(pool_obj, pool_meth, pool_args, _):
                # Thread.spawn(fn, arg) - emit spawn wrapper
                if pool_meth == "spawn":
                    mut th_ps_nm = ""
                    match pool_obj.read():
                        case HirExpr.EIdent(tpn2, _, _): th_ps_nm = tpn2
                        case _: pass
                    if th_ps_nm == "Thread" and pool_args.len >= 1:
                        mut th_ps_fn = ""
                        match pool_args.get(0).read():
                            case HirExpr.EIdent(tpfn, _, _): th_ps_fn = tpfn
                            case _: pass
                        if th_ps_fn != "" and not self.spawn_wrappers.contains(th_ps_fn):
                            self.spawn_wrappers.insert(th_ps_fn, true)
                            if pool_args.len == 1:
                                self.w("static void* _tr_spawn_wrap_" + th_ps_fn + "(void* _vp) { (void)_vp; " + th_ps_fn + "(); return NULL; }\n")
                            elif pool_args.len == 2:
                                mut th_ps_aty = hir_expr_type(pool_args.get(1)).name
                                mut th_ps_cast = "(long long)(uintptr_t)_vp"
                                if not _is_int_type(th_ps_aty) and th_ps_aty != "bool" and th_ps_aty != "char":
                                    mut th_ps_cty = self._spawn_wrap_cast_ty(th_ps_fn, pool_args.get(1))
                                    th_ps_cast = "(" + th_ps_cty + ")_vp"
                                self.w("static void* _tr_spawn_wrap_" + th_ps_fn + "(void* _vp) { " + th_ps_fn + "(" + th_ps_cast + "); return NULL; }\n")
                            else:
                                # multi-arg: wrapper receives heap long long[N] where [0..N-1] = fn args
                                mut th_ps_nfnargs = pool_args.len - 1
                                self.w("static void* _tr_spawn_wrap_" + th_ps_fn + "(void* _vp) {\n")
                                self.w("    long long* _ab = (long long*)_vp;\n")
                                mut th_ps_cs = ""
                                mut th_ps_ii = 0
                                while th_ps_ii < th_ps_nfnargs:
                                    if th_ps_ii > 0: th_ps_cs = th_ps_cs + ", "
                                    mut th_ps_atn = hir_expr_type(pool_args.get(th_ps_ii + 1)).name
                                    if not _is_int_type(th_ps_atn) and th_ps_atn != "bool" and th_ps_atn != "char":
                                        mut th_ps_cty2 = self.type_to_c(hir_expr_type(pool_args.get(th_ps_ii + 1)))
                                        th_ps_cs = th_ps_cs + "(" + th_ps_cty2 + ")_ab[" + str(th_ps_ii) + "]"
                                    else:
                                        th_ps_cs = th_ps_cs + "_ab[" + str(th_ps_ii) + "]"
                                    th_ps_ii = th_ps_ii + 1
                                self.w("    " + th_ps_fn + "(" + th_ps_cs + ");\n")
                                self.w("    free(_ab); return NULL;\n")
                                self.w("}\n")
                # Emit spawn wrappers for pool.spawn(fn, args...) calls
                if pool_meth == "spawn" and hir_expr_type(pool_obj).name == "ThreadPool":
                    if pool_args.len >= 1:
                        # Build a synthetic ECall with fn as callee and remaining args as args
                        mut sp_fn_nm = ""
                        match pool_args.get(0).read():
                            case HirExpr.EIdent(spn, _, _): sp_fn_nm = spn
                            case _: pass
                        if sp_fn_nm != "":
                            if not self.spawn_wrappers.contains(sp_fn_nm):
                                self.spawn_wrappers.insert(sp_fn_nm, true)
                                if pool_args.len == 1:
                                    self.w("static void* _tr_spawn_wrap_" + sp_fn_nm + "(void* _vp) { (void)_vp; " + sp_fn_nm + "(); return NULL; }\n")
                                elif pool_args.len == 2:
                                    mut sp_aty = hir_expr_type(pool_args.get(1)).name
                                    mut sp_cast = "(long long)(uintptr_t)_vp"
                                    if not _is_int_type(sp_aty) and sp_aty != "bool" and sp_aty != "char":
                                        mut sp_cty = self._spawn_wrap_cast_ty(sp_fn_nm, pool_args.get(1))
                                        sp_cast = "(" + sp_cty + ")_vp"
                                    self.w("static void* _tr_spawn_wrap_" + sp_fn_nm + "(void* _vp) { " + sp_fn_nm + "(" + sp_cast + "); return NULL; }\n")
                                else:
                                    mut sp_na = pool_args.len - 1
                                    mut sp_is_void = true
                                    if self.functions.contains(sp_fn_nm):
                                        mut sp_hf = self.functions.get(sp_fn_nm)
                                        sp_is_void = sp_hf.ret_ty.name == "void" or sp_hf.ret_ty.name == ""
                                    self.w("static void* _tr_spawn_wrap_" + sp_fn_nm + "(void* _vp) {\n")
                                    self.w("    long long* _ab = (long long*)_vp;\n")
                                    mut sp_cs = ""
                                    mut sp_ii = 0
                                    while sp_ii < sp_na:
                                        if sp_ii > 0: sp_cs = sp_cs + ", "
                                        mut sp_atn2 = hir_expr_type(pool_args.get(sp_ii + 1)).name
                                        if not _is_int_type(sp_atn2) and sp_atn2 != "bool" and sp_atn2 != "char":
                                            mut sp_ct2 = self.type_to_c(hir_expr_type(pool_args.get(sp_ii + 1)))
                                            sp_cs = sp_cs + "(" + sp_ct2 + ")_ab[" + str(sp_ii + 1) + "]"
                                        else:
                                            sp_cs = sp_cs + "_ab[" + str(sp_ii + 1) + "]"
                                        sp_ii = sp_ii + 1
                                    if sp_is_void:
                                        self.w("    " + sp_fn_nm + "(" + sp_cs + ");\n")
                                    else:
                                        self.w("    _ab[0] = (long long)" + sp_fn_nm + "(" + sp_cs + ");\n")
                                    self.w("    free(_ab); return NULL;\n")
                                    self.w("}\n")
            case _: pass

    pub def prescan_spawns(self, prog: HirProgram):
        if _is_invalid_ptr(prog as usize): return
        if _is_invalid_ptr(prog.functions as usize): return
        if _is_invalid_ptr(prog.classes as usize): return
        mut i = 0
        while i < prog.functions.len:
            mut f = prog.functions.get(i)
            if not _is_invalid_ptr(f as usize):
                if not self.prescanned_fns.contains(f.name):
                    self.prescanned_fns.insert(f.name, true)
                    mut fb = f.body
                    if not _is_invalid_ptr(fb as usize):
                        self.prescan_block_spawns(fb)
            i = i + 1
        i = 0
        while i < prog.classes.len:
            mut c = prog.classes.get(i)
            if not _is_invalid_ptr(c as usize):
                if not _is_invalid_ptr(c.methods as usize):
                    mut mi = 0
                    while mi < c.methods.len:
                        mut m = c.methods.get(mi)
                        if not _is_invalid_ptr(m as usize):
                            mut mk = c.name + "::" + m.name
                            if not self.prescanned_fns.contains(mk):
                                self.prescanned_fns.insert(mk, true)
                                if not _is_invalid_ptr(m.body as usize):
                                    self.prescan_block_spawns(m.body)
                        mi = mi + 1
            i = i + 1

    # -- Async wrapper prescan -------------------------------------------------

    pub def prescan_expr_awaits(self, e: Pointer[HirExpr]):
        if _is_invalid_ptr(e as usize): return
        match e.read():
            case HirExpr.EAwait(inner, _):
                if not _is_invalid_ptr(inner as usize):
                    match inner.read():
                        case HirExpr.ECall(callee, args, call_ty):
                            mut fn_name = ""
                            match callee.read():
                                case HirExpr.EIdent(n, _, _): fn_name = n
                                case _: pass
                            if fn_name != "":
                                self.emit_async_wrapper_for_call(fn_name, args, call_ty.name)
                        case _: pass
                self.prescan_expr_awaits(inner)
            case HirExpr.EAwaitTimeout(ato_inner, ato_ms, _):
                if not _is_invalid_ptr(ato_inner as usize):
                    match ato_inner.read():
                        case HirExpr.ECall(ato_callee, ato_args, ato_call_ty):
                            mut ato_fn_nm = ""
                            match ato_callee.read():
                                case HirExpr.EIdent(nn, _, _): ato_fn_nm = nn
                                case _: pass
                            if ato_fn_nm != "":
                                self.emit_async_wrapper_for_call(ato_fn_nm, ato_args, ato_call_ty.name)
                        case _: pass
                self.prescan_expr_awaits(ato_ms)
            case HirExpr.ECall(callee, args, _):
                self.prescan_expr_awaits(callee)
                mut ai = 0
                while ai < args.len:
                    self.prescan_expr_awaits(args.get(ai))
                    ai = ai + 1
            case HirExpr.EBinOp(_, l, r, _):
                self.prescan_expr_awaits(l)
                self.prescan_expr_awaits(r)
            case HirExpr.EMethodCall(obj, _, margs, _):
                self.prescan_expr_awaits(obj)
                mut mi = 0
                while mi < margs.len:
                    self.prescan_expr_awaits(margs.get(mi))
                    mi = mi + 1
            case _: pass

    pub def prescan_block_awaits(self, block: HirBlock):
        if _is_invalid_ptr(block as usize): return
        mut i = 0
        while i < block.stmts.len:
            self.prescan_stmt_awaits(block.stmts.get(i))
            i = i + 1

    pub def prescan_stmt_awaits(self, s: Pointer[HirStmt]):
        if _is_invalid_ptr(s as usize): return
        match s.read():
            case HirStmt.SExpr(e): self.prescan_expr_awaits(e)
            case HirStmt.SLet(_, _, _, _, _, _, v): self.prescan_expr_awaits(v)
            case HirStmt.SReturn(v): self.prescan_expr_awaits(v)
            case HirStmt.SIf(cond, t, e):
                self.prescan_expr_awaits(cond)
                self.prescan_block_awaits(t)
                self.prescan_block_awaits(e)
            case HirStmt.SWhile(cond, body):
                self.prescan_expr_awaits(cond)
                self.prescan_block_awaits(body)
            case HirStmt.SFor(_, iter, body):
                self.prescan_expr_awaits(iter)
                self.prescan_block_awaits(body)
            case HirStmt.SForUnpack(_, iter, body):
                self.prescan_expr_awaits(iter)
                self.prescan_block_awaits(body)
            case HirStmt.STry(tb, catches, fin):
                self.prescan_block_awaits(tb)
                self.prescan_block_awaits(fin)
                mut ci = 0
                while ci < catches.len:
                    mut cc = catches.get(ci).read()
                    self.prescan_block_awaits(cc.body)
                    ci = ci + 1
            case HirStmt.STaskGroup(body): self.prescan_block_awaits(body)
            case HirStmt.SMultiLet(_, _, v): self.prescan_expr_awaits(v)
            case HirStmt.SAssign(tgt, v):
                self.prescan_expr_awaits(tgt)
                self.prescan_expr_awaits(v)
            case _: pass

    pub def prescan_awaits(self, prog: HirProgram):
        if _is_invalid_ptr(prog as usize): return
        mut i = 0
        while i < prog.functions.len:
            mut f = prog.functions.get(i)
            if not _is_invalid_ptr(f as usize):
                if not _is_invalid_ptr(f.body as usize):
                    self.prescan_block_awaits(f.body)
            i = i + 1
        i = 0
        while i < prog.classes.len:
            mut c = prog.classes.get(i)
            if not _is_invalid_ptr(c as usize):
                if not _is_invalid_ptr(c.methods as usize):
                    mut mi = 0
                    while mi < c.methods.len:
                        mut m = c.methods.get(mi)
                        if not _is_invalid_ptr(m as usize):
                            if not _is_invalid_ptr(m.body as usize):
                                self.prescan_block_awaits(m.body)
                        mi = mi + 1
            i = i + 1

    # -- Statement generation --------------------------------------------------

    pub def gen_stmt(self, s_ptr: Pointer[HirStmt], indent: int):
        if _is_invalid_ptr(s_ptr as usize): return
        pad = _indent_str(indent)
        match s_ptr.read():
            case HirStmt.SExpr(e):
                # ? propagation at expression-statement level
                if e as usize != 0 as usize:
                    match e.read():
                        case HirExpr.ETryExpr(inner_try, _):
                            mut tmp_qr = "_qr" + self.next_temp()
                            self.w(pad + "Result " + tmp_qr + " = (" + self.gen_expr(inner_try) + ");\n")
                            self.w(pad + "if (" + tmp_qr + ".tag == Result_Err) return " + tmp_qr + ";\n")
                            return
                        case _: pass
                self.w(pad + self.flush_wraps(self.gen_expr(e), true) + ";\n")
            case HirStmt.SDefer(inner_defer):
                # defer: save the C code now, emit it before each return.
                mut saved_buf = self.buf
                self.buf = StringBuilder.init(256)
                self.gen_stmt(inner_defer, indent)
                mut deferred_c = self.buf.to_string().as_str()
                self.buf = saved_buf
                self.defer_stack.push(deferred_c)
            case HirStmt.SReturn(e):
                # Flush deferred statements in LIFO order before returning.
                if self.defer_stack.len > 0:
                    mut di2 = self.defer_stack.len - 1
                    while di2 >= 0:
                        self.w(self.defer_stack.get(di2))
                        if di2 == 0: break
                        di2 = di2 - 1
                if e as usize == 0 as usize:
                    if self.cur_throws_ty != "":
                        self.w(pad + "return ((Result){.tag=Result_Ok});\n")
                    elif self.cur_func == "main":
                        self.w(pad + "return 0;\n")
                    else:
                        self.w(pad + "return;\n")
                else:
                    # ? propagation in return position
                    match e.read():
                        case HirExpr.ETryExpr(inner_try2, ok_ty2):
                            mut tmp_qr2 = "_qr" + self.next_temp()
                            self.w(pad + "Result " + tmp_qr2 + " = (" + self.gen_expr(inner_try2) + ");\n")
                            self.w(pad + "if (" + tmp_qr2 + ".tag == Result_Err) return " + tmp_qr2 + ";\n")
                            if self.cur_throws_ty != "":
                                mut ok_c2 = self.type_to_c(ok_ty2)
                                if _is_int_type(ok_ty2.name) or ok_ty2.name == "bool":
                                    self.w(pad + "return ((Result){.tag=Result_Ok, .data.Ok.val=(void*)(uintptr_t)((" + ok_c2 + ")(uintptr_t)" + tmp_qr2 + ".data.Ok.val)});\n")
                                else:
                                    self.w(pad + "return ((Result){.tag=Result_Ok, .data.Ok.val=" + tmp_qr2 + ".data.Ok.val});\n")
                            else:
                                mut ok_c2b = self.type_to_c(ok_ty2)
                                if _is_int_type(ok_ty2.name) or ok_ty2.name == "bool":
                                    self.w(pad + "return (" + ok_c2b + ")(uintptr_t)" + tmp_qr2 + ".data.Ok.val;\n")
                                else:
                                    self.w(pad + "return (" + ok_c2b + "*)" + tmp_qr2 + ".data.Ok.val;\n")
                            return
                        case _: pass
                    if self.cur_throws_ty != "":
                        # throws function: wrap return value in Result_Ok
                        mut ret_s = self.gen_expr(e)
                        ret_s = self.flush_wraps(ret_s, false)
                        mut ret_ty_n = hir_expr_type(e).name
                        if _is_int_type(ret_ty_n) or ret_ty_n == "bool" or ret_ty_n == "char":
                            self.w(pad + "return ((Result){.tag=Result_Ok, .data.Ok.val=(void*)(uintptr_t)(" + ret_s + ")});\n")
                        elif _is_float_type(ret_ty_n):
                            self.w(pad + "return ((Result){.tag=Result_Ok, .data.Ok.val=_tr_f64_to_ptr((double)(" + ret_s + "))});\n")
                        elif _is_str_type(ret_ty_n):
                            self.w(pad + "return ((Result){.tag=Result_Ok, .data.Ok.val=_tr_str_box(" + ret_s + ")});\n")
                        else:
                            self.w(pad + "return ((Result){.tag=Result_Ok, .data.Ok.val=(void*)(" + ret_s + ")});\n")
                    else:
                        mut ret_s2 = self.gen_expr(e)
                        ret_s2 = self.flush_wraps(ret_s2, false)
                        if self.cur_ret_is_borrow:
                            # `-> ref` function: hand back the borrow as-is. No retain — the
                            # caller treats the result as a borrow and will not free it.
                            self.w(pad + "return " + ret_s2 + ";\n")
                        elif self._expr_is_borrow_call(e):
                            # Owned-return function returning a `-> ref` call result: the
                            # callee did NOT retain, so OWN it here (retain) before handing
                            # it back as an owned value the caller will free.
                            if self.is_heap_class_tn(hir_expr_type(e).name):
                                self.w(pad + "return _tr_obj_retain(" + ret_s2 + ");\n")
                            elif _is_str_type(hir_expr_type(e).name):
                                self.w(pad + "return _tr_str_retain(" + ret_s2 + ");\n")
                            else:
                                self.w(pad + "return " + ret_s2 + ";\n")
                        else:
                            # str + heap-class owned returns: retain a borrowed/aliased
                            # result (self, a field) so the caller owns a counted ref;
                            # a returned local transfers (no retain — excluded from drops).
                            self.w(pad + "return " + self.obj_retain_wrap(e, self.str_retain_wrap(e, ret_s2, true), true) + ";\n")
            case HirStmt.SLet(n, _, _, is_const, is_shared, ty, v):
                mut c_ty = self.type_to_c(ty)
                # If SLet.ty is Vec/List without generic args, recover c_ty from the init expression
                if c_ty == "List_ptr*" and v as usize != 0 as usize:
                    mut _init_sfx = "ptr"
                    match v.read():
                        case HirExpr.ECall(_, _, call_ty):
                            if (call_ty.name == "Vec" or call_ty.name == "List") and call_ty.args.len > 0:
                                _init_sfx = self.list_elem_suffix(call_ty.args.get(0).read().name)
                        case HirExpr.EMethodCall(hobj_mc, _m, iargs, call_ty):
                            if (call_ty.name == "Vec" or call_ty.name == "List") and call_ty.args.len > 0:
                                _init_sfx = self.list_elem_suffix(call_ty.args.get(0).read().name)
                            # gen_call already handles Vec[T].init(): reuse the expr's inferred elem sfx
                            elif hobj_mc as usize != 0 as usize and (_m == "init" or _m == "new"):
                                mut hobj_ty_mc = hir_expr_type(hobj_mc)
                                if (hobj_ty_mc.name == "Vec" or hobj_ty_mc.name == "List") and hobj_ty_mc.args.len > 0:
                                    _init_sfx = self.list_elem_suffix(hobj_ty_mc.args.get(0).read().name)
                                elif iargs.len > 0:
                                    # Fallback: infer from first arg to init (capacity hint, same type as elems)
                                    pass
                        case _: pass
                    if _init_sfx != "ptr":
                        c_ty = "List_" + self.list_sfx(_init_sfx) + "*"
                if c_ty == "void" and v as usize != 0 as usize: c_ty = "__auto_type"
                # Track the List_<sfx>* suffix for this local so SAutoDrop can
                # call the matching List_<sfx>_free (only List/Vec need a
                # suffix; Dict/Map/Set are uniformly TrMap*/_TrSet*, freed via
                # Dict_free regardless of element type).
                if (ty.name == "List" or ty.name == "Vec") and c_ty.starts_with("List_") and c_ty.ends_with("*"):
                    mut _lsfx = c_ty.slice(5, c_ty.len() - 1)
                    # A heap-class-element list is List_ptr; encode the element class
                    # ("ptr@Tag") so SAutoDrop frees via List_ptr_free_obj(l, _trdrop_Tag),
                    # releasing each owned element. Raw pointer-aliased element types stay
                    # plain "ptr" (container-only free — is_heap_class_tn excludes them).
                    if _lsfx == "ptr" and ty.args.len > 0:
                        mut _elt = ty.args.get(0).read().name
                        if self.is_heap_class_tn(_elt): _lsfx = "ptr@" + _elt
                    self.coll_local_sfx.insert(n, _lsfx)
                elif (ty.name == "Dict" or ty.name == "Map" or ty.name == "Set") and (c_ty == "TrIDict*" or c_ty == "_TrISet*"):
                    self.coll_local_idict.insert(n, true)
                elif (ty.name == "Dict" or ty.name == "Map" or ty.name == "Set") and (c_ty.starts_with("Dict_") or c_ty.starts_with("Set_")) and c_ty.ends_with("*"):
                    # Typed inline value-type collection (Dict_str_Point* / Set_Point*):
                    # auto-drop frees via the typed <struct>_free.
                    self.coll_local_vtcoll.insert(n, c_ty.slice(0, c_ty.len() - 1))
                # Str-valued Dict/Map local: track for strval free/auto-drop.
                # Use the declared type's args, but fall back to the init value's
                # type args when the local is inferred (`mut m = Map[str,str].init`)
                # and lost its args on the declared type.
                if (ty.name == "Dict" or ty.name == "Map") and ty.args.len > 1 and _is_str_type(ty.args.get(1).read().name):
                    self.coll_local_strval.insert(n, true)
                # Heap-class-VALUE Dict/Map: the dict co-owns each value (insert-retain),
                # so its drop must release them. Encode "d@<i|s>@<ValueClass>" in
                # coll_local_sfx (read only by SAutoDrop) → Dict_free_objval / _tr_idict_free_objval.
                if (ty.name == "Dict" or ty.name == "Map") and ty.args.len > 1 and self.is_heap_class_tn(ty.args.get(1).read().name):
                    mut _dvc = ty.args.get(1).read().name
                    if self.coll_local_idict.contains(n):
                        self.coll_local_sfx.insert(n, "d@i@" + _dvc)
                    else:
                        self.coll_local_sfx.insert(n, "d@s@" + _dvc)
                # Heap-class Set (_TrPtrSet): free via _tr_pset_free_obj releasing each element.
                if ty.name == "Set" and c_ty == "_TrPtrSet*" and ty.args.len > 0 and self.is_heap_class_tn(ty.args.get(0).read().name):
                    self.coll_local_sfx.insert(n, "s@" + ty.args.get(0).read().name)
                # ? propagation in let binding
                if v as usize != 0 as usize:
                    match v.read():
                        case HirExpr.ETryExpr(inner_try3, ok_ty3):
                            mut tmp_qr3 = "_qr" + self.next_temp()
                            self.w(pad + "Result " + tmp_qr3 + " = (" + self.gen_expr(inner_try3) + ");\n")
                            self.w(pad + "if (" + tmp_qr3 + ".tag == Result_Err) return " + tmp_qr3 + ";\n")
                            mut ok_c3 = self.type_to_c(ok_ty3)
                            if ok_c3 == "void" or ok_c3 == "__auto_type": ok_c3 = "long long"
                            mut ok_val3 = ""
                            if _is_int_type(ok_ty3.name) or ok_ty3.name == "bool" or ok_ty3.name == "char":
                                ok_val3 = "(" + ok_c3 + ")(uintptr_t)" + tmp_qr3 + ".data.Ok.val"
                            else:
                                ok_val3 = "(" + ok_c3 + "*)" + tmp_qr3 + ".data.Ok.val"
                            if is_const:
                                self.w(pad + "const " + ok_c3 + " " + _safe_c_varname(n) + " = " + ok_val3 + ";\n")
                            else:
                                self.w(pad + ok_c3 + " " + _safe_c_varname(n) + " = " + ok_val3 + ";\n")
                            self.decl_vars.insert(n, true)
                            return
                        case _: pass
                # EClosure in SLet: gen_closure outlines the body to closure_buf and
                # stashes the env pieces. Bind it with a STACK env (a plain local
                # struct in this function) instead of a heap one — zero-cost and
                # never leaks (reclaimed with the frame). Escape semantics are the
                # same as before: a closure that outlives this frame dangles (its
                # captures' frame is gone), exactly like the old GCC nested fns.
                if v as usize != 0 as usize:
                    match v.read():
                        case HirExpr.EClosure(cl_params, cl_ret_ty, cl_body, _, cl_caps):
                            mut _cdrop = self.gen_closure(cl_params, cl_ret_ty, cl_body, cl_caps)
                            mut _cenv = "__clenv_" + self.last_clo_cname
                            # block-scope prototype so &fn resolves; stack env; tag.
                            self.w(pad + self.last_clo_ret + " " + self.last_clo_cname + "(void*" + self.last_clo_ptypes + ");\n")
                            self.w(pad + self.last_clo_estruct + " " + _cenv + " = " + self.last_clo_init + ";\n")
                            self.w(pad + "void* " + _safe_c_varname(n) + " = (void*)((uintptr_t)&" + _cenv + " | (uintptr_t)1);\n")
                            self.decl_vars.insert(n, true)
                            return
                        case _: pass
                mut _sn = _safe_c_varname(n)
                if is_const:
                    self.w(pad + "const " + c_ty + " " + _sn)
                elif is_shared:
                    self.w(pad + "_TrSharedBox* " + _sn)
                else:
                    # Auto-unlock RAII guard: emit __attribute__((cleanup)) guard before Mutex.get() / RwLock.read() / write()
                    if v as usize != 0 as usize:
                        match v.read():
                            case HirExpr.EMethodCall(au_obj, au_method, _, _):
                                if not _is_invalid_ptr(au_obj as usize):
                                    mut au_oty = hir_expr_type(au_obj)
                                    if au_oty.name == "Mutex" and (au_method == "get" or au_method == "lock"):
                                        self.w(pad + "__attribute__((cleanup(_tr_mutexbox_cleanup))) _TrMutexBox* __g_" + _sn + " = " + self.gen_expr(au_obj) + ";\n")
                                    elif au_oty.name == "RwLock" and (au_method == "read" or au_method == "read_lock"):
                                        self.w(pad + "__attribute__((cleanup(_tr_rwlbox_cleanup_r))) _TrRWLBox* __g_" + _sn + " = " + self.gen_expr(au_obj) + ";\n")
                                    elif au_oty.name == "RwLock" and (au_method == "write" or au_method == "write_lock"):
                                        self.w(pad + "__attribute__((cleanup(_tr_rwlbox_cleanup_w))) _TrRWLBox* __g_" + _sn + " = " + self.gen_expr(au_obj) + ";\n")
                            case _: pass
                    self.w(pad + c_ty + " " + _sn)
                if v as usize != 0 as usize:
                    if is_shared:
                        # Register var in shared_vars with the raw Tauraro type name
                        mut sh_type_name = ty.name
                        if sh_type_name == "void" or sh_type_name == "None":
                            sh_type_name = hir_expr_type(v).name
                        # Detect clone vs new-wrap: if value is an already-shared var, clone it
                        mut is_clone = false
                        match v.read():
                            case HirExpr.EIdent(vn, _, _):
                                if self.shared_vars.contains(vn):
                                    self.w(" = _tr_shared_clone(" + vn + ");\n")
                                    is_clone = true
                            case _: pass
                        if not is_clone:
                            # Pass the payload's drop fn so _tr_shared_drop reclaims a
                            # plain-ARC payload's owned fields (not just the struct).
                            mut _sh_drop = "NULL"
                            if self.is_heap_class_tn(sh_type_name): _sh_drop = self.obj_drop_fn(sh_type_name)
                            # A FRESH construction (`shared s = T.init(..)`) transfers its rc=1
                            # into the box. An EXISTING reference (`shared s = plain`/`= self` —
                            # a var or field) is still owned by its source (which auto-drops or
                            # is a live receiver), so the box must RETAIN it to co-own —
                            # otherwise both free it (double-free).
                            mut _sh_val = self.gen_expr(v)
                            mut _sh_ref = false
                            match v.read():
                                case HirExpr.EIdent(_, _, _): _sh_ref = true
                                case HirExpr.EPropAccess(_, _, _): _sh_ref = true
                                case _: pass
                            if self.is_heap_class_tn(sh_type_name) and _sh_ref:
                                _sh_val = "_tr_obj_retain(" + _sh_val + ")"
                            self.w(" = _tr_shared_new(" + _sh_val + ", " + _sh_drop + ");\n")
                        self.shared_vars.insert(n, sh_type_name)
                    else:
                        # For empty list literals, propagate annotation type so suffix is correct
                        mut init_s = ""
                        # Auto-wrap class instance into interface object
                        if self.interfaces.contains(ty.name):
                            mut _slet_iface = self.interfaces.get(ty.name)
                            mut _slet_iface_name = ty.name
                            if _slet_iface.generics.len > 0 and ty.args.len > 0:
                                _slet_iface_name = ty.name + "_" + self.type_args_suffix(ty.args)
                            mut _slet_val_ty = hir_expr_type(v)
                            mut val_ty_n = _slet_val_ty.name
                            if self.classes.contains(val_ty_n):
                                mut _slet_cls = self.classes.get(val_ty_n)
                                if _slet_cls.generics.len > 0 and _slet_val_ty.args.len > 0:
                                    val_ty_n = val_ty_n + "_" + self.type_args_suffix(_slet_val_ty.args)
                                init_s = val_ty_n + "_as_" + _slet_iface_name + "(" + self.gen_expr(v) + ")"
                        # Zero-copy collection-element borrow: when this binding is an
                        # outlives-PROVEN borrow whose RHS is `coll.get(k)` / `coll[i]`,
                        # generate the str-valued get/index as a pure alias (no retain);
                        # the proven branch below then also skips the release.
                        mut _saved_elide = self.eliding_get_retain
                        self.eliding_get_retain = false
                        if c_ty == "TrStr" and self.cur_proven_borrows.contains(n):
                            match v.read():
                                case HirExpr.EMethodCall(_, _gm, _, _):
                                    if _gm == "get" or _gm == "get_or" or _gm == "get_index": self.eliding_get_retain = true
                                case HirExpr.EIndex(_, _, _): self.eliding_get_retain = true
                                case _: pass
                        if init_s == "":
                            match v.read():
                                case HirExpr.EList(items, list_ty):
                                    # Avoid variable reassignment - ownership model would free list_ty early
                                    if list_ty.args.len == 0 and ty.name == "List" and ty.args.len > 0:
                                        init_s = self.gen_list_literal(items, ty)
                                    else:
                                        init_s = self.gen_list_literal(items, list_ty)
                                case HirExpr.EDict(d_keys, d_vals, d_ty):
                                    # Propagate annotation type for empty dicts (sema stores plain "Dict" with no args)
                                    if (d_ty.args.len == 0 or d_ty.name == "Dict") and (ty.name == "Dict" or ty.name == "Map") and ty.args.len > 0:
                                        init_s = self.gen_dict_literal(d_keys, d_vals, ty)
                                    else:
                                        init_s = self.gen_dict_literal(d_keys, d_vals, d_ty)
                                case _:
                                    init_s = self.gen_expr(v)
                        self.eliding_get_retain = _saved_elide
                        # Dict.get/get_or returning a generic void* into a str-typed
                        # local: gen_method_call only unboxes when call_ty is resolved
                        # to "str"; recover here from the declared SLet type instead.
                        if c_ty == "TrStr":
                            match v.read():
                                case HirExpr.EMethodCall(slv_obj, slv_method, _, slv_call_ty):
                                    if (slv_method == "get" or slv_method == "get_or") and not _is_str_type(slv_call_ty.name):
                                        mut slv_oty = hir_expr_type(slv_obj).name
                                        if slv_oty == "Map" or slv_oty == "Dict":
                                            init_s = "_tr_str_unbox(" + init_s + ")"
                                case _: pass
                        if c_ty == "TrStr":
                            if self.cur_proven_borrows.contains(n):
                                # Outlives-proven `ref` borrow: a pure alias of a value
                                # that provably outlives it → NO retain at the binding and
                                # NO release at scope (not tracked in str_local_names).
                                # Zero-copy borrow.
                                pass
                            else:
                                init_s = self.str_retain_wrap(v, init_s, false)
                                # NOT-proven borrow from a `-> ref` call: the callee did not
                                # retain and the source may not outlive this local, so OWN it
                                # (retain) — this is the safe ARC fallback (balanced by the
                                # release below since the local is registered).
                                if self._expr_is_borrow_call(v):
                                    init_s = "_tr_str_retain(" + init_s + ")"
                                match v.read():
                                    case HirExpr.EPropAccess(_, _, _): pass
                                    case _: self.str_local_names.insert(n, true)
                        elif self.is_heap_class_tn(hir_expr_type(v).name):
                            # Refcounted heap class. A proven borrow is a zero-cost
                            # alias (no retain/release, not tracked). Otherwise this
                            # local OWNS a reference: retain aliases (a fresh ctor /
                            # owned `-> T` result is already rc=1), own `-> ref`
                            # results, and register for release at scope exit.
                            if self.cur_proven_borrows.contains(n):
                                pass
                            else:
                                init_s = self.obj_retain_wrap(v, init_s, false)
                                mut _owns = self._obj_expr_owns_ref(v)
                                if self._expr_is_borrow_call(v):
                                    init_s = "_tr_obj_retain(" + init_s + ")"
                                    _owns = true
                                if _owns:
                                    self.class_local_names.insert(n, true)
                        init_s = self.flush_wraps(init_s, false)
                        self.w(" = " + init_s + ";\n")
                else:
                    if is_shared:
                        self.w(" = NULL;\n")
                        self.shared_vars.insert(n, ty.name)
                    elif c_ty == "Result" or c_ty == "Option":
                        self.w(" = (" + c_ty + "){0};\n")
                    elif ty.name == "Array" and ty.array_size > 0:
                        self.w(" = {0};\n")   # fixed-size array: zero-init the aggregate
                    else:
                        self.w(" = 0;\n")
                self.decl_vars.insert(n, true)
            case HirStmt.SAssign(t, v):
                match t.read():
                    case HirExpr.EIdent(n, _, _):
                        # A bare name's first assignment declares a local, EXCEPT
                        # when it names a file-scope global (then it's a plain
                        # assignment to that global, handled by the fall-through).
                        if not self.decl_vars.contains(n) and not self.global_vars.contains(n):
                            mut _sa_rhs = self.gen_expr(v)
                            _sa_rhs = self.flush_wraps(_sa_rhs, false)
                            if hir_expr_type(t).name == "str":
                                if self.cur_proven_borrows.contains(n):
                                    # proven borrow: pure alias, no retain/release
                                    self.w(pad + "TrStr " + _safe_c_varname(n) + " = " + _sa_rhs + ";\n")
                                else:
                                    _sa_rhs = self.str_retain_wrap(v, _sa_rhs, false)
                                    if self._expr_is_borrow_call(v):
                                        _sa_rhs = "_tr_str_retain(" + _sa_rhs + ")"   # own not-proven borrow
                                    self.w(pad + "TrStr " + _safe_c_varname(n) + " = " + _sa_rhs + ";\n")
                                    match v.read():
                                        case HirExpr.EPropAccess(_, _, _): pass
                                        case _: self.str_local_names.insert(n, true)
                            elif self.is_heap_class_tn(hir_expr_type(v).name):
                                # First assignment declares a heap-class local — same
                                # retain/track as SLet (explicit T* since _tr_obj_retain
                                # yields void*). Proven borrow → zero-cost alias.
                                mut _sa_cty = self.type_to_c(hir_expr_type(v))
                                if self.cur_proven_borrows.contains(n):
                                    self.w(pad + _sa_cty + " " + _safe_c_varname(n) + " = " + _sa_rhs + ";\n")
                                else:
                                    _sa_rhs = self.obj_retain_wrap(v, _sa_rhs, false)
                                    mut _sa_owns = self._obj_expr_owns_ref(v)
                                    if self._expr_is_borrow_call(v):
                                        _sa_rhs = "_tr_obj_retain(" + _sa_rhs + ")"
                                        _sa_owns = true
                                    self.w(pad + _sa_cty + " " + _safe_c_varname(n) + " = " + _sa_rhs + ";\n")
                                    if _sa_owns:
                                        self.class_local_names.insert(n, true)
                            else:
                                self.w(pad + "__auto_type " + _safe_c_varname(n) + " = " + _sa_rhs + ";\n")
                            self.decl_vars.insert(n, true)
                            return
                    case HirExpr.EIndex(idx_obj, idx_key, _):
                        mut idx_ty_n: str = hir_expr_type(idx_obj).name
                        if self.has_method(idx_ty_n, "__setitem__"):
                            mut _si_obj = self.gen_expr(idx_obj)
                            mut _si_key = self.gen_expr(idx_key)
                            mut _si_val = self.gen_expr(v)
                            mut _si_call = self.cls_method_c_call(idx_ty_n, "__setitem__", _si_obj, _si_key + ", " + _si_val)
                            self.w(pad + self.flush_wraps(_si_call, true) + ";\n")
                            return
                        # list[i] = str_value into a legacy List_str (char* elements):
                        # assign the raw char* lvalue, not the _tr_str_lit-wrapped rvalue.
                        if idx_ty_n == "List" or idx_ty_n == "Vec":
                            mut idx_full_ty = hir_expr_type(idx_obj)
                            if idx_full_ty.args.len > 0 and _is_str_type(idx_full_ty.args.get(0).read().name):
                                mut _li_obj = self.gen_expr(idx_obj)
                                mut _li_key = self.gen_expr(idx_key)
                                mut _li_lvalue = _li_obj + "->data[(_tr_bounds_check(" + _li_key + ", " + _li_obj + "->len), " + _li_key + ")]"
                                mut _li_stmt = _li_lvalue + " = " + self.strz(self.gen_expr(v))
                                self.w(pad + self.flush_wraps(_li_stmt, true) + ";\n")
                                return
                    case HirExpr.EMethodCall(mc_obj, mc_meth, mc_args, _):
                        # sema lowers bag[i] = v -> SAssign(EMethodCall(bag, "get_index", [i]), v)
                        if mc_meth == "get_index" and mc_args.len > 0:
                            mut mc_ty_n: str = hir_expr_type(mc_obj).name
                            if self.has_method(mc_ty_n, "__setitem__"):
                                mut _si2_obj = self.gen_expr(mc_obj)
                                mut _si2_key = self.gen_args(mc_args)
                                mut _si2_val = self.gen_expr(v)
                                mut _si2_call = self.cls_method_c_call(mc_ty_n, "__setitem__", _si2_obj, _si2_key + ", " + _si2_val)
                                self.w(pad + self.flush_wraps(_si2_call, true) + ";\n")
                                return
                            # Dict/Map index-assign d[key] = v -> dict set.
                            if mc_ty_n == "Map" or mc_ty_n == "Dict":
                                mut _di_obj = self.gen_expr(mc_obj)
                                mut _di_key_full = hir_expr_type(mc_obj)
                                mut _di_int_key = false
                                if _di_key_full.args.len > 0:
                                    mut _dik = _di_key_full.args.get(0).read()
                                    if _is_int_type(_dik.name) or _dik.name == "int" or _dik.name == "i64" or _dik.name == "i32" or _dik.name == "usize":
                                        _di_int_key = true
                                mut _di_set = ""
                                if _di_int_key:
                                    _di_set = "_tr_idict_set(" + _di_obj + ", " + self.gen_expr(mc_args.get(0)) + ", " + self.dict_val_arg(v) + ")"
                                else:
                                    _di_set = "_tr_dict_set(" + _di_obj + ", " + self.dict_key_arg(mc_args.get(0)) + ", " + self.dict_val_arg(v) + ")"
                                self.w(pad + self.flush_wraps(_di_set, true) + ";\n")
                                return
                            # Fixed-size array index-assign a[i] = v -> a.data[i] = v (bounds-checked lvalue).
                            if mc_ty_n == "Array":
                                mut _ai_obj = self.gen_expr(mc_obj)
                                mut _ai_ty = hir_expr_type(mc_obj)
                                mut _ai_key = self.gen_expr(mc_args.get(0))
                                mut _ai_lval = _ai_obj + ".data[(_tr_bounds_check(" + _ai_key + ", " + _ai_ty.array_size.to_str() + "), " + _ai_key + ")]"
                                self.w(pad + self.flush_wraps(_ai_lval + " = " + self.gen_expr(v), true) + ";\n")
                                return
                    case _: pass
                mut _assign_rhs = ""
                match v.read():
                    case HirExpr.EList(litems, list_ty):
                        if list_ty.args.len == 0:
                            mut tgt_ty = hir_expr_type(t)
                            if (tgt_ty.name == "List" or tgt_ty.name == "Vec") and tgt_ty.args.len > 0:
                                _assign_rhs = self.gen_list_literal(litems, tgt_ty)
                    case _: pass
                if _assign_rhs == "": _assign_rhs = self.gen_expr(v)
                _assign_rhs = self.flush_wraps(_assign_rhs, false)
                if hir_expr_type(t).name == "str":
                    match t.read():
                        case HirExpr.EIdent(_an, _, _):
                            if self.str_local_names.contains(_an):
                                mut _strtmp = "_strtmp" + self.next_temp()
                                mut _wrapped_rhs = self.str_retain_wrap(v, _assign_rhs, false)
                                if self._expr_is_borrow_call(v):
                                    _wrapped_rhs = "_tr_str_retain(" + _wrapped_rhs + ")"   # own not-proven borrow before storing
                                self.w(pad + "TrStr " + _strtmp + " = " + _wrapped_rhs + ";\n")
                                self.w(pad + "_tr_str_release(" + _safe_c_varname(_an) + ");\n")
                                self.w(pad + _safe_c_varname(_an) + " = " + _strtmp + ";\n")
                                return
                        case HirExpr.EPropAccess(_, _, _):
                            # A `ref str` (borrow) field does NOT own its value — the drop
                            # side skips releasing borrow fields (is_borrow check precedes
                            # the str-release), so the store must NOT retain either (else it
                            # leaks). Only OWNING str fields retain.
                            if not self._store_target_is_borrow_field(t):
                                _assign_rhs = self.str_retain_wrap(v, _assign_rhs, false)
                                if self._expr_is_borrow_call(v):
                                    _assign_rhs = "_tr_str_retain(" + _assign_rhs + ")"   # field must OWN: retain borrow
                        case _: pass
                elif self.is_heap_class_tn(hir_expr_type(t).name) and not self.has_method(hir_expr_type(t).name, "free"):
                    # `ref T` (borrow) field store: no co-ownership — plain store, no
                    # retain, no release-old (symmetric with the drop side, which skips
                    # borrow fields). This is the zero-cost borrowed-view case.
                    if self._store_target_is_borrow_field(t):
                        self.w(pad + self.gen_expr(t) + " = " + _assign_rhs + ";\n")
                        return
                    # Refcounted heap-class store (reassign a local, or a field). Retain
                    # the new value (the target now holds a reference) into a temp, then
                    # release the OLD value before overwriting — this avoids a double-free
                    # on `x = y` and reclaims a replaced field. (release() is a no-op on
                    # a NULL/0 old value, so first-time field init is safe.)
                    mut _ctn = hir_expr_type(t).name
                    mut _cdrop = self.obj_drop_fn(_ctn)
                    mut _cty2 = self.type_to_c(hir_expr_type(t))
                    mut _crhs = self.obj_retain_wrap(v, _assign_rhs, false)
                    if self._expr_is_borrow_call(v): _crhs = "_tr_obj_retain(" + _crhs + ")"
                    match t.read():
                        case HirExpr.EIdent(_can, _, _):
                            if self.class_local_names.contains(_can):
                                mut _cltmp = "_cltmp" + self.next_temp()
                                self.w(pad + _cty2 + " " + _cltmp + " = " + _crhs + ";\n")
                                self.w(pad + "_tr_obj_release(" + _safe_c_varname(_can) + ", " + _cdrop + ");\n")
                                self.w(pad + _safe_c_varname(_can) + " = " + _cltmp + ";\n")
                                return
                        case HirExpr.EPropAccess(_, _, _):
                            # The field co-owns its value (released in _trdrop_T), so a
                            # borrow-alias RHS must be retained here (fresh/owned rvalues
                            # already transfer their rc=1).
                            mut _fld_rhs = _crhs
                            if (not self._expr_is_borrow_call(v)) and self._obj_store_needs_retain(v):
                                _fld_rhs = "_tr_obj_retain(" + _fld_rhs + ")"
                            mut _cltmp2 = "_cltmp" + self.next_temp()
                            mut _cfld = self.gen_expr(t)
                            self.w(pad + _cty2 + " " + _cltmp2 + " = " + _fld_rhs + ";\n")
                            self.w(pad + "_tr_obj_release(" + _cfld + ", " + _cdrop + ");\n")
                            self.w(pad + _cfld + " = " + _cltmp2 + ";\n")
                            return
                        case _: pass
                    _assign_rhs = _crhs
                self.w(pad + self.gen_expr(t) + " = " + _assign_rhs + ";\n")
            case HirStmt.SIf(c, t, e):
                self.w(pad + "if (" + self.gen_cond_expr(c) + ") {\n")
                self.gen_block(t, indent + 1)
                mut cur = e
                mut going = not _is_invalid_ptr(cur as usize)
                while going:
                    if _is_invalid_ptr(cur.stmts as usize):
                        going = false
                    elif cur.stmts.len == 1:
                        match cur.stmts.get(0).read():
                            case HirStmt.SIf(ic, it, ie):
                                self.w(pad + "} else if (" + self.gen_cond_expr(ic) + ") {\n")
                                self.gen_block(it, indent + 1)
                                cur = ie
                                going = not _is_invalid_ptr(cur as usize)
                            case _:
                                self.w(pad + "} else {\n")
                                self.gen_block(cur, indent + 1)
                                going = false
                    elif cur.stmts.len > 0:
                        self.w(pad + "} else {\n")
                        self.gen_block(cur, indent + 1)
                        going = false
                    else:
                        going = false
                self.w(pad + "}\n")
            case HirStmt.SWhile(c, b):
                # Statement loop: a valued `break` inside has no result target.
                self.loop_res_stack.push("")
                self.loop_done_stack.push("")
                self.w(pad + "while (" + self.gen_cond_expr(c) + ") {\n")
                self.gen_block(b, indent + 1)
                self.w(pad + "}\n")
                self.loop_res_stack.len = self.loop_res_stack.len - 1
                self.loop_done_stack.len = self.loop_done_stack.len - 1
            case HirStmt.SFor(var, iter, body):
                if self.in_gpu_block > 0:
                    self.w(pad + "#pragma omp for\n")
                self.loop_res_stack.push("")
                self.loop_done_stack.push("")
                self.gen_for_loop(var, iter, body, indent)
                self.loop_res_stack.len = self.loop_res_stack.len - 1
                self.loop_done_stack.len = self.loop_done_stack.len - 1
            case HirStmt.SForUnpack(vars, iter, body):
                self.loop_res_stack.push("")
                self.loop_done_stack.push("")
                self.gen_for_unpack(vars, iter, body, indent)
                self.loop_res_stack.len = self.loop_res_stack.len - 1
                self.loop_done_stack.len = self.loop_done_stack.len - 1
            case HirStmt.SMatch(e, arms):
                self.gen_match(e, arms, indent)
            case HirStmt.STry(try_body, catches, finally_b):
                self.gen_try(try_body, catches, finally_b, indent)
            case HirStmt.SRaise(e):
                if self.cur_throws_ty != "":
                    # throws function: raise becomes return Result_Err
                    self.w(pad + "return ((Result){.tag=Result_Err, .data.Err.err=" + self.wrap_voidp_arg(e) + "});\n")
                else:
                    mut raise_s = self.gen_expr(e)
                    if _is_str_type(hir_expr_type(e).name): raise_s = self.strz(raise_s)
                    else: raise_s = "(char*)(" + raise_s + ")"
                    self.w(pad + self.flush_wraps("_tr_exc_raise(" + raise_s + ")", true) + ";\n")
            case HirStmt.SAssert(cond, msg):
                if msg as usize == 0 as usize:
                    mut _as_cond = self.gen_expr(cond)
                    self.w(pad + self.flush_wraps("_TR_ASSERT(" + _as_cond + ")", true) + ";\n")
                else:
                    mut _as_cond2 = self.gen_expr(cond)
                    mut _as_msg = self.gen_expr(msg)
                    self.w(pad + self.flush_wraps("_TR_ASSERT_MSG(" + _as_cond2 + ", " + _as_msg + ")", true) + ";\n")
            case HirStmt.SUnsafe(b):
                self.w(pad + "/* unsafe block */\n")
                self.gen_block(b, indent)
            case HirStmt.SWith(items, aliases, body):
                mut with_base = self.next_temp()
                mut wi = 0
                while wi < items.len:
                    mut with_item = items.get(wi)
                    # Parser emits `with expr as alias:` as ECast(expr, alias_type) when the
                    # `as` is treated as a type cast rather than a binding alias. Unwrap it.
                    mut actual_wi: Pointer[HirExpr] = with_item
                    mut cast_alias: str = ""
                    match with_item.read():
                        case HirExpr.ECast(wi_inner, wi_cast_ty):
                            actual_wi = wi_inner
                            cast_alias = wi_cast_ty.name
                        case _: pass
                    mut item_s = self.gen_expr(actual_wi)
                    mut item_ty_n: str = hir_expr_type(actual_wi).name
                    # Resolve alias: prefer the SWith alias list, fall back to cast_alias
                    mut alias_n: str = ""
                    if wi < aliases.len and aliases.get(wi) != "":
                        alias_n = aliases.get(wi)
                    elif cast_alias != "":
                        alias_n = cast_alias
                    mut ctx_name = with_base + "_ctx" + wi.to_str()
                    if self.has_method(item_ty_n, "__enter__"):
                        self.w(pad + "__auto_type " + ctx_name + " = " + item_s + ";\n")
                        mut enter_val = self.cls_method_c_call(item_ty_n, "__enter__", ctx_name, "")
                        if alias_n != "":
                            self.w(pad + "__auto_type " + alias_n + " = " + enter_val + ";\n")
                        else:
                            self.w(pad + enter_val + ";\n")
                    else:
                        if alias_n != "":
                            self.w(pad + "__auto_type " + alias_n + " = " + item_s + ";\n")
                        else:
                            self.w(pad + item_s + ";\n")
                    wi = wi + 1
                self.gen_block(body, indent)
                mut rei = items.len - 1
                while rei >= 0:
                    mut with_item_exit = items.get(rei)
                    # Unwrap ECast alias pattern for exit type detection
                    mut exit_actual: Pointer[HirExpr] = with_item_exit
                    match with_item_exit.read():
                        case HirExpr.ECast(we_inner, _):
                            exit_actual = we_inner
                        case _: pass
                    mut exit_ty_n: str = hir_expr_type(exit_actual).name
                    if self.has_method(exit_ty_n, "__exit__"):
                        mut ctx_exit = with_base + "_ctx" + rei.to_str()
                        self.w(pad + self.cls_method_c_call(exit_ty_n, "__exit__", ctx_exit, "_tr_str_lit(\"\"), _tr_str_lit(\"\"), _tr_str_lit(\"\")") + ";\n")
                    rei = rei - 1
            case HirStmt.SAsm(code, outputs, inputs, clobbers):
                mut asm_s = pad + "__asm__ volatile(\"" + _escape_str_for_c(code) + "\""
                if outputs != "" or inputs != "" or clobbers != "":
                    asm_s = asm_s + " : " + outputs
                    if inputs != "" or clobbers != "":
                        asm_s = asm_s + " : " + inputs
                        if clobbers != "":
                            asm_s = asm_s + " : \"" + clobbers + "\""
                self.w(asm_s + ");\n")
            case HirStmt.SSpawn(e):
                match e.read():
                    case HirExpr.ECall(callee, args, _):
                        mut sp_fn = ""
                        match callee.read():
                            case HirExpr.EIdent(n, _, _): sp_fn = n
                            case _: pass
                        if sp_fn == "":
                            self.w(pad + self.gen_expr(e) + "; /* spawn: inline */\n")
                        elif args.len == 0:
                            if self.in_task_group > 0:
                                self.w(pad + "_tr_tg_push(_tr_thread_start(_tr_spawn_wrap_" + sp_fn + ", NULL));\n")
                            else:
                                self.w(pad + "_tr_thread_detach(_tr_thread_start(_tr_spawn_wrap_" + sp_fn + ", NULL));\n")
                        elif args.len == 1:
                            mut arg_ty_n = hir_expr_type(args.get(0)).name
                            mut void_cast = "(void*)(uintptr_t)(" + self.gen_expr(args.get(0)) + ")"
                            if not _is_int_type(arg_ty_n) and arg_ty_n != "bool" and arg_ty_n != "char":
                                void_cast = "(void*)(" + self.gen_expr(args.get(0)) + ")"
                            if self.in_task_group > 0:
                                self.w(pad + "_tr_tg_push(_tr_thread_start(_tr_spawn_wrap_" + sp_fn + ", " + void_cast + "));\n")
                            else:
                                self.w(pad + "_tr_thread_detach(_tr_thread_start(_tr_spawn_wrap_" + sp_fn + ", " + void_cast + "));\n")
                        else:
                            # multi-arg spawn: heap-pack args into long long[N+1] ([0]=result, [1..N]=args)
                            mut sp_nargs = args.len
                            self.w(pad + "{ long long* _sa = (long long*)malloc(" + str(sp_nargs + 1) + " * sizeof(long long));\n")
                            mut sp_ai = 0
                            while sp_ai < sp_nargs:
                                mut sp_atn = hir_expr_type(args.get(sp_ai)).name
                                if not _is_int_type(sp_atn) and sp_atn != "bool" and sp_atn != "char":
                                    self.w(pad + "  _sa[" + str(sp_ai + 1) + "] = (long long)" + self.gen_expr(args.get(sp_ai)) + ";\n")
                                else:
                                    self.w(pad + "  _sa[" + str(sp_ai + 1) + "] = (long long)(" + self.gen_expr(args.get(sp_ai)) + ");\n")
                                sp_ai = sp_ai + 1
                            if self.in_task_group > 0:
                                self.w(pad + "  _tr_tg_push(_tr_thread_start(_tr_spawn_wrap_" + sp_fn + ", _sa)); }\n")
                            else:
                                self.w(pad + "  _tr_thread_detach(_tr_thread_start(_tr_spawn_wrap_" + sp_fn + ", _sa)); }\n")
                    case _:
                        self.w(pad + self.gen_expr(e) + "; /* spawn: non-call sync */\n")
            case HirStmt.STaskGroup(body):
                self.w(pad + "_tr_tg_begin();\n")
                self.w(pad + "{\n")
                self.in_task_group = self.in_task_group + 1
                self.gen_block(body, indent + 1)
                self.in_task_group = self.in_task_group - 1
                self.w(pad + "}\n")
                self.w(pad + "_tr_taskgroup_wait();\n")
            case HirStmt.SGpuBlock(body):
                # gpu: keyword is deprecated in core. Use std.gpu instead.
                # Emits the block body sequentially with no OpenMP wrappers.
                self.w(pad + "/* deprecated gpu: block - use std.gpu for GPU dispatch */\n")
                self.w(pad + "{\n")
                self.in_gpu_block = self.in_gpu_block + 1
                self.gen_block(body, indent + 1)
                self.in_gpu_block = self.in_gpu_block - 1
                self.w(pad + "}\n")
            case HirStmt.SBreak(bv):
                # `break <value>` in a loop/while EXPRESSION assigns the result temp
                # (owned: retain a non-fresh str so it escapes the loop), sets the
                # normal-exit flag off (for while), then breaks. A bare break — or a
                # valued break in a plain statement loop (target "") — just breaks.
                mut _lr = ""
                mut _ld = ""
                if self.loop_res_stack.len > 0: _lr = self.loop_res_stack.get(self.loop_res_stack.len - 1)
                if self.loop_done_stack.len > 0: _ld = self.loop_done_stack.get(self.loop_done_stack.len - 1)
                if bv as usize != 0 as usize and _lr != "":
                    mut _bvs = self.flush_wraps(self.gen_expr(bv), false)
                    if _is_str_type(hir_expr_type(bv).name) and not self._is_fresh_str_expr(bv):
                        self.w(pad + _lr + " = (" + _bvs + "); _tr_str_retain(" + _lr + ");\n")
                    else:
                        self.w(pad + _lr + " = (" + _bvs + ");\n")
                    if _ld != "": self.w(pad + _ld + " = 1;\n")
                self.w(pad + "break;\n")
            case HirStmt.SContinue: self.w(pad + "continue;\n")
            case HirStmt.SPass: self.w(pad + "/* pass */\n")
            case HirStmt.SLineMarker(ln):
                # In --debug builds, emit a C `#line` directive so GCC/GDB map
                # the following generated C back to the original .tr source
                # (file + line). `#line` must start at column 0. Otherwise
                # render the same no-op comment the marker replaced, keeping
                # non-debug output identical.
                if self.emit_line_info and self.cur_src_file.len() > 0:
                    self.w("#line " + str(ln) + " \"" + self.cur_src_file + "\"\n")
                else:
                    self.w(pad + "/* pass */\n")
            case HirStmt.SFree(name): self.w(pad + "if (" + name + ") { free(" + name + "); " + name + " = NULL; }\n")
            case HirStmt.SMultiLet(names, is_mut, val):
                self.gen_multi_let(names, is_mut, val, indent)
            case HirStmt.SChanSelect(cs_arms):
                self.gen_chan_select(cs_arms, indent)
            case HirStmt.SAutoDrop(adn, adc):
                if self.shared_vars.contains(adn):
                    # `shared` (Shared[T]/Rc) local: release its strong reference. The
                    # payload is reclaimed at strong==0 and the block survives any Weak.
                    self.w(pad + "_tr_shared_drop(" + _safe_c_varname(adn) + ");\n")
                elif adc == "Weak":
                    # Weak[T] handle: drop the weak ref (frees the block if it was the
                    # last one and the payload is already gone).
                    self.w(pad + "_tr_weak_drop(" + _safe_c_varname(adn) + ");\n")
                elif self.value_types.contains(adc):
                    # Value type (@value_type): lives on the stack, holds no owned
                    # heap, no refcount — nothing to drop.
                    pass
                elif adc == "str":
                    if self.str_local_names.contains(adn):
                        self.w(pad + "_tr_str_release(" + _safe_c_varname(adn) + ");\n")
                elif adc == "List" or adc == "Vec":
                    if self.coll_local_sfx.contains(adn):
                        mut _ad_sfx = self.coll_local_sfx.get(adn)
                        if _ad_sfx.len() > 4 and _ad_sfx.slice(0, 4) == "ptr@":
                            # Heap-class-element list: release each owned element.
                            self.w(pad + "List_ptr_free_obj(" + _safe_c_varname(adn) + ", " + self.obj_drop_fn(_ad_sfx.slice(4, _ad_sfx.len())) + ");\n")
                        else:
                            self.w(pad + "List_" + _ad_sfx + "_free(" + _safe_c_varname(adn) + ");\n")
                elif adc == "Dict" or adc == "Map" or adc == "Set":
                    mut _ad_strval = self.coll_local_strval.contains(adn)
                    mut _ad_dsfx = ""
                    if self.coll_local_sfx.contains(adn): _ad_dsfx = self.coll_local_sfx.get(adn)
                    if _ad_dsfx.len() > 4 and _ad_dsfx.slice(0, 2) == "d@":
                        # Heap-class-VALUE dict: release each owned value. "d@<i|s>@<Class>".
                        mut _dcls = _ad_dsfx.slice(4, _ad_dsfx.len())
                        if _ad_dsfx.slice(2, 3) == "i":
                            self.w(pad + "_tr_idict_free_objval(" + _safe_c_varname(adn) + ", " + self.obj_drop_fn(_dcls) + ");\n")
                        else:
                            self.w(pad + "Dict_free_objval(" + _safe_c_varname(adn) + ", " + self.obj_drop_fn(_dcls) + ");\n")
                    elif _ad_dsfx.len() > 2 and _ad_dsfx.slice(0, 2) == "s@":
                        # Heap-class Set (_TrPtrSet): release each owned element. "s@<Class>".
                        self.w(pad + "_tr_pset_free_obj(" + _safe_c_varname(adn) + ", " + self.obj_drop_fn(_ad_dsfx.slice(2, _ad_dsfx.len())) + ");\n")
                    elif self.coll_local_vtcoll.contains(adn):
                        # Typed inline value-type collection: Dict_str_Point_free / Set_Point_free
                        self.w(pad + self.coll_local_vtcoll.get(adn) + "_free(" + _safe_c_varname(adn) + ");\n")
                    elif self.coll_local_idict.contains(adn):
                        if _ad_strval:
                            self.w(pad + "_tr_idict_free_strval(" + _safe_c_varname(adn) + ");\n")
                        else:
                            self.w(pad + "_tr_idict_free(" + _safe_c_varname(adn) + ");\n")
                    else:
                        if _ad_strval:
                            self.w(pad + "Dict_free_strval(" + _safe_c_varname(adn) + ");\n")
                        else:
                            self.w(pad + "Dict_free(" + _safe_c_varname(adn) + ");\n")
                else:
                    mut _adn_safe = _safe_c_varname(adn)
                    if self.is_heap_class_tn(adc) and not self.has_method(adc, "free"):
                        # Refcounted plain class: release OUR reference. The struct is
                        # freed and its owned fields dropped (via _trdrop_T) only when
                        # the count hits zero — sound under aliasing. Gated on
                        # class_local_names so only OWNING locals release (balances
                        # retain-on-bind/store/return); borrows never enter that set.
                        if self.class_local_names.contains(adn):
                            self.w(pad + "_tr_obj_release(" + _adn_safe + ", " + self.obj_drop_fn(adc) + ");\n")
                    elif self.has_method(adc, "free"):
                        # User-managed class (defines free()): capture each owned str
                        # field BEFORE free() (so free() can still read it), run free(),
                        # then release the captured copies. (Item #2 destructor.)
                        # A class WITHOUT free() that isn't a droppable heap class (e.g.
                        # a Pointer[T]-managed / raw_aliased type like TomlValue) is NOT
                        # dropped here: its str fields are owned by the raw struct, and
                        # releasing them would UAF the value written through the pointer.
                        mut _ad_tmps = Vec[str].init(0)
                        if self.classes.contains(adc):
                            mut _ad_cls = self.classes.get(adc)
                            mut _ad_fi = 0
                            while _ad_fi < _ad_cls.fields.len:
                                mut _ad_fld = _ad_cls.fields.get(_ad_fi)
                                if _is_str_type(self.resolve_generic_prim(_ad_fld.ty.name)) and not _ad_fld.ty.is_borrow:
                                    mut _ad_tmp = "_ad_f" + self.next_temp()
                                    self.w(pad + "TrStr " + _ad_tmp + " = " + _adn_safe + "->" + _safe_c_varname(_ad_fld.name) + ";\n")
                                    _ad_tmps.push(_ad_tmp)
                                _ad_fi = _ad_fi + 1
                        if self.has_method(adc, "free"):
                            self.w(pad + self.cls_method_c_call(adc, "free", adn, "") + ";\n")
                        mut _ad_ti = 0
                        while _ad_ti < _ad_tmps.len:
                            self.w(pad + "_tr_str_release(" + _ad_tmps.get(_ad_ti) + ");\n")
                            _ad_ti = _ad_ti + 1
            case _: pass

    pub def gen_for_loop(self, var: str, iter: Pointer[HirExpr], body: HirBlock, indent: int):
        pad = _indent_str(indent)
        mut iter_s = self.gen_expr(iter)

        # Check if it's a range call
        match iter.read():
            case HirExpr.ECall(callee, args, _):
                match callee.read():
                    case HirExpr.EIdent(n, _, _):
                        if n == "range":
                            mut start_s = "0LL"
                            mut end_s = "0LL"
                            mut step_s = "1LL"
                            if args.len == 1:
                                end_s = self.gen_expr(args.get(0))
                            elif args.len == 2:
                                start_s = self.gen_expr(args.get(0))
                                end_s = self.gen_expr(args.get(1))
                            elif args.len >= 3:
                                start_s = self.gen_expr(args.get(0))
                                end_s = self.gen_expr(args.get(1))
                                step_s = self.gen_expr(args.get(2))
                            mut cmp = "<"
                            mut step_p = step_s as Pointer[char]
                            if step_p.offset(0).read() as int == 45: cmp = ">"
                            self.w(pad + "for (long long " + var + " = " + start_s + "; " + var + " " + cmp + " " + end_s + "; " + var + " += " + step_s + ") {\n")
                            self.gen_block(body, indent + 1)
                            self.w(pad + "}\n")
                            return
                    case _: pass
            case _: pass

        # Fast path: `for k in <dict>.keys()` over a str-keyed Dict/Map walks the
        # hash buckets DIRECTLY — no intermediate List allocation. `keys()`
        # otherwise materialises a fresh List_TrStr on every call, which dominates
        # dict-iteration hot loops. The key binds as a borrowed `_tr_str_lit`.
        match iter.read():
            case HirExpr.EMethodCall(d_obj, d_meth, d_args, _):
                if d_meth == "keys" and d_args.len == 0:
                    mut d_ty = hir_expr_type(d_obj)
                    if d_ty.name == "Dict" or d_ty.name == "Map":
                        mut d_int_key = false
                        if d_ty.args.len > 0:
                            mut dk = d_ty.args.get(0).read()
                            if _is_int_type(dk.name) or dk.name == "int" or dk.name == "i64" or dk.name == "usize": d_int_key = true
                        if not d_int_key:
                            mut d_s = self.gen_expr(d_obj)
                            mut bw = self.next_temp()
                            self.w(pad + "{ TrMap* " + bw + "d = " + d_s + ";\n")
                            self.w(pad + "  if (" + bw + "d) for (size_t " + bw + "b = 0; " + bw + "b < " + bw + "d->cap; " + bw + "b++)\n")
                            self.w(pad + "  for (_DictNode* " + bw + "n = " + bw + "d->buckets[" + bw + "b]; " + bw + "n; " + bw + "n = " + bw + "n->next) {\n")
                            self.w(pad + "    TrStr " + var + " = _tr_str_lit(" + bw + "n->key);\n")
                            self.gen_block(body, indent + 2)
                            self.w(pad + "  }\n")
                            self.w(pad + "}\n")
                            return
            case _: pass

        # Generic iteration over a collection
        mut tmp = self.next_temp()
        mut iter_ty = hir_expr_type(iter)
        mut iter_ty_n: str = iter_ty.name

        # __iter__ + __next__ protocol (iterator objects)
        if self.has_method(iter_ty_n, "__iter__"):
            mut iter_ret = self.cls_method_ret_ty(iter_ty_n, "__iter__")
            mut it_cls = iter_ret.name
            if it_cls == "" or it_cls == "void": it_cls = iter_ty_n
            if self.has_method(it_cls, "__next__"):
                mut next_ret = self.cls_method_ret_ty(it_cls, "__next__")
                mut elem_ct = "void*"
                mut elem_ty: AstType = AstType.init("void")
                if next_ret.name == "Option" and next_ret.args.len > 0:
                    elem_ty = next_ret.args.get(0).read()
                    elem_ct = self.type_to_c(elem_ty)
                self.w(pad + "{ __auto_type " + tmp + "_it = " + self.cls_method_c_call(iter_ty_n, "__iter__", iter_s, "") + ";\n")
                self.w(pad + "  while (1) {\n")
                self.w(pad + "    __auto_type " + tmp + "_nx = " + self.cls_method_c_call(it_cls, "__next__", tmp + "_it", "") + ";\n")
                self.w(pad + "    if (" + tmp + "_nx.tag == Option_None) break;\n")
                self.w(pad + "    " + elem_ct + " " + var + " = " + self.unwrap_voidp_as(tmp + "_nx.data.Some.val", elem_ty) + ";\n")
                self.gen_block(body, indent + 2)
                self.w(pad + "  }\n")
                self.w(pad + "}\n")
                return

        # __len__ + __getitem__ sequence protocol
        if self.has_method(iter_ty_n, "__len__") and self.has_method(iter_ty_n, "__getitem__"):
            mut col_tmp = self.next_temp()
            self.w(pad + "{ __auto_type " + col_tmp + " = " + iter_s + ";\n")
            self.w(pad + "  long long " + tmp + "_len = (long long)" + self.cls_method_c_call(iter_ty_n, "__len__", col_tmp, "") + ";\n")
            self.w(pad + "  for (long long " + tmp + "_i = 0; " + tmp + "_i < " + tmp + "_len; " + tmp + "_i++) {\n")
            self.w(pad + "    __auto_type " + var + " = " + self.cls_method_c_call(iter_ty_n, "__getitem__", col_tmp, tmp + "_i") + ";\n")
            self.gen_block(body, indent + 2)
            self.w(pad + "  }\n")
            self.w(pad + "}\n")
            return

        # Chan[T] iteration: receive until channel closed
        if iter_ty_n == "Chan":
            mut ch_elem_c = "long long"
            if iter_ty.args.len > 0:
                ch_elem_c = self.type_to_c(iter_ty.args.get(0).read())
            mut ch_ok_v = self.next_temp()
            self.w(pad + "{ int " + ch_ok_v + " = 1;\n")
            self.w(pad + "  while (" + ch_ok_v + ") {\n")
            self.w(pad + "    " + ch_elem_c + " " + var + " = (" + ch_elem_c + ")_tr_chan_recv_ok(" + iter_s + ", &" + ch_ok_v + ");\n")
            self.w(pad + "    if (!" + ch_ok_v + ") break;\n")
            self.gen_block(body, indent + 2)
            self.w(pad + "  }\n")
            self.w(pad + "}\n")
            return

        mut elem_c = "__auto_type"
        if iter_ty.name == "List" or iter_ty.name == "Vec":
            if iter_ty.args.len > 0:
                elem_c = self.type_to_c(iter_ty.args.get(0).read())
        # Use a C for-loop so the index advance lives in the loop clause: a
        # `continue` in the body then runs the increment (a while-loop with the
        # increment at the body's end would skip it on continue -> infinite loop).
        self.w(pad + "{ __auto_type " + tmp + "_col = " + iter_s + ";\n")
        self.w(pad + "  for (long long " + tmp + "_i = 0; " + tmp + "_i < " + tmp + "_col->len; " + tmp + "_i++) {\n")
        if elem_c == "TrStr":
            self.w(pad + "    TrStr " + var + " = _tr_str_lit(" + tmp + "_col->data[" + tmp + "_i]);\n")
        elif elem_c == "__auto_type":
            self.w(pad + "    __auto_type " + var + " = " + tmp + "_col->data[" + tmp + "_i];\n")
        else:
            self.w(pad + "    " + elem_c + " " + var + " = (" + elem_c + ")" + tmp + "_col->data[" + tmp + "_i];\n")
        self.gen_block(body, indent + 2)
        self.w(pad + "  }\n")
        self.w(pad + "}\n")

    pub def gen_for_unpack(self, vars: Vec[str], iter: Pointer[HirExpr], body: HirBlock, indent: int):
        pad = _indent_str(indent)
        mut tmp = self.next_temp()

        # -- Case 1: enumerate(collection) ------------------------------------
        match iter.read():
            case HirExpr.ECall(eu_callee, eu_args, _):
                match eu_callee.read():
                    case HirExpr.EIdent(eu_n, _, _):
                        if eu_n == "enumerate" and eu_args.len == 1 and vars.len >= 2:
                            mut eu_col = eu_args.get(0)
                            mut eu_col_s = self.gen_expr(eu_col)
                            mut eu_ty = hir_expr_type(eu_col)
                            mut eu_elem_c = "__auto_type"
                            if (eu_ty.name == "List" or eu_ty.name == "Vec") and eu_ty.args.len > 0:
                                eu_elem_c = self.type_to_c(eu_ty.args.get(0).read())
                            mut eu_v0 = _safe_c_varname(vars.get(0))
                            mut eu_v1 = _safe_c_varname(vars.get(1))
                            self.decl_vars.insert(vars.get(0), true)
                            self.decl_vars.insert(vars.get(1), true)
                            self.w(pad + "{ __auto_type " + tmp + "_c = " + eu_col_s + ";\n")
                            self.w(pad + "  for (long long " + tmp + "_i = 0; " + tmp + "_i < (long long)" + tmp + "_c->len; " + tmp + "_i++) {\n")
                            self.w(pad + "    long long " + eu_v0 + " = " + tmp + "_i;\n")
                            if eu_elem_c == "TrStr":
                                self.w(pad + "    TrStr " + eu_v1 + " = _tr_str_lit(" + tmp + "_c->data[" + tmp + "_i]);\n")
                            elif eu_elem_c == "__auto_type":
                                self.w(pad + "    __auto_type " + eu_v1 + " = " + tmp + "_c->data[" + tmp + "_i];\n")
                            else:
                                self.w(pad + "    " + eu_elem_c + " " + eu_v1 + " = (" + eu_elem_c + ")" + tmp + "_c->data[" + tmp + "_i];\n")
                            self.gen_block(body, indent + 2)
                            self.w(pad + "  }\n")
                            self.w(pad + "}\n")
                            return
                        if eu_n == "zip" and eu_args.len == 2 and vars.len >= 2:
                            mut za_col = eu_args.get(0)
                            mut zb_col = eu_args.get(1)
                            mut za_s = self.gen_expr(za_col)
                            mut zb_s = self.gen_expr(zb_col)
                            mut za_ty = hir_expr_type(za_col)
                            mut zb_ty = hir_expr_type(zb_col)
                            mut za_c = "__auto_type"
                            mut zb_c = "__auto_type"
                            if (za_ty.name == "List" or za_ty.name == "Vec") and za_ty.args.len > 0:
                                za_c = self.type_to_c(za_ty.args.get(0).read())
                            if (zb_ty.name == "List" or zb_ty.name == "Vec") and zb_ty.args.len > 0:
                                zb_c = self.type_to_c(zb_ty.args.get(0).read())
                            mut zv0 = _safe_c_varname(vars.get(0))
                            mut zv1 = _safe_c_varname(vars.get(1))
                            self.decl_vars.insert(vars.get(0), true)
                            self.decl_vars.insert(vars.get(1), true)
                            self.w(pad + "{ __auto_type " + tmp + "_a = " + za_s + "; __auto_type " + tmp + "_b = " + zb_s + ";\n")
                            self.w(pad + "  long long " + tmp + "_n = (long long)(" + tmp + "_a->len < " + tmp + "_b->len ? " + tmp + "_a->len : " + tmp + "_b->len);\n")
                            self.w(pad + "  for (long long " + tmp + "_i = 0; " + tmp + "_i < " + tmp + "_n; " + tmp + "_i++) {\n")
                            if za_c == "TrStr":
                                self.w(pad + "    TrStr " + zv0 + " = _tr_str_lit(" + tmp + "_a->data[" + tmp + "_i]);\n")
                            elif za_c == "__auto_type":
                                self.w(pad + "    __auto_type " + zv0 + " = " + tmp + "_a->data[" + tmp + "_i];\n")
                            else:
                                self.w(pad + "    " + za_c + " " + zv0 + " = (" + za_c + ")" + tmp + "_a->data[" + tmp + "_i];\n")
                            if zb_c == "TrStr":
                                self.w(pad + "    TrStr " + zv1 + " = _tr_str_lit(" + tmp + "_b->data[" + tmp + "_i]);\n")
                            elif zb_c == "__auto_type":
                                self.w(pad + "    __auto_type " + zv1 + " = " + tmp + "_b->data[" + tmp + "_i];\n")
                            else:
                                self.w(pad + "    " + zb_c + " " + zv1 + " = (" + zb_c + ")" + tmp + "_b->data[" + tmp + "_i];\n")
                            self.gen_block(body, indent + 2)
                            self.w(pad + "  }\n")
                            self.w(pad + "}\n")
                            return
                    case _: pass
            case _: pass

        # -- Case 2: obj.items() - inline dict bucket walk ---------------------
        match iter.read():
            case HirExpr.EMethodCall(di_obj, di_meth, _, _):
                if di_meth == "items":
                    mut di_s = self.gen_expr(di_obj)
                    mut di_ty = hir_expr_type(di_obj)
                    mut di_idict = false
                    if di_ty.args.len > 0:
                        mut di_ka = di_ty.args.get(0).read()
                        if _is_int_type(di_ka.name) or di_ka.name == "int" or di_ka.name == "i64" or di_ka.name == "i32" or di_ka.name == "usize":
                            di_idict = true
                    mut di_v0 = _safe_c_varname(vars.get(0))
                    mut di_v1 = "_di_ign"
                    if vars.len > 1: di_v1 = _safe_c_varname(vars.get(1))
                    self.decl_vars.insert(vars.get(0), true)
                    if vars.len > 1: self.decl_vars.insert(vars.get(1), true)
                    if di_idict:
                        mut di_val_c = "void*"
                        if di_ty.args.len > 1: di_val_c = self.type_to_c(di_ty.args.get(1).read())
                        self.w(pad + "{ TrIDict* " + tmp + "_d = " + di_s + ";\n")
                        self.w(pad + "  for (size_t " + tmp + "_bi = 0; " + tmp + "_bi < " + tmp + "_d->cap; " + tmp + "_bi++) {\n")
                        self.w(pad + "    _TrIDictNode* " + tmp + "_nd = " + tmp + "_d->buckets[" + tmp + "_bi];\n")
                        self.w(pad + "    while (" + tmp + "_nd) {\n")
                        self.w(pad + "      long long " + di_v0 + " = " + tmp + "_nd->key;\n")
                        if di_val_c == "void*" or di_val_c == "void":
                            self.w(pad + "      void* " + di_v1 + " = " + tmp + "_nd->value;\n")
                        elif di_val_c == "TrStr":
                            self.w(pad + "      TrStr " + di_v1 + " = _tr_str_unbox(" + tmp + "_nd->value);\n")
                        else:
                            self.w(pad + "      " + di_val_c + " " + di_v1 + " = (" + di_val_c + ")(uintptr_t)" + tmp + "_nd->value;\n")
                        self.gen_block(body, indent + 3)
                        self.w(pad + "      " + tmp + "_nd = " + tmp + "_nd->next;\n")
                        self.w(pad + "    }\n")
                        self.w(pad + "  }\n")
                        self.w(pad + "}\n")
                    else:
                        mut di_val_c = "void*"
                        if di_ty.args.len > 1: di_val_c = self.type_to_c(di_ty.args.get(1).read())
                        self.w(pad + "{ TrMap* " + tmp + "_d = " + di_s + ";\n")
                        self.w(pad + "  for (size_t " + tmp + "_bi = 0; " + tmp + "_bi < " + tmp + "_d->cap; " + tmp + "_bi++) {\n")
                        self.w(pad + "    _DictNode* " + tmp + "_nd = " + tmp + "_d->buckets[" + tmp + "_bi];\n")
                        self.w(pad + "    while (" + tmp + "_nd) {\n")
                        self.w(pad + "      TrStr " + di_v0 + " = _tr_str_lit(" + tmp + "_nd->key);\n")
                        if di_val_c == "void*" or di_val_c == "void":
                            self.w(pad + "      void* " + di_v1 + " = " + tmp + "_nd->value;\n")
                        elif di_val_c == "TrStr":
                            self.w(pad + "      TrStr " + di_v1 + " = _tr_str_unbox(" + tmp + "_nd->value);\n")
                        else:
                            self.w(pad + "      " + di_val_c + " " + di_v1 + " = (" + di_val_c + ")(uintptr_t)" + tmp + "_nd->value;\n")
                        self.gen_block(body, indent + 3)
                        self.w(pad + "      " + tmp + "_nd = " + tmp + "_nd->next;\n")
                        self.w(pad + "    }\n")
                        self.w(pad + "  }\n")
                        self.w(pad + "}\n")
                    return
            case _: pass

        # -- Generic fallback: List_ptr* of TrTuple* --------------------------
        mut fu_iter_s = self.gen_expr(iter)
        self.w(pad + "{ __auto_type " + tmp + "_col = " + fu_iter_s + ";\n")
        self.w(pad + "  for (long long " + tmp + "_i = 0; " + tmp + "_i < (long long)" + tmp + "_col->len; " + tmp + "_i++) {\n")
        self.w(pad + "    TrTuple* " + tmp + "_pair = (TrTuple*)" + tmp + "_col->data[" + tmp + "_i];\n")
        mut fu_elem_ty = hir_expr_type(iter)
        mut fu_has_tuple_ty = fu_elem_ty.args.len > 0
        mut fu_pi = 0
        while fu_pi < vars.len:
            mut fu_vn = _safe_c_varname(vars.get(fu_pi))
            self.decl_vars.insert(vars.get(fu_pi), true)
            mut fu_elem_n = ""
            if fu_has_tuple_ty:
                mut fu_tt_r = fu_elem_ty.args.get(0).read()
                if fu_tt_r.args.len > fu_pi: fu_elem_n = self.resolve_generic_prim(fu_tt_r.args.get(fu_pi).read().name)
            if _is_str_type(fu_elem_n):
                self.w(pad + "    TrStr " + fu_vn + " = _tr_str_unbox((void*)(uintptr_t)" + tmp + "_pair->data[" + fu_pi.to_str() + "]);\n")
            else:
                self.w(pad + "    long long " + fu_vn + " = " + tmp + "_pair->data[" + fu_pi.to_str() + "];\n")
            fu_pi = fu_pi + 1
        self.gen_block(body, indent + 2)
        self.w(pad + "  }\n")
        self.w(pad + "}\n")

    pub def gen_try(self, try_body: HirBlock, catches: Vec[Pointer[HirCatchClause]], finally_b: HirBlock, indent: int):
        pad = _indent_str(indent)
        mut jb = self.next_temp()
        mut em = self.next_temp()
        self.w(pad + "{\n")
        self.w(pad + "    jmp_buf " + jb + "; char* " + em + " = NULL;\n")
        self.w(pad + "    _tr_exc_push(&" + jb + ", &" + em + ");\n")
        self.w(pad + "    if (setjmp(" + jb + ") == 0) {\n")
        self.gen_block(try_body, indent + 2)
        self.w(pad + "        _tr_exc_pop();\n")
        if catches.len > 0:
            self.w(pad + "    } else {\n")
            # Note: _tr_exc_raise already decremented sp before longjmp.
            # Do NOT call _tr_exc_pop() here - that would remove the outer handler frame.
            mut i = 0
            while i < catches.len:
                mut cc = catches.get(i).read()
                if cc.err_name != "":
                    # sema types the except-binding as `str` (TrStr); the
                    # exception mechanism itself stores a raw char* message.
                    # Wrap as a borrowed TrStr (rc=NULL) - the underlying
                    # message is a literal/owned-elsewhere C string.
                    self.w(pad + "        TrStr " + cc.err_name + " = _tr_str_lit(" + em + ");\n")
                    self.w(pad + "        (void)" + cc.err_name + ";\n")
                self.gen_block(cc.body, indent + 2)
                i = i + 1
        else:
            self.w(pad + "    } else {\n")
            self.w(pad + "        /* exception not caught */\n")
        self.w(pad + "    }\n")
        if finally_b as usize != 0 as usize and finally_b.stmts.len > 0:
            self.w(pad + "    /* finally */\n")
            self.gen_block(finally_b, indent + 1)
        self.w(pad + "}\n")

    pub def gen_chan_select(self, arms: Vec[Pointer[HirChanSelectArm]], indent: int):
        # chan_select generates a polling loop.
        # Active cases (recv/send) are tried in random order each pass.
        # default fires only if NO active case succeeded in a pass (non-blocking).
        # timeout fires only if NO active case succeeded AND deadline passed (soft deadline).
        pad = _indent_str(indent)
        mut tmp = self.next_temp()
        mut n = arms.len
        mut has_default = false
        mut has_timeout = false
        mut timeout_ms_s = "5000LL"
        mut default_idx = -1
        mut timeout_idx = -1
        mut active_n = 0
        mut ai = 0
        while ai < n:
            if not _is_invalid_ptr(arms.get(ai) as usize):
                mut ak = arms.get(ai).read()
                if ak.kind == 3:
                    has_default = true
                    default_idx = ai
                elif ak.kind == 2:
                    has_timeout = true
                    timeout_idx = ai
                    if not _is_invalid_ptr(ak.timeout_ms as usize):
                        timeout_ms_s = self.gen_expr(ak.timeout_ms)
                else:
                    active_n = active_n + 1
            ai = ai + 1
        if active_n == 0: active_n = 1
        self.w(pad + "{ /* chan_select */\n")
        if has_timeout:
            self.w(pad + "  long long _cst_dl_" + tmp + " = _tr_monotonic_ms() + (long long)(" + timeout_ms_s + ");\n")
        self.w(pad + "  int _cst_start_" + tmp + " = (int)(rand() % " + str(active_n) + ");\n")
        self.w(pad + "  int _cst_done_" + tmp + " = 0;\n")
        self.w(pad + "  while (!_cst_done_" + tmp + ") {\n")
        # Build list of active-only indices for random rotation
        self.w(pad + "    int _cst_active_" + tmp + "[" + str(n) + "]; int _cst_na_" + tmp + " = 0;\n")
        mut idx2 = 0
        while idx2 < n:
            if not _is_invalid_ptr(arms.get(idx2) as usize):
                mut ak2 = arms.get(idx2).read()
                if ak2.kind != 2 and ak2.kind != 3:
                    self.w(pad + "    _cst_active_" + tmp + "[_cst_na_" + tmp + "++] = " + str(idx2) + ";\n")
            idx2 = idx2 + 1
        # Try active cases in random order
        self.w(pad + "    for (int _csi_" + tmp + " = 0; _csi_" + tmp + " < _cst_na_" + tmp + " && !_cst_done_" + tmp + "; _csi_" + tmp + "++) {\n")
        self.w(pad + "      int _csc_" + tmp + " = _cst_active_" + tmp + "[(_csi_" + tmp + " + _cst_start_" + tmp + ") % (_cst_na_" + tmp + " > 0 ? _cst_na_" + tmp + " : 1)];\n")
        self.w(pad + "      switch (_csc_" + tmp + ") {\n")
        mut bi = 0
        while bi < n:
            if not _is_invalid_ptr(arms.get(bi) as usize):
                mut arm = arms.get(bi).read()
                if arm.kind != 2 and arm.kind != 3:
                    self.w(pad + "        case " + str(bi) + ": {\n")
                    if arm.kind == 0:
                        # recv arm - extract channel from ch.recv() if needed
                        mut chan_s = ""
                        if not _is_invalid_ptr(arm.chan_expr as usize):
                            match arm.chan_expr.read():
                                case HirExpr.EMethodCall(rc_obj, rc_meth, _, _):
                                    if rc_meth == "recv" or rc_meth == "receive":
                                        chan_s = self.gen_expr(rc_obj)
                                    else:
                                        chan_s = self.gen_expr(arm.chan_expr)
                                case _:
                                    chan_s = self.gen_expr(arm.chan_expr)
                        self.w(pad + "          long long _crv_" + tmp + "_" + str(bi) + " = _tr_chan_try_recv_val(" + chan_s + ");\n")
                        self.w(pad + "          if (_crv_" + tmp + "_" + str(bi) + " != LLONG_MIN) {\n")
                        if arm.var_name != "":
                            self.w(pad + "            long long " + _safe_c_varname(arm.var_name) + " = _crv_" + tmp + "_" + str(bi) + ";\n")
                        self.gen_block(arm.body, indent + 3)
                        self.w(pad + "            _cst_done_" + tmp + " = 1;\n")
                        self.w(pad + "          }\n")
                    elif arm.kind == 1:
                        # send arm - extract chan/val from ch.send(val) if needed
                        mut send_chan_s = ""
                        mut send_val_s = "0LL"
                        if not _is_invalid_ptr(arm.chan_expr as usize):
                            match arm.chan_expr.read():
                                case HirExpr.EMethodCall(sc_obj, sc_meth, sc_args, _):
                                    send_chan_s = self.gen_expr(sc_obj)
                                    if sc_args.len > 0: send_val_s = self.gen_expr(sc_args.get(0))
                                case _:
                                    send_chan_s = self.gen_expr(arm.chan_expr)
                        if not _is_invalid_ptr(arm.val_expr as usize): send_val_s = self.gen_expr(arm.val_expr)
                        if send_chan_s != "":
                            self.w(pad + "          if (_tr_chan_try_send(" + send_chan_s + ", " + send_val_s + ")) {\n")
                            self.gen_block(arm.body, indent + 3)
                            self.w(pad + "            _cst_done_" + tmp + " = 1;\n")
                            self.w(pad + "          }\n")
                    self.w(pad + "          break;\n")
                    self.w(pad + "        }\n")
            bi = bi + 1
        self.w(pad + "        default: break;\n")
        self.w(pad + "      }\n")  # switch
        self.w(pad + "    }\n")    # for active
        # After trying all active cases - check fallback cases
        self.w(pad + "    if (!_cst_done_" + tmp + ") {\n")
        if has_timeout:
            mut to_arm = arms.get(timeout_idx).read()
            self.w(pad + "      if (_tr_monotonic_ms() >= _cst_dl_" + tmp + ") {\n")
            self.gen_block(to_arm.body, indent + 3)
            self.w(pad + "        _cst_done_" + tmp + " = 1;\n")
            self.w(pad + "      } else ")
        else:
            self.w(pad + "      ")
        if has_default:
            mut def_arm = arms.get(default_idx).read()
            if has_timeout:
                self.w("{\n")
            else:
                self.w("{\n")
            self.gen_block(def_arm.body, indent + 3)
            self.w(pad + "        _cst_done_" + tmp + " = 1;\n")
            self.w(pad + "      }\n")
        elif not has_timeout:
            self.w("{ _tr_thread_sleep_ms(0); }\n")
        else:
            self.w("{ _tr_thread_sleep_ms(0); }\n")
        self.w(pad + "    }\n")
        self.w(pad + "  }\n")  # while
        self.w(pad + "} /* end chan_select */\n")

    pub def gen_block(self, b: HirBlock, indent: int):
        if _is_invalid_ptr(b as usize): return
        if _is_invalid_ptr(b.stmts as usize): return
        mut i = 0
        while i < b.stmts.len:
            self.gen_stmt(b.stmts.get(i), indent)
            i = i + 1

    pub def gen_match(self, expr: Pointer[HirExpr], arms: Vec[HirMatchArm], indent: int):
        pad = _indent_str(indent)
        mut subj = self.next_temp()
        self.w(pad + "__auto_type " + subj + " = " + self.gen_expr(expr) + ";\n")

        # If any arm has a guard, use sequential do{...}while(0) with break so
        # that a failing guard falls through to the next arm instead of exiting
        # the whole if/else-if chain.
        mut has_any_guard = false
        mut gk = 0
        while gk < arms.len:
            if arms.get(gk).guard as usize != 0 as usize: has_any_guard = true
            gk = gk + 1

        if has_any_guard:
            # Sequential do{...}while(0): each arm is an independent if block.
            # When a guard fails we fall through to the next arm naturally.
            self.w(pad + "do {\n")
            mut gi = 0
            while gi < arms.len:
                mut garm = arms.get(gi)
                # Compute cond + bindings for this arm (same logic as below).
                mut gcond = "1 /* wildcard */"
                mut gbindings = ""
                match garm.pat:
                    case Pattern.PLitInt(v):   gcond = subj + " == " + v.to_str() + "LL"
                    case Pattern.PLitBool(v):
                        if v:
                            gcond = subj
                        else:
                            gcond = "!" + subj
                    case Pattern.PLitStr(v):   gcond = "_tr_str_eq(" + subj + ", \"" + _escape_str_for_c(v) + "\")"
                    case Pattern.PVariant(tn, vn):
                        mut gpv = vn
                        if tn == "Option" and (vn == "" or vn == "none"): gpv = "None"
                        gcond = subj + ".tag == " + tn + "_" + gpv
                    case Pattern.PVariantBind(tn, vn, field):
                        gcond = subj + ".tag == " + tn + "_" + vn
                        mut gaf = field
                        if tn == "Option" and vn == "Some": gaf = "val"
                        if tn == "Result" and vn == "Ok": gaf = "val"
                        if tn == "Result" and vn == "Err": gaf = "err"
                        if self.enums.contains(tn):
                            mut _gev = self.enums.get(tn)
                            mut _gvi = 0
                            while _gvi < _gev.variants.len:
                                mut _gv = _gev.variants.get(_gvi)
                                if _gv.name == vn and _gv.fields.len > 0: gaf = _gv.fields.get(0).name
                                _gvi = _gvi + 1
                        self.decl_vars.insert(field, true)
                        gbindings = "__auto_type " + _safe_c_varname(field) + " = " + subj + ".data." + vn + "." + _safe_c_varname(gaf) + ";\n"
                    case Pattern.PVariantBindMany(tn, vn, fields):
                        gcond = subj + ".tag == " + tn + "_" + vn
                        mut _gbi = 0
                        while _gbi < fields.len:
                            mut _gbf = fields.get(_gbi)
                            if _gbf != "_":
                                mut _gact = _gbf
                                if self.enums.contains(tn):
                                    mut _gev2 = self.enums.get(tn)
                                    mut _gvi2 = 0
                                    while _gvi2 < _gev2.variants.len:
                                        mut _gv2 = _gev2.variants.get(_gvi2)
                                        if _gv2.name == vn and _gbi < _gv2.fields.len: _gact = _gv2.fields.get(_gbi).name
                                        _gvi2 = _gvi2 + 1
                                self.decl_vars.insert(_gbf, true)
                                gbindings = gbindings + "__auto_type " + _safe_c_varname(_gbf) + " = " + subj + ".data." + vn + "." + _safe_c_varname(_gact) + ";\n"
                            _gbi = _gbi + 1
                    case Pattern.PBind(gn):
                        gcond = "1"
                        self.decl_vars.insert(gn, true)
                        gbindings = "__auto_type " + _safe_c_varname(gn) + " = " + subj + ";\n"
                    case Pattern.PWild: gcond = "1"
                    case _: gcond = "1"
                self.w(pad + "  if (" + gcond + ") {\n")
                if gbindings != "": self.w(pad + "    " + gbindings)
                if garm.guard as usize != 0 as usize:
                    self.w(pad + "    if (" + self.gen_expr(garm.guard) + ") {\n")
                    self.gen_block(garm.body, indent + 3)
                    self.w(pad + "      break;\n")
                    self.w(pad + "    }\n")
                else:
                    self.gen_block(garm.body, indent + 2)
                    self.w(pad + "    break;\n")
                self.w(pad + "  }\n")
                gi = gi + 1
            self.w(pad + "} while(0);\n")
            return

        mut i = 0
        while i < arms.len:
            mut arm = arms.get(i)
            mut cond = "1 /* wildcard */"
            mut bindings = ""

            match arm.pat:
                case Pattern.PLitInt(v): cond = subj + " == " + v.to_str() + "LL"
                case Pattern.PLitBool(v):
                    if v: cond = subj
                    else: cond = "!" + subj
                case Pattern.PLitStr(v): cond = "_tr_str_eq(" + subj + ", \"" + _escape_str_for_c(v) + "\")"
                case Pattern.PVariant(tn, vn):
                    mut pv_vn = vn
                    if tn == "Option" and (vn == "" or vn == "none"): pv_vn = "None"
                    cond = subj + ".tag == " + tn + "_" + pv_vn
                case Pattern.PVariantBind(tn, vn, field):
                    cond = subj + ".tag == " + tn + "_" + vn
                    mut actual_fld = field
                    # Built-in Option/Result: use known field names
                    if tn == "Option" and vn == "Some": actual_fld = "val"
                    if tn == "Result" and vn == "Ok": actual_fld = "val"
                    if tn == "Result" and vn == "Err": actual_fld = "err"
                    if self.enums.contains(tn):
                        mut _ev_def = self.enums.get(tn)
                        mut _vi = 0
                        while _vi < _ev_def.variants.len:
                            mut _ev = _ev_def.variants.get(_vi)
                            if _ev.name == vn and _ev.fields.len > 0:
                                actual_fld = _ev.fields.get(0).name
                            _vi = _vi + 1
                    self.decl_vars.insert(field, true)
                    bindings = "__auto_type " + _safe_c_varname(field) + " = " + subj + ".data." + vn + "." + _safe_c_varname(actual_fld) + ";\n"
                case Pattern.PVariantBindMany(tn, vn, fields):
                    cond = subj + ".tag == " + tn + "_" + vn
                    mut _bi = 0
                    while _bi < fields.len:
                        mut _bf = fields.get(_bi)
                        if _bf != "_":
                            mut _actual = _bf
                            if self.enums.contains(tn):
                                mut _ev_def2 = self.enums.get(tn)
                                mut _vi2 = 0
                                while _vi2 < _ev_def2.variants.len:
                                    mut _ev2 = _ev_def2.variants.get(_vi2)
                                    if _ev2.name == vn and _bi < _ev2.fields.len:
                                        _actual = _ev2.fields.get(_bi).name
                                    _vi2 = _vi2 + 1
                            self.decl_vars.insert(_bf, true)
                            bindings = bindings + "__auto_type " + _safe_c_varname(_bf) + " = " + subj + ".data." + vn + "." + _safe_c_varname(_actual) + ";\n"
                        _bi = _bi + 1
                case Pattern.PBind(n):
                    cond = "1"
                    self.decl_vars.insert(n, true)
                    bindings = "__auto_type " + _safe_c_varname(n) + " = " + subj + ";\n"
                case Pattern.PWild: cond = "1"
                case Pattern.POr(pats):
                    mut or_conds = ""
                    mut oi = 0
                    while oi < pats.len:
                        mut pp = pats.get(oi)
                        mut pc = "1"
                        match pp:
                            case Pattern.PVariant(tn, vn):
                                mut or_vn = vn
                                if tn == "Option" and (vn == "" or vn == "none"): or_vn = "None"
                                pc = subj + ".tag == " + tn + "_" + or_vn
                            case Pattern.PLitInt(vi): pc = subj + " == " + vi.to_str() + "LL"
                            case Pattern.PLitStr(vs): pc = "_tr_str_eq(" + subj + ", \"" + _escape_str_for_c(vs) + "\")"
                            case Pattern.PLitBool(bv):
                                if bv: pc = subj
                                else: pc = "!" + subj
                            case Pattern.PBind(bn):
                                pc = "1"
                                self.decl_vars.insert(bn, true)
                                bindings = bindings + "__auto_type " + _safe_c_varname(bn) + " = " + subj + ";\n"
                            case _: pc = "1"
                        if oi == 0: or_conds = pc
                        else: or_conds = or_conds + " || " + pc
                        oi = oi + 1
                    cond = "(" + or_conds + ")"
                case _: cond = "1"

            # No-guard path: standard if/else-if chain (guards handled above via do-while)
            if i == 0: self.w(pad + "if (" + cond + ") {\n")
            else: self.w(pad + "} else if (" + cond + ") {\n")
            if bindings != "":
                self.w(pad + "    " + bindings)
            self.gen_block(arm.body, indent + 1)
            i = i + 1

        if arms.len > 0: self.w(pad + "}\n")

    # -- Program generation ----------------------------------------------------

    pub def register_program(self, prog: HirProgram):
        # Register type aliases so type_to_c can resolve them.
        if not _is_invalid_ptr(prog.type_alias_names as usize):
            mut tai = 0
            while tai < prog.type_alias_names.len:
                mut ta_name = prog.type_alias_names.get(tai)
                mut ta_ty_p = prog.type_alias_types.get(tai)
                if ta_ty_p as usize != 0 as usize:
                    self.type_alias_map.insert(ta_name, self.type_to_c(ta_ty_p.read()))
                tai = tai + 1
        mut i = 0
        while i < prog.classes.len:
            self.classes.insert(prog.classes.get(i).name, prog.classes.get(i))
            if not prog.classes.get(i).is_class:
                self.value_types.insert(prog.classes.get(i).name, true)
            i = i + 1
        i = 0
        while i < prog.enums.len:
            self.enums.insert(prog.enums.get(i).name, prog.enums.get(i))
            i = i + 1
        i = 0
        while i < prog.interfaces.len:
            self.interfaces.insert(prog.interfaces.get(i).name, prog.interfaces.get(i))
            i = i + 1
        i = 0
        while i < prog.functions.len:
            mut pf = prog.functions.get(i)
            # The bare-name function map is for free functions. A class/enum
            # method (class_name != "") must not clobber a free function of the
            # same name (e.g. Vec.copy vs the generic free copy[T]) -- that would
            # strip the free function's .generics and leak bare T into the C.
            # Free functions always win; a method only registers when the name
            # is otherwise free.
            if pf.class_name == "" or not self.functions.contains(pf.name):
                self.functions.insert(pf.name, pf)
            if pf.class_name != "":
                self.method_owners.insert(pf.class_name + "#" + pf.name, true)
            # Return-ownership: key free functions by name, methods by "Class.method".
            if pf.class_name == "":
                self._reg_fn_owned(pf.name, pf.returns_owned)
            else:
                self._reg_fn_owned(pf.class_name + "." + pf.name, pf.returns_owned)
            i = i + 1
        # Class/enum methods live in their container's method list (not always in
        # prog.functions) — register those too, keyed "Class.method".
        i = 0
        while i < prog.classes.len:
            mut roc = prog.classes.get(i)
            mut rocm = 0
            while rocm < roc.methods.len:
                self._reg_fn_owned(roc.name + "." + roc.methods.get(rocm).name, roc.methods.get(rocm).returns_owned)
                rocm = rocm + 1
            i = i + 1
        i = 0
        while i < prog.enums.len:
            mut roe = prog.enums.get(i)
            mut roem = 0
            while roem < roe.methods.len:
                self._reg_fn_owned(roe.name + "." + roe.methods.get(roem).name, roe.methods.get(roem).returns_owned)
                roem = roem + 1
            i = i + 1
        # Raw-alias scan: any class reachable as Pointer[T] (a class field, enum
        # payload, or fn param/return) is aliased by raw pointers that bypass the
        # refcount — auto-dropping it would free memory other aliases still hold.
        # Collect all such T so is_heap_class_tn can exclude them (e.g. AstType via
        # `AstType.args: Vec[Pointer[AstType]]`, every HIR node via Pointer[HirExpr]).
        i = 0
        while i < prog.classes.len:
            mut rac = prog.classes.get(i)
            mut rafi = 0
            while rafi < rac.fields.len:
                self._scan_ptr_aliased(rac.fields.get(rafi).ty)
                rafi = rafi + 1
            i = i + 1
        i = 0
        while i < prog.enums.len:
            mut rae = prog.enums.get(i)
            mut ravi = 0
            while ravi < rae.variants.len:
                mut ravf = 0
                while ravf < rae.variants.get(ravi).fields.len:
                    self._scan_ptr_aliased(rae.variants.get(ravi).fields.get(ravf).ty)
                    ravf = ravf + 1
                ravi = ravi + 1
            i = i + 1
        i = 0
        while i < prog.functions.len:
            mut raf = prog.functions.get(i)
            mut rapi = 0
            while rapi < raf.params.len:
                self._scan_ptr_aliased(raf.params.get(rapi).ty)
                rapi = rapi + 1
            if raf.ret_ty as usize != 0 as usize: self._scan_ptr_aliased(raf.ret_ty)
            i = i + 1
        i = 0
        while i < prog.classes.len:
            mut ramc = prog.classes.get(i)
            mut rammi = 0
            while rammi < ramc.methods.len:
                mut ramm = ramc.methods.get(rammi)
                mut rampi = 0
                while rampi < ramm.params.len:
                    self._scan_ptr_aliased(ramm.params.get(rampi).ty)
                    rampi = rampi + 1
                if ramm.ret_ty as usize != 0 as usize: self._scan_ptr_aliased(ramm.ret_ty)
                rammi = rammi + 1
            i = i + 1
        # Collection-field ownership scan (drives _trdrop_T's collection-field free).
        self._scan_coll_fields(prog)
        i = 0
        while i < prog.decorator_defs.len:
            mut _dd = prog.decorator_defs.get(i)
            self.decorator_defs.insert(_dd.name, _dd)
            i = i + 1

        # -- Detect overloaded methods (same name, different param count) -----
        # Scan each class/enum for duplicate method names; mark them in overloaded_sigs
        # so gen_func_sig and gen_method_call can emit mangled C names.
        i = 0
        while i < prog.classes.len:
            mut ov_cls = prog.classes.get(i)
            if ov_cls.generics.len == 0:
                mut mi = 0
                while mi < ov_cls.methods.len:
                    mut m1 = ov_cls.methods.get(mi)
                    mut mj = mi + 1
                    while mj < ov_cls.methods.len:
                        if ov_cls.methods.get(mj).name == m1.name:
                            self.overloaded_sigs.insert(ov_cls.name + "_" + m1.name, true)
                            break
                        mj = mj + 1
                    mi = mi + 1
            i = i + 1
        i = 0
        while i < prog.enums.len:
            mut ov_enm = prog.enums.get(i)
            mut mi = 0
            while mi < ov_enm.methods.len:
                mut m1 = ov_enm.methods.get(mi)
                mut mj = mi + 1
                while mj < ov_enm.methods.len:
                    if ov_enm.methods.get(mj).name == m1.name:
                        self.overloaded_sigs.insert(ov_enm.name + "_" + m1.name, true)
                        break
                    mj = mj + 1
                mi = mi + 1
            i = i + 1

    # -- Generic type pre-scan (collect all instantiations before codegen) ----

    pub def scan_mono_ty(self, ty: AstType):
        if ty as usize == 0 as usize: return
        if ty.name == "": return
        mut i = 0
        while i < ty.args.len:
            self.scan_mono_ty(ty.args.get(i).read())
            i = i + 1
        # Fixed-size array [T; N]: emit its value-type struct now (pre-types.h) so the
        # typedef is visible everywhere, not lazily during a later pass.
        if ty.name == "Array" and ty.array_size > 0 and ty.args.len > 0:
            self.ensure_array_type(ty)
        if ty.args.len > 0 and self.classes.contains(ty.name) and ty.name != "Vec" and ty.name != "Map" and ty.name != "Dict" and ty.name != "List":
            mut ucls = self.classes.get(ty.name)
            if ucls.generics.len > 0:
                self.ensure_mono(ucls, ty.args)
        # List/Vec of a GENERIC VALUE TYPE (`List[Box[int]]`): monomorphize the
        # element (Box_i64 struct -> mono_buf, which survives the redirect) and
        # RECORD that List_Box_i64 is needed. We don't ensure_list_type here: this
        # scan runs BEFORE generate_types_header swaps in a fresh list_types_buf,
        # so the emission must be deferred to emit_list_fwd_decls (post-redirect).
        # Non-generic value-type lists (List_StrView, List_Date) are already
        # ensured by emit_list_fwd_decls iterating prog.classes.
        if (ty.name == "List" or ty.name == "Vec") and ty.args.len > 0:
            mut elty = ty.args.get(0).read()
            if self.value_types.contains(elty.name) and elty.args.len > 0 and self.classes.contains(elty.name):
                self.ensure_mono(self.classes.get(elty.name), elty.args)
                self.value_list_elems.push(elty.name + "_" + self.type_args_suffix(elty.args))
        # Dict/Map with a non-generic value-type VALUE -> record a typed inline dict.
        if (ty.name == "Map" or ty.name == "Dict") and ty.args.len > 1:
            mut vty = ty.args.get(1).read()
            if self.value_types.contains(vty.name) and vty.args.len == 0:
                mut kc2 = "str"
                mut kty = ty.args.get(0).read()
                if _is_int_type(kty.name) or kty.name == "int" or kty.name == "i64" or kty.name == "usize": kc2 = "i64"
                self.value_dict_elems.push(kc2 + "|" + vty.name)
        # Set with a non-generic value-type ELEMENT -> record a typed inline set.
        if ty.name == "Set" and ty.args.len > 0:
            mut sty = ty.args.get(0).read()
            if self.value_types.contains(sty.name) and sty.args.len == 0:
                self.value_set_elems.push(sty.name)

    pub def scan_mono_block(self, block: HirBlock):
        if _is_invalid_ptr(block as usize): return
        if _is_invalid_ptr(block.stmts as usize): return
        mut i = 0
        while i < block.stmts.len:
            self.scan_mono_stmt(block.stmts.get(i))
            i = i + 1

    # Scan expression tree for __MONO_-mangled generic function calls.
    pub def scan_mono_expr(self, e: Pointer[HirExpr]):
        if e as usize == 0 as usize: return
        if _is_invalid_ptr(e as usize): return
        match e.read():
            case HirExpr.ECall(callee, args, _):
                self.scan_mono_expr(callee)
                mut ei = 0
                while ei < args.len:
                    self.scan_mono_expr(args.get(ei))
                    ei = ei + 1
                match callee.read():
                    case HirExpr.EIdent(mn, _, _):
                        if mn.contains("__MONO_"):
                            mut nlen = _tr_strlen(mn)
                            mut si2 = 0
                            mut found_s = false
                            mut sep_p = 0
                            while si2 <= nlen - 7 and not found_s:
                                if mn.slice(si2, si2 + 7) == "__MONO_":
                                    found_s = true
                                    sep_p = si2
                                si2 = si2 + 1
                            if found_s:
                                mut gfunc_n = mn.slice(0, sep_p)
                                mut gfunc_t = mn.slice(sep_p + 7, nlen)
                                if self.functions.contains(gfunc_n):
                                    self.ensure_mono_func(gfunc_n, gfunc_t)
                        else:
                            # Inference call (no explicit [T]): specialize before the
                            # mono buffer is flushed so the copy + prototype exist.
                            mut _sit = self.infer_generic_targ(mn, args)
                            if _sit != "": self.ensure_mono_func(mn, _sit)
                    case _: pass
            case HirExpr.EMethodCall(obj, _, margs, _):
                self.scan_mono_expr(obj)
                mut ei2 = 0
                while ei2 < margs.len:
                    self.scan_mono_expr(margs.get(ei2))
                    ei2 = ei2 + 1
            case HirExpr.EBinOp(_, bl, br, _):
                self.scan_mono_expr(bl)
                self.scan_mono_expr(br)
            case HirExpr.EUnaryOp(_, ue, _):
                self.scan_mono_expr(ue)
            case _: pass

    pub def scan_mono_stmt(self, s_ptr: Pointer[HirStmt]):
        if _is_invalid_ptr(s_ptr as usize): return
        match s_ptr.read():
            case HirStmt.SLet(_, _, _, _, _, ty, val):
                self.scan_mono_ty(ty)
                if val as usize != 0 as usize: self.scan_mono_expr(val)
            case HirStmt.SExpr(expr):
                if expr as usize != 0 as usize: self.scan_mono_expr(expr)
            case HirStmt.SReturn(val):
                if val as usize != 0 as usize: self.scan_mono_expr(val)
            case HirStmt.SIf(cond_s, then_b, else_b):
                if cond_s as usize != 0 as usize: self.scan_mono_expr(cond_s)
                self.scan_mono_block(then_b)
                if else_b as usize != 0 as usize:
                    self.scan_mono_block(else_b)
            case HirStmt.SWhile(cond_s2, body):
                if cond_s2 as usize != 0 as usize: self.scan_mono_expr(cond_s2)
                self.scan_mono_block(body)
            case HirStmt.SFor(_, _, body):
                self.scan_mono_block(body)
            case HirStmt.SForUnpack(_, _, body):
                self.scan_mono_block(body)
            case HirStmt.SMatch(subj_s, arms):
                if subj_s as usize != 0 as usize: self.scan_mono_expr(subj_s)
                mut ai = 0
                while ai < arms.len:
                    self.scan_mono_block(arms.get(ai).body)
                    ai = ai + 1
            case HirStmt.STry(try_body, catches, finally_b):
                self.scan_mono_block(try_body)
                if finally_b as usize != 0 as usize:
                    self.scan_mono_block(finally_b)
            case HirStmt.SUnsafe(body):
                self.scan_mono_block(body)
            case HirStmt.STaskGroup(body):
                self.scan_mono_block(body)
            case _: pass

    pub def scan_mono_func(self, f: HirFunction):
        self.scan_mono_ty(f.ret_ty)
        mut i = 0
        while i < f.params.len:
            self.scan_mono_ty(f.params.get(i).ty)
            i = i + 1
        self.scan_mono_block(f.body)

    pub def scan_mono_prog(self, prog: HirProgram):
        # Scan field and method types in concrete (non-generic) classes only.
        # Generic classes use unresolved type params (T, V, ...) in their signatures;
        # scanning them here would call ensure_mono with non-concrete args.
        mut i = 0
        while i < prog.classes.len:
            mut cls = prog.classes.get(i)
            if cls.generics.len == 0:
                mut fi = 0
                while fi < cls.fields.len:
                    self.scan_mono_ty(cls.fields.get(fi).ty)
                    fi = fi + 1
                mut mi = 0
                while mi < cls.methods.len:
                    self.scan_mono_func(cls.methods.get(mi))
                    mi = mi + 1
            i = i + 1
        # Scan free-standing functions (skip methods of generic classes -
        # their signatures contain unresolved type params like T/V).
        i = 0
        while i < prog.functions.len:
            mut fn = prog.functions.get(i)
            mut skip = false
            if fn.class_name != "":
                if self.classes.contains(fn.class_name):
                    mut owner = self.classes.get(fn.class_name)
                    if owner.generics.len > 0: skip = true
            if fn.generics.len > 0: skip = true
            if not skip: self.scan_mono_func(fn)
            i = i + 1
        # Scan top-level stmts
        i = 0
        while i < prog.top_level_stmts.len:
            self.scan_mono_stmt(prog.top_level_stmts.get(i))
            i = i + 1

    pub def generate(self, prog: HirProgram) -> str:
        self.register_program(prog)

        # -- Runtime header include + file-wide optimization pragmas ----
        self.w("#define _TR_MAIN\n")
        if self.tier_define != "": self.w("#define " + self.tier_define + "\n")
        self.w(self.emit_tier_hooks(prog))
        self.w("#include \"tauraro_rt.h\"\n")

        # -- Forward declarations (opaque struct pointers) ------------
        # Skip generic classes - their monomorphized versions are emitted below
        mut i = 0
        while i < prog.classes.len:
            mut cls2 = prog.classes.get(i)
            if cls2.generics.len == 0:
                self.w("typedef struct " + cls2.name + " " + cls2.name + ";\n")
            i = i + 1
        i = 0
        while i < prog.enums.len:
            self.w("typedef struct " + prog.enums.get(i).name + " " + prog.enums.get(i).name + ";\n")
            i = i + 1
        i = 0
        while i < prog.interfaces.len:
            mut iface_fwd = prog.interfaces.get(i)
            if iface_fwd.generics.len == 0:
                self.w("typedef struct _" + iface_fwd.name + "_vtable " + iface_fwd.name + "_vtable;\n")
            i = i + 1
        # Emit forward declarations for value-type List_T structs used in fields
        self.emit_list_fwd_decls(prog)
        self.w("\n")

        # -- Extern C function declarations -------------------------
        # `extern "CPP"`/`extern "C++"` blocks are accepted as synonyms for
        # `extern "C"`: to call into a C++ library, expose (or write a thin
        # shim with) `extern "C"` functions and link the .o/.a via --link.
        i = 0
        while i < prog.extern_funcs.len:
            mut ef = prog.extern_funcs.get(i)
            mut ef_ret = self.type_to_c(ef.ret_ty)
            mut ef_name = ef.name
            if not _starts_with_tr(ef_name):
                self.w("extern " + ef_ret + " " + ef_name + "(")
                mut ef_first = true
                mut epi = 0
                while epi < ef.params.len:
                    mut ep = ef.params.get(epi)
                    if ep.name != "self":
                        if not ef_first: self.w(", ")
                        self.w(self.type_to_c(ep.ty) + " " + ep.name)
                        ef_first = false
                    epi = epi + 1
                if ef.is_variadic:
                    if not ef_first: self.w(", ")
                    self.w("...")
                self.w(");\n")
            i = i + 1
        if prog.extern_funcs.len > 0: self.w("\n")

        # -- Generic monomorphization ------------------------------
        # Pre-scan all HIR types to collect and generate monomorphized classes.
        # mono_buf accumulates: fwd decl + struct body + prototypes + impls.
        self.scan_mono_prog(prog)
        mut mono_out = self.mono_buf.to_string().as_str()
        if mono_out != "":
            self.w(mono_out)
            self.w("\n")

        # -- Struct definitions ---------------------------------------
        self.emit_drop_fwd_decls(prog)
        i = 0
        while i < prog.enums.len:
            self.gen_enum_struct(prog.enums.get(i))
            i = i + 1
        i = 0
        while i < prog.classes.len:
            mut cls3 = prog.classes.get(i)
            if cls3.generics.len == 0:
                self.gen_class_struct(cls3)
            i = i + 1
        i = 0
        while i < prog.interfaces.len:
            self.gen_interface_vtable(prog.interfaces.get(i))
            i = i + 1

        # Flush struct buffer into main output
        self.w(self.struct_buf.to_string().as_str())
        self.struct_buf = StringBuilder.init(16)

        # -- Value-type list definitions (after all enums/structs defined) --
        mut lt_out = self.list_types_buf.to_string().as_str()
        if lt_out != "": self.w(lt_out)

        # -- Top-level global variables ------------------------------
        # Module-level `mut`/`const` vars are declared at C file scope so every
        # function can see them (not just main). The initializer runs in main
        # (in main), since it may be a non-constant expression.
        mut gvi = 0
        while gvi < prog.top_level_stmts.len:
            match prog.top_level_stmts.get(gvi).read():
                case HirStmt.SLet(gvn, _, _, _, _, gvty, gvval):
                    mut gv_cty = self.type_to_c(gvty)
                    if gv_cty == "void" or gv_cty == "__auto_type":
                        if gvval as usize != 0 as usize: gv_cty = self.type_to_c(hir_expr_type(gvval))
                    if gv_cty == "void" or gv_cty == "__auto_type": gv_cty = "long long"
                    self.w(gv_cty + " " + gvn + ";\n")
                    self.global_vars.insert(gvn, true)
                case _: pass
            gvi = gvi + 1

        # -- Function prototypes --------------------------------------
        i = 0
        while i < prog.classes.len:
            mut c = prog.classes.get(i)
            if c.generics.len == 0:
                mut mi = 0
                while mi < c.methods.len:
                    mut m = c.methods.get(mi)
                    self.w(self.get_inline_attrs(m) + self.gen_func_sig(m, c.name) + ";\n")
                    mi = mi + 1
            i = i + 1
        i = 0
        while i < prog.enums.len:
            mut e = prog.enums.get(i)
            mut mi = 0
            while mi < e.methods.len:
                mut m = e.methods.get(mi)
                self.w(self.get_inline_attrs(m) + self.gen_func_sig(m, e.name) + ";\n")
                mi = mi + 1
            i = i + 1
        i = 0
        while i < prog.functions.len:
            mut f = prog.functions.get(i)
            if f.name != "main" and not f.is_extern:
                mut skip4 = false
                if f.class_name != "":
                    skip4 = true   # class/enum methods handled in per-class loops or mono_buf
                # A generic free function is emitted only as monomorphized copies
                # (fname__MONO_T) into mono_buf — never as an erased void* template.
                if f.generics.len > 0:
                    skip4 = true
                if not skip4:
                    if not self.emitted_fns.contains("p_" + f.name):
                        self.emitted_fns.insert("p_" + f.name, true)
                        self.w(self.get_inline_attrs(f) + self.gen_func_sig(f, f.class_name) + ";\n")
            i = i + 1
        self.w("\n")

        # -- Spawn + async wrappers (static thread-entry functions) --
        self.prescan_spawns(prog)
        self.prescan_awaits(prog)
        self.w("\n")

        # -- Method implementations -----------------------------------
        i = 0
        while i < prog.classes.len:
            mut c = prog.classes.get(i)
            if c.generics.len == 0:
                mut mi = 0
                while mi < c.methods.len:
                    mut m = c.methods.get(mi)
                    self.cur_class = c.name
                    self.cur_func  = m.name
                    self.cur_throws_ty = m.throws_ty.name
                    self.decl_vars = Map[str, bool].init(64)
                    self.str_local_names = Map[str, bool].init(16)
                    self.coll_local_sfx = Map[str, str].init(16)
                    self.coll_local_idict = Map[str, bool].init(16)
                    self.coll_local_strval = Map[str, bool].init(16)
                    self.coll_local_vtcoll = Map[str, str].init(16)
                    self.shared_vars = Map[str, str].init(8)
                    self.seed_params(m)
                    self.cur_self_is_ptr = self.value_types.contains(c.name) and self.vt_method_mutates_self(m)
                    self.w(self.get_inline_attrs(m) + self.gen_func_sig(m, c.name) + " {\n")
                    self.gen_func_body(m.body, 1)
                    self.cur_self_is_ptr = false
                    self.w("}\n\n")
                    self.cur_class = ""
                    self.cur_func  = ""
                    self.cur_throws_ty = ""
                    mi = mi + 1
            i = i + 1

        i = 0
        while i < prog.enums.len:
            mut e = prog.enums.get(i)
            mut mi = 0
            while mi < e.methods.len:
                mut m = e.methods.get(mi)
                self.cur_class = e.name
                self.cur_func  = m.name
                self.cur_throws_ty = m.throws_ty.name
                self.decl_vars = Map[str, bool].init(64)
                self.str_local_names = Map[str, bool].init(16)
                self.coll_local_sfx = Map[str, str].init(16)
                self.coll_local_idict = Map[str, bool].init(16)
                self.coll_local_strval = Map[str, bool].init(16)
                self.coll_local_vtcoll = Map[str, str].init(16)
                self.shared_vars = Map[str, str].init(8)
                self.seed_params(m)
                self.w(self.get_inline_attrs(m) + self.gen_func_sig(m, e.name) + " {\n")
                self.gen_func_body(m.body, 1)
                self.w("}\n\n")
                self.cur_class = ""
                self.cur_func  = ""
                self.cur_throws_ty = ""
                mi = mi + 1
            i = i + 1

        # -- Free-standing function implementations -------------------
        i = 0
        while i < prog.functions.len:
            mut f = prog.functions.get(i)
            if f.name != "main" and not f.is_extern:
                mut skip6 = false
                if f.class_name != "":
                    skip6 = true   # class/enum methods handled in per-class loops or mono_buf
                # Generic free function: only monomorphized copies are emitted (mono_buf).
                if f.generics.len > 0:
                    skip6 = true
                # Skip duplicate free-standing functions (same name from multiple modules)
                if not skip6:
                    if self.emitted_fns.contains("i_" + f.name):
                        skip6 = true
                    else:
                        self.emitted_fns.insert("i_" + f.name, true)
                if not skip6:
                    self.cur_func  = f.name
                    self.cur_class = f.class_name
                    self.cur_throws_ty = f.throws_ty.name
                    self.decl_vars = Map[str, bool].init(64)
                    self.str_local_names = Map[str, bool].init(16)
                    self.coll_local_sfx = Map[str, str].init(16)
                    self.coll_local_idict = Map[str, bool].init(16)
                    self.coll_local_strval = Map[str, bool].init(16)
                    self.coll_local_vtcoll = Map[str, str].init(16)
                    self.shared_vars = Map[str, str].init(8)
                    self.seed_params(f)
                    self.w(self.get_inline_attrs(f) + self.gen_func_sig(f, f.class_name) + " {\n")
                    self.gen_func_body(f.body, 1)
                    self.w("}\n\n")
                    self.cur_func  = ""
                    self.cur_class = ""
                    self.cur_throws_ty = ""
            i = i + 1

        # -- C main entry point ---------------------------------------
        self.emit_entry_glue(prog)
        self.w("__attribute__((hot)) int main(int argc, char** argv) {\n")
        self.w("    _tr_argc = argc; _tr_argv = argv;\n")
        self.w("    _tr_init_console();\n")
        # NOTE: the global async pool is created LAZILY on first use (see
        # _tr_async_pool() in the runtime). Eagerly spawning one worker thread
        # per CPU here cost ~1-2 MB of stack per core (~64+ MB on big machines)
        # in EVERY program, even pure-compute ones that never touch async.
        # Set up args list only when main() takes a parameter
        mut main_has_args = false
        mut main_args_name = "args"
        mut mi2 = 0
        while mi2 < prog.functions.len:
            mut mf = prog.functions.get(mi2)
            if mf.name == "main" and mf.params.len > 0:
                main_has_args = true
                main_args_name = mf.params.get(0).name
            mi2 = mi2 + 1
        if main_has_args:
            # Rename to avoid shadowing C's char** argv parameter
            if main_args_name == "argv": main_args_name = "_tr_main_argv"
            self.w("    List_TrStr* " + main_args_name + " = List_TrStr_new();\n")
            self.w("    for (int _ai = 0; _ai < argc; _ai++) { List_TrStr_append(" + main_args_name + ", _tr_str_lit(argv[_ai])); }\n")

        # Call top-level statements. A hoisted global var (declared at file scope
        # at file scope) is initialized here with an assignment, not re-declared.
        i = 0
        while i < prog.top_level_stmts.len:
            mut _tl_global = false
            match prog.top_level_stmts.get(i).read():
                case HirStmt.SLet(tln, _, _, _, _, _, tlv):
                    if self.global_vars.contains(tln) and tlv as usize != 0 as usize:
                        self.w("    " + tln + " = " + self.gen_expr(tlv) + ";\n")
                        _tl_global = true
                case _: pass
            if not _tl_global:
                self.gen_stmt(prog.top_level_stmts.get(i), 1)
            i = i + 1

        # Call user's main function if it exists
        i = 0
        while i < prog.functions.len:
            mut f = prog.functions.get(i)
            if f.name == "main":
                self.cur_func  = "main"
                self.decl_vars = Map[str, bool].init(64)
                self.str_local_names = Map[str, bool].init(16)
                self.coll_local_sfx = Map[str, str].init(16)
                self.coll_local_idict = Map[str, bool].init(16)
                self.coll_local_strval = Map[str, bool].init(16)
                self.coll_local_vtcoll = Map[str, str].init(16)
                self.gen_func_body(f.body, 1)
                self.cur_func  = ""
            i = i + 1

        self.w("#ifndef TAURARO_BARE\n")
        self.w("    _tr_async_pool_shutdown();\n")
        self.w("#endif\n")
        self.w("    return 0;\n}\n")

        self.flush_closures()
        return self.buf.to_string().as_str()

    # -- Modular output helpers ----------------------------------------------------

    # Full types header: forward decls + struct/enum/interface bodies + ALL function
    # prototypes from every module.  Each module .c file does #include "tauraro_types.h"
    # so every cross-module call is visible to the C compiler without extra header files.
    pub def generate_types_header(self, prog: HirProgram) -> str:
        if _is_invalid_ptr(prog as usize): return ""
        if _is_invalid_ptr(prog.classes as usize): return ""
        if _is_invalid_ptr(prog.enums as usize): return ""
        if _is_invalid_ptr(prog.interfaces as usize): return ""
        if _is_invalid_ptr(prog.functions as usize): return ""

        if self.classes.len == 0:
            self.register_program(prog)
            self.scan_mono_prog(prog)

        # Temporarily redirect self.buf / struct_buf / list_types_buf so that the
        # helpers (emit_list_fwd_decls, gen_class_struct, etc.) write into our buffers.
        mut old_buf      = self.buf
        mut old_struct   = self.struct_buf
        mut old_list     = self.list_types_buf
        self.buf           = StringBuilder.init(4096)
        self.struct_buf    = StringBuilder.init(16384)
        self.list_types_buf = StringBuilder.init(2048)

        mut out = StringBuilder.init(65536)
        out.append("#pragma once\n")
        # Suppress rt.h helper fallbacks (StringBuilder, file I/O) when the std library
        # provides its own canonical implementations.  Detect by checking if "StringBuilder"
        # class or "read_file" / "write_file" functions appear in the compiled program.
        mut has_std_lib = false
        mut sbi = 0
        while sbi < prog.classes.len:
            mut sbc = prog.classes.get(sbi)
            if not _is_invalid_ptr(sbc as usize):
                if sbc.name == "StringBuilder":
                    has_std_lib = true
                    break
            sbi = sbi + 1
        if not has_std_lib:
            mut fi2 = 0
            while fi2 < prog.functions.len:
                mut fc = prog.functions.get(fi2)
                if not _is_invalid_ptr(fc as usize):
                    if fc.name == "read_file" or fc.name == "write_file":
                        has_std_lib = true
                        break
                fi2 = fi2 + 1
        if has_std_lib:
            out.append("#define TAURARO_STD_LIB\n")
            out.append("#define TAURARO_RT_NO_STRINGBUILDER\n")
        if self.tier_define != "": out.append("#define " + self.tier_define + "\n")
        # Hook wiring (@allocator/@output) goes in the SHARED header so every module
        # TU — not just main.c — sees TAURARO_ALLOC/... before the runtime include
        # (else a std module like std.hal.mmio hits the TAURARO_KERNEL #error).
        out.append(self.emit_tier_hooks(prog))
        out.append("#include \"tauraro_rt.h\"\n\n")

        # -- Forward declarations ----------------------------------------------
        mut i = 0
        while i < prog.classes.len:
            mut c2 = prog.classes.get(i)
            if not _is_invalid_ptr(c2 as usize):
                if c2.generics.len == 0:
                    mut fwd_key = "fwd_" + c2.name
                    if not self.emitted_fns.contains(fwd_key):
                        self.emitted_fns.insert(fwd_key, true)
                        out.append("typedef struct " + c2.name + " " + c2.name + ";\n")
            i = i + 1
        i = 0
        while i < prog.enums.len:
            mut e2 = prog.enums.get(i)
            if not _is_invalid_ptr(e2 as usize):
                mut fwd_key2 = "fwd_" + e2.name
                if not self.emitted_fns.contains(fwd_key2):
                    self.emitted_fns.insert(fwd_key2, true)
                    out.append("typedef struct " + e2.name + " " + e2.name + ";\n")
            i = i + 1
        i = 0
        while i < prog.interfaces.len:
            mut iface2 = prog.interfaces.get(i)
            if not _is_invalid_ptr(iface2 as usize):
                if iface2.generics.len == 0:
                    out.append("typedef struct _" + iface2.name + "_vtable " + iface2.name + "_vtable;\n")
                    out.append("typedef struct { " + iface2.name + "_vtable* vtable; void* data; } " + iface2.name + "_obj;\n")
                    self.emitted_fns.insert("iface_obj_" + iface2.name, true)
            i = i + 1
        self.emit_list_fwd_decls(prog)          # writes to self.buf
        out.append(self.buf.to_string().as_str())
        self.buf = StringBuilder.init(256)
        out.append("\n")

        # -- Monomorphized generic types (must precede prototypes that use them) -
        mut mono_early = self.mono_buf.to_string().as_str()
        if mono_early != "": out.append(mono_early + "\n")

        # -- Extern C declarations -----------------------------------------------
        if not _is_invalid_ptr(prog.extern_funcs as usize):
            i = 0
            while i < prog.extern_funcs.len:
                mut ef = prog.extern_funcs.get(i)
                if not _is_invalid_ptr(ef as usize):
                    if not _starts_with_tr(ef.name):
                        mut ef_s = "extern " + self.type_to_c(ef.ret_ty) + " " + ef.name + "("
                        mut ef_first = true
                        mut epi = 0
                        while epi < ef.params.len:
                            mut ep = ef.params.get(epi)
                            if ep.name != "self":
                                if not ef_first: ef_s = ef_s + ", "
                                ef_s = ef_s + self.type_to_c(ep.ty) + " " + ep.name
                                ef_first = false
                            epi = epi + 1
                        if ef.is_variadic:
                            if not ef_first: ef_s = ef_s + ", "
                            ef_s = ef_s + "..."
                        out.append(ef_s + ");\n")
                i = i + 1
            if prog.extern_funcs.len > 0: out.append("\n")

        # -- User type aliases: `type Name = Target` -> `typedef Target Name;` -----
        if not _is_invalid_ptr(prog.type_alias_names as usize):
            mut tai = 0
            while tai < prog.type_alias_names.len:
                mut ta_name = prog.type_alias_names.get(tai)
                mut ta_ty_p = prog.type_alias_types.get(tai)
                if ta_ty_p as usize != 0 as usize:
                    mut ta_c = self.type_to_c(ta_ty_p.read())
                    out.append("typedef " + ta_c + " " + ta_name + ";\n")
                tai = tai + 1
            if prog.type_alias_names.len > 0: out.append("\n")

        # -- Struct / enum / interface definitions (BEFORE prototypes) ------------
        # Must come before function prototypes so that Vec[UserType] list structs
        # (e.g. List_JsonVal) are defined before any prototype uses them.
        self.emit_drop_fwd_decls(prog)
        i = 0
        while i < prog.enums.len:
            mut e3 = prog.enums.get(i)
            if not _is_invalid_ptr(e3 as usize):
                self.gen_enum_struct(e3)
            i = i + 1
        i = 0
        while i < prog.classes.len:
            mut c3 = prog.classes.get(i)
            if not _is_invalid_ptr(c3 as usize):
                if c3.generics.len == 0:
                    self.gen_class_struct(c3)
            i = i + 1
        i = 0
        while i < prog.interfaces.len:
            mut iface3 = prog.interfaces.get(i)
            if not _is_invalid_ptr(iface3 as usize):
                self.gen_interface_vtable(iface3)
            i = i + 1
        out.append(self.struct_buf.to_string().as_str())
        out.append(self.list_types_buf.to_string().as_str())
        out.append("\n")

        # -- Freestanding Function Prototypes (so generic monomorphization can call them) --
        i = 0
        while i < prog.functions.len:
            mut f4 = prog.functions.get(i)
            if not _is_invalid_ptr(f4 as usize):
                if f4.name != "main" and not f4.is_extern:
                    if f4.class_name != "":
                        # Extend-block methods: emit prototype with class prefix.
                        # Skip generic classes (Vec, Map, etc.) - monomorphized variants handle their own prototypes.
                        mut skip4_generic = false
                        if self.classes.contains(f4.class_name):
                            mut cls4g = self.classes.get(f4.class_name)
                            if cls4g.generics.len > 0:
                                skip4_generic = true
                        if not skip4_generic:
                            mut ep_key = "p_" + f4.class_name + "_" + f4.name
                            if not self.emitted_fns.contains(ep_key):
                                self.emitted_fns.insert(ep_key, true)
                                out.append(self.get_proto_attrs(f4) + self.gen_func_sig(f4, f4.class_name) + ";\n")
                    elif f4.generics.len == 0:
                        if not self.emitted_fns.contains("p_" + f4.name):
                            self.emitted_fns.insert("p_" + f4.name, true)
                            out.append(self.get_proto_attrs(f4) + self.gen_func_sig(f4, f4.class_name) + ";\n")
            i = i + 1
        out.append("\n")

        # -- ALL function prototypes (cross-module visibility) -----------------
        i = 0
        while i < prog.classes.len:
            mut c4 = prog.classes.get(i)
            if not _is_invalid_ptr(c4 as usize):
                if c4.generics.len == 0:
                    mut mi = 0
                    if not _is_invalid_ptr(c4.methods as usize):
                        while mi < c4.methods.len:
                            mut m = c4.methods.get(mi)
                            if not _is_invalid_ptr(m as usize):
                                mut ep_key3 = "p_" + c4.name + "_" + m.name
                                if not self.emitted_fns.contains(ep_key3):
                                    self.emitted_fns.insert(ep_key3, true)
                                    out.append(self.get_proto_attrs(m) + self.gen_func_sig(m, c4.name) + ";\n")
                            mi = mi + 1
            i = i + 1
        i = 0
        while i < prog.enums.len:
            mut e4 = prog.enums.get(i)
            if not _is_invalid_ptr(e4 as usize):
                mut mi = 0
                if not _is_invalid_ptr(e4.methods as usize):
                    while mi < e4.methods.len:
                        mut m = e4.methods.get(mi)
                        if not _is_invalid_ptr(m as usize):
                            out.append(self.get_proto_attrs(m) + self.gen_func_sig(m, e4.name) + ";\n")
                        mi = mi + 1
            i = i + 1
        i = 0
        while i < prog.functions.len:
            mut f4 = prog.functions.get(i)
            if not _is_invalid_ptr(f4 as usize):
                if f4.name != "main" and not f4.is_extern:
                    if f4.class_name != "":
                        # Extend-block methods: emit prototype with class prefix.
                        # Skip generic classes (Vec, Map, etc.) - monomorphized variants handle their own prototypes.
                        mut skip4b_generic = false
                        if self.classes.contains(f4.class_name):
                            mut cls4bg = self.classes.get(f4.class_name)
                            if cls4bg.generics.len > 0:
                                skip4b_generic = true
                        if not skip4b_generic:
                            mut ep_key2 = "p_" + f4.class_name + "_" + f4.name
                            if not self.emitted_fns.contains(ep_key2):
                                self.emitted_fns.insert(ep_key2, true)
                                out.append(self.get_proto_attrs(f4) + self.gen_func_sig(f4, f4.class_name) + ";\n")
                    elif f4.generics.len == 0:
                        if not self.emitted_fns.contains("p_" + f4.name):
                            self.emitted_fns.insert("p_" + f4.name, true)
                            out.append(self.get_proto_attrs(f4) + self.gen_func_sig(f4, f4.class_name) + ";\n")
            i = i + 1
        out.append("\n")

        # -- Monomorphized generic FREE-function bodies (after all prototypes, so their
        # calls to other user functions resolve; static, so shared-header inclusion in
        # every TU is duplicate-safe). Their prototypes were emitted early in mono_buf.
        mut fn_mono_out = self.fn_mono_body.to_string().as_str()
        if fn_mono_out != "": out.append(fn_mono_out + "\n")

        # -- Spawn + async wrappers (after prototypes so wrappers can call declared fns) -
        self.buf = StringBuilder.init(1024)
        self.prescan_spawns(prog)
        self.prescan_awaits(prog)
        mut sw_out = self.buf.to_string().as_str()
        self.buf = StringBuilder.init(256)
        if sw_out != "":
            out.append(sw_out)
            out.append("\n")

        # -- Interface vtable wrap functions (static inline, after prototypes) -
        mut wi = 0
        while wi < prog.classes.len:
            mut wcls = prog.classes.get(wi)
            if not _is_invalid_ptr(wcls as usize):
                if wcls.generics.len == 0 and wcls.iface_names as usize != 0 as usize and not _is_invalid_ptr(wcls.iface_names as usize):
                    mut wii = 0
                    while wii < wcls.iface_names.len:
                        mut wiface_name = wcls.iface_names.get(wii)
                        if self.interfaces.contains(wiface_name):
                            mut wiface = self.interfaces.get(wiface_name)
                            if not _is_invalid_ptr(wiface as usize):
                                out.append(self.gen_one_iface_wrap(wcls.name, wiface))
                                out.append("\n")
                        wii = wii + 1
            wi = wi + 1

        # -- Module-level `mut`/`let` globals: extern declarations -------------
        # Definitions (with initializers, run in main()) are emitted by
        # the global-variable hoisting only into the entry module's C file.
        # Every other module's C file needs an `extern` declaration to
        # reference these globals, so declare them here in the shared header.
        mut hgi = 0
        while hgi < prog.top_level_stmts.len:
            match prog.top_level_stmts.get(hgi).read():
                case HirStmt.SLet(hgn, _, _, _, _, hgty, hgval):
                    mut hg_cty = self.type_to_c(hgty)
                    if hg_cty == "void" or hg_cty == "__auto_type":
                        if hgval as usize != 0 as usize: hg_cty = self.type_to_c(hir_expr_type(hgval))
                    if hg_cty == "void" or hg_cty == "__auto_type": hg_cty = "long long"
                    out.append("extern " + hg_cty + " " + hgn + ";\n")
                case _: pass
            hgi = hgi + 1

        # Restore all temporary buffers
        self.buf           = old_buf
        self.struct_buf    = old_struct
        self.list_types_buf = old_list

        return out.to_string().as_str()

    # Appended to tauraro_types.h: module-prefixed typedef aliases + Vec/Map struct defs +
    # core_alloc declarations, so include/core/*.c can use module-qualified names against
    # the self-hosted-generated header without modification.
    pub def generate_module_compat(self, all_decl_modules: Vec[str], all_decls: Vec[Pointer[Decl]]) -> str:
        mut out = "\n/* === Module-prefixed typedef aliases (auto-generated) === */\n"
        out = out + "/* Maps module-qualified C names to short-name types in tauraro_types.h */\n\n"

        out = out + "#ifndef TAURARO_RT_NO_STRINGBUILDER\n"
        out = out + "typedef struct core_string_StringObj core_string_StringObj;\n"
        out = out + "typedef core_string_StringObj StringObj;\n"
        out = out + "typedef struct core_string_StringBuilder core_string_StringBuilder;\n"
        out = out + "typedef core_string_StringBuilder StringBuilder;\n"
        out = out + "#endif\n\n"

        mut seen = Map[str, bool].init(128)
        mut i = 0
        while i < all_decl_modules.len:
            mut mod_dp = all_decl_modules.get(i)
            if mod_dp != "":
                mut sm = _c_dot_to_safe(mod_dp)
                match all_decls.get(i).read():
                    case Decl.DClass(c):
                        if c.generics.len == 0:
                            mut key = sm + "_" + c.name
                            if not seen.contains(key):
                                seen.insert(key, true)
                                out = out + "typedef " + c.name + " " + key + ";\n"
                                out = out + "struct core_vec_Vec_" + key + " { " + key + "** data; long long len; long long capacity; };\n"
                                out = out + "typedef struct core_vec_Vec_" + key + " core_vec_Vec_" + key + ";\n"
                                out = out + "struct core_vec_Vec_" + key + "_ptr { " + key + "*** data; long long len; long long capacity; };\n"
                                out = out + "typedef struct core_vec_Vec_" + key + "_ptr core_vec_Vec_" + key + "_ptr;\n"
                                out = out + "struct core_map_MapNode_str_" + key + " { char* key; " + key + "* value; struct core_map_MapNode_str_" + key + "* next; };\n"
                                out = out + "typedef struct core_map_MapNode_str_" + key + " core_map_MapNode_str_" + key + ";\n"
                                out = out + "struct core_map_Map_str_" + key + " { core_map_MapNode_str_" + key + "** buckets; long long capacity; long long len; };\n"
                                out = out + "typedef struct core_map_Map_str_" + key + " core_map_Map_str_" + key + ";\n"
                                out = out + "__attribute__((hot)) " + key + "** core_alloc_alloc_" + key + "(long long count);\n"
                                out = out + "__attribute__((hot)) " + key + "** core_alloc_resize_" + key + "(" + key + "** ptr, long long new_count);\n"
                                out = out + "__attribute__((hot)) void core_alloc_dealloc_" + key + "(" + key + "** ptr);\n"
                                out = out + "__attribute__((hot)) " + key + "*** core_alloc_alloc_" + key + "_ptr(long long count);\n"
                                out = out + "__attribute__((hot)) " + key + "*** core_alloc_resize_" + key + "_ptr(" + key + "*** ptr, long long new_count);\n"
                                out = out + "__attribute__((hot)) void core_alloc_dealloc_" + key + "_ptr(" + key + "*** ptr);\n"
                                out = out + "__attribute__((hot)) core_map_MapNode_str_" + key + "** core_alloc_alloc_core_map_MapNode_str_" + key + "(long long count);\n"
                                out = out + "__attribute__((hot)) void core_alloc_dealloc_core_map_MapNode_str_" + key + "(core_map_MapNode_str_" + key + "** ptr);\n"
                                out = out + "\n"
                    case Decl.DEnum(e):
                        if e.generics.len == 0:
                            mut key = sm + "_" + e.name
                            if not seen.contains(key):
                                seen.insert(key, true)
                                out = out + "typedef " + e.name + " " + key + ";\n"
                                out = out + "struct core_vec_Vec_" + key + " { " + key + "* data; long long len; long long capacity; };\n"
                                out = out + "typedef struct core_vec_Vec_" + key + " core_vec_Vec_" + key + ";\n"
                                out = out + "struct core_vec_Vec_" + key + "_ptr { " + key + "** data; long long len; long long capacity; };\n"
                                out = out + "typedef struct core_vec_Vec_" + key + "_ptr core_vec_Vec_" + key + "_ptr;\n"
                                out = out + "__attribute__((hot)) " + key + "* core_alloc_alloc_" + key + "(long long count);\n"
                                out = out + "__attribute__((hot)) " + key + "* core_alloc_resize_" + key + "(" + key + "* ptr, long long new_count);\n"
                                out = out + "__attribute__((hot)) void core_alloc_dealloc_" + key + "(" + key + "* ptr);\n"
                                out = out + "__attribute__((hot)) " + key + "** core_alloc_alloc_" + key + "_ptr(long long count);\n"
                                out = out + "__attribute__((hot)) " + key + "** core_alloc_resize_" + key + "_ptr(" + key + "** ptr, long long new_count);\n"
                                out = out + "__attribute__((hot)) void core_alloc_dealloc_" + key + "_ptr(" + key + "** ptr);\n"
                                out = out + "\n"
                    case Decl.DInterface(iface):
                        if iface.generics.len == 0:
                            mut key = sm + "_" + iface.name
                            if not seen.contains(key):
                                seen.insert(key, true)
                                out = out + "typedef " + iface.name + "_obj " + key + ";\n\n"
                    case _: pass
            i = i + 1

        out = out + "/* Primitive vec/map types for core modules */\n"
        out = out + "struct core_vec_Vec_str { char** data; long long len; long long capacity; };\n"
        out = out + "typedef struct core_vec_Vec_str core_vec_Vec_str;\n"
        out = out + "__attribute__((hot)) char** core_alloc_alloc_str(long long count);\n"
        out = out + "__attribute__((hot)) char** core_alloc_resize_str(char** ptr, long long new_count);\n"
        out = out + "__attribute__((hot)) void core_alloc_dealloc_str(char** ptr);\n"
        out = out + "struct core_vec_Vec_i64 { long long* data; long long len; long long capacity; };\n"
        out = out + "typedef struct core_vec_Vec_i64 core_vec_Vec_i64;\n"
        out = out + "__attribute__((hot)) long long* core_alloc_alloc_i64(long long count);\n"
        out = out + "__attribute__((hot)) long long* core_alloc_resize_i64(long long* ptr, long long new_count);\n"
        out = out + "__attribute__((hot)) void core_alloc_dealloc_i64(long long* ptr);\n"
        out = out + "struct core_map_MapNode_str_bool { char* key; bool value; struct core_map_MapNode_str_bool* next; };\n"
        out = out + "typedef struct core_map_MapNode_str_bool core_map_MapNode_str_bool;\n"
        out = out + "struct core_map_Map_str_bool { core_map_MapNode_str_bool** buckets; long long capacity; long long len; };\n"
        out = out + "typedef struct core_map_Map_str_bool core_map_Map_str_bool;\n"
        out = out + "__attribute__((hot)) core_map_MapNode_str_bool** core_alloc_alloc_core_map_MapNode_str_bool(long long count);\n"
        out = out + "__attribute__((hot)) void core_alloc_dealloc_core_map_MapNode_str_bool(core_map_MapNode_str_bool** ptr);\n"
        out = out + "struct core_map_MapNode_str_str { char* key; char* value; struct core_map_MapNode_str_str* next; };\n"
        out = out + "typedef struct core_map_MapNode_str_str core_map_MapNode_str_str;\n"
        out = out + "struct core_map_Map_str_str { core_map_MapNode_str_str** buckets; long long capacity; long long len; };\n"
        out = out + "typedef struct core_map_Map_str_str core_map_Map_str_str;\n"
        out = out + "__attribute__((hot)) core_map_MapNode_str_str** core_alloc_alloc_core_map_MapNode_str_str(long long count);\n"
        out = out + "__attribute__((hot)) void core_alloc_dealloc_core_map_MapNode_str_str(core_map_MapNode_str_str** ptr);\n"
        out = out + "struct core_map_MapNode_str_i64 { char* key; long long value; struct core_map_MapNode_str_i64* next; };\n"
        out = out + "typedef struct core_map_MapNode_str_i64 core_map_MapNode_str_i64;\n"
        out = out + "struct core_map_Map_str_i64 { core_map_MapNode_str_i64** buckets; long long capacity; long long len; };\n"
        out = out + "typedef struct core_map_Map_str_i64 core_map_Map_str_i64;\n"
        out = out + "__attribute__((hot)) core_map_MapNode_str_i64** core_alloc_alloc_core_map_MapNode_str_i64(long long count);\n"
        out = out + "__attribute__((hot)) void core_alloc_dealloc_core_map_MapNode_str_i64(core_map_MapNode_str_i64** ptr);\n"
        out = out + "__attribute__((hot)) char* core_alloc_alloc_char(long long count);\n"
        out = out + "__attribute__((hot)) void core_alloc_copy_char(char* dst, char* src, long long count);\n"
        out = out + "__attribute__((hot)) char* core_alloc_resize_char(char* ptr, long long new_count);\n"
        out = out + "__attribute__((hot)) void core_alloc_dealloc_char(char* ptr);\n"
        return out

    # Generate C implementations for one module (no struct defs - those are in tauraro_types.h).
    # class_set: class/enum names declared in this module.
    # fn_set:    standalone function names declared in this module.
    # depth:     how many directories deep the output file is (for relative include path).
    pub def generate_module_c(self, prog: HirProgram, class_set: Map[str, bool], fn_set: Map[str, bool], depth: int) -> str:
        self.buf = StringBuilder.init(65536)

        mut inc_prefix = ""
        mut d = 0
        while d < depth:
            inc_prefix = inc_prefix + "../"
            d = d + 1

        self.w("#include \"" + inc_prefix + "tauraro_types.h\"\n\n")

        # -- Register ALL module-level globals into global_vars FIRST -----------
        # Module .c files are generated before generate_main_c (which also
        # registers these). Without this, an assignment to a module-level global
        # inside a function in THIS module (e.g. `_WAX_APP = self`) would be
        # mis-emitted as a shadowing `__auto_type` local instead of a write to
        # the (extern) file-scope global. prog.top_level_stmts holds every
        # module's globals merged, so registering them here is correct.
        mut _gvm = 0
        if not _is_invalid_ptr(prog as usize) and not _is_invalid_ptr(prog.top_level_stmts as usize):
            while _gvm < prog.top_level_stmts.len:
                match prog.top_level_stmts.get(_gvm).read():
                    case HirStmt.SLet(_gvn, _, _, _, _, _, _): self.global_vars.insert(_gvn, true)
                    case HirStmt.SAssign(_gvt, _):
                        match _gvt.read():
                            case HirExpr.EIdent(_gvn2, _, _): self.global_vars.insert(_gvn2, true)
                            case _: pass
                    case _: pass
                _gvm = _gvm + 1

        # -- Forward declarations for private (non-pub) functions in this module -
        # Public functions are already declared in tauraro_types.h.
        # Private helpers defined after their call sites need a prototype here
        # so GCC doesn't fail with "implicit declaration of function".
        mut fwd_i = 0
        while fwd_i < prog.functions.len:
            mut fwd_f = prog.functions.get(fwd_i)
            if fwd_f.name != "main" and not fwd_f.is_extern and not fwd_f.is_public:
                mut in_this_mod = false
                if fwd_f.class_name == "" and fn_set.contains(fwd_f.name):
                    in_this_mod = true
                elif fwd_f.class_name != "" and class_set.contains(fwd_f.class_name):
                    if self.classes.contains(fwd_f.class_name):
                        if self.classes.get(fwd_f.class_name).generics.len == 0:
                            in_this_mod = true
                if in_this_mod:
                    self.w(self.gen_func_sig(fwd_f, fwd_f.class_name) + ";\n")
            fwd_i = fwd_i + 1
        self.w("\n")

        # -- Class / enum method implementations ------------------------------
        mut i = 0
        while i < prog.classes.len:
            mut c = prog.classes.get(i)
            if c.generics.len == 0 and class_set.contains(c.name):
                if not self.emitted_fns.contains("cls_" + c.name):
                    self.emitted_fns.insert("cls_" + c.name, true)
                    mut mi = 0
                    while mi < c.methods.len:
                        mut m = c.methods.get(mi)
                        # Mark with the per-method key so loop-2 (prog.functions) won't re-emit.
                        self.emitted_fns.insert("i_" + c.name + "_" + m.name, true)
                        self.cur_class = c.name
                        self.cur_func  = m.name
                        self.decl_vars = Map[str, bool].init(64)
                        self.str_local_names = Map[str, bool].init(16)
                        self.coll_local_sfx = Map[str, str].init(16)
                        self.coll_local_idict = Map[str, bool].init(16)
                        self.coll_local_strval = Map[str, bool].init(16)
                        self.coll_local_vtcoll = Map[str, str].init(16)
                        self.seed_params(m)
                        self.cur_self_is_ptr = self.value_types.contains(c.name) and self.vt_method_mutates_self(m)
                        self.w(self.get_proto_attrs(m) + self.gen_func_sig(m, c.name) + " {\n")
                        self.gen_func_body(m.body, 1)
                        self.cur_self_is_ptr = false
                        self.w("}\n\n")
                        self.cur_class = ""
                        self.cur_func  = ""
                        mi = mi + 1
            i = i + 1
        i = 0
        while i < prog.enums.len:
            mut e = prog.enums.get(i)
            if class_set.contains(e.name):
                if not self.emitted_fns.contains("cls_" + e.name):
                    self.emitted_fns.insert("cls_" + e.name, true)
                    mut mi = 0
                    while mi < e.methods.len:
                        mut m = e.methods.get(mi)
                        self.cur_class = e.name
                        self.cur_func  = m.name
                        self.decl_vars = Map[str, bool].init(64)
                        self.str_local_names = Map[str, bool].init(16)
                        self.coll_local_sfx = Map[str, str].init(16)
                        self.coll_local_idict = Map[str, bool].init(16)
                        self.coll_local_strval = Map[str, bool].init(16)
                        self.coll_local_vtcoll = Map[str, str].init(16)
                        self.seed_params(m)
                        self.w(self.get_proto_attrs(m) + self.gen_func_sig(m, e.name) + " {\n")
                        self.gen_func_body(m.body, 1)
                        self.w("}\n\n")
                        self.cur_class = ""
                        self.cur_func  = ""
                        mi = mi + 1
            i = i + 1

        # -- Free-standing function implementations ----------------------------
        i = 0
        while i < prog.functions.len:
            mut f = prog.functions.get(i)
            if f.name != "main" and not f.is_extern:
                mut in_mod = false
                if f.class_name == "" and fn_set.contains(f.name) and f.generics.len == 0:
                    in_mod = true
                elif f.class_name != "" and class_set.contains(f.class_name):
                    # Skip generic class extend methods - only monomorphized instances are emitted.
                    mut is_generic_cls = false
                    if self.classes.contains(f.class_name):
                        if self.classes.get(f.class_name).generics.len > 0:
                            is_generic_cls = true
                    if not is_generic_cls:
                        in_mod = true  # extend method belonging to this module
                if in_mod:
                    mut em_key = "i_" + f.class_name + "_" + f.name
                    if not self.emitted_fns.contains(em_key):
                        self.emitted_fns.insert(em_key, true)
                        self.cur_func  = f.name
                        self.cur_class = f.class_name
                        self.decl_vars = Map[str, bool].init(64)
                        self.str_local_names = Map[str, bool].init(16)
                        self.coll_local_sfx = Map[str, str].init(16)
                        self.coll_local_idict = Map[str, bool].init(16)
                        self.coll_local_strval = Map[str, bool].init(16)
                        self.coll_local_vtcoll = Map[str, str].init(16)
                        self.seed_params(f)
                        self.cur_self_is_ptr = f.class_name != "" and self.value_types.contains(f.class_name) and self.vt_method_mutates_self(f)
                        self.w(self.get_proto_attrs(f) + self.gen_func_sig(f, f.class_name) + " {\n")
                        self.gen_func_body(f.body, 1)
                        self.cur_self_is_ptr = false
                        self.w("}\n\n")
                        self.cur_func  = ""
                        self.cur_class = ""
            i = i + 1

        self.flush_closures()
        return self.buf.to_string().as_str()

    # Generate main.c: main-module implementations + C entry point.
    # Emit a C header (`--lib`) declaring every `export def` free function, so
    # C/Rust/etc. consumers can call into the generated shared library. The
    # generated tauraro_rt.h / tauraro_types.h are included so the declarations
    # resolve TrStr/Result/collection types used at the boundary.
    pub def generate_export_header(self, prog: HirProgram) -> str:
        self.buf = StringBuilder.init(4096)
        self.w("/* Generated by `tauraroc --lib`. Exported Tauraro functions. */\n")
        self.w("#ifndef TAURARO_EXPORTS_H\n#define TAURARO_EXPORTS_H\n\n")
        # Self-contained: only standard C types so a consumer links against the
        # library WITHOUT pulling in the Tauraro runtime. (Exports whose
        # signatures use Tauraro struct types like TrStr/Result are noted below;
        # those need tauraro_rt.h and are a documented v1 limitation.)
        self.w("#include <stdbool.h>\n#include <stdint.h>\n\n")
        self.w("#ifdef __cplusplus\nextern \"C\" {\n#endif\n\n")
        mut i = 0
        if not _is_invalid_ptr(prog as usize) and not _is_invalid_ptr(prog.functions as usize):
            while i < prog.functions.len:
                mut f = prog.functions.get(i)
                if not _is_invalid_ptr(f as usize):
                    if f.is_export and not f.is_extern:
                        mut sig = self.gen_func_sig(f, "")
                        # Drop the dllexport/visibility attribute for the
                        # consumer-side declaration.
                        if sig.starts_with("TR_EXPORT "):
                            sig = sig.slice(10, sig.len())
                        self.w(sig + ";\n")
                i = i + 1
        self.w("\n#ifdef __cplusplus\n}\n#endif\n#endif\n")
        return self.buf.to_string().as_str()

    pub def generate_main_c(self, prog: HirProgram, class_set: Map[str, bool], fn_set: Map[str, bool]) -> str:
        self.buf = StringBuilder.init(65536)

        self.w("#define _TR_MAIN\n")
        if self.tier_define != "": self.w("#define " + self.tier_define + "\n")
        self.w(self.emit_tier_hooks(prog))
        self.w("#include \"tauraro_types.h\"\n\n")

        # Emit spawn + async wrappers (static thread-entry functions) before any function body
        self.prescan_spawns(prog)
        self.prescan_awaits(prog)
        self.w("\n")

        # Main-module class / enum method implementations
        mut i = 0
        if not _is_invalid_ptr(prog as usize) and not _is_invalid_ptr(prog.classes as usize):
            while i < prog.classes.len:
                mut c = prog.classes.get(i)
                if not _is_invalid_ptr(c as usize):
                    if c.generics.len == 0 and class_set.contains(c.name):
                        if not self.emitted_fns.contains("cls_" + c.name):
                            self.emitted_fns.insert("cls_" + c.name, true)
                            mut mi = 0
                            if not _is_invalid_ptr(c.methods as usize):
                                while mi < c.methods.len:
                                    mut m = c.methods.get(mi)
                                    if not _is_invalid_ptr(m as usize):
                                        # Mark with per-method key so loop-2 won't re-emit.
                                        self.emitted_fns.insert("i_" + c.name + "_" + m.name, true)
                                        self.cur_class = c.name
                                        self.cur_func  = m.name
                                        self.cur_throws_ty = m.throws_ty.name
                                        self.decl_vars = Map[str, bool].init(64)
                                        self.str_local_names = Map[str, bool].init(16)
                                        self.coll_local_sfx = Map[str, str].init(16)
                                        self.coll_local_idict = Map[str, bool].init(16)
                                        self.coll_local_strval = Map[str, bool].init(16)
                                        self.coll_local_vtcoll = Map[str, str].init(16)
                                        self.shared_vars = Map[str, str].init(8)
                                        self.seed_params(m)
                                        self.cur_self_is_ptr = self.value_types.contains(c.name) and self.vt_method_mutates_self(m)
                                        self.w(self.get_proto_attrs(m) + self.gen_func_sig(m, c.name) + " {\n")
                                        self.gen_func_body(m.body, 1)
                                        self.cur_self_is_ptr = false
                                        self.w("}\n\n")
                                        self.cur_class = ""
                                        self.cur_func  = ""
                                        self.cur_throws_ty = ""
                                    mi = mi + 1
                i = i + 1
        i = 0
        if not _is_invalid_ptr(prog as usize) and not _is_invalid_ptr(prog.enums as usize):
            while i < prog.enums.len:
                mut e = prog.enums.get(i)
                if not _is_invalid_ptr(e as usize):
                    if class_set.contains(e.name):
                        if not self.emitted_fns.contains("cls_" + e.name):
                            self.emitted_fns.insert("cls_" + e.name, true)
                            mut mi = 0
                            if not _is_invalid_ptr(e.methods as usize):
                                while mi < e.methods.len:
                                    mut m = e.methods.get(mi)
                                    if not _is_invalid_ptr(m as usize):
                                        self.cur_class = e.name
                                        self.cur_func  = m.name
                                        self.cur_throws_ty = m.throws_ty.name
                                        self.decl_vars = Map[str, bool].init(64)
                                        self.str_local_names = Map[str, bool].init(16)
                                        self.coll_local_sfx = Map[str, str].init(16)
                                        self.coll_local_idict = Map[str, bool].init(16)
                                        self.coll_local_strval = Map[str, bool].init(16)
                                        self.coll_local_vtcoll = Map[str, str].init(16)
                                        self.shared_vars = Map[str, str].init(8)
                                        self.seed_params(m)
                                        self.w(self.get_proto_attrs(m) + self.gen_func_sig(m, e.name) + " {\n")
                                        self.gen_func_body(m.body, 1)
                                        self.w("}\n\n")
                                        self.cur_class = ""
                                        self.cur_func  = ""
                                        self.cur_throws_ty = ""
                                    mi = mi + 1
                i = i + 1

        # Top-level global variables: declare at C file scope so every free
        # function in this module can reference them (initialized in main()).
        mut gvi2 = 0
        if not _is_invalid_ptr(prog as usize) and not _is_invalid_ptr(prog.top_level_stmts as usize):
            while gvi2 < prog.top_level_stmts.len:
                match prog.top_level_stmts.get(gvi2).read():
                    case HirStmt.SLet(gvn2, _, _, _, _, gvty2, gvval2):
                        mut gv_cty2 = self.type_to_c(gvty2)
                        if gv_cty2 == "void" or gv_cty2 == "__auto_type":
                            if gvval2 as usize != 0 as usize: gv_cty2 = self.type_to_c(hir_expr_type(gvval2))
                        if gv_cty2 == "void" or gv_cty2 == "__auto_type": gv_cty2 = "long long"
                        self.w(gv_cty2 + " " + gvn2 + ";\n")
                        self.global_vars.insert(gvn2, true)
                    case HirStmt.SAssign(gv_tgt, gv_val):
                        # Bare top-level `NAME = expr` (no `mut`/`let`) lowers to
                        # SAssign; hoist it to a file-scope global too so other
                        # functions in this module can reference NAME.
                        match gv_tgt.read():
                            case HirExpr.EIdent(gvn3, _, _):
                                mut gv_cty3 = self.type_to_c(hir_expr_type(gv_val))
                                if gv_cty3 == "void" or gv_cty3 == "__auto_type": gv_cty3 = "long long"
                                self.w(gv_cty3 + " " + gvn3 + ";\n")
                                self.global_vars.insert(gvn3, true)
                            case _: pass
                    case _: pass
                gvi2 = gvi2 + 1

        # Main-module free-standing function implementations
        i = 0
        if not _is_invalid_ptr(prog as usize) and not _is_invalid_ptr(prog.functions as usize):
            while i < prog.functions.len:
                mut f = prog.functions.get(i)
                if not _is_invalid_ptr(f as usize):
                    if f.name != "main" and not f.is_extern:
                        mut in_mod = false
                        if f.class_name == "" and fn_set.contains(f.name) and f.generics.len == 0:
                            in_mod = true
                        elif f.class_name != "" and class_set.contains(f.class_name):
                            # Skip generic class extend methods - only monomorphized instances are emitted.
                            mut is_generic_cls2 = false
                            if self.classes.contains(f.class_name):
                                if self.classes.get(f.class_name).generics.len > 0:
                                    is_generic_cls2 = true
                            if not is_generic_cls2:
                                in_mod = true  # extend method belonging to this module
                        if in_mod:
                            mut em_key2 = "i_" + f.class_name + "_" + f.name
                            if not self.emitted_fns.contains(em_key2):
                                self.emitted_fns.insert(em_key2, true)
                                self.cur_func  = f.name
                                self.cur_class = f.class_name
                                self.cur_throws_ty = f.throws_ty.name
                                self.decl_vars = Map[str, bool].init(64)
                                self.str_local_names = Map[str, bool].init(16)
                                self.coll_local_sfx = Map[str, str].init(16)
                                self.coll_local_idict = Map[str, bool].init(16)
                                self.coll_local_strval = Map[str, bool].init(16)
                                self.coll_local_vtcoll = Map[str, str].init(16)
                                self.shared_vars = Map[str, str].init(8)
                                self.seed_params(f)
                                self.cur_self_is_ptr = f.class_name != "" and self.value_types.contains(f.class_name) and self.vt_method_mutates_self(f)
                                self.w(self.get_proto_attrs(f) + self.gen_func_sig(f, f.class_name) + " {\n")
                                self.gen_func_body(f.body, 1)
                                self.cur_self_is_ptr = false
                                self.w("}\n\n")
                                self.cur_func  = ""
                                self.cur_class = ""
                                self.cur_throws_ty = ""
                i = i + 1

        # C main() entry point
        self.emit_entry_glue(prog)
        self.w("__attribute__((hot)) int main(int argc, char** argv) {\n")
        self.w("    _tr_argc = argc; _tr_argv = argv;\n")
        self.w("    _tr_init_console();\n")
        # NOTE: the global async pool is created LAZILY on first use (see
        # _tr_async_pool() in the runtime). Eagerly spawning one worker thread
        # per CPU here cost ~1-2 MB of stack per core (~64+ MB on big machines)
        # in EVERY program, even pure-compute ones that never touch async.
        mut main_has_args = false
        mut main_args_name = "args"
        mut mi2 = 0
        if not _is_invalid_ptr(prog as usize) and not _is_invalid_ptr(prog.functions as usize):
            while mi2 < prog.functions.len:
                mut mf = prog.functions.get(mi2)
                if not _is_invalid_ptr(mf as usize):
                    if mf.name == "main" and mf.params.len > 0:
                        main_has_args = true
                        main_args_name = mf.params.get(0).name
                mi2 = mi2 + 1
        if main_has_args:
            # Rename to avoid shadowing C's char** argv parameter
            if main_args_name == "argv": main_args_name = "_tr_main_argv"
            self.w("    List_TrStr* " + main_args_name + " = List_TrStr_new();\n")
            self.w("    for (int _ai = 0; _ai < argc; _ai++) { List_TrStr_append(" + main_args_name + ", _tr_str_lit(argv[_ai])); }\n")

        i = 0
        if not _is_invalid_ptr(prog as usize) and not _is_invalid_ptr(prog.top_level_stmts as usize):
            while i < prog.top_level_stmts.len:
                mut _tlg = false
                match prog.top_level_stmts.get(i).read():
                    case HirStmt.SLet(tln2, _, _, _, _, _, tlv2):
                        if self.global_vars.contains(tln2):
                            # File-scope global: initialize in main's boot path when it has
                            # a value; a value-less global (e.g. a `[u8; N]` arena) is already
                            # zero-initialized by C static storage. Never fall through to
                            # gen_stmt, which would re-declare (shadow) the global as a local.
                            if tlv2 as usize != 0 as usize:
                                self.w("    " + tln2 + " = " + self.gen_expr(tlv2) + ";\n")
                            _tlg = true
                    case _: pass
                if not _tlg:
                    self.gen_stmt(prog.top_level_stmts.get(i), 1)
                i = i + 1

        i = 0
        if not _is_invalid_ptr(prog as usize) and not _is_invalid_ptr(prog.functions as usize):
            while i < prog.functions.len:
                mut f = prog.functions.get(i)
                if not _is_invalid_ptr(f as usize):
                    if f.name == "main":
                        self.cur_func  = "main"
                        self.decl_vars = Map[str, bool].init(64)
                        self.str_local_names = Map[str, bool].init(16)
                        self.coll_local_sfx = Map[str, str].init(16)
                        self.coll_local_idict = Map[str, bool].init(16)
                        self.coll_local_strval = Map[str, bool].init(16)
                        self.coll_local_vtcoll = Map[str, str].init(16)
                        self.gen_func_body(f.body, 1)
                        self.cur_func  = ""
                i = i + 1

        self.w("#ifndef TAURARO_BARE\n")
        self.w("    _tr_async_pool_shutdown();\n")
        self.w("#endif\n")
        self.w("    return 0;\n}\n")
        self.flush_closures()
        return self.buf.to_string().as_str()
