# @trusted: compiler systems module — audited raw-pointer core (like Rust std internals)
# compiler/src/codegen/llvm.tr - LLVM IR backend stub for the Tauraro self-hosted compiler.
#
# Mirrors the structure of src/codegen/llvm.rs from the Rust bootstrap.
# Currently generates skeleton LLVM IR text output.
# Production-ready LLVM bitcode emission (via llvm-sys or similar) is future work.
#
# Pipeline: HirProgram -> LLVM IR text -> llc -> obj -> linker -> EXE

from core.vec import Vec
from core.string import StringBuilder
from core.map import Map
from codegen.c import _is_int_type, _is_float_type, _is_str_type
from hir import HirProgram, HirFunction, HirClass, HirEnum, HirInterface, HirStmt, HirExpr, HirBlock, HirParam, HirField, HirVariant, hir_expr_type

# --- LLVM type mapping --------------------------------------------------------

pub def llvm_type(ty: AstType) -> str:
    n = ty.name
    if n == "void":   return "void"
    if n == "bool":   return "i1"
    if n == "i8":     return "i8"
    if n == "u8":     return "i8"
    if n == "i16":    return "i16"
    if n == "u16":    return "i16"
    if n == "i32":    return "i32"
    if n == "u32":    return "i32"
    if n == "int":    return "i64"
    if n == "i64":    return "i64"
    if n == "u64":    return "i64"
    if n == "isize":  return "i64"
    if n == "usize":  return "i64"
    if n == "f32":    return "float"
    if n == "float":  return "double"
    if n == "f64":    return "double"
    if n == "str":    return "ptr"
    if n == "String": return "ptr"
    if n == "char":   return "i8"
    return "ptr"   # classes/enums/unknown -> opaque pointer

# --- LlvmGenerator ------------------------------------------------------------

pub class LlvmGenerator:
    pub buf:       StringBuilder
    pub temp:      int            # SSA register counter
    pub classes:   Map[str, HirClass]
    pub enums:     Map[str, HirEnum]
    pub functions: Map[str, HirFunction]

extend LlvmGenerator:
    pub def init() -> LlvmGenerator:
        mut g = LlvmGenerator()
        g.buf       = StringBuilder.init(1024)
        g.temp      = 0
        g.classes   = Map[str, HirClass].init(64)
        g.enums     = Map[str, HirEnum].init(32)
        g.functions = Map[str, HirFunction].init(128)
        return g

    pub def w(self, s: str):
        self.buf.append(s)

    pub def next_reg(self) -> str:
        self.temp = self.temp + 1
        return "%_" + self.temp.to_str()

    pub def register(self, prog: HirProgram):
        mut i = 0
        while i < prog.classes.len:
            mut c = prog.classes.get(i)
            self.classes.insert(c.name, c)
            i = i + 1
        i = 0
        while i < prog.enums.len:
            mut e = prog.enums.get(i)
            self.enums.insert(e.name, e)
            i = i + 1
        i = 0
        while i < prog.functions.len:
            mut f = prog.functions.get(i)
            self.functions.insert(f.name, f)
            i = i + 1

    # -- Type declarations ------------------------------------------------------

    pub def emit_type_decls(self, prog: HirProgram):
        # Emit opaque struct types for classes and enums
        mut i = 0
        while i < prog.classes.len:
            mut c = prog.classes.get(i)
            self.w("%struct."); self.w(c.name); self.w(" = type { ")
            mut first = true
            mut fi = 0
            while fi < c.fields.len:
                if not first: self.w(", ")
                self.w(llvm_type(c.fields.get(fi).ty))
                first = false
                fi = fi + 1
            if first: self.w("i8")   # empty struct needs at least one byte
            self.w(" }\n")
            i = i + 1

        i = 0
        while i < prog.enums.len:
            mut e = prog.enums.get(i)
            # Enums as tagged unions: { i32 tag, [max_payload_bytes x i8] payload }
            self.w("%enum."); self.w(e.name); self.w(" = type { i32, [64 x i8] }\n")
            i = i + 1
        if prog.classes.len > 0 or prog.enums.len > 0:
            self.w("\n")

    # -- Function signature -----------------------------------------------------

    pub def emit_func_sig(self, f: HirFunction, class_name: str):
        mut ret_ty = llvm_type(f.ret_ty)
        mut fname = f.name
        if fname == "main": fname = "_tr_main"

        self.w("define ")
        if not f.is_public: self.w("internal ")
        self.w(ret_ty); self.w(" @"); self.w(fname); self.w("(")

        mut first = true
        # Prepend class self pointer
        if class_name != "":
            mut has_self = false
            mut i = 0
            while i < f.params.len:
                if f.params.get(i).name == "self": has_self = true
                i = i + 1
            if has_self and not f.is_static:
                self.w("ptr %self")
                first = false

        mut i = 0
        while i < f.params.len:
            mut p = f.params.get(i)
            if p.name == "self":
                i = i + 1
                continue
            if not first: self.w(", ")
            self.w(llvm_type(p.ty)); self.w(" %"); self.w(p.name)
            first = false
            i = i + 1
        self.w(") {\nentry:\n")

    # -- Expression codegen (simplified - returns SSA register name) -----------

    pub def gen_expr(self, e_ptr: Pointer[HirExpr]) -> str:
        if e_ptr as usize == 0 as usize: return "null"
        e = e_ptr.read()
        match e:
            case HirExpr.ELitInt(v, ty):
                mut reg = self.next_reg()
                mut lty = llvm_type(ty)
                self.w("    "); self.w(reg); self.w(" = add "); self.w(lty); self.w(" 0, "); self.w(v.to_str()); self.w("\n")
                return reg
            case HirExpr.ELitBool(v, _):
                mut reg = self.next_reg()
                mut bval = "0"
                if v: bval = "1"
                self.w("    "); self.w(reg); self.w(" = add i1 0, "); self.w(bval); self.w("\n")
                return reg
            case HirExpr.ELitFloat(v, ty):
                mut reg = self.next_reg()
                self.w("    "); self.w(reg); self.w(" = fadd double 0.0, "); self.w(v.to_str()); self.w("\n")
                return reg
            case HirExpr.ELitStr(v, _):
                mut reg = self.next_reg()
                # String literals: declare as global constant
                mut gname = "@.str." + self.temp.to_str()
                mut len = len(v) + 1
                self.w("    "); self.w(reg); self.w(" = getelementptr ["); self.w(len.to_str())
                self.w(" x i8], ptr "); self.w(gname); self.w(", i32 0, i32 0\n")
                return reg
            case HirExpr.ELitNone(_):
                return "null"
            case HirExpr.EIdent(name, _, is_move):
                mut reg = self.next_reg()
                self.w("    "); self.w(reg); self.w(" = load ptr, ptr %"); self.w(name); self.w("\n")
                return reg
            case HirExpr.EBinOp(op, left, right, ty):
                return self.gen_binop_llvm(op, left, right, ty)
            case HirExpr.ECall(callee, args, _):
                return self.gen_call_llvm(callee, args)
            case _:
                return "undef"

    pub def gen_binop_llvm(self, op: str, left: Pointer[HirExpr], right: Pointer[HirExpr], ty: AstType) -> str:
        mut ls = self.gen_expr(left)
        mut rs = self.gen_expr(right)
        mut lty = llvm_type(ty)
        mut reg = self.next_reg()
        mut instr = "add"
        if op == "+":  instr = "add"
        if op == "-":  instr = "sub"
        if op == "*":  instr = "mul"
        if op == "/":  instr = "sdiv"
        if op == "%":  instr = "srem"
        if op == "&":  instr = "and"
        if op == "|":  instr = "or"
        if op == "^":  instr = "xor"
        if op == "<<": instr = "shl"
        if op == ">>": instr = "ashr"
        if op == "==": instr = "icmp eq"
        if op == "!=": instr = "icmp ne"
        if op == "<":  instr = "icmp slt"
        if op == "<=": instr = "icmp sle"
        if op == ">":  instr = "icmp sgt"
        if op == ">=": instr = "icmp sge"
        self.w("    "); self.w(reg); self.w(" = "); self.w(instr); self.w(" "); self.w(lty); self.w(" "); self.w(ls); self.w(", "); self.w(rs); self.w("\n")
        return reg

    pub def gen_call_llvm(self, callee: Pointer[HirExpr], args: Vec[Pointer[HirExpr]]) -> str:
        mut reg = self.next_reg()
        mut callee_name = ""
        match callee.read():
            case HirExpr.EIdent(n, _, is_move): callee_name = n
            case _:
                pass
        if callee_name == "": callee_name = "unknown"
        self.w("    "); self.w(reg); self.w(" = call ptr @"); self.w(callee_name); self.w("(")
        mut i = 0
        while i < args.len:
            if i > 0: self.w(", ")
            mut arg_reg = self.gen_expr(args.get(i))
            mut arg_ty = hir_expr_type(args.get(i))
            self.w(llvm_type(arg_ty)); self.w(" "); self.w(arg_reg)
            i = i + 1
        self.w(")\n")
        return reg

    # -- Statement codegen ------------------------------------------------------

    pub def gen_stmt(self, s_ptr: Pointer[HirStmt]):
        if s_ptr as usize == 0 as usize: return
        s = s_ptr.read()
        match s:
            case HirStmt.SExpr(e):
                self.gen_expr(e)
            case HirStmt.SReturn(e):
                if e as usize == 0 as usize:
                    self.w("    ret void\n")
                else:
                    mut v = self.gen_expr(e)
                    mut ty = hir_expr_type(e)
                    self.w("    ret "); self.w(llvm_type(ty)); self.w(" "); self.w(v); self.w("\n")
            case HirStmt.SLet(name, ownership, is_mut, is_const, is_shared, ty, val):
                self.w("    %"); self.w(name); self.w(" = alloca "); self.w(llvm_type(ty)); self.w("\n")
                if val as usize != 0 as usize:
                    mut v = self.gen_expr(val)
                    self.w("    store "); self.w(llvm_type(ty)); self.w(" "); self.w(v)
                    self.w(", ptr %"); self.w(name); self.w("\n")
            case HirStmt.SIf(cond, then_b, else_b):
                mut cond_v = self.gen_expr(cond)
                mut then_lbl = "then_" + self.next_reg()
                mut else_lbl = "else_" + self.next_reg()
                mut end_lbl  = "end_" + self.next_reg()
                self.w("    br i1 "); self.w(cond_v); self.w(", label %"); self.w(then_lbl)
                self.w(", label %"); self.w(else_lbl); self.w("\n")
                self.w(then_lbl); self.w(":\n")
                self.gen_block(then_b)
                self.w("    br label %"); self.w(end_lbl); self.w("\n")
                self.w(else_lbl); self.w(":\n")
                self.gen_block(else_b)
                self.w("    br label %"); self.w(end_lbl); self.w("\n")
                self.w(end_lbl); self.w(":\n")
            case HirStmt.SWhile(cond, body):
                mut cond_lbl = "while_cond_" + self.next_reg()
                mut body_lbl = "while_body_" + self.next_reg()
                mut end_lbl  = "while_end_" + self.next_reg()
                self.w("    br label %"); self.w(cond_lbl); self.w("\n")
                self.w(cond_lbl); self.w(":\n")
                mut cond_v = self.gen_expr(cond)
                self.w("    br i1 "); self.w(cond_v); self.w(", label %"); self.w(body_lbl)
                self.w(", label %"); self.w(end_lbl); self.w("\n")
                self.w(body_lbl); self.w(":\n")
                self.gen_block(body)
                self.w("    br label %"); self.w(cond_lbl); self.w("\n")
                self.w(end_lbl); self.w(":\n")
            case HirStmt.SBreak(_):
                self.w("    ; break (unresolved in stub)\n")
            case HirStmt.SContinue:
                self.w("    ; continue (unresolved in stub)\n")
            case HirStmt.SPass:
                pass
            case _:
                self.w("    ; TODO stmt\n")

    pub def gen_block(self, b: HirBlock):
        mut i = 0
        while i < b.stmts.len:
            self.gen_stmt(b.stmts.get(i))
            i = i + 1

    # -- Top-level generate -----------------------------------------------------

    pub def generate(self, prog: HirProgram) -> str:
        self.register(prog)

        # Module header
        self.w("; Tauraro LLVM IR - generated by compiler/src/codegen/llvm.tr\n")
        self.w("source_filename = \"tauraro_module\"\n")
        self.w("target datalayout = \"e-m:e-p270:32:32-p271:32:32-p272:64:64-i64:64-f80:128-n8:16:32:64-S128\"\n")
        self.w("target triple = \"x86_64-unknown-linux-gnu\"\n\n")

        # Runtime declarations
        self.w("declare void @printf(ptr, ...)\n")
        self.w("declare ptr @malloc(i64)\n")
        self.w("declare void @free(ptr)\n")
        self.w("declare ptr @memcpy(ptr, ptr, i64)\n\n")

        # Type declarations
        self.emit_type_decls(prog)

        # Function implementations
        mut i = 0
        while i < prog.functions.len:
            mut f = prog.functions.get(i)
            if f.is_extern:
                # Declare external functions
                self.w("declare "); self.w(llvm_type(f.ret_ty)); self.w(" @"); self.w(f.name); self.w("(...)\n")
                i = i + 1
                continue
            self.emit_func_sig(f, "")
            self.gen_block(f.body)
            self.w("    ret void\n}\n\n")
            i = i + 1

        # Class methods
        i = 0
        while i < prog.classes.len:
            mut c = prog.classes.get(i)
            mut mi = 0
            while mi < c.methods.len:
                mut m = c.methods.get(mi)
                self.emit_func_sig(m, c.name)
                self.gen_block(m.body)
                self.w("    ret void\n}\n\n")
                mi = mi + 1
            i = i + 1

        # _tr_init wrapping top-level statements
        self.w("define internal void @_tr_init() {\nentry:\n")
        i = 0
        while i < prog.top_level_stmts.len:
            self.gen_stmt(prog.top_level_stmts.get(i))
            i = i + 1
        self.w("    ret void\n}\n\n")

        # C entry point stub
        self.w("define i32 @main(i32 %argc, ptr %argv) {\nentry:\n")
        self.w("    call void @_tr_init()\n")
        mut has_main = false
        i = 0
        while i < prog.functions.len:
            if prog.functions.get(i).name == "main": has_main = true
            i = i + 1
        if has_main:
            self.w("    call void @_tr_main()\n")
        self.w("    ret i32 0\n}\n")

        return self.buf.to_string().as_str()
