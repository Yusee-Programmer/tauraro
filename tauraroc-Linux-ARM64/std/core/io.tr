# std.core.io — File and console I/O for the self-hosted Tauraro compiler.
# Drop-in replacement for root core/io.tr.

extern "C":
    def _tr_c_fopen(path: str, mode: str) -> Pointer[void]
    def _tr_c_fclose(fp: Pointer[void]) -> int
    pub def _tr_exit(code: int)
    def _tr_c_fflush(fp: Pointer[void]) -> int
    def _tr_c_fread(ptr: Pointer[void], size: int, count: int, fp: Pointer[void]) -> int
    def _tr_c_fwrite(ptr: Pointer[void], size: int, nmemb: int, fp: Pointer[void]) -> int
    def _tr_c_fseek(fp: Pointer[void], offset: int, whence: int) -> int
    def _tr_c_ftell(fp: Pointer[void]) -> int
    def _tr_c_malloc(size: int) -> Pointer[char]
    def _tr_c_free(ptr: Pointer[char])

pub def read_file(path: str) -> str:
    unsafe:
        mut fp = _tr_c_fopen(path, "rb")
        if fp as usize == 0 as usize:
            return ""
        _tr_c_fseek(fp, 0, 2)
        mut size = _tr_c_ftell(fp)
        _tr_c_fseek(fp, 0, 0)
        mut buffer = _tr_c_malloc(size + 1) as Pointer[char]
        _tr_c_fread(buffer as Pointer[void], 1, size, fp)
        buffer.offset(size).write('\0')
        _tr_c_fclose(fp)
        return buffer as str

pub def file_exists(path: str) -> bool:
    unsafe:
        mut fp = _tr_c_fopen(path, "rb")
        if fp as usize != 0 as usize:
            _tr_c_fclose(fp)
            return True
        return False

pub def write_file(path: str, content: str) -> bool:
    unsafe:
        mut fp = _tr_c_fopen(path, "wb")
        if fp as usize == 0 as usize:
            return False
        mut length = 0
        mut p = content as Pointer[char]
        while p.offset(length).read() as int != 0:
            length = length + 1
        _tr_c_fwrite(content as Pointer[void], 1, length, fp)
        _tr_c_fclose(fp)
        return True

pub def append_file(path: str, content: str) -> bool:
    unsafe:
        mut fp = _tr_c_fopen(path, "ab")
        if fp as usize == 0 as usize:
            return False
        mut length = 0
        mut p = content as Pointer[char]
        while p.offset(length).read() as int != 0:
            length = length + 1
        _tr_c_fwrite(content as Pointer[void], 1, length, fp)
        _tr_c_fclose(fp)
        return True
