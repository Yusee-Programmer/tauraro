# Benchmark 4: XOR Shift PRNG — 1B xorshift64 steps
# Uses i64 (signed); wrapping behaviour matches unsigned in practice
from std.sys.time import Clock
extern "C":
    def _tr_int_to_str(n: int) -> str

def main():
    mut clock = Clock.init()

    mut s: i64 = 0x123456789
    mut i = 0
    while i < 1000000000:
        s = s ^ (s << 13)
        s = s ^ (s >> 7)
        s = s ^ (s << 17)
        i = i + 1

    mut ms = clock.elapsed_ms()
    print(s)
    print(f"TIME_MS:{_tr_int_to_str(ms)}")
