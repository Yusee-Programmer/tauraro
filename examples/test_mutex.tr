def main():
    print("start")
    mut counter: Mutex[int] = Mutex.init(0)
    print("mutex created")
    mut v = counter.get()
    print(f"v = {v}")
    counter.set(v + 5)
    print("set done")
    mut v2 = counter.get()
    print(f"v2 = {v2}")
    counter.unlock()
    print("counter done")
    mut rw: RwLock[int] = RwLock.init(99)
    print("rw created")
    mut val = rw.read()
    print(f"val = {val}")
    rw.read_unlock()
    print("read unlock done")
    mut wval = rw.write()
    print(f"wval = {wval}")
    rw.write_set(200)
    print("write_set done")
