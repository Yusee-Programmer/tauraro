def main():
    mut total = 0
    mut i = 0
    while i < 200000:
        mut l: List[int] = []
        l.append(i)
        l.append(i + 1)
        total = total + l.len()
        mut d: Dict[str, int] = {}
        d.insert("a", i)
        total = total + d.len()
        mut s: Set[int] = Set[int].init()
        s.add(i)
        total = total + s.len()
        i = i + 1
    print("total=" + total.to_str())
