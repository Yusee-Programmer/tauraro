# The first Tauraro program that runs on bare metal (no OS, no libc).
# Built with --freestanding, linked against a Cortex-M3 startup + a UART sink,
# and executed under qemu-system-arm. print() flows through _TR_WRITE → UART.
def main(argv: List[str]):
    mut total = 0
    mut i = 1
    while i <= 100:
        total = total + i
        i = i + 1
    print("hello from bare metal")
    print("sum 1..100 = " + total.to_str())
