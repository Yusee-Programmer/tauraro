def main():
    mut l: List[str] = []
    l.append("hello")
    l.append("world")
    l.push("foo")
    print(l.len())
    print(l.get(0))
    print(l.contains("world"))
    print(l.index_of("foo"))
    l.set(0, "HELLO")
    print(l.get(0))
    print(l.join(", "))
    print(l)

    mut parts = "a,b,c".split(",")
    print(parts)
    print(parts.len())
    print(Str.join(parts, "-"))

    mut s: Set[str] = Set[str].init()
    s.add("x")
    s.add("y")
    s.add("x")
    print(s.len())
    print(s.contains("x"))
    print(s)

    mut d: Dict[str, int] = {}
    d.insert("one", 1)
    d.insert("two", 2)
    print(d)
    mut ks = d.keys()
    print(ks)
    print(ks.len())

    mut r = l.reversed()
    print(r)
    l.reverse()
    print(l)
    print(l.first())
    print(l.last())
    l.remove(0)
    print(l)
    print(l.is_empty())
    l.clear()
    print(l.is_empty())
