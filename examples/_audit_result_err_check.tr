def might_fail(x: int) -> Result[int, str]:
    if x < 0:
        return Err("negative")
    return Ok(x * 2)

def main():
    mut r1: Result[int, str] = might_fail(5)
    mut r2: Result[int, str] = might_fail(-1)
    if r1.is_ok():
        print("r1 ok=" + r1.unwrap().to_str())
    if r2.is_err():
        print("r2 err=" + r2.unwrap_err())
    print("done")
