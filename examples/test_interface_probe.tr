interface Drawable:
    def draw(self) -> void
    def area(self) -> float

class Circle implements Drawable:
    pub radius: float

extend Circle:
    pub def init(r: float) -> Circle:
        mut c = Circle()
        c.radius = r
        return c

    pub def draw(self) -> void:
        print("Drawing circle r=" + self.radius.to_str())

    pub def area(self) -> float:
        return 3.14159 * self.radius * self.radius

class Rect implements Drawable:
    pub w: float
    pub h: float

extend Rect:
    pub def init(w: float, h: float) -> Rect:
        mut r = Rect()
        r.w = w
        r.h = h
        return r

    pub def draw(self) -> void:
        print("Drawing rect " + self.w.to_str() + "x" + self.h.to_str())

    pub def area(self) -> float:
        return self.w * self.h

def render(d: Drawable) -> void:
    d.draw()
    print("area=" + d.area().to_str())

def main():
    mut c = Circle.init(5.0)
    mut r = Rect.init(3.0, 4.0)
    mut d1: Drawable = c
    mut d2: Drawable = r
    render(d1)
    render(d2)
