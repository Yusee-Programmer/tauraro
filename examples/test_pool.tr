def job(id: int) -> void:
    print(f"  pool job {id}")

async def main():
    print("=== ThreadPool ===")
    mut pool: ThreadPool = ThreadPool.new(2)
    pool.spawn(job, 1)
    pool.spawn(job, 2)
    pool.spawn(job, 3)
    pool.wait()
    pool.free()
    print("  all pool jobs done")

    print("=== await_all ===")
    await_all(job(10), job(20), job(30))
    print("  await_all done")

    print("=== multi-arg spawn ===")
    task_group:
        spawn job(100)
        spawn job(200)
    print("  task_group done")
